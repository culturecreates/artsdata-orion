      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww1.ticketpro.ca/event.php?event_id=7186"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "P-A Méthot"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Irrésistiblement attachant et hilarant, P-A Méthot est un raconteur hors pair! Alors qu'il a vendu plus de 500 000 billets de ses deux derniers one-man-shows, Plus gros que nature, et Faire le Beau, ce monstre de l'humour possède un style unique, mélangeant habillement stand-up et improvisation. On se reconnaît tous à travers le regard unique de ce fabuleux conteur. Avec ses mimiques et son charisme, P-A Méthot n'a pas fini de nous séduire! Venez passer une soirée remplie de surprises avec P-A Méthot!</p>"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
