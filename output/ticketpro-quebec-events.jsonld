        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1662943680.jpeg?version=0"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1257200"
      },
      {
        "@id": "_:g1257220"
      },
