      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww1.ticketpro.ca/genid/7bd7861a3749d84c"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww1.ticketpro.ca/event.php?event_id=7398"
