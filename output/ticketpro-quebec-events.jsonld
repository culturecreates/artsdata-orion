    ],
    "http://schema.org/name": [
      {
        "@value": "Neev - En Rodage"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Neev a 40 ans. Il est rendu au point où il ne s'excuse plus de dire les vraies affaires — sur lui, sur nous, sur l'époque. Il fait l'état des lieux, sans filtre et avec le sens du punch qui fait mal... mais qui fait du bien. 25 000 billets vendus pour son premier one-man-show. Le deuxième ? Il ne sera pas plus sage...il sera meilleur !</p>\n\n\n\n"
      }
    ],
