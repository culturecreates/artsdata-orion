  {
    "@id": "https://ticketpro.ca/event/1686263865",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-12T19:00:00-05:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/13549764"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproqc.ticketpro.ca/api/v1/resources/1686265520.jpeg?version=3"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1048620"
      },
      {
        "@id": "_:g1048640"
      },
      {
        "@id": "_:g1048660"
      },
