    "http://schema.org/name": [
      {
        "@value": "Québec Tattoo Show - 21-23 août, 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><span style='font-size: medium;'><strong>August 21, 2026 (12:00 p.m. to midnight)<br>\nAugust 22, 2026 (10:00 a.m. to midnight)<br>\nAugust 23, 2026 (10:00 a.m. to 7:00 p.m.)</strong><br>\nCentre de foires de Québec</span></p>\n\n<p><b>Free for children 14 years old and younger.</b> (The tickets will be available only at the Centre de foires on the day of the event.)</p>\n\n<p><b>3 Day ticket</b>: You will be given a bracelet when you first enter the expo. You will need to wear it to gain access to the event during your subsequent visits in 2026.</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
