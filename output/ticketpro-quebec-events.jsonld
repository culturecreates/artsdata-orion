    "http://schema.org/name": [
      {
        "@value": "Lutte NSPW présente GOLDEN OPPORTUNITY XVI"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Dans le cadre de son 16<sup>e</sup> anniversaire, la NSPW présente le plus gros gala de lutte professionnel au Québec, Golden Opportunity XVI.  </p>\n\n<p>Les meilleurs lutteurs de la scène de lutte indépendante au Québec sont en action.  </p>\n\n<p>La NSPW est nommée la promotion de lutte #1 des 14 dernières années au Québec.</p>\n\n<style>\n.titleTax {\n       display: none !important;\n}\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
