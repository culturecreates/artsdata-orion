      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>BÊTES DE FÊTE c'est LE bal costumé de l'année ! Une invitation, spécialement dédiée aux enfants, petits et grands, à venir tout donner sur la piste de danse, vêtu.es des atours les plus loufoques !</p>\n\n<p>Une limite de 60 personnes (enfants et adultes) pour ce spectacle.</p>\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
