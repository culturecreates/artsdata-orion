    "http://schema.org/name": [
      {
        "@value": "SIXX PAXX DREAMS TOUR"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>WHEN FANTASIES COME TRUE</p>\n\n<p>Close your eyes and imagine your wildest night out—then watch it come to life. The <b>SIXX PAXX DREAMS TOUR</b> arrives in 2026/27, taking the internationally acclaimed sensation to the biggest stages they've ever played.</p>\n\n<p>This all-new production turns up the heat with more seduction, more passion, and more unforgettable moments—featuring <b>electrifying choreography, live vocals, and a high-impact show</b> that begins like a dream and stays with you long after the final bow.</p>\n\n<p>Perfect for a girls' night out, birthday celebration, or bachelorette party, <b>SIXX PAXX</b> delivers an interactive, high-energy experience where fantasy meets world-class performance.</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
