    ],
    "http://schema.org/name": [
      {
        "@value": "Létourno, Nexdrive, NAPA AUTOPRO présentent le 55e SALON AUTO SPORT XPN - 1-3 mai 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The largest indoor and outdoor exhibition of exceptional vehicles in Canada. Hot rods, muscle cars, antique, classic, exotic and street cars, custom builds, race vehicles, heavy trucks and motorcycles. Come meet and talk with experts in high-performance parts and bodywork. The Quebec Auto Sport Show is the annual gathering for enthusiasts of extraordinary vehicles!</p>\n\n<p><b>May 1, 2026 (2:00 PM - 9:00 PM)<br />\nMay 2, 2026 (10:00 AM - 9:00 PM)<br />\nMay 3, 2026 (10:00 AM - 5:00 PM)</b><br>\nCentre de foires de Québec</p>\n\n<p><b>Ticket valid for one entry the day of your choice.</b></p>\n\n<p><b>Free for children 12 years old and younger.</b> (The tickets will be available only at the Centre de foires on the day of the event.)</p>\n\n<p>Outdoor activities:<br>\nSaturday, May 2, 2026 : 8:00 AM - 12:00 PM<br>\nSunday, May 3, 2026 : 8:00 AM - 12:00 PM</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
