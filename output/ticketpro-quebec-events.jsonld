    "http://schema.org/name": [
      {
        "@value": "Marjo - « J'lâche pas »"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Rockeuse émouvante et authentique, Marjo vous offre ses plus grands succès aux rythmes endiablés, ainsi que certaines de ses plus belles balades. Accompagnée de ses trois musiciens et fidèle à sa réputation, elle vous électrisera avec son dynamisme et vous transmettra sa passion pour la musique jusqu'à vous faire dresser le poil sur les bras.</p>"
      }
    ],
