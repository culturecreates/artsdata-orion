  {
    "@id": "https://ticketpro.ca/event/1688879121",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-03T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1411850201"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1688242985.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g617800"
