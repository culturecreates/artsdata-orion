    "http://schema.org/name": [
      {
        "@value": "Wooden Shapes - Du classique au Rock!"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Le spectacle qui a conquis le public est de retour! Après une tournée remarquée au Québec et à l'international, Wooden Shapes débarque avec son tout nouveau spectacle.</p>\n<p>Plongez dans les plus grands classiques du rock, Metallica, Harmonium, Guns N' Roses, David Bowie et bien d'autres, réinventés et joués uniquement sur des instruments à cordes. Avec des arrangements encore plus grandioses, ce spectacle ne cherche pas à imiter, il réinvente.\n</p>\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
