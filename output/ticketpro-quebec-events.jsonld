  {
    "@id": "https://ticketpro.ca/event/1665104451",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-06T20:00:00-04:00"
      }
