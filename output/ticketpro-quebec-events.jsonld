    "http://schema.org/name": [
      {
        "@value": "Vincent Vallières - Au travers de la route"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Vincent Vallières revient sur scène entouré de ses musiciens pour un tout nouveau spectacle, où son imposant répertoire s'unit aux pièces de son nouvel album à paraître à l'automne 2025. Un spectacle à l'image de cet incontournable de la chanson québécoise: rassembleur, vivant et authentique.</p>"
      }
    ],
