      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww1.ticketpro.ca/event.php?event_id=7477"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww1.ticketpro.ca/event.php?event_id=7477"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Bernard Werber - Conférence"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Some shows are just for entertainment. Others open doors!<br>\n\n\n\nThe show <b>V.I.E.</b> (short for VOYAGE INTERIEUR EXPÉRIMENTAL, or 'Experimental Inner Journey') aims to be <b>a new kind of experience</b>. In this blend of waking dreams, guided meditation, humor, and relaxing music, writer <b>Bernard Werber</b> invites you to practice 'SPIRITUAL TOURISM.'.\n<br>\n\nGuided by his voice, dreamlike chants, and the ethereal music of the harpist accompanying him, you'll dive deep into your own imagination during </b>five guided meditations</b>.\n<br>\n\nIt's an astonishing experience in which the renowned author of <i>Fourmis</i>, <i>Prophétie des Abeilles</i> and <i>Thanatonautes</i> invites you to open doors that will lead you to a deeper understanding of yourselves. More than just entertainment, it's a rare moment when the theater becomes an interactive space from which you'll emerge transformed.\n<br>\n\nÊTES-VOUS PRÊTS À TENTER L'EXPÉRIENCE ?</p>\n\n<style>\n@media screen and (max-width: 600px){\niframe{width:100%;}\n}\n\n</style>"
      }
    ],
