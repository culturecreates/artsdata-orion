      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Le vétéran de la musique traditionnelle québécoise Yves Lambert souligne ses 50 ans de carrière avec un spectacle qui revisite son vaste répertoire, de La Bottine Souriante à ses plus récents projets.</p>\n\n\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
