    "http://schema.org/url": [
      {
        "@id": "https://ww1.ticketpro.ca/event.php?event_id=7279"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "ENFANT DIMANCHE (6-12) / CHILD SUNDAY (6-12) - Comiccon de Montréal"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The 16<sup>th</sup> edition of Montreal Comiccon will be held in July 2026 at Palais des congrès.</p>\n\n<p>Montreal Comiccon is a three-day, multi-genre entertainment and pop culture event which features a consumer exhibition of comic books, toys, video games, science-fiction, horror, anime, tabletop games, and non-sport cards and collectibles.</p>\n\n<p>Every year at the Palais des congrès, fiction and fantasy come together and intertwine.  In addition, it includes hundreds of activities like panels, autograph sessions and photo opportunities with artists, special guests and renowned celebrities from all aspects of popular culture. </p>\n\n<p> The vast range of activities and interests represented at Montreal Comiccon draws attendees of all ages, from families with young children to teenaged fans to seasoned collectors.</p>\n\n<p><a href='https://www.montrealcomiccon.com/en/opening-hours/' target='_blank'>montrealcomiccon.com/en/opening-hours</a></p>\n\n\n<style>\n.tw-page-calendar-dates-button{display: none;}\n.location-event-temp {display: none!important;}\n</style>\n"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
