    ],
    "http://schema.org/name": [
      {
        "@value": "CHRISTINE MORENCY - BIEN FAITE"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>C'est reparti pour une deuxième tournée!.</p>\n\n<p>Christine vous rejoint pour partager ses histoires les plus intimes et vous montrer à quel point elle est BIEN FAITE!</p>\n\n<p>Bien faite physiquement (évidemment!), bien faite par les valeurs qui lui ont été transmises, mais surtout bien faite dans sa capacité à en rire plutôt qu'à en pleurer.</p>\n\n<p>As-tu tes billets pour le show de Christine Morency? Oui? T'AS BIEN FAITE!</p>"
      }
    ],
