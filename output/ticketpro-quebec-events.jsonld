    "http://schema.org/name": [
      {
        "@value": "Rince-Crème - (Le Podcast des Denis Drolet)"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Les Denis Drolet discutent ensemble de plusieurs sujets pigés au hasard. Qu'ils soient pointus ou populaires, drôles ou tabous, logiques ou fous, le duo élabore sans retenue ni censure sur les thèmes imposés.</p>\n\n<p>Accompagnés de leur acolyte André, aka Justo-By My-Love, et d'un invité, les Denis se lâchent lousse comme jamais, pour le plus grand plaisir de tous.</p>\n\n<p>This show is part of the Fun Nation Passport program.\nDiscover the benefits of the passport  <a href='https://funnation.ticketpro.ca/en/pages/1662735518' target='_blank'>here.</a></p>\n\n<style>\n@media screen and (max-width: 600px){\niframe{width:100%;}\n}\ntw-seats-selectes-plv{display: none !important;}\n</style>"
      }
