    "http://schema.org/name": [
      {
        "@value": "Marie-Annick Lépine - Le cœur est un rêveur"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Marie-Annick Lépine, multi-instrumentiste des Cowboys Fringants, reprend la route avec son nouvel album qui nous transporte dans son cheminement rempli de franchise, d'humanité et d'autodérision. Le cœur est un rêveur est une ode au retour à la vie. « Malgré la peur et malgré tout » Marie-Annick continue d'avancer.</p>\n\n\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
