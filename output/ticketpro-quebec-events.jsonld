    "http://schema.org/description": [
      {
        "@value": "<p><strong>September 25, 2026 (3:00 p.m. - 11:00 p.m.)<br>\nSeptember 26, 2026 (1:00 p.m. - 11:00 p.m.)<br>\nSeptember 27, 2026 (1:00 p.m. - 6:00 p.m.)</strong><br>\nCentre de foires de Québec</p>\n\n<p><b>18+ ONLY</b></p>\n\n<p><b>3 Day Ticket:</b> A bracelet will be supplied on your first entry to the show. You will need to wear it to gain access to the expo on your subsequent visits in 2026<br>\n<b>1 Day Ticket:</b> Valid for one entry the day of your choice</b></p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
