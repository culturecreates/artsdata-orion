  {
    "@id": "https://ticketpro.ca/event/1683104406",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-28T20:00:00-05:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1106826700"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproqc.ticketpro.ca/api/v1/resources/1683102302.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1464720"
      },
      {
        "@id": "_:g1464740"
      },
      {
        "@id": "_:g1464760"
