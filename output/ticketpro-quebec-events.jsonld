    "http://schema.org/description": [
      {
        "@value": "<p>Souldia pense le rap comme on aiguise un couteau.<br>\nC'est avec une plume d'une dangereuse précision et une verve tout aussi tranchante qu'il impose sa présence charismatique sur la scène québécoise depuis vingt ans</p>\n\n\n\n"
      }
    ],
