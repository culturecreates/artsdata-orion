  {
    "@id": "https://ticketpro.ca/event/1677033635",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-06T20:00:00-05:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1683102335.jpeg?version=0"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1334140"
      },
      {
        "@id": "_:g1334160"
      },
      {
        "@id": "_:g1334180"
