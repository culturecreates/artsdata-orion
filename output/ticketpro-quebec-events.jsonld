        "@id": "https://ticketpro.ca/place/1328442301"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproqc.ticketpro.ca/api/v1/resources/1691567713.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1216800"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww1.ticketpro.ca/event.php?event_id=7398"
