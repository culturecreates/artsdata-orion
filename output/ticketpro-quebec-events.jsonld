      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1675206352.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1080920"
      },
      {
        "@id": "_:g1080940"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
