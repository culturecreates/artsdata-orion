        "@id": "https://ticketpro.ca/place/1106826700"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproqc.ticketpro.ca/api/v1/resources/1683102330.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g528800"
      },
