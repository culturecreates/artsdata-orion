    "http://schema.org/name": [
      {
        "@value": "Fille de trans - Marie-Claude D'Aoust"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><i>Fille de Trans</i> est un récit sensible et poignant sur l'amour, l'identité et les liens\nqui nous façonnent. Marie-Claude D'Aoust y raconte son parcours comme fille\nd'une personne transgenre, Sophia - « sa papa » -, fil conducteur d'un récit\npersonnel qui ouvre sur des questions humaines et sociales universelles.</p>\n<p>À travers son histoire personnelle, l'artiste soulève des questions universelles :\nComment aimer sans toujours comprendre ? Que perd-on, et que gagne-t-on,\nquand l'autre change ? Comment transformer la différence en point de rencontre\nplutôt qu'en fracture ?\n</p>\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
