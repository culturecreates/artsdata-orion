    "http://schema.org/name": [
      {
        "@value": "Michel Pagliaro - Acoustic Saloon"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>It is in an intimate and festive atmosphere that Michel Pagliaro presents 'Acoustic Saloon', a\nshow that brings together his greatest hits, both in English and in French, for a guaranteed\nmemorable evening. Powered by his unique voice, these timeless rock anthems will\nundoubtedly delight spectators. An evening with Michel Pagliaro, where the past and the\npresent become one.<br><br><i>Credit picture : Stephend</i></p>\n<style>\n@media screen and (max-width: 600px){\niframe{width:100%;}\n}\n</style>"
      }
    ],
