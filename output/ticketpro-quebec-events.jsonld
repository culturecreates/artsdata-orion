        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1688242985.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww1.ticketpro.ca/genid/49a9be6afb2773a8"
      },
      {
        "@id": "https://ww1.ticketpro.ca/genid/88a8336dc3ba0774"
