        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1695193862.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww1.ticketpro.ca/genid/201563cd9eab4ae8"
      },
      {
        "@id": "https://ww1.ticketpro.ca/genid/42e85c508d95ec9c"
