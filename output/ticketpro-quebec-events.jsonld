    "http://schema.org/name": [
      {
        "@value": "VMG Entertainment présente: Sal Da Vinci - Per Sempre Si Tour"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The iconic Rialto Théâtre proudly welcomes renowned Italian artist Sal Da Vinci following his well-deserved victory at the Festival di Sanremo for an extraordinary evening of music.</p>\n<p>Celebrated for his powerful voice and remarkable career, Sal Da Vinci will take audiences on an emotional journey through his greatest hits. From unforgettable melodies to songs that have marked generations, this exclusive live performance promises nostalgia, passion, and the very best of Italian musical excellence — for one night only.</p>\n<p>Presented by VMG Entertainment.</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
