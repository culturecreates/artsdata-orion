  {
    "@id": "https://ticketpro.ca/event/1683758134",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-27T20:00:00-05:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1106826700"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproqc.ticketpro.ca/api/v1/resources/1683102330.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g520060"
      },
      {
