        "@id": "https://ticketpro.ca/place/1"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1675206353.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww1.ticketpro.ca/genid/d1cdc97ff67076c7"
      },
      {
        "@id": "https://ww1.ticketpro.ca/genid/6104ff31e2786612"
