      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1106826700"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproqc.ticketpro.ca/api/v1/resources/1683102302.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1397520"
      },
      {
        "@id": "_:g1397540"
      },
      {
        "@id": "_:g1397560"
