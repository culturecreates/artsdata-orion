  {
    "@id": "https://ticketpro.ca/event/1689798631",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-01-15T19:30:00-05:00"
