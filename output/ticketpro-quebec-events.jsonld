      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1683102335.jpeg?version=0"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww1.ticketpro.ca/genid/949aa5b954dd962c"
      },
      {
        "@id": "https://ww1.ticketpro.ca/genid/f7cf78b9311c4c95"
