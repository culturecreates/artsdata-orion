      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-17T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprotsd.ticketpro.ca/api/v1/resources/1660215748.jpeg?version=0"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g507620"
      },
      {
        "@id": "_:g507640"
      },
      {
        "@id": "_:g507660"
