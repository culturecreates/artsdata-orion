  {
    "@id": "https://hector-charland.com/temporary/a64c01bd-e808-482f-bee7-70447cdb1776",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/lempire-musical-horizontal-6ed4042c184bbf9cf09b.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=4frmAnhg7W8"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/lempire-musical"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&#039;Empire Musical"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Porté par les voix puissantes et sensibles de Renee Wilkin, Pascal Dufour et Yvan Pedneault, L’Empire Musical propose une toute nouvelle incursion dans l’univers musical du Royaume-Uni. Un spectacle vibrant, moderne, conçu pour faire rayonner la force et la richesse des grandes chansons britanniques. Après le succès retentissant de Britishow, qui a séduit le public québécois avec plus de 50 000 billets vendus, les trois interprètes originaux sont de retour sur scène, dans une production entièrement renouvelée. L’Empire Musical s’ancre principalement dans les 30 dernières années, de 1995 à 2025. Une période où les légendes du rock britannique ont continué à briller (Queen, Elton John, Paul McCartney, Mick Jagger) tout en laissant émerger une génération d’artistes marquants comme Adele, Dua Lipa, Coldplay, Mumford and Sons, Joss Stone, Ed Sheeran et Harry Styles. Plus qu’un passage de flambeau, le spectacle célèbre la cohabitation de deux générations d’artistes britanniques : celle qui a bâti l’Empire et celle qui le fait vivre encore aujourd’hui. Conçu par la même équipe de création que Britishow, L’Empire Musical est dirigé artistiquement par Mike Gauthier avec Philippe Turcotte à la direction musicale. Une relecture éclatante, actuelle et élégante de trois décennies de musique britannique inoubliable."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-14T02:03:00"
      }
    ]
  },
