    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "The VoodooMonx"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Formule debout.The VooDoo Monx livrent un show explosif aux accents funk, soul et pop. Porté par des influences allant de James Brown à Jamiroquai en passant par les Red Hot Chili Peppers, le groupe propose des grooves contagieux et des refrains accrocheurs qui rassemblent toutes les générations. Sur scène, leur énergie festive et leurs rythmes inspirés du R&amp;amp;B et des sonorités caribéennes transforment chaque performance en véritable célébration."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-27T02:02:00"
      }
    ]
