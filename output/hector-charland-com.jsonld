  {
    "@id": "https://hector-charland.com/temporary/654aca12-d5ad-45a1-b355-6189a510c9d4",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/du-tango-a-la-bossa-nova-horizontal-bd60b62f49f457df1cd9.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/N-nld6x5aP8"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/du-tango-a-la-bossa-nova"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Du Tango à la Bossa Nova"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Grands Concerts en partenariat avec Club Voyage Repentigny. Un abonnement est aussi disponible, tous les détails en cliquant ici. Du tango argentin à la bossa nova brésilienne, les musiciens du Trio Fibonacci vous emportent dans un voyage à la démesure du continent sud-américain. Explorant les rythmes des hauts plateaux andins, ceux de la pampa ou des chutes d’Amazonie, ils interprètent les mélodies qui font l’âme de la musique latine. Le trio apporte, par son jeu nuancé et emplit d’émotions, leur propre couleur aux œuvres telles que Les Quatre saisons de Piazzolla et la Bachianas Brasileiras de Villa-Lobos. Il revisite au passage quelques perles folkloriques vénézuéliennes et mexicaines tout en vous dévoilant ses motifs dansants et sensuels. Un voyage musical empreint de chaleur, de musique et de découvertes!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:01:00"
      }
    ]
  },
