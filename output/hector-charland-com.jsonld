  },
  {
    "@id": "https://hector-charland.com/temporary/2e01e22e-f24d-424f-afc1-b15cd165da31",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/jazzlab-orchestra-horizontal-381684694c61503ddfcb.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/tQcJrWdEhvE"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/jazzlab-orchestra"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jazzlab orchestra"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le port du masque est obligatoire en tout temps pour les personnes de 10 ans et plus. Le prix du billet inclut le nouvel album de Jazzlab Orchestra intitulé LOGUSLABUSMUZIKUS. Vous le recevrez à la sortie de la salle.Le JAZZLAB ORCHESTRA basé à Montréal, se définit comme un groupe spécifique, une véritable institution dans l’univers du jazz canadien depuis 2004. Composé de Mario Allard, (saxophone soprano, alto, baryton et clarinette), Benjamin Deschamps (saxophone soprano, ténor et flûtes), Annie Dominique (saxophone soprano, alto et clarinette basse), Jacques Kuba Seguin (trompette), Thomas Morelli-Bernard (trombone), Félix Stussi (piano), Alain Bédard (contrebasse et composition), Michel Lambert (batterie), il livre une fois de plus, avec le nouvel album LOGUSLABUSMUZIKUS un terroir compositionnel d’une rare intensité. L’effervescence est grande, portée sans cesse par des musiciens stupéfiants qui poussent aussi bien l’enjeu du collectif, que leurs propres chants. "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2021-10-06T09:41:00"
      }
    ]
  },
