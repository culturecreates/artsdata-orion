      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/fredz-horizontal-2e6aef41548e1892482f.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=LRjqG3g4m30&amp;t=141s"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/fredz-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Fredz"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté en formule debout! Avec On s’enverra des fleurs, Fredz transforme la scène en un journal intime vivant. Entre fragilité et puissance, il dépose ses doutes, ses rêves et ses blessures dans des morceaux qui touchent droit au cœur. Chaque chanson devient un miroir où chacun peut retrouver un fragment de sa propre histoire. Porté par une mise en scène à la fois brute et poétique, le spectacle allie émotion pure et énergie débordante, offrant une expérience intense, sensible et universelle.À seulement 23 ans, Fredz s’impose comme l’une des voix les plus singulières de la nouvelle scène francophone ici comme à l’international. L’artiste québécois, déjà fort de plus de 200 millions de streams et de 3 singles d’or, s’est forgé une identité unique : un rap suave, sensible et sans compromis. On s’enverra des fleurs marque une étape décisive : un album scénique, fédérateur et profondément sincère, qui ouvre un nouveau chapitre dans l’ascension fulgurante de Fredz. La première partie sera assurée par l&#039;artiste Blynk, une figure montante du R&amp;amp;B francophone. "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-09-25T02:02:00"
      }
    ]
  },
