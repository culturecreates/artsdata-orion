    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/embrahms-moi"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Embrahms-moi"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de leur série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Dans ce projet, Yannick Rieu s’inspire de l’esprit de Brahms, tout en transcendant les limites de son langage harmonique et formel. Le spectre de Johannes Brahms, figure majeure du romantisme musical, alimente les thèmes de Rieu, donnant aussi naissance à des échanges spontanés, caractéristiques essentielles du jazz. Le nouvel album de Yannick Rieu Symbiosis incarne ainsi le désir de fusionner des styles en apparence disparates, mettant en lumière le lien entre lyrisme et narration musicale. Cette approche offre une vision poétique de Yannick Rieu, explorant la fusion musicale et réinterprétant l’héritage de Brahms à l’aune de la contemporanéité."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:01:00"
      }
    ]
  },
