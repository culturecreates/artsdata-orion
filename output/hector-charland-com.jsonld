  {
    "@id": "https://hector-charland.com/temporary/7a7b47c8-af3d-455b-a4d2-227b5ba05d92",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/mille-secrets-mille-dangers-horizontal-a96a115f56bb8b98c22d.jpg"
