    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Wonderland"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La représentation du 10 décembre 2020 est reportée au 6 mai 2021.Le spectacle sera présenté conformément aux normes sanitaires et de distanciation physique en vigueur.Dans une ambiance feutrée, aux couleurs de son dernier album Wonderland, la pianiste Gentiane nous livre ses plus belles œuvres, entourée de ses complices de longue date, le contrebassiste Levi Dover, et le batteur Louis-Vincent Hamel. Nommée Révélation Jazz Radio-Canada 2018-2019, Gentiane et ses musiciens nous font voyager musicalement entre la tradition jazz et la créativité de leurs œuvres originales. Une soirée dans une atmosphère chaleureuse et intimiste remplie de découvertes, de détente et de conversations musicales et personnelles avec son public au tout nouveau Théâtre Alphonse-Desjardins."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2020-03-16T17:52:00"
      }
    ]
