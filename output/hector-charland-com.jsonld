    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Barbie Boomer suit Sylvie Longpré (67 ans) qui, pour assurer la pérennité d'une partie de sa collection de Barbie, décide de donner les poupées de son enfance au Musée de la civilisation à Québec, qui accepte d’évaluer la proposition."
      }
