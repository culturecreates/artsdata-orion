    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/autour-de-jean-sebastien-bach"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Autour de Jean-Sébastien Bach"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle présenté en admission générale sur la scène du Théâtre Alphonse-Desjardins en partenariat avec Patrick Bonin, député fédéral de Repentigny. Les spectateurs sont installés sur des chaises, autour du piano.Présenté par l&#039;Aramusique dans le cadre de sa série Musique Intimiste.Avec une virtuosité teintée de sensibilité, Stéphane Tétreault explore les résonances de Bach à travers ses Suites pour violoncelle seul, véritables pierres angulaires du répertoire. En contrepoint, il propose deux œuvres d’aujourd’hui : le Præludium en sol majeur d’Airat Ichmouratov, empreint de ferveur et de lyrisme, et la Noche de tango de Denis Plante, qui marie élégance baroque et fougue du tango. Un concert où passé et présent s’entrelacent avec poésie."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
