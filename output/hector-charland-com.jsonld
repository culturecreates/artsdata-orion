    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Drame familial | Québec | 2025 | 13+ Feng Xia, immigrante chinoise de 53 ans et mère de famille vivant à Montréal, a passé sa vie dans une obéissance silencieuse — envers sa famille, sa culture, et un mariage fondé sur le non-dit."
      }
    ],
