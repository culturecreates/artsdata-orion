    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Antoine Dufour et ses artistes invités"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Les soirées de la guitare repose sur une idée rassembleuse : célébrer cet instrument à cordes sous toutes ses formes. Piloté par le guitariste lanaudois de grande renommée Antoine Dufour, ce projet réunit des musiciens canadiens et internationaux au talent prodigieux. Une rencontre musicale où la guitare révèle toute sa richesse et sa puissance."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
