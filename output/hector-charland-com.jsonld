    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Plus de 2 millions de billets vendus en carrière, premier Québécois à présenter un spectacle en résidence à Las Vegas, plusieurs tournées à succès en Europe, création et distribution de grands numéros magiques à l’international : Alain Choquette fait partie des grands noms de la magie à travers le monde et ne manque pas de récits et de numéros pour surprendre, faire rire et éblouir."
      }
    ],
    "http://schema.org/inLanguage": [
