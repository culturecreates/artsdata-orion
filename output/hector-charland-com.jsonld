    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Mon nouveau show s’appelle Ouvert . Bien que je sois habituellement pudique sur ma vie privée, je m’ouvre comme jamais dans ce spectacle! Et aussi, quand même important, je crois que vous allez rire beaucoup!"
      }
