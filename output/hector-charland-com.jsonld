  {
    "@id": "https://hector-charland.com/temporary/35b4cabc-380b-43da-ae85-30946c665b31",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/jules-et-josephine-horizontal-86706c4d94b009a7cbc5.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=-optrwrtZok"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/jules-et-josephine"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jules et Joséphine"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Férue de science, Joséphine Verne correspond avidement, de son Québec natal, avec son cousin français Jules. Entre leurs rêves de voyages ou de fiction, une pensée commune les habite : « Il y a en moi des mondes que je ne soupçonne pas. » Pour provoquer enfin leur rencontre, Joséphine lui parie 80 livres, ceux qu’elle chérit ou ceux qu’il écrira, qu’elle traversera l’Atlantique d’ici la prochaine lune. Du St-Laurent jusqu’à La Loire, les personnages de son périple auront tout ce qu’il faut pour entrer dans l’histoire, celle avec un grand J. Ayant posé les valises de son Tour du monde en 80 jours, le Théâtre Advienne que pourra pose un regard ragaillardi sur l’univers de Jules Verne, dans ses courants sous-marins, aériens ou miraculeux. Ombres, marionnettes et maquettes concourent à échafauder cette ode frémissante à la curiosité."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-08-21T02:01:00"
      }
    ]
  },
