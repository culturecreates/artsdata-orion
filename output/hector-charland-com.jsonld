    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/la-maree-du-forgeron-deuxieme-vague-horizontal-410bba3e207f24f96b75.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/40_vR_vThI8"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/la-maree-du-forgeron-deuxieme-vague"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Marée du Forgeron - Deuxième Vague"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La Marée du Forgeron a déferlé pour la première fois l&#039;an dernier lors de l&#039;inauguration du Théâtre de la Vieille Forge de Petite-Vallée. Elle revient cette année avec une deuxième vague : plus riche, portée par de nouveaux numéros et un invité d&#039;exception : Pierre Flynn.Sous la direction artistique de Louis-Jean Cormier et Alan Côté, ce concert collectif réunit quatre générations d&#039;artistes profondément ancrés dans l&#039;histoire de Petite-Vallée : Louis-Jean Cormier, Marie-Pierre Arthur, Daniel Boucher, Patrice Michaud, Klô Pelgag, Jeanne Côté, Velours Velours, Sandrine Masse et Luan Larobina. Portés musicalement par Tibasse Fournier, Manuel Gasse, Lana Carbonneau et Vincent Carré, les artistes revisitent les œuvres et les voix qui ont façonné ce lieu unique, avec tout ce que ça comporte d&#039;émotions, de souvenirs partagés et de chanson vivante. Une célébration de la chanson québécoise et de son héritage, là où tout recommence."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-26T02:02:00"
      }
    ]
  },
