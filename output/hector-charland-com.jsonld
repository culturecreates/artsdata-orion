    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Laurence St-Martin"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Découvrez Avec Elle, le prochain spectacle de l&#039;auteure-compositrice-interprète qui a déjà conquis près de 3,5 millions d&#039;auditeurs sur les plateformes numériques. Après avoir tourné un peu partout dans le Québec, son dernier show a obtenu une nomination au Gala Country comme Spectacle de l&#039;année. Plongez de nouveau dans une ambiance de feu de camp avec des sonorités new country et laissez-vous emporter par des textes authentiques et reconnaissables. Après le succès de Filles des Îles avec plus de 3 millions de vues, ce nouveau spectacle est une expérience musicale à la fois touchante et festive à ne pas manquer. "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-30T02:01:00"
      }
    ]
