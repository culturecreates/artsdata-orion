  {
    "@id": "https://hector-charland.com/temporary/6aeb87c1-b801-4a93-b3e9-e75bbc867907",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/abba-memories-horizontal-351f08dc53caa9f91259.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://vimeo.com/501464727"
