    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "The Big O&#039;String Band"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Plongez au coeur du bluegrass avec The Big O String Band, une formation passionnée qui redonne vie aux classiques intemporels tout en façonnant un répertoire original riche et vibrant. Inspirés par les racines profondes de la musique traditionnelle américaine, ces musiciens chevronnés conjuguent virtuosité, harmonies vocales envoûtantes et une énergie contagieuse qui transporte le public dans un voyage musical inoubliable."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-05-15T11:14:00"
      }
    ]
  },
