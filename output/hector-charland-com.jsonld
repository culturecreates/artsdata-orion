  {
    "@id": "https://hector-charland.com/temporary/a2dcf5f2-c8cd-4c97-8662-40e41dbd339e",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/the-next-generation-leahy-horizontal-72a10033531211406231.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/ncHpH7apHcw"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/the-next-generation-leahy"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "The Next Generation Leahy"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Next Generation Leahy est une véritable force vive de la musique celtique canadienne, audacieuse, vibrante et irrésistible. Ce groupe familial composé de six frères et sœurs, âgés de 15 à 24 ans, déploie une énergie électrisante sur scène. Portés par un talent exceptionnel, une passion contagieuse et une grande rigueur artistique, leurs spectacles sont aussi puissants qu’inoubliables. Chaque membre du groupe est un multi-instrumentiste accompli, fusionnant avec une aisance remarquable la musique et le mouvement pour offrir une expérience scénique percutante et cohérente.Ancré dans les traditions celtiques et irlandaises et nourri d’influences jazz, canadiennes-françaises, pop, country et swing, Next Generation Leahy développe une signature sonore à la fois actuelle et profondément authentique. Leurs performances, intenses et finement maîtrisées, débordent d’émotion : instrumentations fougueuses, harmonies raffinées et claquettes électrisantes captivent les publics de tous âges.Ayant sillonné l’Amérique du Nord, le groupe a partagé la scène avec des artistes de renom tels que The Chieftains, The Tenors et We Banjo Three. Avec un professionnalisme impressionnant pour leur jeune âge et une détermination sans faille, Next Generation Leahy s’impose comme un moteur d’innovation dans la musique celtique canadienne. Bien plus qu’un groupe, ils incarnent un véritable souffle de renouveau, faisant rayonner la tradition avec audace, créativité et une énergie artistique hors du commun."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-22T02:03:00"
      }
    ]
