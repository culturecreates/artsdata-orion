      {
        "@language": "fr-ca",
        "@value": "Tommy Néron | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Un spectacle porté par un mélange savoureux d’observations et d’anecdotes tirées d’un parcours qui, avec le recul, n’était pas exactement comme celui de tout le monde. Le public peut même y amener son ado : peu de risques de traumatisme… mais à ses risques et périls. Mis en scène par Laurent Paquin…"
      }
    ],
