  {
    "@id": "https://hector-charland.com/temporary/e9fbad32-5816-45ae-8b42-27aeb58bf039",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/dave-morissette-horizontal-d3546682847cda554012.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=MdGLx7Hyeyc"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/dave-morissette"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Dave Morissette"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le seul et unique Dave Morissette monte sur scène avec son tout premier spectacle solo David et il en a des histoires à raconter! Pour la première fois en tournée, le dur à cuire de la LNH devenu animateur adoré du public laisse tomber les gants pour vous offrir une soirée sans filtre, une vraie rencontre. Il vous invite à découvrir l’homme derrière le bagarreur, le doux derrière le colosse, mais surtout le raconteur capable de faire rire et de toucher droit au cœur. Avec une générosité désarmante et un sens du punch bien à lui, il vous amène de Baie-Comeau à Compostelle, en passant par le vestiaire des Canadiens de Montréal et les coulisses des émissions de sports. Avec ses anecdotes aussi drôles que touchantes, vous aurez l’impression de passer une soirée avec un ami de longue date. Vous pensez connaître Dave? Attendez de rencontrer David!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-09T02:02:00"
      }
    ]
  },
