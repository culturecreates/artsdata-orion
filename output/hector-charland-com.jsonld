    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/cine-piano"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ciné-Piano"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté dans le cadre des Sons et Brioches en partenariat avec McDonald&#039;s - La Famille Lemay. Collation offerte gracieusement par McCafé à partir de 10h.Le pianiste Roman Zavada propose un voyage dans le temps en redonnant une seconde vie aux classiques du cinéma muet. Avec son piano, il rend hommage aux plus grands génies du cinéma qui de nos jours, sont tombés dans l’oubli. Sur les Chaplin, Keaton et Laurel &amp;amp; Hardy, pour ne nommer que ceux-là, il jongle avec les touches noires et blanches du piano afin de juxtaposer l’émotion musicale en parfaite symbiose avec l’action du film. Avec une narration musicale improvisée et spontanée, Zavada assure une performance hors du commun et comme par magie, devient le complice des images en noir et blanc. Bon cinéma!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2023-04-25T09:37:00"
      }
    ]
  },
