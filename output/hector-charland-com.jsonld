    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Comme le veut la culture hip-hop, les danseurs et danseuses de rue se présentent comme invincibles quand ils s’affrontent par la danse pour démontrer leur valeur et asseoir leur domination."
      }
