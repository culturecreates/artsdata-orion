    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Jey Fournier | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Un jour, on se réveille et on réalise qu’on a 30 ans (ou presque). On voit les autres avancer, on essaie de ne pas trop se comparer, mais on a quand même l’impression d’être en retard sur la vie. Entre la séparation, les remises en question et la quête du bonheur, j’ai choisi d’en rire. Tant qu’à…"
      }
    ],
