  {
    "@id": "https://hector-charland.com/temporary/e2c82e1e-35a6-4fe4-b43d-89813ed042f8",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/les-origines-du-bing-bang-horizontal-f49e615e5c64cdc41bfc.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/We6mKzqG9HI"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/les-origines-du-bing-bang"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les origines du Bing Bang!"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté dans le cadre des Sons et Brioches en partenariat avec McDonald&#039;s - La Famille Lemay. Collation offerte gracieusement par McCafé à partir de 10h.C’est une grosse journée pour Marton et Bruno, les deux copains percussionnistes. Le premier a une audition à la batterie le jour même et doit pouvoir jouer une variété de rythmes de différentes régions du monde; le second participe à une grande parade multiculturelle et ne sait pas quels instruments choisir tellement il y a de possibilités. Tous deux vont se remuer les méninges très intensément sous nos yeux… et dans nos oreilles! Ils vont explorer toutes sortes de percussions – cajón, claves, surdo, bodhran, djembé – et toutes sortes de pays et régions du monde – le Pérou, le Brésil, Cuba, l’Irlande, les États-Unis, l’Afrique… sans oublier le Québec! Au terme de cette journée haute en couleur, où chacun cherche son rythme, comment Marton et Bruno atteindront-ils leurs buts?"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:02:00"
      }
    ]
  },
