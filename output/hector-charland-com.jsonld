    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/michel-rivard-horizontal-8fd8629c049362bc4eeb.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtube.com/shorts/e2P7IwNu_zE?feature=share"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/michel-rivard-2"
