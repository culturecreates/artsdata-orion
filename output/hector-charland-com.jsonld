    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après un premier spectacle acclamé pour l'originalité des angles et la précision des punchs, P-O Forget vous convie maintenant au rodage d'une œuvre encore plus éclatée, encore plus incisive et avec votre aide, encore plus hilarante. Venez découvrir ou retrouver cette star montante de l'humour québécois dans sa version la plus authentique."
      }
    ],
