  {
    "@id": "https://hector-charland.com/temporary/9c0a58a1-01e1-423e-bd4c-aafae2b93cc8",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/grosse-isle"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=cQ-C8HkHkOI"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/grosse-isle"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Grosse Isle"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Vous avez envie de découvrir les instruments uilleann pipes et whistle d’Irlande? Le trio Grosse Isle, c’est un sublime mélange de répertoire irlandais, répertoire québécois et compositions originales. Sophie Lavoie du Lac-Saint-Jean, Fiachra O&#039;Regan d&#039;Irlande et le légendaire André Marchand (La Bottine Souriante, Les Charbonniers de l&#039;Enfer) présentent un nouveau spectacle inspiré de l’album de musique traditionnelle Le Bonhomme sept heures/The Bonesetter. L’union des deux cultures, l’authenticité et l’immense talent des artistes donnent un impressionnant résultat. Des complaintes aux chansons plus rythmées, le concert est varié et affiche les 1001 couleurs de ce trio rafraîchissant! Laissez-vous charmer par cette musique riche et enveloppante."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2023-08-08T10:39:00"
      }
    ]
  },
