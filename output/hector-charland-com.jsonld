  {
    "@id": "https://hector-charland.com/temporary/3b6cca6a-19a2-4cc8-950f-255419e3303a",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/flambant-nue-horizontal-13a2c4876032d5cfbc65.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/PUrv1tgmJZk"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/flambant-nue-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Flambant nue"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Flambant nue plonge au cœur d’une question universelle : quelle est notre place dans l&#039;univers? Cette interrogation, aussi vieille que l&#039;humanité elle-même, est exacerbée par les récentes avancées scientifiques, notamment la fascinante théorie des univers multiples. Au bout de ce parcours, est-ce que nos personnages trouvent une réponse à cette question? Portée par un chœur de personnages vibrants et attachants, ce texte de Pierre-Michel Tremblay mêle profondeur et humour à travers une série de tableaux qui reflètent nos différentes identités dans des situations qui résonnent avec des enjeux de notre époque.Une rencontre unique sur scène avec quatre virtuoses de l’interprétation : Christian Bégin, Marie Charlebois, Isabelle Vincent et Pier Paquette. Ensemble, ils donnent vie à un spectacle touchant, drôle et captivant qui invite à réfléchir… et à rêver."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2024-12-03T18:31:00"
      }
    ]
  },
