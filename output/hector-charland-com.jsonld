    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Elton Songs"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Préparez-vous à voyager dans le temps!Elton Songs vous invite à vivre les plus grands succès de Elton John, interprétés par le groupe, en costumes emblématiques des années 1970 et 1980, le tout centré sur une imitation vocale si authentique que vous vous croirez en sa présence!Les membres de Elton Songs, soit Steven Rosati (Elton), Ian Belhamou à la guitare, Norman Di Blasio aux claviers, Dave Neil à la batterie, Phil Ashley au violon et au saxophone, et Pascal Tirapani à la basse, sont prêts à passer une soirée mémorable avec vous!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2024-03-07T09:22:00"
      }
    ]
