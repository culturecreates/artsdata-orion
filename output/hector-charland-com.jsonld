    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/chemin-des-femmes"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Chemin des femmes"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Musique du monde en partenariat avec Godin Blouin Audioprothésistes.Camino de mujeres, ou encore Chemin des femmes, est un spectacle qui plonge les auditeurs dans l&#039;univers éclectique de Mikhaëlle Salazar et de son groupe Mikha.elles créé en 2020. Quatre voix uniques, soit celles de Marie-Neiges Harvey, Carmelle Gauvin, Judith Little-Daudelin et Mikhaëlle elle-même, ses origines métissées d&#039;une mère québécoise et d&#039;un père chilien, étant une source d&#039;inspiration pour les différents thèmes abordés tout au long de ce spectacle. Convergeant vers une seule et même expression vocale et explorant un répertoire aux rythmes latins, ce Chemin des femmes est chanté en espagnol et en français. Elles sont accompagnées aux percussions par la talentueuse Lara Klaus."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:02:00"
      }
    ]
  },
