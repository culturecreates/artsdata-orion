    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Safia Nolin"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Safia Nolin remonte sur scène pour la première fois depuis 2016 afin de présenter des versions épurées de classiques québécois qu’elle revisite depuis près de dix ans. Entre folk, nostalgie et mélancolie, ce spectacle propose un voyage introspectif à travers la culture québécoise, guidé par une milléniale passionnée de pop et de souvenirs."
      }
    ],
    "http://schema.org/uploadDate": [
