      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le nouveau spectacle de Viviane Audet met en lumière son plus récent album instrumental, Le piano et le torrent — un récit pianistique de quinze pièces, enraciné dans ce petit village côtier de la Baie-des-Chaleurs qui l’a vue naître, grandir et devenir : Maria."
      }
    ],
