    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Bouger Bouger!"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Sons et Brioches.Collation offerte gracieusement par McCafé à partir de 10h.Bouger Bouger est un spectacle participatif inspiré de l’Afrique de l’Ouest où le chant, la danse, la musique et les costumes traditionnels permettent aux spectateurs de voyager et de vivre une expérience unique. Dans un environnement festif traditionnel, un danseur et trois musiciens amènent le public à la découverte de masques africains et d’instruments traditionnels. Bouger Bouger, le spectacle dont vous êtes le héros ! « Le spectacle, c’est vous! » "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-16T16:42:00"
      }
    ]
