    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Trois générations, quatre voix et cent mille chansons.Ce concert unique réunit sur scène une véritable famille de chanteuses qui vous invite à partager la magie du temps des fêtes comme si vous étiez dans leur salon."
      }
