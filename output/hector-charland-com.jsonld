    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Vous serez emportés dans un tourbillon de medleys autour de l'amitié, de la famille et de la fête, à l'image de ce que les musiciens et choristes de l'émission nous ont habitués depuis 10 ans."
      }
