      {
        "@language": "fr-ca",
        "@value": "Les Illusionnistes | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Forcé de remplacer sa partenaire de scène de longue date à quelques jours de la grande première de leur spectacle, un artiste de vaudeville en déclin, nouvellement recyclé en magicien, doit composer avec une nouvelle musicienne lunatique et moqueuse qui vient chambouler une présentation cruciale…"
      }
    ],
