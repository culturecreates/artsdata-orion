    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les Illusionnistes"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Forcé de remplacer sa partenaire de scène de longue date à quelques jours de la grande première de leur spectacle, un artiste de vaudeville en déclin, nouvellement recyclé en magicien, doit composer avec une nouvelle musicienne lunatique et moqueuse qui vient chambouler une présentation cruciale pour un producteur influent.Rencontre unique de prouesses de magie actuelle (disparitions, lévitations, télépathie,...) et d&#039;un récital de femme-orchestre aux instruments inusités montés en boucles électroniques, ce duo théâtral captivant convie toutes les générations pour un rendez-vous intimiste à la fois classique, drôle et envoûtant."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2022-03-29T12:16:00"
      }
    ]
  },
