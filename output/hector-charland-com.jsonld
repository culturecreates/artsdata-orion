  {
    "@id": "https://hector-charland.com/temporary/451630cc-e345-48f6-8d3e-e0806d23bb5f",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/jonathan-roy-horizontal-0e3ddeb58a7daf4baaf5.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=ugyfM93-Ni4"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/jonathan-roy-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jonathan Roy"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La représentation du 18 avril 2025 est reportée au 12 décembre 2025.Jonathan Roy, auteur-compositeur-interprète, poursuit son chemin sur la scène musicale avec sa nouvelle tournée intitulée Symphony of Doubts. Depuis deux ans, sa carrière prend son envol vers les plus hauts sommets, où chaque concert remplit les salles en Amérique du Nord et en Europe. Sa dernière tournée Life Distortions a été un triomphe international, survolant près de 30 pays et illuminant près de 125 spectacles. Cette tournée lui a d&#039;ailleurs valu le prestigieux Félix pour la catégorie Spectacle de l’année anglophone.Avec un nouveau single déjà dévoilé, Nice To Meet You, Jonathan annonce un spectacle encore plus impressionnant, où chaque chanson résonnera comme une invitation à plonger dans son univers unique. Préparez-vous à être emportés pendant près de 90 minutes dans un tourbillon d&#039;émotions et de mélodies!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2024-05-22T15:48:00"
      }
    ]
