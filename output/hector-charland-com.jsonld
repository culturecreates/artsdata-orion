  {
    "@id": "https://hector-charland.com/temporary/faf6e508-ee79-4876-b985-2f74083c5c3e",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/la-grande-veillee-du-2-pierrots-horizontal-0ad791507921e601cccf.jpg"
      }
    ],
