  {
    "@id": "https://hector-charland.com/temporary/bdecc44d-7b78-46c7-b3e1-35a6168ce096",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/location": [
      {
        "@id": "https://hector-charland.com/genid/aacaf33a64ca42f7"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/philippe-laprise-horizontal-76f44404fce2718a3c93.jpg"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://hector-charland.com/genid/b706c7ea27c9b570"
      }
    ],
    "http://schema.org/performer": [
      {
