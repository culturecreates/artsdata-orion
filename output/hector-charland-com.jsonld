  {
    "@id": "https://hector-charland.com/temporary/d551c9ff-811e-410f-975e-868f8d173943",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/lecho-des-racines-horizontal-b5e7bfae0bad3f2d83e0.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=JNEbC8uADOI"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/lecho-des-racines"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&#039;écho des racines"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L&#039;écho des racines est un projet chorégraphique créé par La Sporée/Sarah Bronsard issu d’un dialogue fécond entre le flamenco et la gigue québécoise. Rassemblant huit danseurs et musiciens chevronnés, l&#039;oeuvre explore les liens qui unissent de manière implicite ces deux traditions, tout en questionnant les limites qui les définissent dans le temps et l’espace. Sur scène, les interprètes évoluent au coeur d’un réseau de laine qui se transforme progressivement au fil de leurs échanges. Inspirée par un phénomène souterrain observé dans les forêts, la laine symbolise les hyphes (racines des champignons), lesquelles permettent aux arbres de communiquer sur de grandes distances à même leurs racines par l’entremise de la mycorhize. À l’image des champignons, L&#039;écho des racines illustre avec poésie et dans une approche contemporaine la mutation perpétuelle des formes traditionnelles nourries par une infinité de connexions, d’influences et de vécus. À la fois réflexive et résolument festive, foisonnante et accessible, cette oeuvre rassemble tant les publics de la danse que de la musique."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-03-20T02:01:00"
      }
    ]
  },
