    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Barbie Boomer"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Documentaire | Québec | 2025 | GEn présence du réalisateur Marc Joly-Corcoran et de Sylvie Longpré. Sylvie est une collectionneuse invétérée de Barbie. Barbie Boomer suit Sylvie Longpré (67 ans) qui, pour assurer la pérennité d&#039;une partie de sa collection de Barbie, décide de donner les poupées de son enfance au Musée de la civilisation à Québec, qui accepte d’évaluer la proposition. Or, on se demande si elle vivra un deuil de séparation. D’autant plus qu’elle voit la condition physique de sa meilleure amie Linda, aussi une collectionneuse de Barbie, être sérieusement atteinte par la maladie."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-11-14T11:10:00"
      }
