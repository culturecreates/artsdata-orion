      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/la-legende-chet-baker-a-lhonneur"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La légende Chet Baker à l&#039;honneur!"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La représentation du 27 janvier 2021 est reporté au 9 juin 2021.Le spectacle sera présenté conformément aux normes sanitaires et de distanciation physique en vigueur.Trois des meilleurs jazzmans du Québec, le contrebassiste Frédéric Alarie, le pianiste John Roney et le trompettiste Ron Di Lauro se réunissent pour un concert rendant hommage à deux icônes du jazz : Chet Baker, trompettiste et compositeur, et Scott LaFaro, contrebassiste. Ces deux légendes du jazz ont joué ensemble au tout début de leur carrière dans le Chet Baker Quintet. Le trio Frédéric Alarie leur fait donc honneur et c’est avec bonheur que vous reconnaitrez les grands succès de ces deux étoiles du jazz : My Funny Valentine, Jade Vision, But not for me, It could happen to you, Someday my prince will come, Witchcraft et bien d’autres encore!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2020-09-22T00:05:00"
      }
    ]
  },
