    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/hommage-a-michel-legrand-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Hommage à Michel Legrand"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de leur série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.C’est avec émotion que le Trio Lorraine Desmarais, accompagné de la chanteuse Sonia Johnson, recrée sur scène leurs pièces coups de cœur du légendaire pianiste, chanteur et acclamé compositeur Michel Legrand sur des arrangements de Lorraine Desmarais. Dans des styles allant du swing au funk en passant par la valse jazz et la ballade romantique, vous serez touchés par l’interprétation émouvante de ces artistes sur les magnifiques chansons de Legrand telles que l’Été 42, Les moulins de mon cœur, La valse des lilas et La chanson de Maxence. Jazzé à souhait, ce concert vous ravira par ses performances grandioses où créativité, virtuosité et élégance sont à l’honneur."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:01:00"
      }
    ]
  },
