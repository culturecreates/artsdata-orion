    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Voyage à travers les Amériques"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle présenté en admission générale sur la scène du Théâtre Alphonse-Desjardins.Les spectateurs sont installés sur des chaises, autour de l&#039;artiste.Présenté par l&#039;Aramusique dans le cadre de sa série Musique Intimiste en partenariat avec General Dynamics.Chambriste et récitaliste passionné, le guitariste Daniel Bolshoy a foulé les scènes de concerts à travers l’Europe, l’Asie, le Moyen-Orient et les Amériques. Il nous propose une escapade musicale pour nous présenter les œuvres des compositeurs sud-américains Agustín Barrios Mangoré, Manuel Ponce et Sergio Assad. Entre commentaires et histoires de ces voyages terrestres et musicaux, Daniel Bolshoy nous ramènera au pays avec la prestation de la pièce Aurore Boréale, du compositeur franco-canadien Patrick Roux."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:01:00"
      }
    ]
