    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Katherine Levac"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle annuléAussi attachante et pince sans rire sur scène qu’à la télé, Katherine Levac dévoile de nouvelles facettes de sa personnalité dans ce premier spectacle solo fort attendu. Avec une couleur qui lui est propre, la jeune humoriste partage ses réflexions sur sa vie de jeune adulte avec toute la spontanéité et l’authenticité qu’on lui connait. Alliant naïveté et candeur, franchise et mordant, on peut dire que Katherine Levac est véritablement une main de fer dans un gant de velours."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2020-04-22T03:00:00"
      }
    ]
