    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/cirque-collini-horizontal-58268fe42064f3f1f344.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
