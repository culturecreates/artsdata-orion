    "http://schema.org/url": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/_1200x630_crop_center-center_82_none/daniel-karlsson-trio-horizontal-2127a6e0482278975029.jpg?mtime=1715117927"
      }
    ]
  },
  {
    "@id": "https://hector-charland.com/temporary/70cd7d28-2efa-41fd-aa5e-1603f9b0e9cf",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/daniel-karlsson-trio-horizontal-2127a6e0482278975029.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=517cfTCA6iQ"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/daniel-karlsson-trio"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Daniel Karlsson Trio"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le Trio Daniel Karlsson se démarque comme l’un des groupes les plus intéressants dans l’univers du jazz suédois et européen depuis la sortie de leur premier album Das Taxibåt en septembre 2013. Leur deuxième album Fusion for Fish sorti en août 2014 a remporté de nombreux prix en Suède dont celui de groupe jazz de l’année. Le trio s’est par la suite fait connaître à l’étranger notamment en Allemagne, au Royaume-Uni, en Irlande et en Italie. Leur troisième album At the Feel Free Falafel, a obtenu un accueil chaleureux par la presse et la radio. Leur quatrième album Ding Dong a aussi été très bien reçu comme le prouve sa nomination au Swedish Jazz Grammy Award pour le meilleur album de jazz en 2018. Cinq ans après leurs débuts, le Trio Daniel Karlsson sort un nouvel album intitulé simplement #5. Leur sixième album en carrière, Fuse number eleven, est sorti en 2019. Le trio a ensuite eu le bonheur de partir en tournée en Allemagne, en Italie et au Royaume-Uni.  Le groupe travaille présentement sur leur nouvel album qui sortira cet automne et l’amènera ensuite à effectuer une tournée en Europe et au Canada.  En 2021, le Swedish National Jazz Association, a louangé le travail de Daniel Karlsson, soulignant notamment son innovation et sa contribution à la musique jazz. L’Association a justifié sa décision en décrivant Daniel Karlsson comme un talentueux musicien ayant un leadership remarquable avec ses musiciens ainsi qu&#039;une maîtrise du jazz tant traditionnel que contemporain. Elle a aussi mis de l’avant sa sa grande curiosité musicale et sa personnalité artistique unique.  Daniel Karlsson est bien connu pour sa participation dans le Magnus Öström Band. Il a collaboré à plusieurs reprises avec, entre autres, Till Brönner, Nils Landgren, Viktoria Tolstoy and Rigmor Gustafsson. En 2005, il a été nominé comme Artiste de jazz de l’année. Christian Spering a lui aussi eu la chance de jouer avec des icônes de jazz comme Peter Erskine, Bobo Stenson and Jon Christensen. Fredrik Rundqvist a joué, entre autres, avec Bobo Stenson and Palle Danielsson. Dans les dernières années, on peut l’entendre jouer avec le groupe de la pop star indie Sarah Blasko.  La musique du Trio, écrite par Daniel Karlsson est décrite comme étant unique et extravertie, avec des influences claires de jazz, de soul et de la pop des années 60, le tout avec un parfum nordique! "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2022-05-10T09:57:00"
      }
    ]
