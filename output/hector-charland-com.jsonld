    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le spectacle  Noël une tradition en chanson  sera de retour en 2026 pour une neuvième édition, réunissant les plus belles voix du Québec dans un rendez-vous festif et empreint de nostalgie, mis en scène par Joël Legendre et dirigé musicalement par Jacques Roy.  Stef Carse, Annie Villeneuve, Étienne…"
      }
    ],
