    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Véronic Dicaire"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Suite au succès de son dernier spectacle, qui a remporté le Félix du Spectacle de l’année à l’ADISQ, Véronic est enfin de retour avec son tout nouveauspectacle! L’artiste aux multiples talents a la goût de se faire plaisir et vous propose un spectacle musical rempli des plus grands succès et des plus grandes voix. Il y aura assurément de l’humour et des imitations, mais Véronic veut mettre cette fois-ci les émotions au premier plan. Elle nous prépare donc un spectacle qui lui ressemble et qui promet de nous faire vivre une soirée exceptionnelle!"
      }
    ],
