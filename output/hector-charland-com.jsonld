  {
    "@id": "https://hector-charland.com/temporary/2345272b-03f6-4432-9622-f5d9157be2f7",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/boogie-wonder-band-horizontal-3e5c736f9c2b78d835db.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=fiec47vyvks&amp;list=RDfiec47vyvks&amp;start_radio=1"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/boogie-wonder-band-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Boogie Wonder Band"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Impossible de ne pas danser sur les chansons du Boogie Wonder Band, pas vrai? Vous le constaterez par vous-mêmes lors du spectacle! Notez qu&#039;il est très probable que des gens autour de vous soient debout lors de la représentation.Le Boogie Wonder Band, célèbre pour son énergie contagieuse et ses grooves irrésistibles, présente un tout nouveau spectacle électrisant Disco Honey! Plongez dans un tourbillon de paillettes et de boules miroirs, où les rythmes endiablés de la basse et les envolées des cuivres vous transportent instantanément dans l’atmosphère exaltant des années disco.De Donna Summer aux Bee Gees, en passant par Gloria Gaynor et KC &amp;amp; the Sunshine Band, le répertoire du Boogie Wonder Band rassemble les plus grands hits qui ont marqué l&#039;histoire de la musique des années 70. Attendez-vous à des costumes étincelants, à des chorégraphies captivantes et à une ambiance électrisante qui vous incitera à vous lever pour rejoindre la piste de danse.Que vous soyez un nostalgique des années disco ou simplement en quête d&#039;une soirée inoubliable, le spectacle du Boogie Wonder Band est un incontournable pour tous les amateurs de musique. Préparez-vous à danser, à chanter et à célébrer, car, avec le Boogie Wonder Band, la fête ne fait que commencer!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-10-01T02:01:00"
      }
    ]
  },
