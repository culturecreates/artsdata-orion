    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/wooden-shapes-horizontal-f5623e8ee910485cb283.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=RlAJQJ99JEg"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/wooden-shapes"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Wooden Shapes"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le spectacle qui a conquis le public est de retour! Après une tournée remarquée au Québec et à l’international, Wooden Shapes débarque avec son tout nouveau spectacle. Plongez dans les plus grands classiques du rock : Metallica, Harmonium, Guns N’ Roses, David Bowie et bien d’autres, réinventés et joués uniquement sur des instruments à cordes. Avec six musiciens talentueux et des arrangements encore plus grandioses, ce spectacle ne cherche pas à imiter, il réinvente. Une célébration audacieuse du rock, qui frappe droit au cœur!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-01-22T01:02:00"
      }
