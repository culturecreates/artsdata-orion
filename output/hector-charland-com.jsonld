  {
    "@id": "https://hector-charland.com/temporary/aeb0f40a-761b-47f2-9c19-4334aa1d178a",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/guillaume-pineault-horizontal-d4d5e1ba469fdf9dce62.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/CsyKtap8BCk"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/guillaume-pineault-1"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Guillaume Pineault"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Malgré l’air calme et confiant que je peux dégager sur mon affiche, derrière cette façade, se cachent plusieurs mécanismes de défense, beaucoup d’anxiété et 65 % d’eau (oui, c’est vraiment le pourcentage d’eau dans le corps adulte; je le sais, je l’ai appris à l’université, et j’adore rappeler aux gens que j’ai des connaissances biologiques grâce à mon passé académique).Dans ce spectacle, il n’y a plus de filtre, aucune carapace : vous aurez accès à un Guillaume plus intime, authentique et vulnérable. Bien entendu, mon désir premier est de vous faire rire, mais également de vous faire découvrir l’humain derrière l’humoriste.Au plaisir de vous voir et de vous présenter Vulnérable."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2023-06-01T09:24:00"
      }
    ]
  },
