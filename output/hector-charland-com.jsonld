    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jesse Cook"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Jesse Cook est un guitariste, compositeur et producteur canadien reconnu pour avoir révolutionné la musique du monde en mêlant flamenco, jazz et influences culturelles venues des quatre coins du globe. Avec plus de 900 millions d’écoutes en ligne et plus de 130 millions de vues sur YouTube, son impact est incontestable. Depuis trois décennies, Cook a donné des milliers de concerts dans des dizaines de pays. Il est accompagné d’un groupe exceptionnel : Fethi Nadjem (violon, mandole), Dan Minchom (basse), Matt Sellick (guitare) et Matais Recharte ou Marito Marques (batterie, cajón et percussions).﻿"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-12-10T01:02:00"
      }
    ]
