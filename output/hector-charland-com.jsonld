    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "HYL"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle présenté en formule debout sur la scène du Théâtre Alphonse-Desjardins.HYL se définit entre la chanson et un rap pop, électro coloré. Des mots pour dessiner des mélodies dans la lignée d’Orelsan, Gaël Faye, ou l’énergie communicative de Thérapie TAXI, à mi-chemin entre l’insouciance et la prise de conscience. En 2024, un 2ème EP a vu le jour aux croisements de mondes qui nourrissent l’artiste. Réalisé par le studio « La Tanière » (Bigflo &amp;amp; Oli, etc.), ce nouveau regard affirmé nous projette dans des histoires et des émotions que l’on semble avoir déjà tous vécues."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-10-02T09:44:00"
      }
    ]
  },
