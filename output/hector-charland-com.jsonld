    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ian Kelly"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Accompagné du multi-instrumentiste Marcus Lowry et parfois, de sa fille Mahika, Ian présente un spectacle naturel et en toute simplicité. Avec vingt ans de carrière, il compte sur ses meilleures chansons pour bâtir un répertoire survolant son parcours dans une performance avec guitares, piano et une voix remplie d&#039;émotion pour livrer des paroles qui n&#039;ont rien d’artificiel."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-10-07T02:02:00"
      }
    ]
  },
