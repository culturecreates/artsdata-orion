      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/la-femme-la-plus-riche-du-monde"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La femme la plus riche du monde"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Comédie dramatique | France-Belgique | 2025 | GCésar 2026 du Meilleur acteur (Laurent Lafitte)La femme la plus riche du monde : sa beauté, son intelligence, son pouvoir. Un photographe : son ambition, son insolence, sa folie. Le coup de foudre qui les emporte. Une héritière méfiante qui se bat pour être aimée. Un majordome aux aguets qui en sait plus qu’il ne dit. Des secrets de famille. Des donations astronomiques. Une guerre où tous les coups sont permis.« Tandis que les acteurs se balancent des répliques tantôt assassines, tantôt câlines au gré d’une mise en scène stylisée, le spectateur ne peut s’empêcher de prendre un malin plaisir à voir s’étaler les malheurs des riches et célèbres. » - La Presse"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-28T02:03:00"
      }
    ]
