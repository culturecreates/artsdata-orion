  {
    "@id": "https://hector-charland.com/temporary/e26873c0-1870-4727-a222-03b0c3e758fd",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/pierre-luc-pomerleau-horizontal-f8b5e5918d73de894c7a.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
