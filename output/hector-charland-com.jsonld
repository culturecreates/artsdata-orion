    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/poesie-et-virtuosite"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Poésie et virtuosité!"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle présenté en admission générale sur la scène du Théâtre Alphonse-Desjardins.Les spectateurs sont installés sur des chaises, autour du piano.Présenté par l&#039;Aramusique dans le cadre de sa série Musique Intimiste.Le pianiste, Jean-Philippe Sylvestre vous présente un programme mêlant œuvres iconiques et découvertes fascinantes. Laissez-vous emporter par la virtuosité de la Rhapsodie hongroise n°2 de Liszt et la poésie intemporelle du Clair de lune de Beethoven, en plus de découvrir l’oeuvre sublime de Maurice Ravel, Pavane pour une infante défunte. Le Concerto de Québec du compositeur québécois André Mathieu complètera le programme ainsi que la pièce Islamey de Mili Balakirev, un morceau aussi envoûtant que puissant!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
