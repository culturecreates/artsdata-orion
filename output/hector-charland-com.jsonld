    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Du passé au présent"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Ce concert Du passé au présent du saxophoniste, compositeur et arrangeur de renom, Jean-Pierre Zanella, vous invite à un voyage sonore inédit, où il revisite avec son quartet, les œuvres majeures de Chopin à Villa-Lobos, en passant par Fauré et Beethoven. Ce spectacle est incontournable pour les jazz aficionados exigeants, tout autant que pour le grand public en quête d&#039;une expérience musicale riche et accessible. Ne manquez pas cette rencontre au sommet de l&#039;art et l&#039;énergie du jazz enrobée dans l&#039;éternelle beauté des grands classiques dont le poignant Prélude Opus 28 no 4 de Frédéric Chopin et la célèbre Lettre à Élise (Für Elise) de Beethoven."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
