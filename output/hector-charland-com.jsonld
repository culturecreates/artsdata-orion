    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Prodige musical, Ron Artis II compose et interprète une musique originale qui captive les publics à travers le monde. Son jeu de guitare polyvalent et puissant accompagne une écriture soulful, authentique et unique. Sur scène, il offre une expérience intense qui touche et électrise les spectateurs grâce à des textes profondément humains."
      }
    ],
    "http://schema.org/uploadDate": [
