    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Cutting through the noise"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Cutting Through the Noise est un voyage physique et sensoriel pour 9 interprètes portés par une trame musicale propulsive. Entre parcours obsessifs, métamorphoses subtiles et concert euphorisant, la pièce évoque une jeunesse marquée par l’ère numérique. Dans un monde saturé de stimulations, elle revendique la puissance du corps et du mouvement comme actes de présence. Un élan collectif, viscéral, qui célèbre la liberté et la connexion humaine."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-03-20T02:01:00"
      }
    ]
