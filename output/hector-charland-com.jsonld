    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Northern Trails – Le meilleur du New Country"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Northern Trails – Le meilleur du new country vous transporte au cœur des Honky Tonks de Nashville dans un spectacle électrisant qui célèbre les plus grands succès de la musique country actuelle. Porté par une formation musicale de haut calibre et trois interprètes au charisme indéniable (Justin Legacy, Laurence Doire et Jordan Levesque) le spectacle fait vibrer les classiques de Luke Combs, Chris Stapleton, Miranda Lambert, Keith Urban, Zac Brown Band, Morgan Wallen et plusieurs autres figures emblématiques. Northern Trails offre une soirée aussi festive qu’émotive, à la croisée de l’authenticité country et de l’intensité des scènes live de Nashville. Une célébration incontournable du new country, pensée pour faire lever les foules."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-02-04T01:02:00"
      }
    ]
  },
