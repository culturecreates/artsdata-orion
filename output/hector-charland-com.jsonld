  {
    "@id": "https://hector-charland.com/temporary/91cd70f2-4d0a-4644-8a70-ab7e8da7f895",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/un-piano-et-des-mots-horizontal-26b600fd4061668e9ae7.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=rHMC558JFsM"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/un-piano-et-des-mots"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Un piano et des mots"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Plongez au cœur d&#039;une expérience musicale inoubliable! Productions Grand V. vous présente Un piano et des mots, un spectacle à la fois intimiste et vibrant. Marc-André Fortin et Audrey-Louise Beauséjour, accompagnés de trois musiciens talentueux, vous convient à un voyage à travers le temps, mettant en lumière les joyaux du répertoire musical francophone. Des paroles évocatrices, des mélodies envoûtantes, Un piano et des mots offre une ode à la nostalgie et à l&#039;authenticité. Ces chansons, qui résonnent comme des marqueurs temporels dans nos vies, seront interprétées avec passion et virtuosité, créant ainsi un moment privilégié où chaque note et chaque mot résonnent avec émotion. On a qu’à penser à certaines paroles telles que : « C’est dans la pénombre que la lumière est belle »« T’es la plus belle saison de ma vie »« Pour l’amour qu’il nous reste »« S’il fallait » Rejoignez-nous pour une soirée unique où la puissance des mots et la magie du piano se rencontrent!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2023-11-14T08:37:00"
      }
    ]
  },
