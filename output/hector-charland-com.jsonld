  {
    "@id": "https://hector-charland.com/temporary/a6a25532-42f7-4a70-9ebb-f1bfcb2d4d95",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/montreal-ma-belle-horizontal-7ac661f3aef176798724.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
