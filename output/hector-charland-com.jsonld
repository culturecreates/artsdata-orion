    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/charles-beauchesne"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Londres, la fin du 19e siècle. Alors que la populace œuvre matin et soir dans les usines toxiques et dangereuses de l'ère industrielle, un monstre sans nom ni visage se terre dans les ruelles. Un meurtrier dont on ne connait rien, qui donnera naissance au 20e siècle par l'utérus ensanglanté des prostitués de Whitechapel, avant d'inexplicablement disparaître à jamais dans le brouillard londonien. Suivez l'humoriste le plus sinistre en ville sur les traces de Jack L'Éventreur alors qu'il tente (tout en humour doit-on le rappeler) de percer le secret du plus légendaire des tueurs en série."
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr-ca"
      }
    ],
    "http://schema.org/name": [
