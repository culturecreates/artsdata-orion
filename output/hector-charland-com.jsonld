    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Spectacle annulé Aussi attachante et pince sans rire sur scène qu’à la télé, Katherine Levac dévoile de nouvelles facettes de sa personnalité dans ce premier spectacle solo fort attendu. Avec une couleur qui lui est propre, la jeune humoriste partage ses réflexions sur sa vie de jeune adulte avec…"
      }
    ],
