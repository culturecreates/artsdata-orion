      {
        "@id": "https://www.youtube.com/watch?v=xC2fbAWLgVA"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/la-grande-veillee-du-2-pierrots"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La grande veillée du 2 Pierrots"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté en formule debout! Le 2 Pierrots est de retour pour faire revivre au public des moments inoubliables avec son spectacle La grande veillée du 2 Pierrots qui vient souligner la sortie de son plus récent album portant le même nom. Fidèle à ses habitudes, la légendaire boîte à chansons a pour but de faire danser et chanter sur les airs des chansons québécoises et francophones les plus connues et aimées. De Paul Piché aux Cowboys Fringants en passant par Les Colocs, le spectacle met en lumière la riche histoire musicale du Québec de façon festive comme le 2 Pierrots avait l’habitude de le faire chaque soirée dans son établissement de l’époque à Montréal. Avec un groupe de 6 musiciens sur scène accompagné d’un chansonnier pilier du 2P, La grande veillée du 2 Pierrots offre une occasion aux nostalgiques de renouer avec l’endroit et à ceux qui n’ont jamais eu la chance d’y aller d’expérimenter un party comme seule cette boîte à chanson peut offrir."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-05T02:01:00"
      }
    ]
  },
