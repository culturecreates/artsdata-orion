    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=VDcrGxJmBp4&amp;list=PLvePi35JP1xwQfjDPV2gf0lH0aW6Htate&amp;index=7"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/sur-la-route"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Sur la route"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Voyage Musical en partenariat avec Godin-Blouin Audioprothésistes. Voici maintenant 20 ans que Christine Tassan et les Imposteures roulent leur bosse à travers le monde. Vingt ans à faire rayonner jazz manouche et chansons swing sur des scènes prestigieuses ainsi que dans des villages reculés du Labrador, de Terre-Neuve, de l’île de Vancouver ou de la France. C’est en se remémorant ce parcours incroyablement dense et riche en aventures que les musicien.nes ont eu l’idée de créer Sur la route. Ce spectacle captivant transporte le public au cœur de leurs tournées épiques, à travers des paysages grandioses et des anecdotes savoureuses. Vivez l’ascension de la grande muraille de Chine, une balade à vélo dans Stanley Park à Vancouver, la traversée des Rocheuses en pleine tempête de neige ou la visite de Samois-sur-Seine, village de Django Reinhardt!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-16T14:42:00"
      }
    ]
  },
