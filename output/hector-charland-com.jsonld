    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Avec son premier one-man-show Stand-Up a vendu près de 70 000 billets, ses milliers d’abonnés sur les réseaux sociaux, ses nominations au Gala Les Olivier 2024: Olivier de l’année et Émission humoristique télé de l’année avec Club Soly , tout le monde attend le retour de l’inimitable humoriste!"
      }
