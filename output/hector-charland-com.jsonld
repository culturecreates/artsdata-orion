    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Guy Nantel - Bienveillant | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Alors que l’actualité regorge de sujets explosifs, d’opinions tranchées et de contradictions bien de chez nous, l’humoriste Guy Nantel revient avec un tout nouveau spectacle au titre pour le moins intrigant: Bienveillant. Avec ce 7e spectacle en carrière, Guy Nantel continue de faire ce qu’il fait…"
      }
    ],
