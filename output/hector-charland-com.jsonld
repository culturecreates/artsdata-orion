    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Safia Nolin remonte sur scène pour la première fois depuis 2016 afin de présenter des versions épurées de classiques québécois qu’elle revisite depuis près de dix ans. Entre folk, nostalgie et mélancolie, ce spectacle propose un voyage introspectif à travers la culture québécoise, guidé par une…"
      }
