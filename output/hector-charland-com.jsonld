      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/symbiose-cafe-korige"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Symbiose - Café Korigé"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Musique du monde en partenariat avec Godin Blouin Audioprothésistes.Dans ce projet, Komty Ondoua, Ricardo Soriano et Geremia Lodi explorent les paysages cachés dans leurs langues maternelles : le Maka’a (langue de l’Est-Cameroun), l’espagnol et l’italien. Les paysages sonores émergents sont comparés, superposés, remixés dans l’effort de retrouver un sentiment d’appartenance en suivant deux directions: remonter aux origines de sa propre langue tout en générant un nouvel espace de rencontre avec d’autres langues. Comment un groove de jazz latin se métamorphose lorsqu’il est superposé à une polyphonie pygmée et aux sons de la forêt équatoriale? Comment les polyrythmies équatoriales peuvent-elles dialoguer avec des mélodies vocales en italien? Ce projet répond à ces interrogations, où les langues sont utilisées pour leur puissance poétique et musicale, en écho aux terres mêmes qui les ont engendrées."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:02:00"
      }
    ]
  },
