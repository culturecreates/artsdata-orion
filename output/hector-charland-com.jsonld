  {
    "@id": "https://hector-charland.com/temporary/ca35b7a7-dc3f-4b46-b8ee-e3aa8239703c",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/eclat-nocturne-horizontal-56a370381042307be9a4.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/tMmd9T32lc0"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/eclat-nocturne"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Éclat Nocturne"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de leur série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.La violoniste Marie Neige Lavigne vous invite à découvrir ses compositions originales avec son spectacle Éclat Nocturne. Ce concert traduit une volonté de trouver la lumière dans les parts d’ombre et de magnifier l’éclat de chaque être vivant, qu’il soit lunaire ou solaire. Appuyées par des musiciens exceptionnels - Bernard Falaise à la guitare, Pierre Tanguay à la batterie et Jean Félix Mailloux à la contrebasse - les mélodies de Marie Neige vous feront voyager dans un espace-temps unique, là où la musique est notre lieu commun. Les mélodies simples sont un prétexte pour laisser libre cours à des improvisations exaltantes qui démontrent que le tout est plus grand que la somme des parties! Se promenant entre le world, le jazz et sans oublier la finesse de sa base classique, le langage musical de Marie Neige est accessible à tous et offre une grande palette de paysages sonores, tel de petits films explorant des moments de liberté."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:01:00"
      }
    ]
  },
