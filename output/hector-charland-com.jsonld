    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/nebulae-harpe-cosmos-et-droleries-horizontal-7d288c32418bfca241ac.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=7JFwgu6Edfw"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/nebulae-harpe-cosmos-et-droleries"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "NEBULAE : Harpe, cosmos et drôleries"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Les Grands Concerts en partenariat avec Blanchelle.Un abonnement est aussi disponible, tous les détails en cliquant ici.Le nouveau spectacle Nebulae - Harpe, cosmos et drôleries de la harpiste Valérie Milot expose une réflexion artistique et philosophique à travers la science des phénomènes astraux. La harpe se positionne comme témoin de l’évolution de l’humain et de sa relation avec l’univers. Ce parcours grandiose et omnipotent prédispose à une réflexion sur l’existence et nous fera traverser des siècles de musique, ponctués entre autres, par le Clair de lune de Debussy et d’une Danse des esprits bienheureux pour illustrer ces propos. Un concert intime teinté de réflexions, d’humour et de musique enivrante tissera un lien précieux entre l’artiste et les mélomanes."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
  },
