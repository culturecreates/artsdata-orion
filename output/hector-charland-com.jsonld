      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Chants de Victoires est un voyage musical vibrant au cœur d’un moment charnière de l’histoire de la Nouvelle-France. Porté par un ensemble de musiciens d’exception, Chants de Victoires fait résonner l’histoire dans un croisement saisissant d’ancien et de nouveau, de mémoire et de création."
      }
    ],
