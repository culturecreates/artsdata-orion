    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Babouche"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Sons et Brioches en partenariat avec McDonald&#039;s - La famille Lemay. Collation offerte gracieusement par McCafé à partir de 10h.Babouche : un voyage musical avec les poètes du fou rire! Quatre clowns musiciens envahissent la scène avec une charrette pleine d’instruments mystérieux et une envie folle de s’amuser. Ils ont pensé à tout : jongler dans le noir, se transformer en moustique et faire des acrobaties verbales! Ce qu’ils aiment, c’est jouer avec les mots. Babouche, c’est la voix avec de l’imagination, des instruments avec des paroles craquantes, l’accordéon avec de l’art clownesque."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-16T16:42:00"
      }
    ]
