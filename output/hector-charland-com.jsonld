      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Au fil de sa carrière, La Bottine Souriante a enregistré treize albums originaux, dont quatre certifiés Or et trois certifiés Platine, totalisant plus de 750 000 albums vendus au Québec et a remporté une dizaine de distinctions majeures , telles que prix Juno, Félix et BBC Awards."
      }
    ],
