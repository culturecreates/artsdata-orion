    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ricordi"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de leur série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Le trompettiste Ron Di Lauro partage avec vous ses coups de cœur des chansons italiennes qui ont meublé son enfance. Entouré du guitariste David Rourke et de John Roney au piano, qui a réalisé les arrangements, Ron nous bercera au son de sa trompette dans vos airs préférés dont O Solo mio, Volare, Arrivederci Roma et l’incontournable mélodie du Cinéma Paradiso du grand Morricone. Une soirée toute en douceur et chaleur aux saveurs italiennes pour vous réchauffer le cœur et le corps et vous éloigner de la froidure de l’hiver le temps d’un apéro."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:01:00"
      }
    ]
