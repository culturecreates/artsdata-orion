    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/embrahms-moi-horizontal-57b242f027e1b22812bb.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
