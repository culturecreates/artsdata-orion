    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "André Sauvé"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "André Sauvé fait un retour sur scène avec une création audacieuse où son regard unique sur le monde puise son inspiration dans la nature et ses mystères. Il nous livre ses observations dont chaque détail prend une dimension surprenante, ne voyant dans cette nature qui l&#039;entoure qu’une métaphore de l’esprit humain. À travers ce voyage, il tisse un lien entre humour et poésie, explorant l’âme humaine à travers le prisme de son environnement. Humour et réflexion s’unissent dans cette expérience fidèle à la touche et au talent inimitable d’André Sauvé. "
      }
    ],
