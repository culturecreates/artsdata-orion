  },
  {
    "@id": "https://hector-charland.com/temporary/c4958e2b-eee4-4eb8-9b92-a60e7cf8aaa8",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/angelique-francis-horizontal-336e466324d78962137f.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=Svi1xNBtdGk"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/angelique-francis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Angelique Francis"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L&#039;autrice-compositrice-interprète originaire d&#039;Ottawa, Angelique Francis est une musicienne polyvalente et exceptionnellement douée. Cette auteure-compositrice-interprète multi-instrumentiste a séduit le public du monde entier avec ses performances électrisantes, ses capacités instrumentales et sa voix texturée puissante. Elle est connue pour son mélange éclectique de divers genres musicaux, notamment le blues, la soul, le folk, le jazz, le gospel et le rock.Son album Long River a été décoré du prix Juno du meilleur album blues et son plus récent album Not Defeated attire déjà l&#039;attention, notamment grâce à la participation de Christone Kingfish Ingram et Eric Gales. Angélique a partagé la scène et fait les premières parties de nombreux musiciens reconnus tels que Gary Clark Jr, Beth Hart, Tom Cochrane, Burton Cummings, Sugar Ray, Jimmy Vivino et plusieurs autres. Elle a participé à plusieurs évènement et festivals d&#039;envergure donc Sighisoara Blues Festival (Romania), Massey Hall à Toronto (Women&#039;s Blues Revue), Festival International de Jazz de Montréal, Ottawa Jazz festival, Ottawa Blues Festival, White Mountain Boogie Festival, Festival International du Blues de Tremblant, Trois-Rivières en Blues, Ottawa Folk Fest, pour en nommer quelques un. Récemment la jeune prodige a fait partie de la croisière Keeping The Blues Alive At Sea pour une deuxième fois avec Joe Bonamassa, Samantha Fish, Keb Mo et Georges Thorogood."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-12-03T08:53:00"
      }
    ]
