    "@id": "https://hector-charland.com/temporary/873428bc-fc8d-48d6-93c6-db813ad1059d",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/avec-amour-et-acharnement-horizontal-418efd8856652d05a8f7.jpg"
