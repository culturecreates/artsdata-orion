    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "QW4RTZ - Ça goûte Noël | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Pour le temps des Fêtes, QW4RTZ vous a mijoté un spectacle entremêlant chansons, recettes, humour et anecdotes savoureuses. Arômes de cannelle, effluves de girofle et muscade, chacun de vos quatre chefs/cuistots de l'a cappella y présente, en chanson, la recette de son plat signature du temps des…"
      }
    ],
