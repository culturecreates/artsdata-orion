      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tommy Néron"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Un spectacle porté par un mélange savoureux d’observations et d’anecdotes tirées d’un parcours qui, avec le recul, n’était pas exactement comme celui de tout le monde. Le public peut même y amener son ado : peu de risques de traumatisme… mais à ses risques et périls. Mis en scène par Laurent Paquin et peaufiné avec la complicité de Korine Côté, Les fleurs poussent encore prend tout son sens une fois le rideau levé. "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-27T02:02:00"
      }
    ]
