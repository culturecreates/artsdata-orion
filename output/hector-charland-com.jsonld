    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "MG3 joue Ennio Morricone"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Considéré comme l’un des meilleurs ensembles au pays, le MG3, Montréal Guitare Trio, impose sa virtuosité et son époustouflante présence scénique ici et à l’étranger depuis plus de 25 ans. Voilà que les trois guitaristes proposent un concert hommage à la mémoire du grand Ennio Morricone. Depuis leur tout premiers débuts, les musiques de cet illustre compositeur font partie du répertoire des trois comparses. Des classiques comme l’Homme à l’harmonica, Mon nom est Personne et Il était une fois dans l’Ouest prennent une nouvelle vie à travers le prisme des trois guitares et des arrangements des artistes. Ce concert est dédié à ce grand compositeur, rehaussé comme il se doit de quelques surprises à la façon MG3!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
