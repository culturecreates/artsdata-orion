    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Mario Introia est de retour et nous dévoile le troisième volet consacré à son Italie natale. Rendez-vous ensuite en Ombrie, petit cœur secret de l’Italie, où la nature s’impose comme une présence vivante et silencieuse."
      }
    ],
