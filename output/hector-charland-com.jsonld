    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Sara Dufour"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "À l&#039;occasion de la parution de son nouvel album cet automne, Sara Dufour annonce du même coup qu&#039;elle repartira en tournée en salles partout au Québec en 2027. Entourée de ses musiciens, elle propose un spectacle où se mêlent nouvelles chansons et incontournables, porté par son authenticité, son énergie contagieuse et sa proximité unique avec le public."
      }
    ],
    "http://schema.org/uploadDate": [
