    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Matt Holubowski"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Figure de proue de l’indie-folk depuis plus d’une décennie, Matt Holubowski n’a besoin d’aucune présentation. Envolées lyriques, voyages au cœur de l’intime et solo de guitare déchaîné se conjuguent au sein d’une discographie à l’ambition rare parmi ses pairs Québécois. En formule solo, il vous propose une immersion dépouillée et vibrante dans son univers."
      }
    ],
