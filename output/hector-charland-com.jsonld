    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "QW4RTZ"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour le temps des Fêtes, QW4RTZ vous a mijoté un spectacle entremêlant chansons, recettes, humour et anecdotes savoureuses. Arômes de cannelle, effluves de girofle et muscade, chacun de vos quatre chefs/cuistots de l&#039;a cappella y présente, en chanson, la recette de son plat signature du temps des Fêtes. Vos oreilles se délecteront des meilleurs succès de Noël, de l&#039;électro-trad à Marie-Noël en passant par Last Christmas et Le sentier de neige."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-09T02:02:00"
      }
