  {
    "@id": "https://hector-charland.com/temporary/d133ad3f-b32c-4bcb-8eb3-020fb6a45587",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/boucar-diouf-horizontal-7d1b9180e69aea76d685.jpg"
