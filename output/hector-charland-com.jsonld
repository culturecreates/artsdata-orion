      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/noel-une-tradition-en-chanson-3"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/noel-une-tradition-en-chanson-3"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Des voix chaleureuses pour la 8e édition! Certaines coutumes sont indélogeables et pour une huitième année, le spectacle Noël une tradition en chanson vient célébrer le temps des fêtes en musique. Mis en scène par Joël Legendre, le spectacle mise sur la nostalgie, l’humour et les souvenirs du temps des fêtes de différentes générations. À la direction musicale, Jacques Roy poursuit l’excellent travail des années précédentes, en insufflant au spectacle une ambiance festive."
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr-ca"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Noël une tradition en chanson | Théâtre Hector-Charland"
      }
    ],
