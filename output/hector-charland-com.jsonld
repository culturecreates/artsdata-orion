  },
  {
    "@id": "https://hector-charland.com/temporary/b3b98dee-bc31-40ed-9fb0-953823f51bcc",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/passion-celine-horizontal-6872e93e0580f243d12e.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=bn8Ay7fcxg0"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/passion-celine"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Passion Céline"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dès les premières notes, vous aurez le souffle coupé par l’incroyable ressemblance vocale avec Céline Dion!​ L’interprète Catherine Pearson entourée de ses musiciens exceptionnels, sous la direction musicale de David Champoux, saura assurément ravir les plus grands fans de Céline en leur offrant un spectacle époustouflant.​ Un concept réunissant les plus grands succès en carrière de la diva ainsi que des tenues de scène créées sur mesure pour Catherine par le designer québécois Yves Jean Lacasse. Vous en ressortirez éblouis et touchés tant par la puissance vocale que par le vibrant message d&#039;amour qui s&#039;inscrit dans la continuité de celui qu&#039;a livré Céline sur les plus grandes scènes du monde."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-10-23T02:02:00"
      }
    ]
  },
