    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Trois des meilleurs jazzmans du Québec, le contrebassiste Frédéric Alarie, le pianiste John Roney et le trompettiste Ron Di Lauro se réunissent pour un concert rendant hommage à deux icônes du jazz : Chet Baker, trompettiste et compositeur, et Scott LaFaro, contrebassiste."
      }
    ],
