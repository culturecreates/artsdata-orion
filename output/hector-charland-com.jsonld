    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Inspirée par un phénomène souterrain observé dans les forêts, la laine symbolise les hyphes (racines des champignons), lesquelles permettent aux arbres de communiquer sur de grandes distances à même leurs racines par l’entremise de la mycorhize."
      }
