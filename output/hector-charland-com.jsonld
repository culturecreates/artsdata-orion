    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alphonse Bisaillon"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Formule deboutAlphonse est une bête de scène et un poète. Avec t.o.m. ou la trajectoire des perséides, il plonge dans son passé de garçon rural. Une épopée qui questionne les modèles masculins offerts aux jeunes hommes. Sur scène, les musiciens portent son énergie, du jazz au dubstep, guidée par la force des mots. Un spectacle théâtral où t.o.m., ami ou amour, incarne ce que chaque homme peut devenir."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-27T02:03:00"
      }
    ]
  },
