      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Tire le coyote pour la première fois seul en scène. Une occasion pour l’auteur-compositeur de revisiter son répertoire et de proposer de nouvelles chansons dans une parfaite ambiance intime, qui laissera toute la place à la poésie des mots, à son talent de guitariste et à cette voix unique qui nous…"
      }
    ],
