    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "JF Pauzé, membre des Cowboys Fringants et auteur-compositeur des chansons du groupe (Félix – Auteur-compositeur de l’année 2024), fera ses débuts en solo avec un premier album à titre d’interprète, composé de 11 nouveaux titres originaux. Une sortie des plus attendues à l’automne 2025. JF remettra…"
      }
    ],
