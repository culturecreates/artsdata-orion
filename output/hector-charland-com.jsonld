  {
    "@id": "https://hector-charland.com/temporary/2be1750d-5812-4d26-b635-7c23127e1096",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/maroc-en-vanlife-horizontal-30bf084be82ef718da5e.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
