        "@value": "Elliot Maginot"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Elliot Maginot crée une atmosphère enveloppante avec sa voix vibrante, oscillant entre ombre et lumière. Mélancolique et sensible, il mêle pop, folk, trad et country. Accompagné de ses musiciens, il interprète son nouvel album I Need To Stay Here et ses précédents opus, offrant un spectacle émouvant et vulnérable."
      }
    ],
