  {
    "@id": "https://hector-charland.com/temporary/84dc7b35-3713-4a2e-aa85-b880e8109647",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/fallait-etre-la-horizontal-bf0b605ef927bf4962d1.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=y0nbZKXGgKQ"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/fallait-etre-la"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Fallait être là!"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fallait être là est un nouveau concept de spectacle humoristique et interactif qui redéfinit les codes de l’impro et de l’humour de scène traditionnel afin de créer des moments déjantés. Philippe Laprise, maître de cérémonie, accueille quatre invités vedettes, Jay Laliberté, Richardson Zéphir, Marie Eve Morency ainsi que Korine Côté, qui participent à des défis humoristiques décalés, avec comme objectif de déclencher les plus grands fous rires. Fallait être là est un spectacle événementiel audacieux, hilarant et surprenant, dans lequel le public sera amené à participer à plusieurs niveaux. Assistez à une expérience inédite de laquelle vous sortirez en vous disant : « Fallait être là! ».Fallait être là – Le jeu : 1 animateur, 4 improvisateurs vedettes, 0 reprise"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-09-11T02:01:00"
      }
    ]
  },
