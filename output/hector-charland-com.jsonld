    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Juju et Marcelle - Et l&#039;incroyable heure du bain"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté dans le cadre du Festival Petits Bonheurs en partenariat avec McDonald&#039;s - La Famille Lemay. Collation offerte gracieusement par McCafé à partir de 10h.Juju et Marcelle sont des jumelles débordantes d’énergie. Du haut de la chambre de bain du deuxième étage de leur maisonnée, elles réinventent le monde afin de gagner du temps... Tout, tout, tout pour retarder ce moment fatidique où elles devront prendre leur bain. Ce théâtre musical ludique a été créé par le Théâtre Omnivore."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
