      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Mettant en vedette les talentueuses Guylaine Tanguay, Claudine Mercier, Geneviève Charest et Catherine Sénart dans une mise en scène de Alexis Pitkevicht, Ménopause, la parodie musicale vous fera rire aux éclats, mais aussi chanter et danser sur des parodies de grands succès musicaux anglophones…"
      }
    ],
