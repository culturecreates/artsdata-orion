    ]
  },
  {
    "@id": "https://hector-charland.com/temporary/98d12338-e121-4342-ad9c-409dfec5a6b3",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/tramp-of-the-century-horizontal-432450a45332ff06f6a6.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/6i1qJevv9NM?si=B6hUZNEZsKX9l8or"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/tramp-of-the-century"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tramp Of The Century"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Depuis plus de quinze ans, six musiciens partagent une même ferveur: celle de Supertramp. Leur parcours, jalonné de près de 300 représentations et de plus de 100 000 spectateurs enchantés, reflète une fidélité rare envers l’œuvre de Roger Hodgson et Rick Davies. Tramp of the Century insuffle sur scène toute la magie, la virtuosité et l’émotion du groupe britannique. Chaque concert rayonne d’énergie, de passion et d’un souci du détail qui frôle la perfection. Le public redécouvre ces mélodies marquantes issues d’albums cultes tels que Crime of the Century, Crisis? What Crisis?, Even in the Quietest Moments et Breakfast in America. L’Ultime Hommage à Supertramp se veut une célébration du génie de l’œuvre musicale et permet, l’espace d’une soirée, de replonger dans l’esprit d’une époque et de rallumer la flamme de ce groupe mythique."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2022-05-03T09:00:00"
      }
    ]
  },
