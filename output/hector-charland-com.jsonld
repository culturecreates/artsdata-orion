    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "« Constance Meyer capte la solitude d'un comédien qui se détache lentement du monde. Pourtant, à tous les dix ou quinze ans depuis, un rôle lui permet de rappeler à quel point c'est plus qu'un grand acteur: c'est un essentiel."
      }
