    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Une épopée amoureuse et poétique dans les forêts shakespeariennes, là où se révèlent les passions, se dévoilent les secrets, se poursuivent les amant·e·s dans un chassé-croisé avec des elfes et des fées d’un genre tout à fait spécial."
      }
