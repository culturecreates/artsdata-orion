    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/ville-jacques-carton-horizontal-5030b1d1bc2fd6bddb0c.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
