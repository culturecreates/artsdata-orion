    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Love Guns - Hommage à KISS | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Cette dévotion à l’exactitude et au showmanship a valu à Love Guns d’être sélectionné par KISS eux-mêmes parmi les 20 meilleurs groupes hommage à KISS au monde, une distinction exceptionnelle qui en dit long."
      }
    ],
    "http://ogp.me/ns#image": [
