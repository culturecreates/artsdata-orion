  {
    "@id": "https://hector-charland.com/temporary/6e97be00-2656-49fc-99b4-0517d8809fac",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/eric-lapointe-horizontal-a681c3b8f63996b111ea.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/3IAAfBhhZvg"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/eric-lapointe-3"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Éric Lapointe"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fêtant ses 30 ans de carrière, Éric Lapointe soulignera cet anniversaire avec un réenregistrement des dix chansons de son album Obsession (Terre promise, N’importe quoi, L’exquise, etc.) et la parution d’une édition vinyle. Aussi, plusieurs événements spéciaux sont prévus, dont un spectacle-anniversaire, Obsession 30 ans, célébrant sur scène les trois décennies bien remplies depuis la parution de ce premier disque. L’énergie et la fougue bien connues du chanteur seront au rendez-vous! Une soirée de grands succès et de belles surprises vous attend."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-02-18T01:02:00"
      }
    ]
  },
