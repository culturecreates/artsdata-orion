  {
    "@id": "https://hector-charland.com/temporary/89e99e3f-e517-4301-a209-aad5c4ae1c81",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/harmonie-des-opposes-horizontal-1c0fabe180b67ffe884f.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=VJGJ7ESJUvM"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/harmonie-des-opposes"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Harmonie des opposés"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Les Grands Concerts en partenariat avec Usinage G.G. Inc.Un abonnement est aussi disponible, tous les détails en cliquant ici.Pour célébrer les vingt ans d’une amitié et d’une carrière exceptionnelles, les pianistes du Duo Fortin-Poirier présentent Harmonie des opposés : un spectacle qui explore le thème de la dualité sous ses multiples facettes et où la musique est magnifiée par une signature visuelle audacieuse et poétique. Paradoxes, enchevêtrements, clair-obscur… Harmonie des opposés est conçu comme un voyage musical et émotionnel à travers différentes formes de dualités spécifiques à chaque pièce, illustrées, entre autres, dans le célèbre Rhapsody in Blue de Gershwin et l’endiablée Danse sacrale du Sacre du printemps de Stravinsky. Les œuvres musicales, portées par des interprètes sensibles qui ont fait leur marque sur les scènes québécoises et internationales, se vivent sur scène comme de véritables tableaux.Aboutissement heureux de résidences de création, inspiré autant par les nombreux voyages des artistes que par leur amour de l’art visuel et du cinéma, le spectacle Harmonie des opposés est également le fruit d’une collaboration avec la conceptrice d’éclairage renommée Julie Basse. En mettant leur créativité au service de l’émotion, les pianistes Amélie Fortin et Marie-Christine Poirier transforment plus que jamais le concert classique traditionnel en événement incomparable, où la chorégraphie de leurs mains se déploie en jeux d’ombres ou sur grand écran. Le concert Harmonie des opposés est un événement musical à ne pas manquer, mettant en vedette deux musiciennes québécoises complices et aguerries, où la virtuosité s’allie à une poésie visuelle des plus touchantes."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
  },
