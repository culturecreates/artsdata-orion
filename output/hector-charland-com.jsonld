    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Fils manqués? | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Clin d’oeil au livre de psycho-pop culte Père manquant, fils manqués , le spectacle magnifie la surprésence du clown et la surabsence du père, oscillant constamment entre l’hommage et le règlement de compte."
