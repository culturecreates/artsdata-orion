    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Une Vie d’Amour , c’est un hommage vibrant à la puissance des mots et des mélodies, une ode à l’amour sous toutes ses formes, un rendez-vous avec l’âme du patrimoine musical francophone."
      }
    ],
