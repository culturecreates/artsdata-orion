    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Glenn Gould, naissance d'un prodige | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Exigeant envers lui-même, agité de manies et d’obsessions, naviguant avec peine entre ses ambitions artistiques démesurées et l’immense pression qui vient avec la célébrité, Glenn Gould va s’imposer dans le monde de la musique classique grâce à l’inventivité et la fougue de son jeu pianistique."
      }
    ],
