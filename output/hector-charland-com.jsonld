    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Souvenirs"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle présenté en admission générale sur la scène du Théâtre Alphonse-Desjardins.Les spectateurs sont installés sur des chaises, autour du piano.Présenté par l&#039;Aramusique dans le cadre de sa série Musique Intimiste.Le pianiste Jean-Michel Dubé vous fera voyager par une multitude d&#039;émotions en passant par la musique de son frère, le pianiste et compositeur, Ghislain Dubé. Ce dernier est décédé en 2022 laissant derrière lui une bande sonore des œuvres qu&#039;il avait composées mises en partition par son frère Jean-Michel. En plus des œuvres de Ghislain, vous entendrez aussi des compositeurs qui l&#039;ont influencé tels que Ludovico Einaudi, Hans Zimmer, Frédéric Chopin, Franz Liszt et Claude Debussy. Un récital commenté par Jean-Michel expliquant les œuvres de Ghislain à caractère cinématographique et en racontant des anecdotes familiales. Cette grande première des œuvres de Ghislain est un rendez-vous unique à ne pas manquer!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
  },
