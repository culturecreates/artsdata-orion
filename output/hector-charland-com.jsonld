    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Situé au cœur de l’Asie centrale, région qui fut l’un des grands carrefours de la Route de la Soie, l’Ouzbékistan vous révèle son histoire, ses traditions et son patrimoine au fil de rencontres avec des artisans perpétuant des savoir-faire millénaires. Plongez au cœur d’un pays façonné par le…"
      }
    ],
