    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/alexandre-poulin"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La représentation du 27 janvier 2022 est reporté au 18 juin 2022.  Au moment d’imprimer ces lignes, Alexandre Poulin est à mettre la touche finale à son prochain spectacle. Secret et mystérieux comme à son habitude, l’artiste nous promet une rencontre vivante et intimiste où ses nouvelles histoires tissées en filigranes nous entrainent bien au-delà des chansons. Cet artiste inclassable qui fêtait l’année dernière ses 10 ans de carrière présentera sur scène et entouré de ses musiciens les chansons de son plus récent album, Nature Humaine, tout en revisitant les pièces marquantes de son vaste répertoire."
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr-ca"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alexandre Poulin - Nature humaine | Théâtre Hector-Charland"
      }
    ],
