      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Bolling et un Noël Jazzé"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de leur série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Pour ce deuxième concert en hommage au pianiste et compositeur français Claude Bolling, la flûtiste Nadia Labrie est accompagnée par John Roney au piano, Sébastien Pellerin à la contrebasse et Bernard Riche à la batterie afin de vous interpréter la Suite no 2 pour Flûte et Trio piano jazz. Cette pièce a vu le jour près de 10 ans après la Suite no 1, composée en 1973, complétant ainsi l’œuvre de métissage entre la musique jazz et la musique classique de Claude Bolling. Également au programme de magnifiques pièces de Noël!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-04-10T02:01:00"
      }
