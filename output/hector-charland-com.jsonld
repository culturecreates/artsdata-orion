      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tout ça"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Véritable trésor de la dramaturgie britannique et monologue audacieux pour une actrice, nous assistons sous nos yeux à la naissance d’un être humain; sa vie, distillée avec sensibilité et humour, défilera jusqu’à sa mort en à peine une heure et quart. Ce périple bouleversant, qui condense une vie entière, prend forme grâce au génie d&#039;Alistair McDowall, qui n’utilise que des mots – rien d’autre! Tout commence par des sons simples, des consonnes, des syllabes répétées qui évoquent les premiers balbutiements de la vie. Puis, les sons deviennent des mots, des phrases, qui deviennent des découvertes qui forment l’existence. Le monde intérieur de cette femme et son rapport au monde se complexifient dans un rythme en accéléré: ne dit-on pas que la vie passe en un éclair?Obtenez 20 % de rabais sur l&#039;achat de ce spectacle avec votre carte Privilège. Cliquez ici pour en savoir plus."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-25T02:02:00"
      }
    ]
  },
