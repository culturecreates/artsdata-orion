    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "JF Pauzé"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "JF Pauzé, membre des Cowboys Fringants et auteur-compositeur des chansons du groupe (Félix – Auteur-compositeur de l’année 2024), fera ses débuts en solo avec un premier album à titre d’interprète, composé de 11 nouveaux titres originaux. Une sortie des plus attendues à l’automne 2025. JF remettra les pieds sur scène en 2026, entouré de musiciens, avec un spectacle généreux et festif qui comptera plus de 20 chansons. Un moment important dans le paysage musical québécois pour les saisons à venir! "
      }
    ],
