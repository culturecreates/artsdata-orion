    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/les-chants-de-mon-pays"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les chants de mon pays"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Les Grands Concerts en partenariat avec Ratelle. Un abonnement est aussi disponible, tous les détails en cliquant ici.Les chants de mon pays voit Marie-Josée Lord rendre hommage aux mélodies de son enfance, ces grands classiques québécois qui ont bercé sa jeunesse. Sur le tourne-disque familial défilaient Vigneault, Leclerc, Leyrac, Léveillée, Dubois et Charlebois. Chaque chanson racontait une histoire : de guerre, de folie, de printemps, d’un pays à construire, d’une langue à défendre et des récits de cœur, de souvenirs, de veillées et de quartiers. Ces poètes, elle les porte en elle, tissés à sa vie. Un voyage intime et collectif au cœur de la chanson québécoise."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
  },
