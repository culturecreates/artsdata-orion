  {
    "@id": "https://hector-charland.com/temporary/aebb303a-4f4d-469f-89f8-5f16f6347d31",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/albanie-horizontal-26cb3b1cfd1a6a4534c7.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
