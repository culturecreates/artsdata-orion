  {
    "@id": "https://hector-charland.com/temporary/adf6fc5e-abed-4a03-8a39-63993f99b7d5",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/quatuor-esca-horizontal-f578b4bf0c98be4ddd34.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=DOUEptty_38"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/quatuor-esca"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Quatuor Esca"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Depuis plus de vingt ans, le Quatuor Esca marque la scène musicale d’ici par sa présence inspirante et son audace artistique. Ces musiciennes d’exception ont accompagné sur scène et à la télévision des artistes aussi marquants que Jean Leloup, Les Sœurs Boulay, Harry Manx, Diane Dufresne, Bruno Pelletier, Half Moon Run, pour ne nommer que ceux-là. Au fil des collaborations, Esca a façonné une signature sonore unique, un quatuor vibrant où le classique rencontre la pop.Avec Apesanteur, Esca prend enfin toute la lumière et vous convie dans un univers qui lui ressemble : lumineux, sensible et résolument moderne. Le spectacle tisse avec finesse des œuvres originales tirées de leur plus récent album à des relectures évocatrices de chansons ayant marqué leur parcours. On y reconnaît des clins d’œil à Ingrid St-Pierre, Alexandra Stréliski, Daniel Bélanger, Half Moon Run et les Beatles, portés par la sensibilité et la virtuosité qui font la signature du quatuor. Une expérience musicale immersive, accessible et profondément émotive! "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-07T02:03:00"
      }
    ]
  },
