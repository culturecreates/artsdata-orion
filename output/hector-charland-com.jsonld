  },
  {
    "@id": "https://hector-charland.com/temporary/87a416a0-78c3-48d5-9c45-ff725214708f",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/marie-annick-lepine-horizontal-fa96906d4d18bfa9c402.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/eWGDeTPqKV0"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/marie-annick-lepine-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Marie-Annick Lépine"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Marie-Annick Lépine, multi-instrumentiste des Cowboys Fringants, reprend la route avec son nouvel album qui nous transporte dans son cheminement rempli de franchise, d’humanité et d’autodérision. Le cœur est un rêveur est une ode au retour à la vie. « Malgré la peur et malgré tout » Marie-Annick continue d’avancer.Et c’est magnifiquement accompagnée de ses complices musiciens que l’autrice-compositrice-interprète vous donne rendez-vous. Elle nous fera sourire, chanter, crier, réfléchir avec des textes riches et intimes, livrés sur ses musiques accrocheuses, dans un esprit de bienveillance où un brin de lumière est toujours présent."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-11-26T14:06:00"
      }
    ]
  },
