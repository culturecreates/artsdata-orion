    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&#039;âme idéale"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Comédie dramatique | France | 2025 | GElsa, 40 ans, célibataire, a renoncé aux histoires d’amour. Un don un peu spécial la garde à distance des autres : elle peut voir et parler aux morts. Pourtant un soir elle rencontre Oscar, un homme drôle et charmant, qui lui fait espérer à nouveau que tout est possible. Mais au moment où elle commence enfin à tomber amoureuse, Elsa réalise que leur histoire n’est pas aussi réelle que ce qu’elle pensait…« Si L&#039;âme idéale est autant une réussite, au-delà de ses qualités scénaristiques, c’est en grande partie grâce à l’alchimie saisissante entre ses deux comédiens. » - Abus de Ciné"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-28T02:03:00"
      }
    ]
  },
