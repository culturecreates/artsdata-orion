  {
    "@id": "https://hector-charland.com/temporary/a03a1c95-3480-4df2-a898-2ad5f5b09cf3",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
