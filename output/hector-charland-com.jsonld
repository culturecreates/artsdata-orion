      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le port du masque est obligatoire en tout temps pour les personnes de 10 ans et plus. Dans une démarche métissant musiques du monde, art clownesque et percussions corporelles, les fanfarons utilisent tout ce qu’ils trouvent pour montrer qu’on peut faire de la musique avec des instruments, mais…"
      }
    ],
