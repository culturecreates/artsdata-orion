    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Michel Rivard - Après on va où? | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Durant les deux semaines (symboliques) que dure la magnifique floraison du magnolia qui illumine la fenêtre de sa chambre, «l'homme qui me ressemble» (74 ans) se questionne sur sa vie, avant et après la mort, en confrontant ses doutes et ses certitudes. Entre un rendez-vous médical et le choix…"
      }
    ],
