  {
    "@id": "https://hector-charland.com/temporary/69cd4a4a-2ba6-4eec-bf2e-0f0e14ec7816",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/chants-de-victoires-horizontal-8f90b8d6eedca61bfa12.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/dtbsLxr1KYU"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/chants-de-victoires"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Chants de Victoires"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Les Grands Concerts en partenariat avec Markus Homme et Femme.Un abonnement est aussi disponible, tous les détails en cliquant ici.Chants de Victoires est un voyage musical vibrant au cœur d’un moment charnière de l’histoire de la Nouvelle-France. Tout au long du concert, trois perspectives sonores se répondent et s’entrelacent pour raconter une même épopée : celle du naufrage de la flotte anglaise de l’amiral Walker en 1711 et de son échec à conquérir le territoire. Des chants inédits issus du manuscrit Chants de Victoires donnent la parole aux habitants de la région, témoins de l’événement. Ces textes, mis en musique avec finesse par Seán Dagher, côtoient des chants de marins anglophones traduits en français, nés d’une fascinante spéculation historique : celle de survivants du naufrage ayant partagé leurs mélodies avec les communautés des berges du Saint-Laurent. De cette rencontre imaginaire émergent des adaptations musicales inédites, puissantes et émouvantes. Finalement, des compositions instrumentales dans le style traditionnel, signées Michel Bordeleau, complètent ce tableau musical dans un croisement d’ancien et de nouveau, de tradition et de modernité! Porté par un ensemble de musiciens d’exception, Chants de Victoires fait résonner l’histoire dans un croisement saisissant d’ancien et de nouveau, de mémoire et de création. Issu d’un projet de recherche de l’UQAR (l’Université du Québec à Rimouski), ce concert est bien plus qu’une reconstitution : c’est une première mondiale attendue depuis plus de 300 ans!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
  },
