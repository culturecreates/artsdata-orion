    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "David Corriveau - 100 contrefaçons | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "C’est dans une ambiance intime, chaleureuse et feel good qu’il nous raconte comment il a réussi à passer du poulailler familial de Saint-Boniface-de-Shawinigan à la Place des Arts de Montréal pour réaliser son rêve de chanter sur scène comme ses idoles, qu’il imite de façon spectaculaire!"
      }
    ],
