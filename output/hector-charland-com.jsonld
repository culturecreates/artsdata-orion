    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Fanfare fanfaronne"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le port du masque est obligatoire en tout temps pour les personnes de 10 ans et plus.Dans une démarche métissant musiques du monde, art clownesque et percussions corporelles, les fanfarons utilisent tout ce qu’ils trouvent pour montrer qu’on peut faire de la musique avec des instruments, mais aussi avec nos mains, nos pieds, et, pourquoi pas, avec le plancher, un banc, ou un mur!"
      }
    ],
