    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/coups-de-coeur-du-festival-regard-2025"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Les coups de coeur du Festival Regard 2025 Le punk de Natashquan de Nicolas Lachapelle Canada (Québec). Nuuhkuum uumichiwaapim de Lindsay Chewanish Canada (Québec). Nuuhkuum uumichiwaapim (« Le tipi de ma grand-mère ») est une immersion dans l’univers sensoriel et tactile du tipi d'une grand-mère. Ce documentaire s’appuie sur les souvenirs de la vie dans un tipi, en observant le bonheur de cuisiner et le passage du temps. Berthe, ma grand-mère, veut mourir."
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr-ca"
      }
    ],
    "http://schema.org/name": [
