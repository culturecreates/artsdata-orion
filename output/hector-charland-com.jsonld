  {
    "@id": "https://hector-charland.com/temporary/1adc2900-e1cb-4af8-b323-6efcb0467f3d",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/lexpedition-de-la-rythmobile-horizontal-1b6ff581d5cdfbce1edb.jpg"
