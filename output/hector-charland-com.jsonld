  {
    "@id": "https://hector-charland.com/temporary/cd56d4b2-43c5-4990-b3c4-f520e634d1f2",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/la-harpe-et-ses-secrets-horizontal-6b3f70292b19d3cb77ee.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/ieFpbop6JBE"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/la-harpe-et-ses-secrets"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La harpe et ses secrets"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle présenté en admission générale sur la scène du Théâtre Alphonse-Desjardins.Les spectateurs sont installés sur des chaises, autour de l&#039;artiste.Présenté par l&#039;Aramusique dans le cadre de sa série Musique Intimiste en partenariat avec General Dynamics.Valérie Milot présente son instrument – la harpe – avec qui elle partage sa vie depuis plus de 30 ans. Tantôt légère et aérienne, tantôt fougueuse et intense, la harpe permet une variété de timbres qui évoquent et dévoilent des mondes insoupçonnés. À travers ses pièces préférées, Valérie vous partagera les secrets de la harpe, dont l’histoire est millénaire. Des hiéroglyphes égyptiens à Marie-Antoinette, cet instrument aux cordes multiples possède un parcours truffé d’anecdotes, auxquelles se superposent celles de la vie de musicienne de Valérie et de sa complice, Apollonia. "
      }
    ],
