    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Les coups de coeur du Festival Regard 2025 Le punk de Natashquan de Nicolas Lachapelle Canada (Québec). Nuuhkuum uumichiwaapim de Lindsay Chewanish Canada (Québec). Nuuhkuum uumichiwaapim (« Le tipi de ma grand-mère ») est une immersion dans l’univers sensoriel et tactile du tipi d'une grand-mère.…"
      }
    ],
