    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Brittany Kennell"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Couronnée Interprète féminine de l’année au Gala Country, Brittany Kennell offre un spectacle authentique et vibrant, porté par une voix puissante et un charisme naturel. Entre country vintage et sonorités modernes, elle interprète ses plus grands succès, dévoile de nouvelles chansons et revisite des classiques incontournables. Une soirée rassembleuse qui fait lever les foules."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-27T02:03:00"
      }
