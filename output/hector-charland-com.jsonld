      }
    ]
  },
  {
    "@id": "https://hector-charland.com/temporary/1619c808-ef90-4042-a6a5-ede785268f8b",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/la-chimie-de-noel-horizontal-55bbf7555a7c634e7e94.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=1OD75S3W8dI"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/la-chimie-de-noel"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La chimie de Noël"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "À la demande générale, Yannick Bergeron vous offre une série d’expériences chimiques pour le temps des fêtes! Fidèle à lui-même, il vous transportera dans son univers de démonstrations scientifiques des plus surprenantes. Vêtu de son sarrau emblématique, notre enseignant conserve la même folie et le plaisir à vous faire découvrir des réactions chimiques dignes du Pôle Nord! La neige artificielle, la poudre de perlinpinpin, le rire du père Noël et du papier d’emballage scientifiques, pour ne nommer que celles-ci.Auteur, enseignant et membre de l’Ordre des chimistes du Québec, ce communicateur hors pair poursuit sa mission de susciter l’intérêt des jeunes pour les sciences avec son approche ludique et singulière. Lauréat du prix de la personnalité scientifique de La Presse Radio-Canada, récipiendaire du prix Hubert-Reeve et créateur des expériences du magazine scientifique Les Débrouillards, on peut le voir dans de multiples émissions télé en tant que chroniqueur et vulgarisateur scientifique. Figure reconnue au Québec et dans la francophonie canadienne, il n’a pas fini de vous surprendre avec ses mille et un projets en cours et à venir!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-11-05T01:02:00"
      }
    ]
  },
