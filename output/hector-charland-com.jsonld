    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Maroc en VanLife | Rencontre avec Marc Temmerman Voyage libre et inspiré, c'est à bord de son van aménagé que Marc nous fait découvrir \"son\" Maroc depuis Tanger jusqu'à Dakhla, dans l'extrême sud du pays. Parti depuis sa Belgique natale avec son van, Marc rejoint Tanger depuis Marseille."
      }
    ],
