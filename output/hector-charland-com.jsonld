    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le Grand Bal de Noël"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Sons et Brioches en partenariat avec McDonald&#039;s - La famille Lemay. Collation offerte gracieusement par McCafé à partir de 10h.En provenance de leur banquise lointaine, marchant pieds de côté, trois pingouins musiciens viennent aux festivités du pôle Nord. Pour participer à la fête, ils doivent composer une chanson de Noël originale en quelques minutes. Amatin, Ademain et Atemplein trouveront-ils l’inspiration? Seront-ils prêts à temps pour cette soirée inoubliable? Venez vivre la magie du temps des fêtes dans ce concert clownesque où les enfants chantent et participent à la création d’une chanson."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2020-09-22T00:05:00"
      }
    ]
