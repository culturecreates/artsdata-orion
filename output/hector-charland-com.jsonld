    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/tango-virtuoso"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le spectacle sera présenté conformément aux normes sanitaires et de distanciation physique en vigueur.  Le célèbre violoncelliste Stéphane Tétreault et l'irremplaçable bandonéoniste Denis Plante font équipe pour une plongée dans l'univers du tango classique et du tango nuevo : ce tandem inusité interprétera sur leurs précieux instruments des œuvres d'Astor Piazzolla, Osvaldo Pugliese, Juan Carlos Cobián et Dino Saluzzi, ainsi que des compositions originales de Denis Plante."
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr-ca"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tango virtuoso | Théâtre Hector-Charland"
