      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/elliot-maginot-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Elliot Maginot"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour Elliot Maginot, Noël est une affaire de famille choisie. Une occasion de passer le plus de temps possible avec les gens qu’on aime, autant ceux sur scène que dans la salle. Pour ce spectacle, il s’entoure de musicien·nes talentueux·ses et sensibles, qui sont aussi de précieux ami·es, créant une atmosphère à la fois joyeuse et complice. Elliot Maginot sera pour l’occasion entouré de sa grande famille, avec des cordes, bois, cuivres, choeurs et tout le reste de la crèche, pour finir l’année avec communion et apaisement."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-05-05T15:51:00"
      }
    ]
