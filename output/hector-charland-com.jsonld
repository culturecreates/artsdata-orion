      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Montréal Jazz"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Plongez au cœur de l’histoire riche et vibrante du jazz à Montréal dans ce concept original de John Roney et Charles Biddle Jr. Ce spectacle met en lumière les géants du jazz issus de Montréal ou qui ont migré ici, tout en éveillant les sens par la musique, l’histoire et des images captivantes. Sous la direction du talentueux pianiste John Roney accompagné du chanteur/musicien Charles Biddle Jr. et de leurs musiciens, nous invitons le public à un voyage inoubliable à travers les décennies, célébrant les contributions inestimables de figures comme Oscar Peterson, Oliver Jones, Charles Biddle, Reggie Wilson, Bernard Primeau et bien d&#039;autres."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
