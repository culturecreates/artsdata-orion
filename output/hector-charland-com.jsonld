    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "SPECTACLE ANNULÉ Le port du masque est obligatoire en tout temps pour les personnes de 10 ans et plus. Deux ans de repos Deux ans de voyages Deux ans pour m’inspirer Deux ans pour écrire Deux ans qu’on ne s’est pas vu Deux heures pour se revoir Deux heures pour te chanter du nouveau Deux heures…"
      }
    ],
