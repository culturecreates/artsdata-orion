    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/francois-bellefeuille-horizontal-6960bed4892b0cb4ea27.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
