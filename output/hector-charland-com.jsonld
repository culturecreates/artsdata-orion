    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/alex-roy-horizontal-d4c6d7f20fec124ea13a.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=DftWmE_Mk1Y"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/alex-roy"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alex Roy"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Vous l’avez découvert lors des premières parties de Lise Dion et des Grandes Crues et maintenant il nous présente son premier one-man show Des choses qui arrivent avec déjà plus de 17 000 billets vendus!Charismatique à souhait, Alex Roy est une bête de scène. Une machine à gag munie d’un style unique et d’une séduisante innocence. Avec ses 5 enfants, ses 3 chiens, ses 3 chats, sa maladresse et son anxiété sur les petites choses de la vie, comme perdre son passeport le jour de son départ, Alex nous plonge instantanément dans son univers autant surprenant qu’hilarant. Impossible de ne pas tomber sous le charme d’Alex Roy!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2022-05-03T09:00:00"
      }
    ]
  },
