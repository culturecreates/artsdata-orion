    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Rafaëlle Roy"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Rafaëlle Roy, autrice-compositrice-interprète et multi-instrumentiste, est reconnue pour sa voix puissante. Le public a d’abord eu accès à son grand talent d’interprète à La Voix 2019, où elle a été finaliste, ainsi qu’à Zénith 2024, qu’elle a fièrement remporté. Prête à faire découvrir son univers, elle vous invite à plonger au coeur de son tout premier projet musical, qui mettra en avant ses compositions authentiques et plusieurs éléments organiques qui témoignent bien de sa démarche artistique. Choriste pour l&#039;artiste reconnu Jonathan Roy, Rafaëlle trace désormais sa propre voie créative. Maman de deux enfants, elle a aussi publié deux livres en littérature jeunesse. "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-08-22T02:02:00"
      }
    ]
  },
