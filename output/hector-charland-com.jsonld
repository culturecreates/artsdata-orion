    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Avec ce 3e one-man-show, et entre l’écriture de ses livres plusieurs fois bestseller (150 000 copies vendues), Jérémy s’amuse à aller dans des zones plus personnelles et étonnera assurément par un contenu délicieusement audacieux qu’on ne lui soupçonnait pas… Avec une franchise à la fois désarmante…"
      }
    ],
