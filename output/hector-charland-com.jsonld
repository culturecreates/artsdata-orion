  {
    "@id": "https://hector-charland.com/genid/1fb19936f828e8cf",
    "@type": [
      "http://schema.org/PerformingGroup"
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Heart of Gold"
      }
    ]
  },
  {
    "@id": "https://hector-charland.com/temporary/2224795d-ae53-4279-a2f5-7ff677ab197b",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/heart-of-gold-horizontal-4ee92933b4980c742332.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=ErkoCPLiRJg"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/heart-of-gold"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Hommage à Neil Young"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Quatre musiciens chevronnés de Lévis, évoluant dans leur univers musical respectif et fans fini de Neil Young, ont décidé de marier leur passion commune pour créer un spectacle acoustique basé sur le répertoire de cette icône de la musique folk nord-américaine.C’est ainsi que Daniel Lizotte (Deadlock – guitare, harmonica, voix principale), Denis Viel (Songs of Mercy – pedal steel guitar, dobro accordéon, voix), Francis Leblond (Time it Was – basse, voix) et Michel Roy (Kevin Parent - batterie, voix) ont donné naissance au projet Heart of Gold.Le spectacle offre un amalgame de pièces tirées du vaste répertoire acoustique de Neil Young, auquel s’ajoutent des versions acoustiques de quelques pièces habituellement plus électriques. De Heart of Gold à Harvest Moon, en passant par Comes a Time, Southern Man et Like a Hurricane, les amateurs de Neil Young pourront apprécier une interprétation chaleureuse et convaincante, livrée en toute simplicité. Un pur moment de bonheur qui fait du bien au cœur et aux oreilles !"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2024-03-27T19:31:00"
      }
    ]
  },
