    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Matt Andersen livre chaque chanson avec une intensité rare et une authenticité désarmante. Porté par une voix puissante et une présence scénique captivante, l’auteur-compositeur du Nouveau-Brunswick mélange folk, soul et blues dans des performances aussi intimes que percutantes. Avec plus de 33 millions d’écoutes sur Spotify, des tournées internationales et une nomination aux prix Juno en 2024, Andersen s’impose comme l’un des artistes canadiens les plus marquants de sa génération."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-21T10:41:00"
      }
    ]
