      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/liliane-blanco-binette-3"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Liliane Blanco-Binette"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Avec une lucidité désarmante et une autodérision qui frappe juste, Liliane, récipiendaire de l’Olivier 2026 de la Découverte de l’année, propose un premier spectacle solo, où l’humour se mêle à l’intime. Avec déjà plus de 25 000 billets vendus, ce n’est pas un simple spectacle, c’est une rencontre. Elle transforme ses vulnérabilités en matière comique, révélant une façon décalée d’observer le monde et d’assumer ses contradictions. Entre confidences crues et complicité partagée, elle entraîne le public dans un moment à la fois fragile et nécessaire, où l’on se reconnaît dans ce qui nous échappe et nous dépasse."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2024-10-16T19:31:00"
      }
    ]
  },
