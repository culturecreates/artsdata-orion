  {
    "@id": "https://hector-charland.com/temporary/400dfd30-cae8-420c-899a-1ea8dcae39c2",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/chris-klafford-horizontal-b76c40ab5fe5f77dfa2e.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/3t54gWwwQG4"
