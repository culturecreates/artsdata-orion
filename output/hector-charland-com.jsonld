    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/ma-mere-dieu-et-sylvie-vartan-horizontal-4178e57c89e1c8282fad.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/YGTE7AQ6klM"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/ma-mere-dieu-et-sylvie-vartan"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ma mère, Dieu et Sylvie Vartan"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Comédie dramatique | Québec - France | 2025 | GAvec invité | Le monteur du film Ma mère, Dieu et Sylvie Vartan, Yvann Thibodeau (1995, Les jours heureux, Starbuck, Louis Cyr, Au revoir le bonheur, Piché: entre ciel et terre, 19-2, Les Invincibles) sera présent lors de la projection. En 1963, Esther met au monde Roland, petit dernier d&#039;une famille nombreuse. Roland naît avec un pied-bot qui l&#039;empêche de se tenir debout. Contre l&#039;avis de tous, elle promet à son fils qu&#039;il marchera comme les autres et qu&#039;il aura une vie fabuleuse. Dès lors, Esther n&#039;aura de cesse de tout mettre en œuvre pour tenir cette promesse.« Une histoire vraie qui fait passer du rire aux larmes et touche droit au cœur. » Barbara Théate, Le Journal du Dimanche"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-05-16T02:01:00"
      }
    ]
  },
