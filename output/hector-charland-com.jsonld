  {
    "@id": "https://hector-charland.com/temporary/c694a6f4-a452-4326-88b2-24e7a794eb25",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/le-curieux-destin-dmarcel-horizontal-26e53eaf3603f33f4617.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=ydaWZNO0kVc"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/le-curieux-destin-dmarcel"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le curieux destin d&#039;Marcel"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le spectacle sera présenté conformément aux normes sanitaires et de distanciation physique en vigueur.Les meilleurs concepteurs de Monarque offriront à Marcel Leboeuf un incroyable terrain de jeux lui permettant de créer un spectacle inédit, accomplissement d’une vie pour l’artiste qui a pris part à plus de 60 pièces de théâtre. donné plus de 2 800 conférences et a remporté plus de 5 coupes Charade, ce qui fait de lui l’un des plus récompensés dans l’histoire de la LNI. Il offrira à son public un savant mélange de ses trois grandes passions : le théâtre, les conférences et l’improvisation dans une pièce où les faits vécus cohabiteront avec l’imaginaire, permettant à l’artiste de s’éclater comme acteur et à tous d’apprécier ses talents."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2020-11-27T11:42:00"
      }
    ]
  },
