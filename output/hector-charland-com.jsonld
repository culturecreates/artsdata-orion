    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le choeur a ses saisons"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pas simple d’organiser une fête pour un 35e anniversaire. Surtout quand ceux qui sont en charge ne s’entendent pas. Ça va donner lieu à toute sortes de situations comiques. Mais avec MOC, ça fini toujours bien. En ces temps moroses, pourquoi ne pas venir rire un bon coup avec nous. Une comédie musicale originale écrite, réalisée et mise en scène pour votre plaisir et le nôtre."
      }
    ],
