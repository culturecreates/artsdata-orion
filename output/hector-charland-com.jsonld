    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=q13Hza7RuxM"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/avec-amour-et-acharnement"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Avec amour et acharnement"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Drame | France | 2022 | G - Déconseillé aux jeunes enfantsJean et Sara vivent ensemble depuis dix ans. Quand ils se sont rencontrés, Sara partageait la vie de François, le meilleur ami de Jean. Un jour, Sara aperçoit François dans la rue. Il ne la remarque pas, mais elle est submergée par la sensation que sa vie pourrait soudainement changer. « Au sommet de son art, Claire Denis signe un drame au plus près de la complexité des relations amoureuses, sans fard ni édulcorant, et surtout, sans chercher à dédouaner ses personnages, qu’elle place face à leurs actes. » - Caroline Chatelard, Le Devoir"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2022-09-01T11:30:00"
      }
    ]
  },
