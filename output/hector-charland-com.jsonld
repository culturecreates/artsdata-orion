  {
    "@id": "https://hector-charland.com/temporary/1ccd58ba-f53a-4d83-bf71-2b9ef20d57eb",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/generation-musique-plus-horizontal-db3d4e7f365bc9e96abe.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
