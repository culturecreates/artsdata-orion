  {
    "@id": "https://hector-charland.com/temporary/22063786-6685-4d7b-bfab-e26966f74228",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/autour-de-jean-sebastien-bach-horizontal-cb0ff95eda01a02b6a42.jpg"
