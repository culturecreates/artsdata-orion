  {
    "@id": "https://hector-charland.com/temporary/0ca37387-3583-473f-be0c-41072552e473",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/les-trois-accords-horizontal-62e4b5569a8c0b9b221c.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://alphonse-desjardins.com/programmation-spectacles/les-trois-accords-2"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/les-trois-accords-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les Trois Accords"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté en formule debout! De retour de l’un de leurs nombreux voyages initiatiques, Les Trois Accords prennent une pause de leurs aventures le temps d’une nouvelle série de spectacles à travers le Québec. Désormais marqués d’une sagesse et de coups de soleil profonds, ces grands explorateurs nous racontent leurs récits de voyage, des faits vécus hautement rythmés, des expéditions musicales qui nous mènent tantôt sur des sentiers inconnus, tantôt vers des rencontres étranges… On attend impatiemment la sortie du nouvel album le 24 octobre prochain!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-09-18T02:02:00"
      }
    ]
  },
