      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/lensemble-en-direct-de-lunivers"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&#039;Ensemble En direct de l&#039;univers"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L&#039;Ensemble En direct de l&#039;Univers vous offre encore cette année leur soirée du temps des fêtes. Vous serez emportés dans un tourbillon de medleys autour de l&#039;amitié, de la famille et de la fête, à l&#039;image de ce que les musiciens et choristes de l&#039;émission nous ont habitués depuis 10 ans. 90 minutes d&#039;émotion, de plaisir et de partage. Un public qui tape des mains, qui chante. Le bonheur est palpable dans la salle comme sur scène. C&#039;est sans aucun doute la meilleure façon de terminer l&#039;année!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2022-04-12T12:23:00"
      }
    ]
  },
