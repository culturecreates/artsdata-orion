  {
    "@id": "https://hector-charland.com/temporary/97feecc4-4d22-477e-a7b0-9780d3e549fd",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/matt-lang-horizontal-ca1745864afdc5e8a503.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=1IawXL_rL_g"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/matt-lang-3"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Matt Lang"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Impossible de ne pas danser sur les chansons de Matt Lang, pas vrai? Vous le constaterez par vous-mêmes lors du spectacle! Notez qu&#039;il est très probable que des gens autour de vous soient debout lors de la représentation.Matt Lang débarque en ville avec sa nouvelle tournée Ain’t That Bad ! Figure incontournable de la musique country au Canada, Matt et ses musiciens nous entraînent dans un spectacle honky-tonk déjanté et spectaculaire, où son 4e album prend vie dans une mise en scène immersive et inédite. Inspiré par l’énergie débridée du film The Hangover, cet album-concept de 10 titres raconte une nuit complètement imprévisible et légendaire, du premier shooter jusqu’au chaos du lendemain matin. Sur scène, Lang fusionne country et rock avec énergie, en interprétant les pièces de son nouvel album ainsi que ses meilleurs succès. Les fans découvriront un spectacle cinématographique et spectaculaire, avec effets visuels et pyrotechnie qui offrent une expérience scénique unique. Avec Ain’t That Bad, Matt Lang nous rappelle que parfois, les meilleures soirées sont celles qu’on n’avait pas prévues, celles dont on ne se souvient pas parfaitement… mais qu’on ne veut jamais oublier."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-19T02:02:00"
      }
    ]
  },
