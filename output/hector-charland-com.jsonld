    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=cp-hainmioQ"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/plus-fort-que-moi"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Plus fort que moi"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Comédie | Royaume-Uni | 2025 | GInspiré de la vie et des expériences de John Davidson, Plus fort que moi retrace son parcours d’adolescent incompris dans la Grande-Bretagne des années 1980 jusqu’à aujourd’hui, où il est devenu un défenseur de la compréhension et de l’acceptation du syndrome de Tourette. Diagnostiqué à l’âge de 15 ans, John parvient, contre toute attente, à traverser une adolescence difficile jusqu’à l’âge adulte, trouvant son inspiration dans la bienveillance des autres et découvrant ainsi son véritable but dans la vie.« Bercé par la très belle musique, discrètement émouvante, de Stephen Rennicks, Plus fort que moi peut compter sur la solidité de ses acteurs, son sens de l’humour désarmant et la mise en scène poétique de Kirk Jones pour vous faire passer un merveilleux moment de cinéma populaire, qui n’insulte jamais notre intelligence. » - Le Point"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-19T12:32:00"
      }
    ]
