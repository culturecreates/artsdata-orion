  {
    "@id": "https://hector-charland.com/temporary/283d5df0-01d8-458c-97b5-bed20d63c924",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/robuste-horizontal-163e8ef9d294f46022a2.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
