      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "ABBA Memories"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le fabuleux spectacle d’envergure, One The ABBA Memories Show, se veut non pas une caricature du légendaire groupe ABBA, mais bien la reproduction vocale et musicale intégrale des fabuleuses chansons du groupe. Six artistes sur scène évoluent dans l’univers musical adapté à la fine pointe de la technologie des années 2021. Depuis 2009 quelques deux cent mille personnes ont acclamé ce spectacle qui ne cesse d’étonner le plus fanatiques.II n’y a qu’une seule manière de jouer ABBA et c’est à la manière de ABBA. Ce spectacle vous donnera de l’énergie, vous rendra joyeux et fera fuir les blues et l’impression de solitude de cette bulle. Pour les fans de ABBA vous allez certainement chanter avec nous leurs plus grands succès et même peut- être en découvrir de nouveaux et pour ceux qui ne les connaisse pas ou peu nous pouvons vous garantir que vous allez devenir des adeptes de cette merveilleuse musique qui ont fait de ABBA une légende."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2024-11-11T15:20:00"
      }
    ]
  },
