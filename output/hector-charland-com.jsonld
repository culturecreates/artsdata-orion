  {
    "@id": "https://hector-charland.com/temporary/320c545f-0017-4741-b540-71a7f03fff7f",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/le-songe-dune-nuit-dete-horizontal-fb07ea6ceab8b6730b98.jpg"
