    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/jazz-noisette-horizontal-f85033a93d46467a7d45.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
