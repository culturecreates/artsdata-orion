  {
    "@id": "https://hector-charland.com/temporary/08c3830f-d556-4de5-9bc1-f55771c9bc6f",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/love-guns-hommage-a-kiss-horizontal-f9afe32a0fd6f7dd6db4.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=jwGj2O4EfAY"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/love-guns-hommage-a-kiss"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Love Guns - Hommage à KISS"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Depuis plus de vingt ans, Love Guns livre l’un des spectacles hommage à KISS les plus électrisants et authentiques au Canada. Originaires de la région de Moncton, Mike Bourgeois, Danny Bourgeois, Jon Arsenault et Stephen LeBlanc recréent avec passion, précision et puissance l’univers spectaculaire du légendaire groupe KISS. Ce qui a commencé comme un hommage à leur plus grande influence musicale est devenu un spectacle complet digne des grandes tournées : costumes spectaculaires, énergie brute, guitares en feu et une présence scénique qui frappe fort. Cette dévotion à l’exactitude et au showmanship a valu à Love Guns d’être sélectionné par KISS eux-mêmes parmi les 20 meilleurs groupes hommage à KISS au monde, une distinction exceptionnelle qui en dit long. Dès que les projecteurs s’allument, le public est plongé dans une véritable expérience KISS : son fidèle, voix puissantes, éclairage explosif, et tous les classiques incontournables, de Rock and Roll All Nite à I Was Made for Lovin’ You, Lick It Up, Detroit Rock City et Firehouse."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-09T02:03:00"
      }
    ]
  },
