  },
  {
    "@id": "https://hector-charland.com/temporary/8efb2ba1-0945-4364-92a1-97c4357ed9a4",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/angel-forrest-horizontal-c322b4f4bc5dc338dfa7.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=LQ59P-FzroY"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/angel-forrest"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Angel Forrest"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Angel Forrest présente avec fierté son tout nouveau spectacle Still Here for You : une célébration exceptionnelle marquant les 20 ans de l’album emblématique Here for You. Ce concert spécial vous plongera dans un univers rempli d’amour, d’inspiration et d’émotions, présenté dans un cadre acoustique intimiste qui met en lumière toute la profondeur de son talent. Avec sa voix incomparable et sa présence magnétique, Angel vous invite à partager une soirée unique, où chaque note résonne comme une déclaration de gratitude envers ses fans et sa carrière musicale. Ce spectacle « up close and personal » est une véritable ode à la connexion humaine et à la magie de la musique. Ne manquez pas cette occasion rare de redécouvrir les chansons qui vous ont marquée, revisitées avec toute l’authenticité et la passion qui définissent Angel Forrest. Une expérience inoubliable vous attend, entre souvenirs et nouvelles émotions, pour célébrer deux décennies de musique légendaire!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-05-15T02:01:00"
      }
    ]
  },
