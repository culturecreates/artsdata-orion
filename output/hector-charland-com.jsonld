  {
    "@id": "https://hector-charland.com/temporary/a9f1068c-316b-4fe5-8692-8da3b92eebd5",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/symbiose-cafe-korige-horizontal-acd78d05937289b9997f.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
