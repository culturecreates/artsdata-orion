    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Alexandre Poulin - Nature humaine | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "La représentation du 27 janvier 2022 est reporté au 18 juin 2022.  Au moment d’imprimer ces lignes, Alexandre Poulin est à mettre la touche finale à son prochain spectacle. Secret et mystérieux comme à son habitude, l’artiste nous promet une rencontre vivante et intimiste où ses nouvelles histoires…"
      }
    ],
