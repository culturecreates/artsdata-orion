    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ariane Moffatt"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ariane Moffatt est de retour avec une irrésistible envie de jouer! Son nouveau spectacle s’annonce festif et enivrant. Une aventure synth pop guidée par le beat!Le quatuor sur scène oscillera entre les grands succès d’Ariane devenus incontournables et ses nouvelles chansons aux textes universels et d’une pertinence désarmante. Ses rythmes contagieux prendront vos corps d&#039;assaut. Allez, l&#039;heure est venue de combattre le feu par le jeu et de danser à cœur ouvert, les yeux fermés."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-03-26T12:06:00"
      }
    ]
  },
