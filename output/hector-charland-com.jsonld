  },
  {
    "@id": "https://hector-charland.com/temporary/d8046ba3-6f7c-4de8-9e65-d2c381f60b34",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/elliot-maginot-horizontal-0aefbca0ba94d0da6b2f.jpg"
