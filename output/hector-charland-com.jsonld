    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/tommy-neron-horizontal-961eeaf5badce7bdad0e.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
