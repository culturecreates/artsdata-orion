    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "C’est une exploration du folklore québécois sous toutes ses formes, des chansons folk à la Vallières aux reels de Louis Boudreault, en passant par l’indie rock des années 2000 et la gigue québécoise. Sandra Contour Autrice-compositrice-interprète originaire d’Alma au Lac-St-Jean, Sandra Contour…"
      }
    ],
