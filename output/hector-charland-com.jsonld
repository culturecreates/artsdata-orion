    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Daniel Mille - Après la pluie"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Le musicien accompli, l’accordéoniste Daniel Mille, navigue dans plusieurs styles musicaux apportant toujours une sensibilité et créativité remarquable. Les œuvres de son album Après la pluie reflètent cette sensibilité du musicien qui nous amène dans les sentiers de son imaginaire musical à caractère jazz, ponctué de reflets musicaux cinématographiques. Quelques pièces du pianiste Yves Léveillé en plus du très connu Oblivion de Piazzolla viennent admirablement bien compléter cet ensemble de musique dont l’écoute nous laisse avec un goût de mélancolie et de beauté."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
  },
