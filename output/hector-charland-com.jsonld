    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Dumas - PIANO VOIX DIAPOS | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Piano voix diapos, c’est Dumas sans guitare, accompagné d’un pianiste et de diapositives. Dans une mise en scène minimaliste, il se raconte en chansons, revisitant 25 ans de répertoire, avec sensibilité et toujours cette volonté d’offrir une expérience inoubliable et lumineuse au public."
      }
    ],
