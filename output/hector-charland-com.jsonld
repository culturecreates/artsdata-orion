      {
        "@language": "fr-ca",
        "@value": "Ludovick Bourgeois - Karaoké 90 | Théâtre Hector-Charland"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Soutenu par un riche univers visuel, dans la lignée de son plus récent spectacle en hommage aux BB, Karaoké 90 se déploiera en trois tableaux : les hits québécois, ceux du groupe Les BB et les mégatubes mondiaux. Du grunge de Nirvana aux power ballades de Céline Dion, en passant par les hymnes pop…"
      }
    ],
