      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Propulsé par le rappeur Adamo Marinacci et accompagné de son fidèle acolyte, J7, le duo originaire de la Rive-Sud fait son entrée dans l’univers du hip-hop québécois dès les années 2000. Depuis, le duo Gros Big, avec son style unique et sa musique accrocheuse, a rapidement conquis le cœur du public."
      }
    ],
