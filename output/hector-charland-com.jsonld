      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Déterminée à sauver sa famille, Margot fait appel à Miss Dalloway, une soi-disant spécialiste de l’occulte, espérant qu’elle pourra l’aider à se débarrasser de l’intruse qui a pris sa famille en otage."
      }
    ],
