  {
    "@id": "https://hector-charland.com/temporary/54b43195-b286-4ce1-9367-ae0f3ead5650",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/jean-michel-blais-horizontal-c4a77c6239afdede2c72.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/ZW4Iy9ocL24?si=I94Ce6Ep1Mje0V4x&amp;t=14"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/jean-michel-blais-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jean-Michel Blais"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Jean-Michel Blais est un pianiste, compositeur et interprète basé à Montréal. Son premier album, Il, s’est vu nommé parmi les 10 meilleurs albums de 2016 par le magazine Time, et sa musique cumule depuis plus de 375 millions d’écoutes à travers le monde. Membre de la communauté LGBTQ+ et vivant avec le syndrome de Gilles de la Tourette, il puise également dans son expérience d’éducateur spécialisé pour créer des compositions à la fois extatiques et intimistes, mêlant un piano virtuose à de riches textures orchestrales et électroniques, nourries par l’improvisation.Blais s’est produit partout dans le monde, en solo, en formation de chambre et avec orchestre symphonique. Ses tournées internationales l’ont mené en Europe et en Amérique du Nord : des salles de récital intimistes jusqu’aux foules de 40 000 personnes du Festival international de jazz de Montréal, il captive constamment le public par des performances immersives et d’une grande virtuosité.Il a collaboré avec Alex Weston, ancien assistant de Philip Glass, et a effectué des résidences au studio de Yann Tiersen en France ainsi qu’au Centre Arvo Pärt en Estonie. Sa musique s’étend également à l’image : elle lui a valu un Cannes Soundtrack Award pour Matthias &amp;amp; Maxime de Xavier Dolan, et l’a conduit à signer la musique de Wonderfall, une installation immersive de Moment Factory à l’aéroport Changi de Singapour. Ses compositions ont aussi été utilisées dans la série The Brother Sun de Netflix, une publicité de Tudor et une campagne de Louis Vuitton.Son plus récent album, désert, une collaboration improvisée d’une heure avec la harpiste électronique Lara Somogyi, est resté 32 semaines au classement Billboard Classical USA et a reçu une nomination aux prix JUNO dans la catégorie Album instrumental de l’année, faisant suite à aubades, également lauréat d’un prix Libera (A2IM). Il se prépare actuellement à tourner son prochain album, dont la sortie est prévue à l’automne 2026."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T15:39:00"
      }
    ]
  },
