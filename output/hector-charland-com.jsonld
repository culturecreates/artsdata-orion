    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Amaryllis étudie en sciences à l’université. Ils aboutiront pourtant dans le même petit local terne où, deux heures par semaine, Amaryllis se transformera en professeure de français et Anthony, en élève du secondaire."
      }
