    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Echoes - Hommage à Pink Floyd"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Echoes, c&#039;est des musiciens de talents, soucieux de reproduire le plus fidèlement possible l&#039;oeuvre musicale de Pink Floyd avec la qualité du son du groupe. Le tout vous replongera dans l&#039;univers de ce groupe culte. En couvrant toutes les époques de Pink Floyd soit autant la période Syd Barrett jusqu&#039;à The Division Bell à chaque spectacle, Echoes est définitivement l&#039;hommage à Pink Floyd à voir et à revoir."
      }
    ],
