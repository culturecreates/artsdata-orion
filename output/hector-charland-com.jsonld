        "@value": "Myokine"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Danse contemporaineMyokine explore la façon dont la lumière naît de l’obscurité et la nécessité de leur coexistence. Inspirée par les molécules régénératrices libérées par le mouvement, Anne Plamondon fait de la scène un espace de résilience, d’urgence et d’espoir partagé, où les interprètes, par un mouvement puissant et lumineux, révèlent la capacité du corps à rassembler, guérir et faire sens — même dans l’ombre.Obtenez 20 % de rabais sur l&#039;achat de ce spectacle avec votre carte Privilège. Cliquez ici pour en savoir plus."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-25T02:02:00"
      }
    ]
