    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le Noël de Charlie Brown"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo.Vince Guaraldi a composé la musique de la série « Charlie Brown » en 1964, pour sa diffusion en 1965. Plus de 60 ans plus tard, ces chansons font partie intégrante de nos fêtes de fin d&#039;année et de nos traditions familiales. John Roney et son quatuor rendent hommage à cette musique mythique et proposent des morceaux à la fois familiers et inédits. Ce concert ne manquera pas de ravir petits et grands!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
