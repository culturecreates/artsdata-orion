    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/jay-scott-horizontal-c0e78f35f386b0f187d5.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
