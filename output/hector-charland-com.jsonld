    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le Train"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Drame | Québec | 2025 | GSuivi d&#039;un entretien avec Marie Brassard.Au Québec dans les années 1960, Agathe, enfant asthmatique à l’imagination fertile, vit en banlieue avec sa mère Thérèse, une artiste mélancolique. La nuit, le sifflement d’un train nourrit les visions d&#039;Agathe d&#039;un monde parallèle étrange. Adolescente dans les années 1970, elle découvre le milieu bohème et y rencontre Frank, un jeune écrivain de science-fiction.« C’est un cinéma de l’intime, qui parle doucement mais qui, pour celles et ceux qui s’y ouvrent, résonne longtemps après le dernier plan. » - Ciné-Bulles"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-11-14T11:10:00"
      }
