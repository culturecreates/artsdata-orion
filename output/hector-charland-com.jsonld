  {
    "@id": "https://hector-charland.com/temporary/9e15263d-3e1d-492a-8061-157681592fca",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/liliane-blanco-binette-horizontal-0b5ae58ce0280fa316b2.jpg"
