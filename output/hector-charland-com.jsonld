    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Guylaine Tanguay"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Avec I Love Rock&#039;N&#039;Roll, Guylaine Tanguay nous ramène là où tout a commencé : au bar Le Clairon de Normandin, où elle chantait, pendant ses études, les grands succès rock des années 80. De Joan Jett, Pat Benatar, Heart, AC/DC, Queen, Bon Jovi, The Police, Kiss et Tina Turner, jusqu’à Paul Daraîche, elle revisite avec fougue et nostalgie les chansons qui ont marqué son parcours. Un spectacle festif, vibrant et plein d’énergie! "
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-02-09T17:41:00"
      }
    ]
