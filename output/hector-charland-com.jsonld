  {
    "@id": "https://hector-charland.com/temporary/d1c1ce17-6a66-467b-8451-d85485aaa4de",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/estuaire-horizontal-36595c7cbced00bc4ff6.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=LKjGfRmxJkY"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/estuaire"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Estuaire"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Voyage Musical en partenariat avec Godin-Blouin Audioprothésistes.L’Estuaire, ce lieu où l’eau douce rencontre l’eau salée, évoque le passage, le renouveau, la fertilité. Un espace de transition et de transformation, où surgissent des possibles inattendus tout comme les rencontres musicales imaginées par Constantinople. Dans cette nouvelle collaboration, Ablaye Cissoko, maître de la kora, et Kiya Tabassian, virtuose du sétar persan, croisent leurs chemins pour la troisième fois, mêlant les courants de leurs mémoires musicales. À leurs côtés, leur complice de toujours, le percussionniste Patrick Graham, insuffle rythme et nuances à cette conversation sonore. Au fil des années, leur dialogue s’est étoffé, devenant une conversation musicale profonde et inspirante. Et lorsque les étoiles s’alignent, le temps d’un concert, la kora et le sétar entremêlent leurs voix pour créer un univers envoûtant, qui suspend le temps et apaise les esprits."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-16T14:42:00"
      }
    ]
  },
