  {
    "@id": "https://hector-charland.com/temporary/b5451f01-fc1a-46c7-a18b-0a414b6921e8",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/caity-gyorgy-jazz-duo-horizontal-a618b3d2bc0636244043.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://youtu.be/90i4kraKVxk"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/caity-gyorgy-jazz-duo"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Caity Gyorgy Jazz Duo"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Apéro-Jazz en partenariat avec Planète Haute-Fidélité, spécialiste audio-vidéo. Rejoignez-nous pour une fantastique soirée de jazz vocal avec Caity Gyorgy, l&#039;une des jeunes voix les plus passionnantes du genre au Canada. La chanteuse et compositrice, trois fois lauréate d&#039;un prix Juno, est célèbre pour son swing naturel, son phrasé enjoué et sa maîtrise de l&#039;improvisation vocale. S&#039;inspirant de l&#039;âge d&#039;or du jazz tout en y ajoutant sa touche moderne, Caity Gyorgy apporte charme, esprit et sophistication à chacune de ses performances. En compagnie de son incroyable pianiste Mark Limacher, sa musique fait le pont entre tradition et innovation, mêlant des standards intemporels, tels que The man I love and All of me à des compositions originales qui mettent en valeur sa voix chaleureuse et son timing impeccable. Avec sa présence scénique dynamique et son amour profond pour la narration à travers la chanson, Caity Gyorgy captive le public et vous amène dans un univers de bonheur et de pur ravissement."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:03:00"
      }
    ]
  },
