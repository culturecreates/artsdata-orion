  {
    "@id": "https://hector-charland.com/temporary/5b715b26-4cbb-4042-a3a6-b797f152940a",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/sri-lanka-horizontal-560a2a62a55cc318f288.jpg"
      }
    ],
