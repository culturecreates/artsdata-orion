  {
    "@id": "https://hector-charland.com/temporary/e19c74ab-151e-444b-9240-b4e18497c988",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/les-chants-de-mon-pays-horizontal-976cedfd1aaa42a9ad58.jpg"
