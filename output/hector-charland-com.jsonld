      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Conte musical de Denis Plante, Les lettres de Chopin donne la parole à George Sand qui révèle avec humour et tendresse les secrets de sa relation bouleversante avec ce jeune génie, Frédéric Chopin, le tout accompagné par la musique des plus belles pages du célèbre pianiste."
      }
    ],
