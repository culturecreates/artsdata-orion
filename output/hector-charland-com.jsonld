    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/baie-james-1975-le-choc-des-nations"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Baie James 1975 : le choc des nations"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Documentaire | Québec | 2025 Suivi d&#039;un entretien avec la réalisatrice Myriam Berthelet.Ce film nous ramène à l’origine de deux grandes révolutions : l’expansion fulgurante d’Hydro-Québec avec la construction du complexe La Grande et l’éveil des nations autochtones du Nord du Québec. Un choc des civilisations où deux visions du monde entrent en collision. Le Québec rêve de prendre son destin en main en devenant un géant de l’énergie sur le continent. Tandis qu’au Nord, une nouvelle génération de jeunes Cris et Inuit se soulève dans le but de protéger ce qu’ils ont de plus précieux : leur territoire et leur culture.« Voilà un film nécessaire et extrêmement éclairant, qui aide à comprendre l’héritage paradoxal de la Baie-James. » - La Presse"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-01-22T16:58:00"
      }
    ]
