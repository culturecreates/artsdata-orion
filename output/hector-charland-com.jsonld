    "http://schema.org/embedUrl": [
      {
        "@id": "https://can01.safelinks.protection.outlook.com/?url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D8E8ikKkubmE%26list%3DRD8E8ikKkubmE%26start_radio%3D1&amp;data=05%7C02%7Clmorote%40hector-charland.com%7C4f9dcf7e453b4b36cdf508de26daca22%7C212a9838b3914a3fad2765cdb811ded3%7C0%7C0%7C638990918310837164%7CUnknown%7CTWFpbGZsb3d8eyJFbXB0eU1hcGkiOnRydWUsIlYiOiIwLjAuMDAwMCIsIlAiOiJXaW4zMiIsIkFOIjoiTWFpbCIsIldUIjoyfQ%3D%3D%7C0%7C%7C%7C&amp;sdata=ulQQqunkohM4RI8ZKyYUMxdrl1UCrig1Sdfc9YmUKNo%3D&amp;reserved=0"
