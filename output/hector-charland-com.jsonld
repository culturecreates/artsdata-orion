    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Dave Fenley"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Avec près de 40 000 billets vendus et plus de 50 spectacles au Québec, le coup de cœur des Québécois, Dave Fenley revient avec un tout nouveau spectacle en formule trio! Le chanteur américain folk country à la voix impressionnante qui a été découvert en 2022 via la populaire émission En direct de l’Univers, s’entoure de deux musiciens québécois pour cette aventure. De nouvelles chansons, de nouvelles interprétations des chansons populaires parsemées de savoureuses anecdotes vous attendent dans ce tout nouveau spectacle de Dave Fenley!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2024-10-29T17:07:00"
      }
    ]
  },
