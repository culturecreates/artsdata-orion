  {
    "@id": "https://hector-charland.com/temporary/8b0b31a8-3128-4ede-affe-ae71938867d7",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/in-my-body-horizontal-f5e1a2dd663f79258614.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=M8RO9eaL3Ys"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/in-my-body"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "In My Body"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "On dit que la chose la plus courageuse qu’un danseur puisse faire est de vieillir. Comme le veut la culture hip-hop, les danseurs et danseuses de rue se présentent comme invincibles quand ils s’affrontent par la danse pour démontrer leur valeur et asseoir leur domination. Mais enfermés dans une prison de muscles et d’os, les danseurs, à la merci du temps qui passe, vibrent encore et aspirent toujours à s’exprimer, à se pousser hors d’eux-mêmes en explorant de nouvelles façons de tenter le sort. Dans In My Body, Crazy Smooth, l’un des danseurs et chorégraphes les plus reconnus dans le domaine de la danse urbaine au Canada, réunit un groupe intergénérationnel de danseurs et danseuses de rue, et une équipe de création internationale pour explorer de façon intensément athlétique le développement identitaire et les conséquences inéluctables du vieillissement et du passage du temps.In My Body est accompagné de la poésie orale d’Alejandro Rodriguez, récitée sur les rythmes de DJ Shash’U."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-03-20T02:01:00"
      }
    ]
  },
