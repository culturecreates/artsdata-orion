  {
    "@id": "https://hector-charland.com/temporary/6466220e-4432-45c3-b44c-75dcb9dc979f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/location": [
      {
        "@id": "https://hector-charland.com/genid/e5157e5f241db916"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/tout-sur-le-sexe-horizontal-a714c8378321cb985c94.jpg"
      }
    ],
