  {
    "@id": "https://hector-charland.com/temporary/4d0f287d-c09e-4bf8-a6a4-be251ab75f03",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/plus-fort-que-moi-horizontal-d8a13bfe5b3b21382c16.jpg"
