    ]
  },
  {
    "@id": "https://hector-charland.com/temporary/7371cef8-66ef-4abd-ad58-92945887c0be",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/de-lautre-cote-du-miroir-horizontal-05ca66bf18e5fc706ccf.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=a9nHNhR6QXw"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/de-lautre-cote-du-miroir"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "De l&#039;autre côté du miroir"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle présenté en admission générale sur la scène du Théâtre Alphonse-Desjardins.Les spectateurs sont installés sur des chaises, autour du piano.Présenté par l&#039;Aramusique dans le cadre de sa série Musique Intimiste en partenariat avec Patrick Bonin, Député fédéral de Repentigny. L&#039;expérience musicale, De l&#039;autre côté du miroir, telle qu&#039;imaginée et présentée par le duo Cordelia, vient chambouler les repères conventionnels du concert de musique de chambre. Contemplation, humour, et ravissement sont au rendez-vous alors que les deux musiciennes chevronnées de cet ensemble violon-piano entraînent leur auditoire dans une aventure musicale innovatrice. Elles mettront de l&#039;avant un répertoire diversifié issu de l&#039;œuvre de compositeurs révolutionnaires ou politiquement engagés à leur époque, ainsi que des compositions originales de la violoniste Vanessa Marcoux. S&#039;inspirant de la résilience de ces artistes, pour qui l&#039;évasion vers des paysages musicaux fabuleux comportait la seule issue possible aux réalités de leur époque, le Duo Cordelia témoigne de la profondeur de notre rapport essentiel à la musique. Et par moments, le répertoire faisant place à l&#039;improvisation, le public s&#039;unit l&#039;espace d&#039;un instant dans un élan de création partagée."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-15T02:02:00"
      }
    ]
