    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "New World Men"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "New World Men célèbre, à sa façon, le 40e anniversaire du légendaire album de Rush, Moving Pictures. Voyez Mathieu Groulx, François Larouche et Marc Girard jouer l&#039;intégral de cet album et livrer à la perfection les classiques radiophoniques tels que: Tom Sawyer, Red Barchetta, Limelight ainsi que plusieurs autres! Le mandat du groupe est de recréer de façon identique les sonorités qui ont fait la réputation du groupe canadien Rush. Les amateurs de rock progressif seront servis à souhait. Venez passer une soirée mémorable avec les hommes en rouge!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2023-03-09T10:09:00"
      }
    ]
  },
