      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Après le succès phénoménal de la série de concerts PianoMan , qui a rassemblé plus de 150 000 spectateurs à travers le Québec au cours des dernières années, Christian Marc Gendron revient sur scène dès avril 2026 avec un tout nouveau spectacle : Trilogie . Ce concept unique réunira les meilleurs…"
      }
    ],
