    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/garou-horizontal-d51a62602b227e788484.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=bsmF77aegsU"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
