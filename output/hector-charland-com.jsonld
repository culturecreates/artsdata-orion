  {
    "@id": "https://hector-charland.com/temporary/06dab21f-0016-4607-952a-a29da185a4d9",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/bleu-jeans-bleu-horizontal-e126fd1d5ffd39ece964.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=a9m3mORP_EY"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/bleu-jeans-bleu-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Bleu Jeans Bleu"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Les gars de Bleu Jeans Bleu font du bien. Ils l’ont toujours fait et ils poursuivent sur leur lancée avec un tout nouveau spectacle, la tournée Record NºV.L’élégance d’un parfum haut de gamme, le réconfort d’un macaroni à la viande. L’énergie d’un Monster Truck, la finesse d’une Mercedes vintage. Ce nouveau spectacle allie irrésistiblement leur musique efficace à leur humour décalé, dans une parfaite complicité avec le public : une signature qui fait de Bleu Jeans Bleu un des groupes chouchous de la scène québécoise. Ambiance feutrée, décor italo-romantique… laissez-vous envoûter par la fragrance du bonheur pur!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2025-11-18T10:10:00"
      }
    ]
  },
