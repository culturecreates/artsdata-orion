    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Avec  I Love Rock'N'Roll , Guylaine Tanguay nous ramène là où tout a commencé : au bar  Le Clairon  de Normandin, où elle chantait, pendant ses études, les grands succès rock des années 80. De Joan Jett, Pat Benatar, Heart, AC/DC, Queen, Bon Jovi, The Police, Kiss et Tina Turner, jusqu’à Paul…"
      }
