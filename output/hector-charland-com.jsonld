  {
    "@id": "https://hector-charland.com/temporary/76b9031c-2c23-406c-80b0-eea5e3f8c2b4",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/les-peres-petu-la-tradition-horizontal-a1077b1024372aed6d4d.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=Fg6z534r0yE"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://hector-charland.com/programmation-spectacles/les-peres-petu-la-tradition"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les pères Pétu : La Tradition"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté par l&#039;Aramusique dans le cadre de sa série Sons et Brioches en partenariat avec McDonald&#039;s - La famille Lemay. Collation offerte gracieusement par McCafé à partir de 10h.Le spectacle La Tradition, c’est une célébration vibrante, ludique et résolument actuelle du patrimoine culturel traditionnel. À travers une exploration captivante de thèmes variés (chansons à répondre, gigues françaises et irlandaises, art culinaire, bonnes manières et progrès), Éric Bégin et Éloi Amesse proposent un regard à la fois rafraîchissant et rassembleur sur les traditions qui façonnent encore aujourd’hui notre quotidien. Avec complicité et humour, ils dépoussièrent le folklore et le rendent étonnamment proche du public. Porté par une énergie communicative, le duo surprend et ravit en intégrant à son univers des touches de rap, d’électro et des compositions originales. Cette rencontre audacieuse entre héritage et modernité crée un spectacle rythmé, accessible et hautement festif. Musique, mouvement et clins d’œil savoureux se succèdent dans une mise en scène dynamique qui invite spontanément à taper du pied, fredonner et même danser. Petits et grands y trouvent leur compte, redécouvrant avec plaisir un folklore bien vivant, en constante évolution. Les pères Pétu, c’est la preuve éclatante que nos racines culturelles ne sont pas figées dans le passé : elles respirent, se transforment et continuent de nous rassembler aujourd’hui. Un moment festif, rassembleur et intergénérationnel à partager en famille!"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-16T16:42:00"
      }
    ]
  },
  {
    "@id": "https://hector-charland.com/temporary/b4ea62ac-9e2a-4ba5-b262-ef6b87eb6b44",
