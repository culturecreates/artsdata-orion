  {
    "@id": "https://hector-charland.com/temporary/363fbec7-9cb2-450b-96af-29133b9c76bf",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/il-pleut-il-plaint-il-rage-skltr-horizontal-35dcbf3fc43b33b90c1b.jpg"
      }
    ],
    "http://schema.org/embedUrl": [
