  {
    "@id": "https://hector-charland.com/temporary/437cc4dd-af3f-432d-a871-f069ac26ab72",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://hector-charland.com/uploads/spectacles/matt-lang-horizontal-e1533ed9682cb538a1f4.jpeg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=E3TztSprgZI"
