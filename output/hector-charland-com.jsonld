    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tire le coyote"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Tire le coyote pour la première fois seul en scène. Une occasion pour l’auteur-compositeur de revisiter son répertoire et de proposer de nouvelles chansons dans une parfaite ambiance intime, qui laissera toute la place à la poésie des mots, à son talent de guitariste et à cette voix unique qui nous bouleverse. Encore une fois un grand rendez-vous."
      }
    ],
