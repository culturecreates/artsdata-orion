    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Après de nombreuses années à faire rire la francophonie avec ses albums culte (plus de 2 millions de ventes) et ses œuvres à la radio et à la télé, François Pérusse signe ici sa toute première pièce de théâtre originale dans la plus pure tradition du Boulevard. L’intrigue de Boulevard Pérusse…"
      }
