  {
    "@id": "https://www.kingstongrand.ca/about/resident-companies/theatre-kingston",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Theatre Kingston"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Theatre Kingston produces professional new and existing work, the TK Fringe Festival and out of the TK Studio provides a series of child/youth/adult engagement and education activities in the theatre arts. Theatre Kingston collaborates with local theatre practitioners to build a strong cultural voice in the region. Our primary goal is to give our audiences examples of the art form at a calibre seen on the stages of the major Canadian urban centres."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/company/hero/TK%20Collage.png"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/about/resident-companies/theatre-kingston"
      }
    ]
  },
  {
    "@id": "https://www.kingstongrand.ca/events/the-shoop-shoop-show-the-cher-collection",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "The Shoop Shoop Show - The Cher Collection"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Get ready to experience a Cher show like no other – heading to theatres across the UK, Europe and Canada in 2026! ‘Turn Back Time’ with The Shoop Shoop Show - The Cher Collection, an exhilarating music-led production with a party atmosphere. It is led by international powerhouse vocalist Rachael Hawnt, the winner of ITV’s Starstruck. The show spans every decade of Cher’s incredible career so be prepared to be dazzled by disco HITS and pop rock chart-toppers. As the show unfolds Rachael’s spot-on impersonation will make you ‘Believe’."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/Cher%201080%20x%201920%20pixels%20-%20Princess%20Street.jpg"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca’ featuring performers in Cher-inspired costumes with event details for Friday"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caMay 22 at KingstonGrand.ca\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/the-shoop-shoop-show-the-cher-collection"
