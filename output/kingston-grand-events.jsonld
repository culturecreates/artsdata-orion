  {
    "@id": "https://www.kingstongrand.ca/events/the-velveteen-rabbit",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "The Velveteen Rabbit"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Embark on the journey of The Velveteen Rabbit, reimagined in the modern day: we follow the journey of our titular protagonist - a shy toy who wants nothing more than to become ‘real.’ In other words, to be truly loved by the child that takes care of you. Through the story we experience the unbreakable bond between the Velveteen Rabbit and the Girl. On the way, we meet outlandish characters, deal with major toy-world crises, sing, dance, and most importantly, have fun."
      }
    ],
    "https://ogp.me/ns#image": [
      {
