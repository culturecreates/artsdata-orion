    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Making its Kingston debut, TaikoProject brings thunderous taiko drumming, athletic precision and electrifying choreography together in a jaw-dropping live performance. The group has performed on the Academy Awards, the Grammy Awards, and NBC's The Voice."
      }
