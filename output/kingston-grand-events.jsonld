    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "The colourful history of Newfoundland’s fishers and loggers, sealers and whalers is told with story, song and incredible visuals in this engaging musical review by Shipyard Kitchen Party, creators of “Tom Thomson’s Wake” and “100 Years from Now”."
      }
