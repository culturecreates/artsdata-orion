        "@language": "en",
        "@value": "Matthew Good and His Band featuring Kevin Fox and His String Quartet"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Matthew Good and His Band take the stage in a uniquely immersive live experience, joined by a stunning string quartet led by renowned cellist Kevin Fox. Across two dynamic 45-minute sets, the evening weaves together beloved hits, deep cuts, and rare b-sides, reimagined through a rich interplay of acoustic intimacy and full-band intensity."
      }
    ],
