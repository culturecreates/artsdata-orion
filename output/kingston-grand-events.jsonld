  {
    "@id": "https://www.kingstongrand.ca/events/gerry-dee-2026",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Gerry Dee: Funny You Should Say That"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Gerry Dee was the star and co-creator of the hit CBC comedy “Mr.D” for 8 seasons. He is currently the host of “Family Feud Canada”. He currently plays the role of “Templeton Dudge” in the sitcom “Animal Control” on FOX Television. His first book, “Teaching: It’s Harder Than It Looks” was released in 2012 and was a National best seller. He released his second book in October 2023. For more information visit www.gerrydee.com"
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/Gerry%20Dee%20Promo%201.jpg"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.castanding against a plain background.\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/gerry-dee-2026"
