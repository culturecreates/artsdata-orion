  {
    "@id": "https://www.kingstongrand.ca/events/walk-like-a-man",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Walk Like A Man"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Walk Like A Man is the ultimate celebration of Frankie Valli & The Four Seasons, recreating the iconic powerful falsetto with perfection. Produced by its very own West End star, Mark Halliday, Walk Like A Man has amazed audiences across the globe from Cardiff to Columbia, from London to Lithuania, with their incredible vocals, slick moves, infectious charm and timeless hits."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/WLAM%201080%20x%201920%20pixels%20%28with%20date%29.jpg"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caMarch 26 show date.\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/walk-like-a-man"
      }
    ]
