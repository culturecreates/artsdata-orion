        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Classic Albums Live – The Stranger (Billy Joel)"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "The Stranger is the breakthrough 1977 release that propelled Billy Joel to international stardom, featuring iconic tracks like “Just the Way You Are,” “Movin’ Out (Anthony’s Song)” and “Only the Good Die Young.” Blending sharp storytelling with unforgettable melodies, Classic Albums Live will perform this album note for note, cut for cut, live on stage followed by a set of Billy Joel’s greatest hits."
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/classic-albums-live-the-stranger-billy-joel"
      }
    ]
