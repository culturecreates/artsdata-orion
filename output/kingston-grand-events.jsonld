    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Meet the Hatter"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "A magical, cinematic dance and multimedia spectacle Joss Arnott Dance's latest production. Prepare to be amazed by this fantastical and extraordinary family show that you won’t want to miss! Combining powerful dance with new storytelling and mesmerizing visuals, complemented by an emotionally charged original score, this dance and multimedia show is an epic retelling of the iconic Hatter from Lewis Caroll’s Alice’s Adventures in Wonderland – but with a twist."
      }
    ],
