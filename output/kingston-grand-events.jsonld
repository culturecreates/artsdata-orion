  {
    "@id": "https://www.kingstongrand.ca/events/kingston-sings",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Kingston Sings"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Can You Sing Canada is coming to Kingston to discover our community’s outstanding local singers. Now in its 7th year, this exciting production travels across the country in search of remarkable new voices, creating unforgettable moments on stage where courage, talent, and community pride take the spotlight. Through a locally focused audition process, the show uncovers the very best performers, and will produces a live concert at Kingston Grand featuring a dynamic lineup spanning all ages and musical styles - from rock and country to piano ballads, crooners, and pop."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/33%20Kingston%20Sings.png"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/kingston-sings"
      }
    ]
  },
