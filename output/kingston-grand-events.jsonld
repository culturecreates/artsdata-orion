[
  {
    "@id": "https://www.kingstongrand.ca/events/take-me-home",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Take Me Home: Celebrating John Denver and Glen Campbell"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "\"Take Me Home: Celebrating John Denver & Glen Campbell\" is a heartfelt celebration of two legendary voices who shaped the sound of American music. Blending folk, country, and pop with unmatched sincerity, Glen Campbell and John Denver wrote songs that spoke to longing, hope, love, and the pull of home, music that still feels deeply personal decades later. This concert invites audiences on a journey through timeless classics and treasured gems, including “Wichita Lineman,” “Rhinestone Cowboy,” “Take Me Home, Country Roads,” and “Annie’s Song.”"
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/Take%20Me%20Home%20Website.png"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/take-me-home"
      }
    ]
