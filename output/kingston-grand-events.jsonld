        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/PHOTO%20Queen%20SaintJohn%20030524%20Copr%20Robert%20Doiron%2042.jpg"
      },
      {
        "@language": "en",
