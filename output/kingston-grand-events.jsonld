  {
    "@id": "https://www.kingstongrand.ca/events/ksa2526-pops3-under-paris-skies",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "POPS3 - Under Paris Skies"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Jill Barber, Singer Lucas Waldin, Guest Conductor Enjoy the timeless classics of Edith Piaf, Charles Trenet, Jacques Brel, and others performed by award-winning Canadian songstress Jill Barber and your Kingston Symphony. In Under Paris Skies, Jill brings her special affinity for French chansons and her warm contralto voice to such hits as La Vie En Rose, C’est Si Bon, and La Mer. The evening also features musical love letters to the City of Lights by Count Basie, Nat King Cole, Eartha Kitt, and more."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/KS__Grand_Hero_Portrait_Pop3.jpg"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
