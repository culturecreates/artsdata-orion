    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Queen: It's a Kinda Magic"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "ARE YOU READY TO ROCK?! Direct from Australia, the hit tribute returns to Canada in 2026 - bigger, better and louder than ever! See the rock spectacular that Canadians flock to every year, bringing big sound, big screens, crazy lighting and outlandish costumes for a night of non-stop rock anthems, including Bohemian Rhapsody, We Will Rock You, We Are the Champions, Radio GaGa, I Want to Break Free, Somebody to Love, Don’t Stop Me Now, Another One Bites the Dust and so many more."
      }
    ],
