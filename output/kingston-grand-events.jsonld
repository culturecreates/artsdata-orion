  {
    "@id": "https://www.kingstongrand.ca/events/1999-the-ultimate-prince-experience",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "1999 The Ultimate Prince Experience"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "The genius, innovation and grandeur of the one and only Prince - this immersive stage show experience pays tribute and reverence to one of the greatest musical pioneers of our time. Dedicated live performances from talented multi-instrumentalist Dale Ray on vocals, guitar and piano, are a fitting commemoration in this world-class production that evokes the wondrous and quixotic realm of Prince - his music, his art, his vision."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/IMG%20Prince%201080x1920.jpg"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cashowing a performer playing a purple guitar amid blue stage lighting and smoke"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.castarring Dale Ray.\" />"
      }
    ],
