  {
    "@id": "https://www.kingstongrand.ca/events/los-desperados-2026",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Los Desperados - Tribute to the Eagles"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Formed in March 2021 in Ottawa, Ontario, Los Desperados is a tribute band dedicated to celebrating the legendary music of the Eagles. The band features a talented lineup with Cory Maxam (lead vocals, guitar), Izzy Martinez (guitar and vocals), Ed Lauzon (bass and vocals), Gabor Obert (guitar, keyboards, and vocals), and Michael Paterson (keyboards). With their rich harmonies and expert musicianship, Los Desperados faithfully recreate the iconic sound that has captivated audiences for decades."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/Los%20D%202550x3300.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caan Eagles tribute band"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cafeaturing show details for a performance on October 3rd at The Spire in Kingston.\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/los-desperados-2026"
      }
