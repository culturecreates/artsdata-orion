        "@value": "Classic Albums Live – The Immaculate Collection (Madonna)"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Experience Madonna’s iconic greatest hits album performed note-for-note,cut for cut in a high-energy concert celebrating one of pop music’s most influential artists. From “Like a Virgin” to “Vogue,” this electrifying live performance brings the sound, style and attitude of Madonna to the stage with stunning precision."
      }
    ],
