  {
    "@id": "https://www.kingstongrand.ca/events/by-a-thread-produced-by-one-fell-swoop-circus",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "By A Thread (Produced by One Fell Swoop Circus)"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Seven acrobats and 30 metres of rope. This exhilarating physical theatre and circus performance weaves stunning aerial artistry with a compelling story of connection, tension and human resilience. Performed with breathtaking precision on ropes, silks and apparatus, this visually striking show invites audiences into a world where balance, risk and daring creativity collide in spellbinding motion."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
