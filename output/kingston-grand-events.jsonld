    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Internationally touring comedian Jeff Leeson comes to Kingston for a night of Live stand-up comedy you will never forget! With 25 years of experience touring all across North America and over 150 Million views online, find out why this is definitely one show you absolutely Do Not want to miss!"
      }
    ],
