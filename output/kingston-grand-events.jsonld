    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/three-roads-home-featuring-stephen-fearing-james-keelaghan-and-irish-mythen"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Three Roads Home featuring Stephen Fearing, James Keelaghan and Irish Mythen"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "​​Celebrating Irish heritage through the songs and stories of three Canadian folk legends \n\nThree Roads Home brings together three of Canada’s most beloved singer-songwriters — James Keelaghan, Irish Mythen and Stephen Fearing — for an unforgettable evening of songs, stories, and shared heritage. All three artists draw on deep Irish roots that continue to shape their music, storytelling, and sense of identity. "
      }
    ]
  },
