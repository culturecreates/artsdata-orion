  {
    "@id": "https://www.kingstongrand.ca/events/hells-bells-2026",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "HELLS BELLS"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Since their electrifying inception in 1994 in the heart of Toronto, Hells Bells has soared to become the World’s Longest Touring Tribute to the legendary AC/DC, lighting up stages across Canada, United States, Mexico and as far as Dubai , United Emirates. Don’t miss your chance to experience the sound, look and attitude, from the wall of Marshall Amps, the Thundering Cannons, the Giant Bell, and the signature schoolboy outfit. Join us to celebrate the spirit of AC/DC. Where the music is contagious, and the memories are unforgettable."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/HELLS_BELLS_-_5044_X_6572_-WEBSITE_HERO_IMAGE%5B1%5D%20%281%29.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca’ described as the world’s longest‑touring AC/DC tribute"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cafeaturing lightning graphics"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.calarge bells"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caand a performer in a school‑uniform outfit\" />"
      }
    ],
