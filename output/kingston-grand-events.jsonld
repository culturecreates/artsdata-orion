    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Cabaret for a Cure 2026"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Cabaret for a Cure is back! Join us for an unforgettable evening of live music, captivating performances, and powerful storytelling, brought to you by the Queen’s Law Cancer Society in support of Brain Cancer Canada and the Canadian Cancer Society. Set in an intimate cabaret atmosphere, this inspiring night brings together talented performers and a community united by hope, resilience, and the belief that meaningful change is possible."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/QLCS%20Cabaret%20PS%20DIN.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.casupporting cancer charities\" />"
      }
    ],
