    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Heritage Day 2026"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "The India-Canada Association of Kingston invites you to its 27th Annual Heritage Day celebration. This is a 2 to 3 hour event, showcasing amazing local talent, featuring a delightful mix of high energy dance performances from various states of India, music, skits, and traditional folk dances. The event also includes a variety of delicious Indian snacks, all included in the ticket price, offering a complete cultural and culinary experience."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
