    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Gerry Dee: Funny You Should Say That"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Gerry Dee was the star and co-creator of the hit CBC comedy “Mr.D” for 8 seasons. \n\nHe is currently the host of “Family Feud Canada”. \n\nHe currently plays the role of “Templeton Dudge” in the sitcom “Animal Control” on FOX Television. \n\nHis first book, “Teaching: It’s Harder Than It Looks” was released in 2012 and was a National best seller. He released his second book in October 2023. \n\nFor more information visit www.gerrydee.com "
      }
    ]
  },
