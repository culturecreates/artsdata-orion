      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/PHOTO%20Queen%20Peterborough%20220825%20Copr%20John%20Formosa%206.jpg"
