    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "International Guitar Night"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "International Guitar Night (IGN) returns to Canada in 2027 with a thrilling nationwide tour celebrating the world’s finest acoustic guitarists. Renowned for sold-out performances and virtuosic artistry, this unforgettable evening blends Brazilian, flamenco, Middle Eastern and gypsy jazz influences into one dynamic concert experience. A must-see for music lovers, IGN showcases four world class players, jaw-dropping technique and the pure power of the acoustic guitar. "
      }
    ]
  },
