  {
    "@id": "https://www.kingstongrand.ca/events/hold-on-to-your-butts",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Hold On To Your Butts"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "The West End and Off-Broadway hit goes on tour! This wildly inventive live comedy parodies the iconic dinosaur film Jurassic Park with clever physical theatre, simple props and live Foley sound effects. Performed by a small ensemble who recreate every moment and character on stage with boundless energy and humour, this family-friendly show delivers non-stop laughs and imaginative theatrical fun."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
