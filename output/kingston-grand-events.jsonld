      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "2026 Come Play by the Lake One Act Play Festival"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Plays performed on Friday, July 3rd: • \"Rulers\" by Gord Love • \"Ethically Sourced Chocolate in the Post-Extinction Era\" by B.C. Gorrie, N. Neokleous & M. Thaker • \"A Quarter Hour With Arsene Lupin\" By Maurice Leblanc, Translated & Adapted by Matt Kane Plays performed on Saturday, July 4th: • \"Check Please\" By Jonathan Rand • \"The Death of Me\" By Norm Foster • \"Losers’ Lunch\" By Penny Barker"
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
