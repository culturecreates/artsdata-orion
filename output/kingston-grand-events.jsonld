    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Ukraine Fire is a visceral and poetic stage performance by acclaimed Ukrainian ensemble Dakh Daughters that blends live music, cabaret and multimedia storytelling to confront the realities of war with raw emotion and creative defiance. This bold and unforgettable experience channels grief, resilience, and hope into a powerful artistic act of resistance."
      }
    ],
