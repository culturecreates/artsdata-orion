    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Welcome to OZ From Sparkle to Strength"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Our dancers invite you into a world where kindness and curiosity light the path. In Act 1, Oz opens in sparkle: playful, bright, and full of wonder. As the journey unfolds, confidence begins to grow. After intermission, strength emerges—not as darkness, but as courage, clarity, and pride in who we are becoming. The heart of this story is simple: sparkle and strength belong together. Joy does not disappear. It grows stronger."
      }
    ],
    "https://ogp.me/ns#image": [
      {
