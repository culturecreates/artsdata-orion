  {
    "@id": "https://www.kingstongrand.ca/events/carrie-the-musical",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "CARRIE: The Musical"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Based on the iconic horror novel by Stephen King, Carrie: The Musical follows teenage outcast Carrie White as she navigates newfound powers in the wake of a vicious act of bullying. Dismissed by her abusive mother, Carrie’s attempts to fit in ultimately lead to the destruction of life as she—and everyone around her—knows it. Carrie: The Musical is based on the novel by Stephen King, with music by Michael Gore, lyrics by Dean Pitchford, and book by Lawrence D. Cohen."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/3.%20Carrie%20The%20Musical%20%2812%20x%2017%20in%29.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cawith show dates April 10–19"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca2026"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caat the Baby Grand Theatre. The design includes production credits"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.calicensing information"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caand logos for Queen’s Musical Theatre and Kingston Grand Theatre.\" />"
      }
