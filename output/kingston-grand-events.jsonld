  {
    "@id": "https://www.kingstongrand.ca/events/gravity-and-other-myths-presents-ten-thousand-hours",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Ten Thousand Hours"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Everybody is a master of something. Blink, step, jump, balance, flip, fly. This is an ode to the countless hours needed to achieve great things. A tribute to the dedication required to realize our physical ambitions. An acknowledgement of the backstory that is often more spectacular than the finished product."
      }
    ],
