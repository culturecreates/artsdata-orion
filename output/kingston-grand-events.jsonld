    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Get ready for an unforgettable night of country music as three Canadian legends share one stage on The Great Canadian Roadtrip tour. Featuring Doc Walker, Jason McCoy and Michelle Wright, this all-star lineup delivers hit after hit in a powerhouse evening. "
      }
