    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Steve Poltz has fun on stage. Steve Poltz has fun off stage. Every show has its own vibe. Raucous, joyous, improvisational and always spectacularly strange and wonderful. Stellar guitar work and songs that will have you smiling one minute and crying the next."
      }
    ],
