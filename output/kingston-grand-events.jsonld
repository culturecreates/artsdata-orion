    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "2026 AB Elite Showcase"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "It is with great pride and excitement that we present the AB Elite Showcase, a celebration of strength, artistry, and dedication. Each piece reflects the hard work, passion, and perseverance of our dancers, who have challenged themselves and grown throughout the season. We are so proud to share this special performance with you."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/Alina%201080x1920px.png"
      },
