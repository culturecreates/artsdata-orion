    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "A Two Band Celebration of Tom Petty and Fleetwood Mac!"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "FLEETWOOD MAC MEETS TOM PETTY! AN EXCLUSIVE 2 BAND CELEBRATION. North America’s Top Fleetwood Mac Tribute A visually and musically stunning performance featuring the renowned Fleetwood Nicks. All the hits of Fleetwood Mac PLUS the solo work of Stevie Nicks performed flawlessly to the last detail – including full costume and instrumentation! AND as a special bonus, you’ll be treated to the hits of Stevie Nicks with special guest Tom Petty!!!"
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
