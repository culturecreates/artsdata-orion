  {
    "@id": "https://www.kingstongrand.ca/events/cinderella-2027",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Cinderella, presented by the United European Ballet Company"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Produced by Classical Arts Entertainment, experience the magic of Cinderella, a beloved classical ballet set to the enchanting music of Sergei Prokofiev. Featuring elegant choreography, stunning hand-painted scenery, and exquisite costumes, this production brings the timeless story to life with a talented international cast, including principal dancers from Ukraine. A visually rich and family-friendly performance, Cinderella offers a perfect blend of artistry, storytelling, and theatrical charm for audiences of all ages."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/18%20Cinderella.png"
