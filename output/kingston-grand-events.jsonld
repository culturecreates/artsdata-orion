      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Women Fully Clothed"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "After selling out theatres in Toronto, Montreal, New York, Edinburgh and so many wonderful towns in between, Jayne Eastwood (My Big Fat Greek Wedding, Hairspray, Dawn of The Dead, The Santa Clause), Teresa Pavlinek (Doc, Workin' Moms), Kathy Greenwood (Whose Line Is It Anyway?, Ghosts) and Robin Duke (Saturday Night Live, SCTV, Schitt's Creek) have put together a \"Best Of\" show. This show highlights the hilarity of life through scene and song and makes us laugh at ourselves until there isn’t a dry seat in the house."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/1000043132.jpg"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cadressed in formal evening attire against a softly lit background with bokeh-style lights.\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/women-fully-clothed"
      }
    ]
