  {
    "@id": "https://www.kingstongrand.ca/about/resident-companies/theatre-kingston",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Theatre Kingston"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Theatre Kingston produces professional new and existing work, the TK Fringe Festival and out of the TK Studio provides a series of child/youth/adult engagement and education activities in the theatre arts. Theatre Kingston collaborates with local theatre practitioners to build a strong cultural voice in the region. Our primary goal is to give our audiences examples of the art form at a calibre seen on the stages of the major Canadian urban centres."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/company/hero/TK%20Collage.png"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/about/resident-companies/theatre-kingston"
      }
    ]
  },
  {
    "@id": "https://www.kingstongrand.ca/events/real-love-2026",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "REAL LOVE - Kenny & Dolly Tribute"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Get ready for an unforgettable evening of country music magic! “Real Love” the world's #1 Kenny Rogers and Dolly Parton Tribute Show is performed by award-winning country artists Alan Turner and Laurie Lynn. This concert promises to be a night filled with classic hits and the timeless charm of two country music legends."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/REAL%20LOVE%20Kenny%20%26%20Dolly%20Kingston%20hero.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.castarry background. The person on the left wears a sparkly black and silver outfit with an updo hairstyle"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.calarge earrings"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caand a necklace. The person on the right has light-colored hair and a beard"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cadressed in a white shirt and dark jacket.\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/real-love-2026"
      }
    ]
