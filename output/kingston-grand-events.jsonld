  {
    "@id": "https://www.kingstongrand.ca/events/hadestown-teen-edition",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Hadestown Teen Edition"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Based on Greek Mythology, Hadestown: Teen Edition tells the tale of two intertwining love stories - that of the young dreamers Orpheus and Eurydice, and that of the immortal gods King Hades and Queen Persephone. This timeless tale invites audiences to journey into the underworld and back with music inspired by classic American folk and vintage New Orleans jazz. Anaïs Mitchell’s riveting sung-through musical pits industry against nature, doubt against faith, and fear against love."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/LSP%20Website.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cafeaturing a red flower on a black background with production credits for Lemon Seed Productions.\" />"
      }
