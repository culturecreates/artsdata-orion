    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Just for Laughs Road Show 2026"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "WARNING: Live comedy performances may contain adult content, parental discretion is advised. Just For Laughs is delighted to be back on the road with some of the funniest comedians around! The 21st edition of the Just For Laughs Road Show will bring four hilarious comics to Kingston for an evening of belly laughs and busted guts."
      }
    ],
