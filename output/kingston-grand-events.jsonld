    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Toronto Jazz Orchestra Salutes the Big Bands, with special guest artist Heather Bambrick"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "One of Toronto's most exciting big bands, Toronto Jazz Orchestra, performing everything from classic swing to contemporary big band sounds, joins forces with vocalist Heather Bambrick, a Canada National Jazz Award recipient and Juno nominee. "
      }
    ]
