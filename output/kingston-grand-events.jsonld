  {
    "@id": "https://www.kingstongrand.ca/events/hyprov-featuring-colin-mochrie-and-asad-mecci",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Hyprov featuring Colin Mochrie and Asad Mecci"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "A wildly entertaining live show that fuses hypnosis with master hypnotist Asad Mecci and improv comedy with legend Colin Mochrie, inviting audience volunteers to be hypnotized before joining professional improvisers on stage. Fast-paced, unpredictable and laugh-out-loud funny! Hilarious. Unpredictable. Unlike anything you’ve ever seen."
      }
    ],
    "https://ogp.me/ns#image": [
      {
