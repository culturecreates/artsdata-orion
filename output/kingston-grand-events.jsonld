    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Tom Lavin & The Legendary Powder Blues with special guest David Gogo"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "For over four decades Powder Blues has been Canada’s leading blues band. The mix of swing, blues, jazz, rock & roll and r & b has an appeal so wide that people from seven to seventy swing side by side at a Powder Blues concert. Over the years the band has toured non-stop through Canada, the US and overseas, sharing their feel-good music."
      }
    ],
    "https://ogp.me/ns#image": [
