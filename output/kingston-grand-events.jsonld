    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Plays performed on Friday, July 3rd:  \n•    \"Rulers\" by Gord Love\n•   \"Ethically Sourced Chocolate in the Post-Extinction Era\" by B.C. Gorrie, N. Neokleous & M. Thaker\n•   \"A Quarter Hour With Arsene Lupin\" By Maurice Leblanc, Translated & Adapted by Matt Kane\n\nPlays performed on Saturday, July 4th:\n•     \"Check Please\" By Jonathan Rand\n•    \"The Death of Me\" By Norm Foster \n•     \"Losers’ Lunch\" By Penny Barker  "
      }
    ]
