        "@language": "en",
        "@value": "Beatlemania"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Join us as London BEATLEMANIA touches down for a truly unforgettable show! Experience a live Beatles show through all eras of their career, live on stage with their high energy, impeccable musicianship, showmanship, and humour. From early Ed Sullivan to Let it be, you'll get all the hits."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/Beatlemania%20%20%281920%20x%201080%20px%29%20%281080%20x%201920%20px%29.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca2026"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caat Kingston Grand Theatre featuring a live band in Sgt. Pepper's uniforms performing on stage.\" />"
      }
    ],
