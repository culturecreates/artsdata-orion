  {
    "@id": "https://www.kingstongrand.ca/events/ksa2526-family2-jacob-two-two",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "FAMILY2 - Jacob Two-Two Meets the Hooded Fang"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Dean Burry, Narrator Rafael Luz, Guest Conductor Poor Jacob Two-Two. Not only must he say everything twice to be heard over his older brothers and sisters, but he also finds himself the prisoner of the dreaded Hooded Fang. What did he do to deserve such a punishment? The worst crime of all - insulting a grown-up! Join the Kingston Symphony as we bring to life this classic tale by Mordecai Richler, with music by award-winning Canadian composer, Dean Burry, and text adapted by the author’s son Jacob Richler - none other than Jacob Two-Two himself!"
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/KS__Grand_Hero_Portrait_Fam2.jpg"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/ksa2526-family2-jacob-two-two"
      }
    ]
