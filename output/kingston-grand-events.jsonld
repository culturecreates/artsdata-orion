  {
    "@id": "https://www.kingstongrand.ca/events/megastars-country-music",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "The Megastars of Country Music"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "The MEGASTARS OF COUNTRY MUSIC is an exciting, fun-filled, live concert experience featuring tributes to country music’s most legendary singers and songwriters. This incredible show which features Larry Turner and Doug Brewin pays homage to the incredible careers of ALAN JACKSON, GEORGE STRAIT and BROOKS & DUNN"
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/Megastars_Of_Country_Tour_2026_Image_1080x1920.jpeg"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caBrooks & Dunn"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caand Alan Jackson” featuring four people in cowboy hats with bold text reading “Megastars of Country.”\" />"
      }
    ],
