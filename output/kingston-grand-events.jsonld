    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Gowan – 40th Anniversary Tour of Strange Animal"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Born in Glasgow, Scotland, and raised in Canada, Lawrence Gowan enjoyed a lengthy and successful solo career with four Platinum and three Gold albums and one Gold single to his credit, prior to joining Styx in 1999 as keyboardist and one of their three lead vocalists. At age 19, Gowan achieved an ARCT in classical piano performance from the Royal Conservatory of Music in Toronto."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/39%20Gowan.png"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/monks"
      }
    ]
  },
