    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "CARRIE: The Musical"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Based on the iconic horror novel by Stephen King, Carrie: The Musical follows teenage outcast Carrie White as she navigates newfound powers in the wake of a vicious act of bullying. Dismissed by her abusive mother, Carrie’s attempts to fit in ultimately lead to the destruction of life as she—and everyone around her—knows it.  \n\nCarrie: The Musical is based on the novel by Stephen King, with music by Michael Gore, lyrics by Dean Pitchford, and book by Lawrence D. Cohen.  "
      }
    ]
  },
