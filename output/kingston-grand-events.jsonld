    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Miigis: Underwater Panther – A Red Sky Performance production"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "A powerful contemporary Indigenous dance work inspired by the epic Anishinaabe journey along ancient water routes from the Atlantic Ocean to the Great Lakes. This performance brings to life themes of origin, memory, spirit beings, and the Seven Fire Prophecies—carried forward through striking movement, music, and visual design."
      }
    ],
    "https://ogp.me/ns#image": [
