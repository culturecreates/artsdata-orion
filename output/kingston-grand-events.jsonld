  {
    "@id": "https://www.kingstongrand.ca/events/the-lady-next-door",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "The Lady Next Door"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "This is the story of two very different neighbors who share a common yard. One woman is orderly and organized, while the other is messy and exuberant. Huguette delights in singing loudly while hanging laundry, camping in her yard, or riding her acrobatic bicycle—much to her neighbour Vana’s chagrin. Vana is most bothered by Huguette’s overflowing garbage cans, not to mention her snoring! Together, these two very different neighbours learn how to communicate with one another. It turns out they are not so different after all… they may even become friends."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/14%20-%20the%20lady%20next%20door.png"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/the-lady-next-door"
      }
    ]
  },
