  {
    "@id": "https://www.kingstongrand.ca/events/the-comedy-of-errors",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "The Comedy of Errors"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "A Classic Comedy by William Shakespeare The Comedy of Errors is a fast, funny, and wildly entertaining romp full of mistaken identities, slapstick, and unexpected reunions. When two sets of identical twins—separated at birth—end up in the same city, confusion and chaos take over as friends, lovers, and strangers keep mixing them up. One of Shakespeare’s earliest and most crowd-pleasing comedies, The Comedy of Errors is a joyful celebration of love, family, and the hilarity that comes from a case of truly mixed-up lives. DIRECTED BY EMILY PICKETT"
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/CoE%20480x480.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cafeaturing a mirrored black‑and‑white figure in period costume on a pink and blue radiating background"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cawith text crediting William Shakespeare and director Emily Pickett.\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/the-comedy-of-errors"
      }
    ]
  },
