  {
    "@id": "https://www.kingstongrand.ca/events/emerald-isle-a-joyful-celebration-of-irish-music-song-and-dance",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Emerald Isle: A Joyful Celebration of Irish Music, Song and Dance"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Emerald Isle is a breath-taking live show that transports audiences on a magical journey through the heart and soul of Ireland. Created by the visionary producer Chris Hannon, former Lord of the Dance Star and creator of the global sensation Murphy's Celtic Legacy, this extraordinary performance celebrates the rich tapestry of Irish culture, from its vibrant traditions to its mythical stories and ancient sites."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
