    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Led Zeppelin Meets Pearl Jam"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "A NIGHT OF ROCK LEGENDS Get ready for an unforgettable night of rock music as two legendary tribute bands take the stage! Experience the Magic of Led Zeppelin with Zepology: Canada's premier Led Zeppelin tribute band, is renowned for their electrifying performances and faithful renditions of Zeppelin's iconic hits. From \"Stairway to Heaven\" to \"Whole Lotta Love,\" Zepology captures the essence and spirit of the rock legends, delivering an authentic concert experience that transports you back to the golden age of rock."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/ZEPPELIN%20X%20PEARL%20KINGSTON%20%281080%20x%201920%20px%29.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caMarch 28"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca2026"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cawith a purple-lit crowd and raised hands.\" />"
      }
    ],
