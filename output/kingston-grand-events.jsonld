    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Hyprov featuring Colin Mochrie and Asad Mecci"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A wildly entertaining live show that fuses hypnosis with master hypnotist Asad Mecci and improv comedy with legend Colin Mochrie, inviting audience volunteers to be hypnotized before joining professional improvisers on stage. Fast-paced, unpredictable and laugh-out-loud funny! \n\nHilarious. Unpredictable. Unlike anything you’ve ever seen."
      }
    ]
  },
