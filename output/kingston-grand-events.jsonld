  {
    "@id": "https://www.kingstongrand.ca/events/menopause-the-musical-2-2026",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Menopause The Musical 2"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "All aboard, sisters! The hysterical sequel to the smash-hit Menopause The Musical® is finally here! Five years after their chance encounter in a department store, we set sail with our beloved ladies for more high jinks on the high seas. Menopause The Musical 2: Cruising Through ‘The Change’® is a hilarious and heartfelt look at the joys of menopause and friendship — plus hot flashes, mood swings, and memory lapses! Join us on a trip of self-discovery, backed by a new soundtrack of toe-tapping parodied hits from the 70s, 80s and 90s."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/MTM_KIN_72DPI_1080x1920.jpg"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cashowing five dancing women in cruise outfits on a ship deck"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.cawith show title and Kingston date details.\" />"
      }
    ],
