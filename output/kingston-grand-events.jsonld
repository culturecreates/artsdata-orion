    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Dance Fitazzet presents their 43rd and jACkRO their 13th annual Dance/Acro Recital. “Where Do We Go From Here?”. Please join us as we perform to songs that have a Direction in the Title. Our students range in age from 2 to adult and will feature a variety of Tap, Jazz, Ballet, Acro, Hip Hop, Contemporary, Rhythm Tap and Musical Theatre."
      }
    ],
