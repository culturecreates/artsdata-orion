      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Take Me Home: Celebrating John Denver and Glen Campbell"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "\"Take Me Home: Celebrating John Denver & Glen Campbell\" is a heartfelt celebration of two legendary voices who shaped the sound of American music. \n\nBlending folk, country, and pop with unmatched sincerity, Glen Campbell and John Denver wrote songs that spoke to longing, hope, love, and the pull of home, music that still feels deeply personal decades later.\n\nThis concert invites audiences on a journey through timeless classics and treasured gems, including “Wichita Lineman,” “Rhinestone Cowboy,” “Take Me Home, Country Roads,” and “Annie’s Song.” "
      }
    ]
  },
