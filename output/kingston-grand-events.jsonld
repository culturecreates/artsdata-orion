      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Ballet Kelowna - Macbeth"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "This powerful full-length ballet adaptation of Shakespeare’s timeless tragedy is brought vividly to life through dynamic choreography, a haunting original score and striking multimedia visuals. This compelling production plunges into themes of ambition, power and corruption as dancers portray the doomed rise and fall of Macbeth and Lady Macbeth with dramatic intensity and expressive movement."
      }
    ],
    "https://ogp.me/ns#image": [
      {
