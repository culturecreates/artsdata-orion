      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "BORED TEACHERS: \"IS IT FRIDAY YET?!\" COMEDY TOUR"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "They’ve graded the papers, survived the staff meetings, and lost their last ounce of patience… and now they’re taking it out on stage! Bored Teachers is BACK with brand-new jokes, bigger laughs, and the most relatable teacher comedy you’ll ever hear. For nearly a decade, Bored Teachers has been the #1 voice of teacher humour—racking up over 1 billion views, amassing 10 million+ followers, and hosting the #1 teacher-comedy podcast on the planet."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/BoredTeachers_KING%2CON_1080x1350.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caKingston"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caThursday December 3"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca7:00 PM at Kingston Grand Theatre.\" />"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
