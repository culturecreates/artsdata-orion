  {
    "@id": "https://www.kingstongrand.ca/events/three-roads-home-featuring-stephen-fearing-james-keelaghan-and-irish-mythen",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "en",
        "@value": "Kingston Grand Theatre"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "en",
        "@value": "Three Roads Home featuring Stephen Fearing, James Keelaghan and Irish Mythen"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "​​Celebrating Irish heritage through the songs and stories of three Canadian folk legends Three Roads Home brings together three of Canada’s most beloved singer-songwriters — James Keelaghan, Irish Mythen and Stephen Fearing — for an unforgettable evening of songs, stories, and shared heritage. All three artists draw on deep Irish roots that continue to shape their music, storytelling, and sense of identity."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.ca/sites/kingstongrand.ca/files/img/event/hero/36%20-%20Three%20Roads%20Home.png"
      },
      {
        "@language": "en",
        "@value": "http://www.kingstongrand.caIrish Mythen and Stephen Fearing\" title=\"Three Roads Home\" /> Three Roads Home"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://www.kingstongrand.ca/events/three-roads-home-featuring-stephen-fearing-james-keelaghan-and-irish-mythen"
      }
    ]
  },
