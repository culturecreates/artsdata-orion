    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "LABOUR - Emily Gualtieri + David Albert-Toth"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A piece for five firebrand performers, LABOUR embraces a minimalist physicality. Raw, sweaty, visceral, and tinged with absurdity, it rejects any aesthetic politeness and imagines a shared power, both intimate and collective, rooted in a plurality of femme perspectives."
      }
    ],
    "http://schema.org/duration": [
      {
        "@language": "en",
        "@value": "T60M"
      }
    ],
