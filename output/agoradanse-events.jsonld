    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "LABOUR - Emily Gualtieri + David Albert-Toth"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pièce pour cinq interprètes puissantes, LABOUR embrasse une physicalité minimaliste. Brute, moite, viscérale, et teintée d’absurde, elle rejette toute politesse esthétique et imagine une puissance partagée, intime et collective, ancrée dans une pluralité d&rsquo;expériences féminines."
      }
    ],
    "http://schema.org/duration": [
      {
