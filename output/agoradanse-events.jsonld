    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Raw energy, spatial geometries, and electronic pulses. In the intimate setting of Agora de la danse, the Morin/Leroux duo delivers a physical performance in which five performers search for the tipping point between exhilaration and transcendence."
      }
