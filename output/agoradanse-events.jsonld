    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Presented in collaboration with Le Vivier as part of La Semaine du Neuf, a festival dedicated to new music, Holding Present brings together choreographer Ula Sickle and the Brussels-based contemporary music ensemble Ictus. Together, they create a performance where music and dance merge into a powerful collective gesture."
      }
