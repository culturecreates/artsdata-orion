      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après avoir choisi le temps et l&#039;espace comme matière à blague lors de ses deux premiers spectacles solo, Virginie Fortin flirte avec l&#039;idée les réalités alternatives et des mauvaises décisions qui donnent envie de retourner dans le passé et changer le cours de l&#039;histoire, dans ce troisième opus à la fois profond et léger, troublant et hilarant."
      }
    ]
  },
