    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Monsieur Crapulet, marchand avare et cupide, vend paisiblement ses légumes au marché, jusqu'au jour où le Docteur Alèse vient s'installer à côté de son…"
      }
