      {
        "@language": "fr",
        "@value": "DOMINIC PAQUET | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Après avoir vendu plus de 250 000 billets de son dernier spectacle, le populaire humoriste Dominic Paquet est de retour avec un tout nouveau one-man-show…"
