      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/cabaret-sweet-woman"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/cabaret-sweet-woman"
      }
    ],
    "http://schema.org/copyrightYear": [
      {
        "@language": "fr",
        "@value": "2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Créé par des femmes comme toi. Pour les femmes comme toi. Le Cabaret Sweet Woman, ce n'est pas un spectacle parfait. C'est un spectacle vrai. Ce sont des femmes qui travaillent fort, élèvent des enfants, gèrent mille responsabilités, traversent des tempêtes en silence. Des femmes qui doutent, qui sont fatiguées... mais qui continuent d'avancer. Et un jour, elles décident de monter sur scène. Pas pour être parfaites. Mais pour se rappeler qui elles sont profondément. Ici, on ne s'excuse pas d'être. Trop sensuelle. Trop ambitieuse. Trop intense. Trop lumineuse. On transforme nos insécurités en puissance, nos cicatrices en lumière, nos peurs en mouvement. Ce sont des femmes qui ont choisi de se choisir. Une fois par semaine. Toute l'année. Elles ont répété. Elles ont douté. Elles ont osé. Elles ont grandi. Et ce spectacle en est le résultat. La finalité. L'aboutissement d'une année de courage. Quand les lumières s'allument, ce que vous voyez sur scène... Ce n'est pas juste un show. C'est une transformation. Et qui sait.... peut-être que l'an prochain vous serez l'une des nôtres ?"
      }
    ],
