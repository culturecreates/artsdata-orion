    "http://ogp.me/ns#image:alt": [
      {
        "@language": "fr",
        "@value": "Le spectacle hommage à Jean-Pierre Ferland Le petit roi pour toujours sera présenté au Théâtre des Deux Rives de Saint-Jean-sur-Richelieu le 20 mars 2027."
      }
    ]
