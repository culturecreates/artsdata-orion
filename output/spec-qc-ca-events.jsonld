    "http://schema.org/image": [
      {
        "@id": "https://spec.qc.ca/uploads/fathern-son-horizontal-39f56420d9c6c4d7d0c1.jpeg"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
