    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La SPEC du Haut-Richelieu qui présente plus de 300 spectacles au Théâtre des Deux Rives, Cabaret-Théâtre du Vieux-Saint-Jean et 164 Lounge à Saint-Jean-sur-Richelieu, au Pôle culturel de Chambly et à Venise-en-Québec. Elle possède le service de billetterie vosbillets.ca"
      }
    ],
