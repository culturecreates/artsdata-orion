    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&#039;écluse À La Ferme"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L&#039;Ensemble vocal de l&#039;Écluse, sous la direction de Sylvie Payette, présente son tout nouveau spectacle: L&#039;Écluse à la ferme. Petites voix et Intermezzo se joignent aux adultes de l&#039;Écluse pour offrir un spectacle haut en couleurs! Les chansons seront belles et amusantes, les costumes et la mise en scène surprenants! Une soirée à ne pas manquer, assurément!"
      }
    ]
  },
