    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Jean-Michel Anctil n'avait pas envie d'un retour, mais de retrouvailles. C'est donc à l'occasion de ses 60 ans qu'il présentera un tout nouveau spectacle,…"
      }
    ],
