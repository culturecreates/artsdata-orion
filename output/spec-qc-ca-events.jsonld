    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Ce qui est extraordinaire avec les contes de fées, c'est qu'ils sont des miroirs de leur époque : ils révèlent les peurs, les élans du cœur et les règles…"
      }
    ],
