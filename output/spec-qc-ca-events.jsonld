    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Gabrielle Caron"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "18 ans et +\n\nGabrielle Caron est à la barre de ce spectacle d&#039;humour à saveur parentale. Inspiré par\nle balado qui parle d&#039;accouchement, ici on plonge tête première dans la parentalité.\nSans censure, sans tabou et sans gêne. Franche et décomplexée, avec mille anecdotes\nen poche, Gabrielle adore sa vie de famille. Mais surtout elle sait en rire!\n\nTrouvez-vous une gardienne et venez passer une soirée mémorable! (Promis, ça ne\nfinira pas trop tard, on doit se lever tôt demain matin pour aller au cours de piscine!)"
      }
    ]
  },
