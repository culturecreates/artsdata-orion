      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Grazia"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nÀ quelques mois de la fin de son mandat, le président italien Mariano De Santis doit évaluer les dossiers de deux prisonniers susceptibles d&#039;être graciés : une femme ayant tué son mari violent et un professeur ayant mis fin aux jours de son épouse atteinte d&#039;Alzheimer. Entre audiences privées avec le pape et conseils de sa fille avocate, qui lui demande aussi de signer une loi sur l&#039;aide médicale à mourir, De Santis questionne le sens de son pouvoir, l&#039;éthique et sa propre existence. Film présenté en version originale en italien avec sous-titres en français.\n\n\nDrame de Paolo Sorrentino. Avec : Toni Servillo, Anna Ferzetti, Orlando Cinque, Massimo Venturiello, Milvia Marigliano. Italie. 2025. 2 h 13. (G)."
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/2d10c03b-a45d-45f2-a889-940e4ea9d19c",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-09T19:30:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
