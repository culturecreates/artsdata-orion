      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/la-grande-dictee-richelieu-2026"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/la-grande-dictee-richelieu-2026"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Grande Dictée Richelieu 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nPour une 34e édition, la Dictée annuelle se tiendra le mercredi 18 mars prochain. L&#039;auteure de la dictée 2026 est Virginie Roy et l&#039;artiste invité durant la correction est Thomas Hodgson. L&#039;an dernier, nous avons ajouté et initié le volet grand public à cette activité jusque-là réservée aux élèves de 3e à 5e secondaires de la région. C&#039;est pourquoi nous entendons dorénavant nommer La Grande Dictée Richelieu. Les élèves, inscrits par leur enseignant, reçoivent des bourses. Les citoyens sont invités à participer pour le plaisir et des prix de participation seront tirés. L&#039;inscription à la dictée est gratuite, mais si les adultes veulent souper durant la correction et le spectacle, il en coûtera 22$."
      }
    ]
  },
