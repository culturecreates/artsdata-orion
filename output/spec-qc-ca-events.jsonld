    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les Sacoches S&#039;a Poud"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nFrance D&#039;Amour et Geneviève Gagnon, deux belles sacoches sur le kombucha qui rient fort et qui parlent fort mais tellement attachantes animent un podcast devant public avec un invité mystère qui jasent ensemble d&#039;anecdotes croustillantes de coulisses dans une ambiance tout en humour! \n\nUn invité mystère dans chaque épisode — exclusivité à découvrir !"
      }
    ]
  },
