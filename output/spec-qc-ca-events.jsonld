    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Né à Toronto en 1932, Glenn Gould demeure l'une des figures mythiques de la musique classique et l'un des pianistes les plus fascinants du XXe siècle. À…"
      }
    ],
    "http://ogp.me/ns#image": [
