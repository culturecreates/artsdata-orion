    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/angel-forrest"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Angel Forrest"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Angel Forrest célèbre les 20 ans de son album Here for You avec une tournée anniversaire attendue. Sa voix puissante, marquée par une carrière foisonnante, livre le blues avec une intensité brute et des nuances infinies. Rare sur nos scènes depuis son départ vers la Colombie-Britannique, elle offre un retour généreux et passionné. Entre nostalgie et nouveauté, ce concert promet des moments d&#039;émotion vive et de communion. Pour les amateurs de blues, c&#039;est un rendez-vous incontournable."
      }
    ]
  },
