    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Mi-cuit, c'est mon spectacle... presque prêt! Idéal si vous avez envie de rire et si vous souhaitez secrètement qu'une trentenaire qui ne sait pas…"
      }
    ],
