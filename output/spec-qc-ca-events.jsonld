    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Spectacle Bénéfice Au Profit De La Fondation Jeunes En Tête"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nPréparez-vous à vivre un moment mémorable au profit de la Fondation Jeunes en tête. Le groupe johannais Five Past Dawn vous invite à une soirée riche en émotions, animée avec brio par Marianne Paquin. Vous aurez l&#039;occasion de découvrir deux artistes de la région : l&#039;humoriste Alexis Fortin et le DJ Antonin Prinz. La soirée se terminera en beauté avec une prestation du groupe hôte."
      }
    ]
  },
