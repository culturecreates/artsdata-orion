      }
    ],
    "http://schema.org/publisher": [
      {
        "@id": "https://spec.qc.ca/programmation/pierre-lapointe#creator"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/pierre-lapointe"
