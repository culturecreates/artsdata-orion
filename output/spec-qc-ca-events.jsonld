    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/atelier-lyrique-de-chambly"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/atelier-lyrique-de-chambly"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Atelier Lyrique De Chambly"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nEmma-Albani est l&#039;une des sopranos les plus célèbres du XIXe siècle et du début du XXe siècle. Cette enfant de Chambly quitte son village natal pour conquérir la gloire sur les plus grandes scènes lyriques du monde. Elle est la première cantatrice québécoise et canadienne à devenir une célébrité internationale.\n\nLe concert-spectacle « Emma-Albani et compagnie » nous fait voyager au travers des événements lyriques marquants de sa carrière, en compagnie des chanteuses et chanteurs qui ont partagé la scène avec elle. "
      }
    ]
  },
