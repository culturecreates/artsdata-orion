    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Manman la mer  raconte l'histoire de Marjolaine, née avec la faculté troublante de connaître l'avenir. Forcée par sa mère à taire cette clairvoyance,…"
      }
