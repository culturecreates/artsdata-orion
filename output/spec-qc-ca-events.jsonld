    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Mon nouveau show s'appelle OUVERT. Bien que je sois habituellement pudique sur ma vie privée, je m'ouvre comme jamaisdans ce spectacle!  Et aussi, quand…"
