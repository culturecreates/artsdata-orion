    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Nirvana Jazz"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "PRÉSENTÉ DANS LE CADRE DU FESTIVAL QUINZAINE JAZZ 2026\n\nPlongez dans Nirvana Jazz, une relecture intense et envoûtante de Nirvana par Guillaume Martineau. Entre tension, liberté et improvisations habitées, le quartet fusionne l&#039;énergie grunge et la richesse du jazz. Un spectacle puissant et raffiné où les classiques renaissent avec une nouvelle profondeur."
      }
    ]
  },
