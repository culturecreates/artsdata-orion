    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Stéphanie Bédard"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nAu fil de la vie de Stéphanie Bédard, les chansons de Céline Dion ont accompagné son évolution en tant que femme. À chaque peine, à chaque pas, à chaque moment de croissance, ces chansons étaient là, proches de son oreille et de son coeur. Pour elle, ces chansons lumineuses et bienveillantes viennent rappeler combien il est essentiel, aujourd&#039;hui plus que jamais, de parler d&#039;amour sous toutes ses formes."
      }
    ]
  },
