        "@id": "https://spec.qc.ca/programmation/olivier-martineau#creator"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/olivier-martineau"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/olivier-martineau"
      }
    ],
    "http://schema.org/copyrightYear": [
      {
        "@language": "fr",
        "@value": "2025"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Société, c'est fini. Oui, on a eu de beaux moments, mais là, c'est trop. T'as changé. Moi, je m'en vais. Je te laisse tes règles farfelues et tes promesses en plastique. J'en ai assez de cette mascarade. C'EST PAS MOI, C'EST TOI, c'est du stand-up pur et dur, un véritable feu roulant de gags où chaque punch frappe en plein cœur. Un regard sans filtre, mordant, mais surtout hilarant, sur une société où la rupture était inévitable. Après trois spectacles, celui-ci est le plus audacieux, le plus osé, le plus authentique. Bref, c'est la fin d'une histoire... et le début d'un show qui décoiffe. Mais moi, je m'en fous, j'ai pas de cheveux."
      }
    ],
    "http://schema.org/headline": [
      {
        "@language": "fr",
        "@value": "OLIVIER MARTINEAU | SPEC du Haut-Richelieu"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr-ca"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "OLIVIER MARTINEAU | SPEC du Haut-Richelieu"
      }
    ]
  },
