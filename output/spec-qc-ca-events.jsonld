  {
    "@id": "https://spec.qc.ca/temporary/882127bc-f194-4465-8f4d-01e487c18d48",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-07-04T19:30:00"
      }
    ],
    "http://schema.org/endDate": [
      {
