    "http://schema.org/offers": [
      {
        "@id": "https://spec.qc.ca/genid/eb6c2793bdf8a3f3"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/yves-lambert"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/yves-lambert"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Yves Lambert"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour souligner ses 50 ans de carrière, Yves Lambert vous offre un spectacle généreux et festif qui explore son grand répertoire bâti depuis ses tout débuts avec la Bottine Souriante jusqu&#039;à aujourd&#039;hui. Amoureux de l&#039;harmonie, de la musicalité, peu importe le style de musique, Yves Lambert s&#039;entoure du Grand Orchestre composé de sept musiciennes et musiciens virtuoses. Avec une orchestration qui tend vers de nouvelles avenues harmoniques et rythmiques, Yves Lambert présente ses titres les plus connus, tels que La ziguezon, La cuisinière et Dans nos vieilles maisons, ainsi que plusieurs chansons qui ont façonné son parcours empreint de textures sonores affirmant toujours sa « québécitude » passionnée, ouverte et créative ! Venez célébrer ces grands classiques de chez nous !"
      }
    ]
  },
