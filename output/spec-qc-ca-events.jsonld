    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Christophe Dupéré"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "18 ans et +\n\nÇa y est! Christophe Dupéré travaille pour ENFIN vous présenter son premier vrai one-man-show! Un rêve devenu réalité! Sauf qu&#039;avant de le présenter dans des grandes salles avec du linge chic et propre, il doit l&#039;écrire dans des plus petites salles dans du linge propre, mais moins chic. Pour ce faire, il a besoin de vous. Ce rodage est un tout nouveau show où Christophe aborde des anecdotes familiales et sportives. Un spectacle pour vous permettre de voir la vie comme il la voit, avec ses yeux d&#039;anxieux.  "
      }
    ]
  },
