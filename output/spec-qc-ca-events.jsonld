        "@id": "https://spec.qc.ca/uploads/guy-nantel-horizontal-7b949ab1fa968e0a2736.jpeg"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1556200"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
