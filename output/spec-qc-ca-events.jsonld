      {
        "@id": "_:g674240"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/michel-rivard"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/michel-rivard"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Michel Rivard"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nDurant les deux semaines (symboliques) que dure la floraison spectaculaire du magnolia devant sa fenêtre, « l&#039;homme qui me ressemble » - 74 ans - s&#039;interroge sur sa vie, avant et après la mort. Il confronte ses doutes, ses certitudes. Entre un rendez-vous médical et le choix d&#039;une urne dans un catalogue, entre un premier amour et une marche en forêt avec son petit-fils de sept ans, il monologue, rêve à voix haute et chante sa quête du « plus-grand-que-soi ». Un spectacle d&#039;une douce beauté, écrit et interprété par Michel Rivard, dans une mise en scène sensible de Marie-Thérèse Fortin. Avec la complicité des talentueux musiciens François Richard, Blanche Baillargeon et Guillaume Bourque."
      }
    ]
  },
