    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "BRUNO PELLETIER | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Bruno Pelletier, l'un des chanteurs les plus appréciés de la francophonie, revient sur scène avec une nouvelle tournée intitulée « 3 et moi ». Ce…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://spec.qc.ca/uploads/_1200x630_crop_center-center_82_none/bruno-pelletier-horizontal-8f84f3f23d641e5118a6.jpeg?mtime=1762546481"
