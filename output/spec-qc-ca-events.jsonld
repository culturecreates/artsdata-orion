      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/tommy-neron"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/tommy-neron"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tommy Néron"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fallait décrire mon show en quelques lignes pis j&#039;ai décidé de ne pas laisser l&#039;assistante du bureau le faire, ce qui explique pourquoi tu n&#039;as pas encore vu les termes Star du web ou encore Vedette sur les réseaux sociaux. Ces termes-là, c&#039;est comme le mot Flamboyant, Y&#039;a pas un humoriste qui se décrit lui-même comme flamboyant. Mon spectacle, c&#039;est un gros mélange d&#039;observations et d&#039;anecdotes sur mon passé qui, avec le recul, n&#039;était pas exactement comme tout le monde. Pour le show, j&#039;ai la chance d&#039;être entouré de la brillante Korine Côté pour la script-édition et du talentueux Laurent Paquin à la mise en scène. Le titre aurait pu être Flamboyant mais j&#039;ai choisi Les fleurs poussent encore... Tu vas comprendre pourquoi en voyant le spectacle !\n\nEnvie d&#039;en connaître davantage sur le spectacle de Tommy Néron? Lisez l&#039;entrevue avec l&#039;artiste publiée dans le magazine l&#039;Entracte en cliquant ici. "
      }
    ]
  },
