    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/la-femme-la-plus-riche-du-monde"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Femme La Plus Riche Du Monde"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nLa femme la plus riche du monde : sa beauté, son intelligence, son pouvoir. Pierre-Alain Fantin, photographe flamboyant, incarne l&#039;ambition, l&#039;insolence et la folie. Leur coup de foudre improbable les emporte, bouleversant familles et secrets bien gardés. Marianne Ferrer, héritière méfiante, lutte pour être aimée tandis que son majordome observe, conscient de tout. Entre donations astronomiques, manipulations audacieuses et rivalités familiales, s&#039;ouvre une guerre où tous les coups sont permis, portée par un humour féroce et jubilatoire qui dévoile les excès du monde des ultra-riches.\n\n\nComédie dramatique de Thierry Klifa. Avec : Isabelle Huppert, Laurent Lafitte, Marina Foïs, Raphaël Personnaz, André Marcon. France (Belgique). 2025. 2 h 01. (G)."
      }
    ]
  },
