    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/pierre-lapointe"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/pierre-lapointe"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Pierre Lapointe"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " Le nouveau spectacle de Pierre Lapointe, Chansons démodées pour ceux qui ont le cœur abimé, promet une magnifique soirée. Sur scène, pour accompagner les pièces de son dernier album, l&#039;artiste a créé un univers envoutant où se mêlent décor déroutant et arrangements soignés. Pierre Lapointe explore un répertoire aussi contemporain qu&#039;intemporel, inspiré par les grands noms de la chanson francophone comme Léveillée, Barbara, Aznavour et Brel. Accompagné du duo Fortin-Poirier, avec des arrangements épurés par Amélie Fortin, aussi au piano, parfois à quatre mains, Pierre Lapointe revisite des chansons dans une forme plus intime. Ce choix audacieux met en lumière la virtuosité et la rigueur artistique qui caractérisent son œuvre. Ne manquez pas cette occasion de découvrir ou redécouvrir l&#039;un des chanteurs les plus fascinants de sa génération."
      }
    ]
  },
