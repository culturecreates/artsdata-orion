    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté dans le cadre du Festival d&#039;humour en Montérégie\nPantelis est un humoriste Gréco-Québécois qui se représente en français et en anglais partout au Canada et aux États-Unis. Il est également l&#039;un des pionniers du podcasting canadien. Nous sommes heureux de l&#039;accueillir avec son célèbre Podcast Le Frenchcast"
      }
    ]
  },
