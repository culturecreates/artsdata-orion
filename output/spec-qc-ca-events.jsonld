    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/conference-alexandre-belliard"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/conference-alexandre-belliard"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alexandre Belliard"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le 31 mai prochain, prenez part à un café-causerie avec Alexandre Belliard à l&#039;Espace Desjardins de 13h00 à 14h30.\n\nDans une ambiance chaleureuse et décontractée, venez prendre un café avec l&#039;artiste et discuter librement d&#039;art, de création, de démarche artistique et des histoires qui inspirent son travail.\n\nEntre anecdotes, réflexions et échanges spontanés, cette rencontre propose un moment simple et humain pour parler de ce qui nourrit l&#039;inspiration, fait naître les œuvres et donne envie de raconter des histoires.\n\n\nUne belle occasion de partager un moment inspirant avec un artiste accessible, authentique et assurément passionné."
      }
    ]
  },
