    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Quand le soleil descend sur le Richelieu et que les terrasses du Vieux s'animent, la Place publique se transforme en piste de danse à ciel ouvert. Tous…"
      }
    ],
