      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Vivre un épuisement professionnel, c'est aussi vivre une recharge professionnelle. Autrement dit : travailler mon deuxième one-man-show de façon encore…"
      }
    ],
