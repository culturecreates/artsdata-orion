    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Rémi Bolduc"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "PRÉSENTÉ PAR LA SPEC DU HAUT-RICHELIEUDANS LE CADRE DU FESTIVAL QUINZAINE JAZZ 2026\n\nÀ l&#039;occasion de ce spectacle, le saxophoniste virtuose Rémi Bolduc et ses musiciens aguerris rendent hommage aux grands musiciens de jazz de notre époque : Dave Brubeck, Oscar Peterson, Miles Davis, Charlie Parker et quelques autres. Tous ces acteurs de l&#039;univers du jazz vous attendent pour une soirée exceptionnelle. Une unique et fort agréable rencontre avec la « blue note » !"
      }
    ]
  },
