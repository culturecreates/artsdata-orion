      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Michelle Desrochers"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nMi-cuit, c&#039;est mon spectacle... presque prêt!\nIdéal si vous avez envie de rire et si vous souhaitez secrètement qu&#039;une trentenaire qui ne sait pas cuisiner vous donne la recette du bonheur.\n\nMi-cuit, c&#039;est une liste d&#039;ingrédients et beaucoup de bonne volonté, mais ce n&#039;est pas tout à fait terminé. Comme le mot « rodage » a perdu tout son sens, je vous ai préparé cet humble petit gâteau. Je vous promets une soirée qui fait autant de bien que d&#039;éteindre la hotte du four après une longue recette!"
      }
    ]
  },
