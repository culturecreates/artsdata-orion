    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "ALEXANDRE CADIEUX | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Comment le théâtre québécois a-t-il trouvé sa voix ? Parcourez 70 ans de dramaturgie québécoise, à travers ses thèmes, ses figures et ses formes. À partir…"
      }
    ],
