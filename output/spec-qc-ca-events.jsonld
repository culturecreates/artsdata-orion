      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/marc-dery-2"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/marc-dery-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Marc Déry"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " Marc Déry incarne une liberté créative sans précédent. Une contrebassiste et un percussionniste accompagneront Marc sur scène et cet essai artistique a pour but d&#039;inviter le spectateur dans l&#039;intimité du mélomane et de vous donner accès à un moment musical de haute qualité. La spontanéité et l&#039;imprévue résument le spectacle, tout en restant fidèles à ce qui nous hypnotise déjà depuis plus de 20 ans.\nHabile mélodiste doté d&#039;un formidable sens du groove, Marc Déry contemple le monde qui l&#039;entoure et plonge en lui-même, livrant ses observations dans la langue vivante et truffée d&#039;images qu&#039;on lui connaît. Cet artiste chevronné choisit cette fois de placer la voix au premier plan sur un fond d&#039;expérimentations sonores avec échantillonnages tripatifs, des orchestrations à vapeur et une touche de folk, pour créer une atmosphère de douce mélancolie."
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/0febbd16-7446-4064-9b9c-0c614ffdce21",
    "@type": [
      "http://schema.org/WebPage"
    ],
    "http://schema.org/author": [
      {
