    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "P-A MÉTHOT | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Le seul et unique P-A Méthot est enfin de retour sur scène avec un nouveau spectacle intitulé Pardon?! . Raconteur authentique et rassembleur, P-A sait…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://spec.qc.ca/uploads/_1200x630_crop_center-center_82_none/p-a-méthot-horizontal-b1db460ada7d32a73a11.jpeg?mtime=1764090043"
