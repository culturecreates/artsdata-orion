    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/aureo-et-lunette"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/aureo-et-lunette"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Auréo Et Lunette"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nMonsieur Crapulet, marchand avare et cupide, vend paisiblement ses légumes au marché, jusqu&#039;au jour où le Docteur Alèse vient s&#039;installer à côté de son kiosque pour y vendre ses « boissons énergisantes ». Alarmé à la perspective de sa ruine, monsieur Crapulet cherche, par tous les moyens, à se débarrasser de ce nouvel arrivant. Jusqu&#039;où ira-t-il? Inconscient de cette menace, le Docteur Alèse espère trouver en ces lieux nouveaux les solutions à ses propres soucis. Auréo, son fils, aimerait bien l&#039;aider lorsqu&#039;il croise le chemin de l&#039;étonnante Lunette, fille de Crapulet, qui rompt brusquement sa solitude. Les deux enfants arriveront-ils à réconcilier leurs parents rivaux ?\n\nCe projet est une présentation de la Ville de Chambly."
      }
    ]
  },
