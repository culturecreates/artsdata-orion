    "http://schema.org/image": [
      {
        "@id": "https://spec.qc.ca/uploads/en-qu%C3%AAte-de-votre-argent-horizontal-e74fe960da1cad6e2cdd.jpeg"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/en-quete-de-votre-argent"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/en-quete-de-votre-argent"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "En Quête De Votre Argent"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nCette pièce de théâtre a pour objectif d&#039;apprendre aux personnes aînées et à leur entourage à détecter les arnaques financières et faire connaitre les différents stratagèmes employés par les fraudeurs. Elle traite des quatre types des fraudes dont les aîné(e)s sont le plus victimes : faux représentant, amoureuse, maltraitance et grands-parents. La pièce sera accompagnée d&#039;intervention des agent(e)s sociocommunautaires de la Régie intermunicipale de police Richelieu-Saint-Laurent. Cette initiative est mise en place par les partenaires de la Table des aînés du Bassin de Chambly!\n \n\nCe projet est une présentation de la Ville de Chambly."
      }
    ]
  },
  {
