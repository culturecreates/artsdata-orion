    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le Show De L&#039;espoir"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nVenez passer un bon moment en compagnie du groupe musicale SYNERGIE 16 avec un répertoire allant des chansons des années 50 à aujourd&#039;hui ! \n\nSur scène, 16 musiciens, chanteurs et chanteuses vous feront vibrer au rythme des grands classiques et des succès actuels. \n\nEn plus de vous divertir, cet événement est présenté  au profit de la Société Canadienne du Cancer. Une belle occasion de joindre l&#039;utile à l&#039;agréable !"
      }
    ]
  },
