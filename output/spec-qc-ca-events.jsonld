      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "MINIME RENCONTRE LES GRANDS COMPOSITEURS | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Minime est une petite souris gourmande de fromage et follement éprise de musique. Ce soir, un matou menaçant aux trousses, sa mission la mènera de Venise…"
      }
    ],
    "http://ogp.me/ns#image": [
