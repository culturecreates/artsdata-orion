    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Cette voix se veut un témoignage d'affection de Dan Bigras envers son ami, mais aussi monument de la musique au Québec : Gerry Boulet. Dans ce spectacle,…"
      }
    ],
    "http://ogp.me/ns#image": [
