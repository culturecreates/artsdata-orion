    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "La réputation de Vincent Vallières n'est plus à faire. Depuis 1996, l'auteur-compositeur-interprète taille sa place dans les radios avec des chansons…"
      }
    ],
