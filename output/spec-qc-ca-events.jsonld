    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Auditions Du Gala Ma Première Scène De Festival"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nNe manquez pas l&#039;occasion de découvrir de nouveaux talents lors de nos auditions d&#039;humour pour le Gala « Ma Première scène de festival » lors du Festival d&#039;humour en Montérégie le 12 juillet 2026!\nPréparez-vous à vivre une soirée mémorable et à encourager les talents de demain. On vous attend nombreux pour partager cette expérience \n"
      }
    ]
  },
