      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/guy-nantel"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Guy Nantel"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Alors que l&#039;actualité regorge de sujets explosifs, d&#039;opinions tranchées et de\ncontradictions bien de chez nous, l&#039;humoriste Guy Nantel revient avec un tout\nnouveau spectacle au titre pour le moins intrigant : Bienveillant.\n\nOui, vous avez bien lu. BIENVEILLANT. Le mot qu&#039;on associe le moins\nspontanément à un humoriste reconnu pour son franc-parler, son regard critique\net son humour sociopolitique sans compromis. Disons que le titre donne le ton!\nDepuis toujours, Nantel est cette voix différente qui ose dire tout haut ce que tout\nle monde pense tout bas. Avec sa lucidité mordante et son ironie bien placée, il\nmet le doigt sur nos travers collectifs, nos incohérences et nos grands débats\nd&#039;époque, tout ça au grand plaisir du public. Avec ce 7e spectacle en carrière, Guy\nNantel continue de faire ce qu&#039;il fait le mieux : nous dérouter, nous désarmer et\nsurtout nous faire rire à gorge déployée!\n\nMais la question demeure : comment s&#039;y prend-il pour le faire avec bienveillance?\nOn ne demande qu&#039;à voir... mais surtout à entendre. Avouez que ça promet!"
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/215738ed-e1a8-494d-bc16-aeb038009b7e",
