    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Daniel Lemire Et Denis Bouchard"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Grands amis dans la vie, Daniel Lemire et Denis Bouchard unissent enfin leurs talents dans un tout nouveau spectacle d&#039;humour où ils racontent leurs meilleures histoires de voyage. Entre fous rires et confidences, le duo revisite ses périples les plus cocasses, ses imprévus de tournée et ses rencontres inoubliables. Une soirée pleine d&#039;esprit, de complicité et d&#039;autodérision, où les deux comparses nous entraînent dans leur univers aussi drôle qu&#039;humain."
      }
    ]
  },
