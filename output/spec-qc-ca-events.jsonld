    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://spec.qc.ca/uploads/trio-bellini-horizontal-2de0cae12d51d071806c.jpeg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=lhqN-grXow0"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
