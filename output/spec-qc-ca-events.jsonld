    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "18 ans et + \n\nJesse Proteau est un auteur-compositeur-interprète multidisciplinaire que l&#039;on a pu découvrir d&#039;abord comme finaliste de la 6e édition de la populaire émission La Voix. Il marquera ensuite le paysage musical québécois sous le pseudonyme ZAGATA, et cumulera les succès radiophoniques."
      }
    ]
  },
