      }
    ],
    "http://schema.org/copyrightYear": [
      {
        "@language": "fr",
        "@value": "2025"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Patrick Groulx revient avec un cinquième one-man-show, nourri de toute l'expérience et de la tendresse qu'il partage avec son public depuis plus de 25 ans. Toujours aussi spontané et attachant, il transforme ses anecdotes en moments hilarants et rassembleurs. Son humour accessible, son sens de la proximité et son charisme naturel font de chaque spectacle une rencontre chaleureuse. Sa nouvelle création promet autant de surprises que de fous rires, dans un esprit de complicité unique."
      }
    ],
    "http://schema.org/headline": [
