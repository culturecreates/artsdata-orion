    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Au cours d'une représentation théâtrale, un acteur s'écroule sur scène. La thèse de l'accident étant très vite écartée, il faut se rendre à l'évidence :…"
