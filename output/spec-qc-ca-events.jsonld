  {
    "@id": "https://spec.qc.ca/temporary/18490345-d3dc-4f9c-934b-10dbf45dd39e",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-09-25T20:00:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
