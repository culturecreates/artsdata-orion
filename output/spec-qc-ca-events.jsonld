    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/ecole-de-musique-jocelyne-laberge"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "École De Musique Jocelyne Laberge"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nFréquentée par plus de 300 élèves, l&#039;école de musique Jocelyne Laberge présentera cinq concerts différents durant la fin de semaine du 6 et 7 juin 2026. Les élèves de différents niveaux présenteront au public un répertoire très varié autant en musique classique que populaire.  Chanteurs, pianistes, batteurs, guitaristes, bassistes, flûtistes, violonistes, violoncellistes, clarinettistes et saxophonistes ainsi que diverses formations tels que duos, trios, quatuors, ensembles vocaux et combos occuperont la scène tout au long de cette captivante fin de semaine toute en musique !"
      }
    ]
  },
