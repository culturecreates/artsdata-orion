    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/wooden-shapes"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/wooden-shapes"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Wooden Shapes"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le spectacle qui a conquis le public est de retour! Après une tournée remarquée au Québec et à l&#039;international, Wooden Shapes revient avec un tout nouveau concert encore plus audacieux. Plongez dans les plus grands classiques du rock — Metallica, Harmonium, Guns N&#039; Roses, David Bowie et bien d&#039;autres — réinventés et joués exclusivement sur des instruments à cordes. Formé d&#039;étudiants du Conservatoire de musique de Trois-Rivières et de Québec, le sextuor marie virtuosité classique et énergie rock pour créer un univers sonore unique. Avec des arrangements grandioses et une intensité électrisante, Wooden Shapes ne cherche pas à imiter : il réinvente. Une célébration vibrante du rock, qui frappe droit au cœur."
      }
    ]
  },
