    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "PRÉSENTÉ DANS LE CADRE DU FESTIVAL QUINZAINE JAZZ 2026  Plongez dans Nirvana Jazz, une relecture intense et envoûtante de Nirvana par Guillaume Martineau.…"
      }
    ],
    "http://ogp.me/ns#image": [
