    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Patrick Groulx"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Patrick Groulx revient avec un cinquième one-man-show, nourri de toute l&#039;expérience et de la tendresse qu&#039;il partage avec son public depuis plus de 25 ans. Toujours aussi spontané et attachant, il transforme ses anecdotes en moments hilarants et rassembleurs. Son humour accessible, son sens de la proximité et son charisme naturel font de chaque spectacle une rencontre chaleureuse. Sa nouvelle création promet autant de surprises que de fous rires, dans un esprit de complicité unique."
      }
    ]
  },
