    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Venez passer un bon moment en compagnie du groupe musicale SYNERGIE 16 avec un répertoire allant des chansons des années 50 à aujourd'hui !  Sur scène, 16 musiciens, chanteurs et chanteuses vous feront vibrer au rythme des grands classiques et des succès actuels.  En plus de vous divertir, cet événement est présenté  au profit de la Société Canadienne du Cancer . Une belle occasion de joindre l'utile à l'agréable !"
      }
    ],
