    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/broue"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/broue"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Broue"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Depuis la toute première représentation qui a eu lieu le mercredi 21 mars 1979 l&#039;histoire d&#039;amour entre le public québécois et Broue aura duré presque 39 ans sans interruption.\n\nCette pièce de théâtre a dépassé depuis longtemps le simple statut de divertissement et de comédie pour devenir un véritable objet de fierté nationale.\n\nCar Broue a fracassé de nombreux records.\n\nSes personnages hauts en couleurs font partis de notre imaginaire collectif, dans un portrait d&#039;un Québec pré-référendaire, à la veille d&#039;une invasion qui menacent leur aire protégée : l&#039;arrivée des femmes dans ce lieu sacro-saint qu&#039;est... la Taverne !\n\nBob, Pointu, Verrue, Travolta et tous les autres continueront de vivre et de vous faire rire.\n\nNous vous invitons donc cher public à poursuivre l&#039;aventure avec nous. Vous êtes tous cordialement invités à venir ou revenir lever votre verre à la Taverne chez Willy !\n\nEt... Bienvenue aux dames !!!\n\nLa Nouvelle administration : Benoît Brière, Luc Guérin et Martin Drainville"
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/d2dca27d-58d1-47bc-87be-a10abd13d35f",
    "@type": [
