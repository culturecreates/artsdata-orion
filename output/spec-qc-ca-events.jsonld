    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Hommage À Cohen"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle sur scène et projections immersives\n\nDans la foulée du dixième anniversaire du décès de Leonard Cohen, redécouvrez une nouvelle mouture bonifiée de notre spectacle immersif présenté au cœur de la cathédrale. Musique, poésie et images monumentales s&#039;unissent pour offrir une expérience encore plus enveloppante. L&#039;interprétation sensible de Thomas Hodgson magnifie l&#039;œuvre de Cohen dans une soirée d&#039;une rare intensité."
      }
    ]
  },
