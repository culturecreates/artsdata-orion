    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Christine Morency"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " \nC&#039;est reparti pour une deuxième tournée! Après avoir conquis plus de 200 000 spectateurs avec Grâce, un premier one-woman-show certifié Double Platine, Christine Morency revient sur scène pour partager ses histoires les plus intimes et vous montrer à quel point elle est BIEN FAITE ! Bien faite physiquement (évidemment!), bien faite par les valeurs qui lui ont été transmises, mais surtout bien faite dans sa capacité à en rire plutôt qu&#039;à en pleurer. As-tu tes billets pour le show de Christine Morency? Oui? T&#039;AS BIEN FAITE!"
      }
    ]
  },
