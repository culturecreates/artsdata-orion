    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/lheritage-britanique"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/lheritage-britanique"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&#039;héritage Britannique"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après le succès remarqué de &#039;Fiori-Séguin &amp;amp; Cie&#039;, Mathieu Grégoire revient avec &#039;L&#039;Héritage Britannique - The Jukebox&#039;. Ce spectacle électrisant vous plonge au cœur de 50 ans de rock et de pop anglaise, revisités avec fougue et précision par cinq musiciens chevronnés.\n\nDes Beatles à Bowie, de Queen aux Rolling Stones, en passant par des medleys irrésistibles qui font chanter et danser toutes les générations, Mathieu Grégoire vous invite dans une véritable machine à remonter le temps musicale. Porté par une mise en scène immersive, un son puissant et une énergie contagieuse, &#039;The Jukebox&#039; promet une soirée festive, nostalgique et rassembleuse — dans la lignée du succès de son précédent spectacle.\n\n\n\n* Pour profiter de la promotion 20%, ajoutez tous les spectacles au panier et le tarif s&#039;ajustera automatiquement."
      }
    ]
  },
