      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://spec.qc.ca/genid/3ff0455b0e6b3f36"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spec.qc.ca/uploads/sinem-kara-horizontal-b66cea226f0856f34bc4.jpeg"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://spec.qc.ca/genid/58ee59073915cfb9"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/sinem-kara"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/sinem-kara"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Sinem Kara"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Sinem Kara monte sur scène avec une énergie contagieuse. D&#039;origine turque et née au Québec, elle porte un regard à la fois tendre et piquant sur nos habitudes, nos contradictions et nos petites manies — un regard qui mélange deux cultures avec la finesse d&#039;un trait d&#039;humour bien placé. \n\nAttendez-vous à des anecdotes du quotidien revisitée à la manière Sinem, la famille, la langue, les repas qui durent des heures, les malentendus et ces petites situations qui prennent une dimension universelle quand elle les raconte. \n\nSon ton est chaleureux, souvent autodérisoire toujours proche du public. \n\nVenez pour rire, mais aussi pour voir l&#039;œuvre naître, vos réactions comptent, vos rires aident à sculpter le spectacle. C&#039;est une expérience intime et généreuse, parfaite pour celles et ceux qui aiment l&#039;humour en devenir et le regard neuf d&#039;une artiste qui observe le monde et nous le rend plus drôle."
      }
    ]
  },
