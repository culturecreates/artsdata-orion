    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Après avoir marqué la francophonie avec son humour culte, François Pérusse signe sa première pièce de théâtre. Boulevard Pérusse met en scène une famille…"
      }
    ],
