    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/kevin-parent"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Kevin Parent"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "En toute simplicité, seul avec sa guitare, Kevin Parent nous replonge dans l&#039;univers de Pigeon d&#039;argile comme si c&#039;était hier. Sorti en 1995, ce premier album est rapidement devenu un classique, propulsant l&#039;artiste au sommet des palmarès et franchissant le cap des 375 000 exemplaires vendus. Pour célébrer les 30 ans de ce disque marquant, il revisite ses chansons avec une intensité renouvelée, offrant un moment intime, vrai et chaleureux. Une soirée complice où la proximité avec l&#039;artiste est au cœur de l&#039;expérience."
      }
    ]
  },
