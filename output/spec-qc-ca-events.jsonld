    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ludovick Bourgeois"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Soutenu par un univers visuel éclaté et une mise en scène signée Sylvain Cossette, Karaoké 90 se déploie en trois tableaux : les hits québécois, ceux des BB et les mégatubes mondiaux. De Nirvana à Céline Dion, en passant par U2, Bon Jovi et Mario Pelchat, Ludovick Bourgeois nous entraîne dans une véritable célébration musicale des années 90. Un moment de nostalgie et de plaisir partagé, où chaque soir un spectateur montera sur scène pour chanter aux côtés de l&#039;artiste dans une ambiance survoltée !"
      }
    ]
  },
