    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/mehdi-bousaidan"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/mehdi-bousaidan"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Mehdi Bousaidan"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " Dans son tout nouveau spectacle, Mehdi Bousaidan se dévoile comme jamais. Avec ce troisième one-man show, il choisit l&#039;introspection et partage une analyse intime avec l&#039;humour efficace qu&#039;on lui connaît. Ce spectacle invite à jeter un œil à travers la fenêtre de sa vie. C&#039;est un voyage, de sa tendre enfance à l&#039;homme qu&#039;il est aujourd&#039;hui, en se rapprochant un peu plus de sa réalité. À travers des anecdotes surprenantes, il brouille la frontière entre histoire personnelle et universel. C&#039;est un Mehdi qu&#039;on reconnaît, certes, pour son sens critique, ses analyses inhabituelles et ses punchs inattendus, mais aussi un Mehdi qu&#039;on découvre sous un nouveau visage. Il ouvre le livre de sa vie privée pour la première fois, dans un humour toujours aussi rafraîchissant."
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/ca60ffa4-8fec-41cf-a03e-437d89773e04",
