    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Soirée Crooner : Croon &amp; Roll"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Porté par Louis-Daniel St-Marseille (guitariste et vocaliste) et Pierre Racine (vocaliste), Croon &amp;amp; Roll propose un voyage musical entre les grands classiques crooner, le soft country, le folk et les incontournables du rock pour vous faire danser. Interprétées en français, en anglais et en espagnol, les chansons de leur répertoire créent une ambiance chaleureuse et rassembleuse, parfaite pour les soirées d&#039;été au parc Honoré-Mercier.\n\nLes musi-mercredis sont présentés par : \n\n\n\n\n\n Restez informé\n\nIndiquez votre intérêt pour cet événement en ajoutant ce spectacle à votre panier, ainsi vous serez informé en cas d&#039;annulation \n* Notez qu&#039;aucun billet ne vous sera transmis par courriel et aucun billet ne sera requis pour accéder à l&#039;événement.\n"
      }
    ]
  },
