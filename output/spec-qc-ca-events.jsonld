    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/vincent-vallieres"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Vincent Vallières"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La réputation de Vincent Vallières n&#039;est plus à faire. Depuis 1996, l&#039;auteur-compositeur-interprète taille sa place dans les radios avec des chansons marquantes comme On va s&#039;aimer encore, À hauteur d&#039;homme, Lili, Le temps passe mais aussi avec des performances sur scène saisissantes. Récompensé par 3 Félix et fort de 21 nominations au gala de l&#039;ADISQ, Vincent Vallières revient sur scène entouré de ses musiciens avec un tout nouveau spectacle. Son riche répertoire s&#039;y mêle aux pièces de son prochain album, attendu à l&#039;automne 2025. Un spectacle à l&#039;image de cet incontournable de la chanson québécoise: rassembleur, vivant et authentique."
      }
    ]
  },
