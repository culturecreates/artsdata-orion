    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Miche &amp; Rob Rhythm&#039;n&#039;blues Duo"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Guidée par une voix chaude et puissante Miche &amp;amp; TheBoys Musiciens d&#039;expérience baignant dans l&#039;univers musical depuis plusieurs années sont heureux de partager leur passion pour le blues, soul et le Rock, inspiré par des artistes comme Beth Hart, Etta James, Tina Turner, Eric Clapton et plusieurs autres...Offrant sur scène une présence magnétique et vibrante qui ne laisse personne indifférente.\n\nLes musi-mercredis sont présentés par : \n\n\n\n\n\n Restez informé\n\nIndiquez votre intérêt pour cet événement en ajoutant ce spectacle à votre panier, ainsi vous serez informé en cas d&#039;annulation \n* Notez qu&#039;aucun billet ne vous sera transmis par courriel et aucun billet ne sera requis pour accéder à l&#039;événement.\n"
      }
    ]
  },
