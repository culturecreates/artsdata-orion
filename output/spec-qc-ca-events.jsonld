    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Robert Robert"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "18 ans et + Robert Robert vient de Montréal et fait des chansons sur son ordinateur. BOOST, le nouvel album hopecore et cinétique de l&#039;artiste, fait briller les connexions humaines comme réponse aux pannes de courant qui paralysent nos cerveaux. À l&#039;image du choc électrique ressenti quand deux mains se frôlent, Robert Robert invoque ce qui nous rapproche, ce qui nous éloigne et l&#039;énergie cachée dans ces espaces."
      }
    ]
  },
