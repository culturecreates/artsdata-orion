    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/rire-pour-la-sante"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/rire-pour-la-sante"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Rire Pour La Santé"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nPour une 10e édition, Martin Vachon, humoriste, animateur et porte-parole de la Fondation Santé, sera de retour à l&#039;animation du spectacle-bénéfice Rire pour la santé, présenté par Déry Toyota. Sous la présidence d&#039;honneur de Steve Trépanier, propriétaire du réputé Steve Steakhouse, cette soirée promet encore une fois d&#039;être mémorable. Rendez-vous le jeudi 9 juillet à 20 h au Théâtre des Deux Rives pour célébrer en grand cette édition anniversaire!\n\nAnnée après année, cet événement rassemble des centaines de personnes autour d&#039;une même volonté : faire une différence concrète pour les soins de santé dans notre région. Pour cette 10e édition, Martin accueillera sur scène des humoristes invités spéciaux, qui seront dévoilés au courant des prochaines semaines sur les réseaux sociaux de la Fondation. Restez à l&#039;affût... et préparez-vous à rire pour la cause!"
      }
    ]
  },
