    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "En toute simplicité, seul avec sa guitare, Kevin Parent nous replonge dans l'univers de Pigeon d'argile comme si c'était hier. Sorti en 1995, ce premier…"
      }
