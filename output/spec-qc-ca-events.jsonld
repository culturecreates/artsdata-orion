    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jay Laliberté, Louis Girard-Bock"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "18 ans et +\n\nLouis et Jay sont des improvisateurs d&#039;expérience, des humoristes de profession et des meilleurs amis d&#039;amitié. Ils font tout ensemble, même leur spectacle. « Rodage à deux », c&#039;est une heure et quart de Louis et Jay qui enchaînent chacun leurs blagues, à deux sur scène, dans une partie de ping-pong humoristique où le public fait office de table."
      }
    ]
  },
