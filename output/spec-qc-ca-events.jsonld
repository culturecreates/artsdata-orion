    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Centre Musical Emf"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nC&#039;est avec grand plaisir que le Centre Musical EMF\nprésentera son concert des élèves 2026 le dimanche 14\njuin prochain.\nLes chanteuses, chanteurs, violonistes, pianistes,\nguitaristes, bassistes et batteurs de tous âges proposeront\nun répertoire varié.\nAccompagné(e)s de leur professeur(e)s, ils/elles monteront\nsur la scène du Cabaret Théâtre pour souligner leur bon\ntravail et surtout pour partager leur passion de la musique\navec le public."
      }
    ]
  },
