    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/maude-landry"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Maude Landry"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dans un monde où il faut se démarquer tout en suivant les tendances, Maude Landry se demande pourquoi elle n&#039;a jamais fait partie de la gang des cools. C&#039;est ce qui la rend attachante. Décontractée et pince-sans-rire, elle pose son regard taquin sur elle-même et sur la société, en passant délibérément par quatre chemins. Un spectacle moderne et assumé, pendant lequel on se dit parfois « C&#039;est niaiseux!... Mais fallait y penser ». Maude vous invite dans un périple au cœur de ses réflexions, ses doutes et ses déboires, pour que vous sortiez de la salle en disant : « C&#039;était trop cool! » "
      }
    ]
  },
