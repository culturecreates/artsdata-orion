    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "HYL se définit entre la chanson et un rap pop, électro coloré. Des mots pour dessiner des mélodies dans la lignée d'Orelsan, Gaël Faye, ou l'énergie…"
      }
    ],
