    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/breen-leboeuf"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Breen Leboeuf"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Breen LeBoeuf, l&#039;une des plus grandes voix du Québec et légende du Rock, continue d&#039;impressionner après plus de 55 ans de carrière. Son spectacle Mes blues passent plus dans porte replonge dans l&#039;époque marquée par le groupe culte Offenbach, dont il fut un pilier. Accompagné de musiciens talentueux, dont Réjean Lachance (guitare), Pierre Beauregard (clavier, sax) et Marc Brodeur (batterie), Breen Leboeuf interprète les plus grands classiques du groupe. Avec son énergie inépuisable et ses anecdotes uniques, il vous fera redécouvrir un répertoire musical emblématique du Québec. Un hommage vibrant à Offenbach et à notre histoire musicale, porté par une voix et une présence scénique exceptionnelles."
      }
    ]
  },
