    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Guylaine Tremblay et Denis Bouchard forment un duo explosif dans cette comédie où les échanges fusent avec mordant. Diane et Normand partent en escapade…"
      }
    ],
