    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Ça mousse, ça explose, ça change de couleur. Et personne ne s'y attend. Avec La magie de la chimie , Yannick Bergeron transforme le plateau en laboratoire…"
      }
