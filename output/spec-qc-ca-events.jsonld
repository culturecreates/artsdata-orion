    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/pianoman"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/pianoman"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Pianoman"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ayant lancé l&#039;an dernier la première saison des Musi-Mercredis, qui a rassemblé des centaines de personnes au parc Honoré-Mercier dans une ambiance chaleureuse et rassembleuse, Guy Martin, le pianoman de Saint-Jean, est de retour et donne le coup d&#039;envoi à la saison 2026 avec un nouveau spectacle consacré aux grandes signatures musicales d&#039;ici. Auteur-compositeur-interprète, pianiste et chanteur reconnu dans la région, il propose un univers riche mêlant rock, blues, jazz et country. Ce spectacle met en valeur un répertoire québécois marquant, avec Claude Dubois, Robert Charlebois et d&#039;autres incontournables, parfois bonifié de classiques américains et anglais, pour le plaisir du public. \n\nLes musi-mercredis sont présentés par : \n\n\n\n\n\n Restez informé\n\nIndiquez votre intérêt pour cet événement en ajoutant ce spectacle à votre panier, ainsi vous serez informé en cas d&#039;annulation \n* Notez qu&#039;aucun billet ne vous sera transmis par courriel et aucun billet ne sera requis pour accéder à l&#039;événement.\n"
      }
    ]
  },
