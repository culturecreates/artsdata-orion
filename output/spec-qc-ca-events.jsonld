    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Bruno Pelletier"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Bruno Pelletier, l&#039;un des chanteurs les plus appréciés de la francophonie, revient sur scène avec une nouvelle tournée intitulée « 3 et moi ». Ce spectacle, conçu comme un moment de partage privilégié, plonge le public dans un univers musical intime, où l&#039;artiste se dévoile avec authenticité. Entouré de trois musiciens talentueux, Bruno Pelletier propose une interprétation dépouillée de ses plus grands succès et de chansons coups de coeur, choisies avec soin pour cette aventure unique."
      }
    ]
  },
