    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/la-sainte-flanelle-les-series-eliminatoires-a-la-cathedrale"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/la-sainte-flanelle-les-series-eliminatoires-a-la-cathedrale"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Sainte Flanelle - Les Séries Éliminatoires À La Cathédrale !"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Venez vivre les séries éliminatoires du tricolore comme vous ne les avez jamais vécues auparavant.\nTous les soirs de match, la cathédrale Saint‑Jean‑l&#039;Évangéliste se transforme en un immense lieu de rassemblement où le sport, la création, la lumière et le patrimoine se rencontrent. Le match est diffusé en temps réel sur un écran géant de 35 pieds, au cœur de la nef, entouré de projections immersives qui prennent d&#039;assaut les murs et l&#039;architecture du lieu.\n\nL&#039;expérience va bien au‑delà de la diffusion sportive :\n- Une ambiance musicale et sonore immersive, de l&#039;animation sur place, des consommations offertes, et des moments forts pensés pour faire vibrer la foule.\n- L&#039;orgue de la cathédrale sera mis à contribution avec l&#039;organiste officiel Mario Coutu, ajoutant une dimension spectaculaire et inédite à l&#039;événement\n- L&#039;hymne national sera interprété en direct par la cantatrice Dominica Merola, tandis que l&#039;animation sera assurée par Lysanne Richard et Thomas Hodgson.\n\nHeure : Selon l&#039;heure du match \nOuverture des portes : 1 h avant le début du match\nAccessible aux personnes à mobilité réduite"
      }
    ]
  },
