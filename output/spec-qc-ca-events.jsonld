    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Mona De Grenoble"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " L&#039;humoriste et drag-queen de type « matante sur le party » a la sacoche bien pleine de talent : le roast, le crowdwork, l&#039;improvisation, le lipsync, et le stand-up. Mona de Grenoble sillonne le Québec avec son premier one-drag-show et voilà ce qu&#039;elle a à vous dire : « J&#039;aurais pu appeler ce show d&#039;humour Étalon en talons ou Entre Bâton Rouge et matante, mais après je me suis rendu compte que vous alliez sûrement vous reconnaître dans mon personnage que certains décrivent comme étant flamboyant, grivois et solvable depuis Big Brother. Parce que dans le fond, on le sait, les paillettes, les robes pis les grosses perruques, c&#039;est juste de la poudre aux yeux ! »"
      }
    ]
  },
