    "http://schema.org/offers": [
      {
        "@id": "https://spec.qc.ca/genid/d7b8a063c8a9021f"
      },
      {
        "@id": "https://spec.qc.ca/genid/5c74eef376139bfe"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/alexandre-cadieux"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/alexandre-cadieux"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alexandre Cadieux"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nComment le théâtre québécois a-t-il trouvé sa voix ? Parcourez 70 ans de dramaturgie québécoise, à travers ses thèmes, ses figures et ses formes. À partir d&#039;extraits de textes phares, écoutez ses transformations, saisissez les nuances, là où la langue et la manière de dire le monde se redéfinissent. Guidez par Alexandre Cadieux, suivez les grandes étapes du théâtre de création québécois et plongez au cœur d&#039;œuvres miroirs de nombreux enjeux sociaux, culturels et politiques du Québec. Deux interprètes redonnent chair aux mots et figures de notre imaginaire collectif. Une traversée qui révèle toute la force de notre dramaturgie.\n\nNotre conférencier, Alexandre Cadieux\nAlexandre Cadieux a été chargé de cours à l&#039;UQAM et à l&#039;Université d&#039;Ottawa, critique de théâtre au Devoir et à la revue JEU, bibliothécaire à l&#039;École nationale de théâtre du Canada, animateur, médiateur et concepteur à la LNI. Il est aujourd&#039;hui responsable du centre de documentation au Centre des auteurs dramatiques.\nMise en vente: 12 mai 2026 à 10 h"
      }
    ]
  },
