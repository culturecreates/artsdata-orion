      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Pianoman"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Guy Martin, le pianoman de Saint-Jean, revient avec une formule plus électrique où le piano devient moteur de grands classiques rock. Artiste authentique et passionné, il est reconnu dans la région pour ses prestations généreuses et son lien naturel avec le public. Le spectacle revisite des incontournables comme Elton John, les Bee Gees et plusieurs autres titres marquants, cette fois en formule full band. Attention, ça va swingner. Ambiance festive garantie.\n\nLes musi-mercredis sont présentés par : \n\n\n\n\n\n Restez informé\n\nIndiquez votre intérêt pour cet événement en ajoutant ce spectacle à votre panier, ainsi vous serez informé en cas d&#039;annulation \n* Notez qu&#039;aucun billet ne vous sera transmis par courriel et aucun billet ne sera requis pour accéder à l&#039;événement.\n"
      }
    ]
  },
