    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/ensemble-vocal-euphoria"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ensemble Vocal Euphoria"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nUn concert qui raconte une vie entière en musique.\n\nDe la première étincelle aux grands tournants, Symphonie d&#039;une vie vous invite à traverser les grandes étapes de l&#039;existence, portée par un répertoire vibrant, populaire et profondément humain. Un voyage musical où chaque chanson devient un souvenir, un élan, une révélation. Venez sentir battre la vie en harmonie.\n\nSymphonie d&#039;une vie, c&#039;est l&#039;énergie de l&#039;Ensemble vocal Euphoria au service d&#039;un parcours universel. Venez vivre l&#039;émotion en direct."
      }
    ]
  },
