    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Venez découvrir un spectacle où passion, créativité et talent prennent vie sur scène ! Nos danseurs, de tous âges et niveaux, vous offrent des chorégraphies qui reflètent leur parcours, leurs efforts et leur évolution tout au long de l'année. Un moment unique rempli d'énergie et de plaisir à ne pas manquer !"
      }
    ],
