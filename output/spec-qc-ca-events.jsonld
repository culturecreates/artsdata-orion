  },
  {
    "@id": "https://spec.qc.ca/temporary/bd4b52fc-6c3a-4538-a992-f6697351b4b3",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-17T13:00:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
