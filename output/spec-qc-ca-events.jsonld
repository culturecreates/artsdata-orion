      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/p-a-methot"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "P-A Méthot"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le seul et unique P-A Méthot est enfin de retour sur scène avec un nouveau spectacle intitulé Pardon?!. Raconteur authentique et rassembleur, P-A sait autant toucher le public que le faire rire. Après plus de 500 000 billets vendus pour ses deux premiers spectacles, l&#039;humoriste chouchou revient avec son humour ancré dans le vrai monde et ses histoires savoureuses, transformant chaque situation du quotidien en un moment comique où tout le monde se reconnaît.\n\nDans ce nouveau one-man-show, notre habile conteur répond aux grands questionnements de la vie avec une seule et unique question : « PARDON?! ». Un troisième spectacle vrai, authentique et surtout hilarant."
      }
    ]
  },
