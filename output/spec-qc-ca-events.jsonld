    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "OLIVIER MARTINEAU | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Société, c'est fini. Oui, on a eu de beaux moments, mais là, c'est trop. T'as changé. Moi, je m'en vais. Je te laisse tes règles farfelues et tes…"
      }
    ],
