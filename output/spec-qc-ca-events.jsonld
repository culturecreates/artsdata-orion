    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Emile Proulx-Cloutier"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après trois albums aux textes éloquents, d&#039;une richesse musicale saluée par le public et la critique, ÉMILE PROULX-CLOUTIER nous éblouit une fois de plus avec sa voix percutante, assumée et émouvante, confirmant qu&#039;il a su définir le son d&#039;un univers musical bien à lui.\n\nDans ce spectacle, l&#039;auteur-compositeur-interprète nous livre les nouvelles chansons de son album Ma main au feu, ainsi que plusieurs autres pièces poétiques et vives de son répertoire."
      }
    ]
  },
