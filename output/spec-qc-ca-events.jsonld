    "http://schema.org/performer": [
      {
        "@id": "_:g2390180"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spec.qc.ca/uploads/ana%C3%AFs-barbeau-lavalette-horizontal-c302a271dd2522390b36.jpeg"
