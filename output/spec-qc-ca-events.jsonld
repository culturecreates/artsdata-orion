    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Swamp - Hommage À Ccr"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nSouvent cité parmi les meilleurs hommages à CCR au Canada, Swamp séduit les foules par ses prestations festives et authentiques.\nAprès une tournée à guichet fermé dans le ROSEQ en 2022, Swamp revient en force avec un spectacle exaltant pour souligner leur 20e anniversaire.\n"
      }
    ]
  },
