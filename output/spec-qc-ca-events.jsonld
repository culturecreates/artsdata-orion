    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "J'ai 24 ans. J'suis extra vieux. Vraiment full mature pis profond. J'comprends un peu rien à la vie mais j'commence à comprendre mon métier. Le nom le…"
      }
