      {
        "@language": "fr",
        "@value": "DANSE COUNTRY AVEC DANNY BEAUREGARD | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Le mercredi venu, la Place publique enfile ses bottes pour une soirée de country pop. Aux commandes, Danny Beauregard : danseur depuis l'âge de quatorze…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
