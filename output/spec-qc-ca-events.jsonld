    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/boulevard-perusse"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Boulevard Pérusse"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après avoir marqué la francophonie avec son humour culte, François Pérusse signe sa première pièce de théâtre. Boulevard Pérusse met en scène une famille québécoise à la tête d&#039;une multinationale écolo, confrontée à une crise internationale inattendue. Fidèle à son style, la pièce enchaîne situations absurdes, jeux de mots et rebondissements déjantés, dans un univers aussi drôle qu&#039;imprévisible. Bien qu&#039;il ne soit pas sur scène physiquement, François Pérusse demeure omniprésent : il signe toute l&#039;ambiance sonore du spectacle, des musiques aux effets sonores en passant par les voix hors champ."
      }
    ]
  },
