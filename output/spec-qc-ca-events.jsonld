    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présenté dans le cadre du Festival d&#039;humour en Montérégie\nJF Denommée est reconnu partour pour ses soirées GHB (Gore Hard et Brutal) qui sont toujours complets et que nous voulons vous faire découvrir! Une soirée avec un humour politiquement incorrect mais tellement drôle dont vous n&#039;êtes pas prêts d&#039;oublier! \n"
      }
    ]
  },
