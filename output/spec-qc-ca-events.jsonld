    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "LOU-ADRIANE CASSIDY | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Après avoir marqué la première moitié de 2025 avec Journal d'un loup-garou, dont l'album et le spectacle ont récolté une pluie d'éloges et un succès…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
