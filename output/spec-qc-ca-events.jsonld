    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/cecile-doo-kingue"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/cecile-doo-kingue"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Cécile Doo-Kingué"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Voix suave, guitare envoûtante, Cécile Doo-Kingué repousse les frontières musicales. Entre blues, soul, chanson et rythmes africains, elle crée une signature sonore unique. Née de parents camerounais, élevée à New York, passée par la France et installée à Montréal, Cécile incarne un métissage musical vibrant. Sur scène, sa voix profonde et ses riffs ensorcelants captivent, transportant le public dans un univers où émotion et virtuosité se rencontrent. Guitariste et chanteuse hors pair, elle séduit par son énergie, sa sensibilité et sa présence magnétique. Chaque performance est une expérience authentique, où mélodie, groove et intensité se conjuguent pour marquer durablement. Aujourd&#039;hui, Cécile revient sur scène plus inspirée que jamais, prête à faire vibrer toutes les scènes avec sa musique puissante et émotive."
      }
    ]
  },
