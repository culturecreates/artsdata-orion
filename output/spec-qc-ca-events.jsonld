    "http://schema.org/offers": [
      {
        "@id": "https://spec.qc.ca/genid/4db86bb853a1b8c4"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/la-magie-de-noel"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/la-magie-de-noel"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Magie De Noël"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nAlerte au pôle Nord : la magie de Noël a disparu. Sans elle, pas de tournée, pas de cadeaux, pas de nuit enchantée. Le Père Noël et son lutin Bourrasque ont besoin de renfort. Et ce renfort, ce sont les enfants dans la salle. Dans ce spectacle interactif de 45 minutes, petits et grands deviennent les héros de l&#039;aventure. Tours de magie, chansons et éclats de rire fusent dans un univers féerique où solidarité et imagination sont les clés pour sauver Noël. En prime, un calendrier de l&#039;avent numérique prolonge la fête jusqu&#039;au réveillon : 25 capsules vidéo à savourer une à une. Et le compte à rebours vers Noël peut commencer. \n\nVariété\nDurée : 45 minutes.\nProduction : Alinéa Productions\nPublic cible : 4 à 8 ans\n\nForfait 3 spectacles pour 48 $\nAjoutez tous les spectacles au panier et le tarif s&#039;ajustera automatiquement."
      }
    ]
  },
