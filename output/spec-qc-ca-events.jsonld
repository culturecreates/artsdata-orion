    ],
    "http://schema.org/copyrightYear": [
      {
        "@language": "fr",
        "@value": "2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Cette pièce de théâtre a pour objectif d'apprendre aux personnes aînées et à leur entourage à détecter les arnaques financières et faire connaitre les différents stratagèmes employés par les fraudeurs. Elle traite des quatre types des fraudes dont les aîné(e)s sont le plus victimes : faux représentant, amoureuse, maltraitance et grands-parents. La pièce sera accompagnée d'intervention des agent(e)s sociocommunautaires de la Régie intermunicipale de police Richelieu-Saint-Laurent. Cette initiative est mise en place par les partenaires de la Table des aînés du Bassin de Chambly!   Ce projet est une présentation de la Ville de Chambly."
      }
    ],
