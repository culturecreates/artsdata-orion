    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Il fait rire le Québec depuis maintenant 32 ans. On l'a vu partout : sur scène, à la télé, à la radio. L'humour, pour lui, c'est une rencontre vraie.…"
      }
