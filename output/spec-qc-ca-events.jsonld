      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Spectacul&#039;air"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nSpectacul&#039;Air est un spectacle de variété mettant en scène les étudiant.es faisant partie de la troupe de danse Pulsion, les étudiant.es faisant partie de la troupe de chant À contre-temps et d&#039;autres étudiant.es-artistes du Cégep Saint-Jean-sur-Richelieu. Une vingtaine de numéros des arts de la scène vous seront présentés durant cette soirée qui s&#039;annonce excitante !\n\nAnimé par Dimitri Lapointe et Maélie Béliveau.\n"
      }
    ]
  },
