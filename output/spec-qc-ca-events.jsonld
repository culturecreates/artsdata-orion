    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Amaryllis étudie en sciences à l'université. Anthony est incarcéré dans un pénitencier. Ils auraient dû mener leur vie en parallèle, sans se croiser. Ils…"
      }
