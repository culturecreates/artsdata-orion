    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Voix suave, guitare envoûtante, Cécile Doo-Kingué repousse les frontières musicales. Entre blues, soul, chanson et rythmes africains, elle crée une…"
      }
    ],
