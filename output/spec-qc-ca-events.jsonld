    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/jean-michel-anctil"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/jean-michel-anctil"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jean-Michel Anctil"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nJean-Michel Anctil n&#039;avait pas envie d&#039;un retour, mais de retrouvailles. C&#039;est donc à l&#039;occasion de ses 60 ans qu&#039;il présentera un tout nouveau spectacle, limité à 60 représentations seulement, pour célébrer, rire et se retrouver. Cette tournée sera une grande célébration assumée où chaque soir réservera sa surprise : un artiste mystère viendra le rejoindre sur scène. Au programme : matériel inédit, numéros coup de cœur revisités et retour de personnages marquants comme Râteau et Priscillia. Avec l&#039;expérience et le regard de ses 60 ans, il aborde le temps qui passe et ses surprises, fidèle à sa signature drôle, humaine et touchante."
      }
    ]
  },
