      {
        "@id": "https://spec.qc.ca/programmation/angel-forrest"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/angel-forrest"
      }
    ],
    "http://schema.org/copyrightYear": [
      {
        "@language": "fr",
        "@value": "2025"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Angel Forrest célèbre les 20 ans de son album Here for You avec une tournée anniversaire attendue. Sa voix puissante, marquée par une carrière foisonnante, livre le blues avec une intensité brute et des nuances infinies. Rare sur nos scènes depuis son départ vers la Colombie-Britannique, elle offre un retour généreux et passionné. Entre nostalgie et nouveauté, ce concert promet des moments d'émotion vive et de communion. Pour les amateurs de blues, c'est un rendez-vous incontournable."
      }
    ],
    "http://schema.org/headline": [
