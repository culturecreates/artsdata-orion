      }
    ],
    "http://ogp.me/ns#image:alt": [
      {
        "@language": "fr",
        "@value": "Le documentaire Shifting baselines sera présenté au Cinéclub du Théâtre des Deux Rives le 6 avril 2026 à 15h15 et 19h30 en collaboration avec l'AREQ"
      }
    ]
  },
