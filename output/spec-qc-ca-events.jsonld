    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/guillaume-pineault-2"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Guillaume Pineault"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Guillaume Pineault est fier d&#039;entamer la confection du petit 2e avec vous. Il sillonne donc le Québec avec le rodage de son prochain spectacle dans le but de vous faire rire, de vous faire du bien, mais également de vous faire découvrir davantage l&#039;humain derrière l&#039;humoriste. Guillaume est un raconteur né, candide, sympathique et doté d&#039;un charisme indéniable. C&#039;est avec simplicité et adresse qu&#039;il provoquera vos rires avec ses histoires personnelles et improbables. Plus besoin de détour, Guillaume Pineault est là où il doit être : sur scène, à vous faire rire !, Guillaume Pineault sillonne le Québec avec le rodage de son prochain spectacle. Alors qu&#039;il nous parlait d&#039;avoir pris des détours professionnels lors de son premier spectacle solo, notamment en obtenant un diplôme en ergothérapie et en ostéopathie, l&#039;humoriste délaisse finalement sa carrière en santé pour se consacrer à ce qu&#039;il aime le plus : l&#039;humour. Guillaume est un raconteur né, candide, sympathique et doté d&#039;un charisme indéniable. C&#039;est avec simplicité et adresse qu&#039;il provoquera vos rires avec ses histoires personnelles et improbables. Plus besoin de détour, Guillaume Pineault est là où il doit être : sur scène, à vous faire rire ! , Eh bien verrat! Je suis extrêmement fier d&#039;entamer la confection du petit 2e avec vous. \n\nJ&#039;ai envie de vous faire rire, de vous faire du bien, mais également de vous faire découvrir davantage l&#039;humain derrière l&#039;humoriste."
      }
    ]
  },
