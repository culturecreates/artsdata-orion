    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Laurence Jalbert"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " Une voix née de la mer, portée par le cœur et l&#039;instinct.\n\nCélébrez 35 ans de musique et redécouvrez ce premier album mythique de Laurence Jalbert, dans un spectacle riche en émotions et en intensité. Accompagnée de ses musiciens, elle vous fera vibrer au son de ses plus grands succès tirés de cet album, dont : Tomber, Au nom de la raison, Les yeux noirs et Rage. L&#039;artiste vous réserve également quelques surprises qui sauront réconforter et toucher l&#039;âme du public.\n\nCe spectacle se veut une célébration de la passion, de la force et d&#039;un amour profond envers le public, entretenu depuis plus de 35 ans."
      }
    ]
  },
