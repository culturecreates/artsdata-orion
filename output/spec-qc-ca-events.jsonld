    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "18 ans et +\n\n\nPREMIER ONE-MAN-SHOW\n\nNatif et habitant toujours au Nord du Lac-Saint-Jean, Mat est un &#039;&#039;raconteux&#039;&#039;.\nSa parlure et ses anecdotes colorées défilent à la vitesse d&#039;une bonne toune punk.\nIl décrit lui-même son style en disant : &#039;&#039;C&#039;est comme du Michel Barrette mais avec ben de la\nsauce piquante!&#039;&#039;\n"
      }
    ]
  },
