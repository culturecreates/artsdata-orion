    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "S'il y a trois voix que l'on rêve d'entendre à l'unisson, ce sont bien celles de Luce Dufault, Lulu Hughes et Kim Richardson. Ce rêve deviendra réalité…"
      }
    ],
