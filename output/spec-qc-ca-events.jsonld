    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "LE PETIT ROI POUR TOUJOURS | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Jean-Pierre Ferland , icône de la chanson québécoise, restera à jamais  Le Petit Roi  pour tous ceux et celles qui ont eu la chance d'entendre, de…"
      }
    ],
    "http://ogp.me/ns#image": [
