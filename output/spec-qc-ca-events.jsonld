    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/luce-dufault-lulu-hugues-et-kim-richardson"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/luce-dufault-lulu-hugues-et-kim-richardson"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Luce Dufault, Lulu Hughes Et Kim Richardson"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " S&#039;il y a trois voix que l&#039;on rêve d&#039;entendre à l&#039;unisson, ce sont bien celles de Luce Dufault, Lulu Hughes et Kim Richardson. Ce rêve deviendra réalité puisque les trois interprètes se retrouveront ensemble sur scène dans un nouveau spectacle intitulé ELLES, et qui est en quelque sorte un retour aux sources pour les trois artistes. Leur répertoire? Des chansons jazz, soul, rhythm and blues, folk et rock qui leur permettront de s&#039;éclater. Frissons garantis. Au sommet de leur art, les trois interprètes habiteront la scène avec panache, que ce soit en solo, en duo ou en trio, dans une rencontre exceptionnelle où la spontanéité et la folie ressemblent à l&#039;amitié qui les unit depuis 30 ans. Dans une mise en scène de Michel Poirier et sous la direction musicale de Jean Garneau."
      }
    ]
  },
