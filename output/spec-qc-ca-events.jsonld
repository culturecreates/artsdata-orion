    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/coeur-de-pirate"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/coeur-de-pirate"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Coeur De Pirate"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " Depuis ses débuts fulgurants en 2008, Cœur de pirate séduit autant qu&#039;elle surprend. Icône pop internationale partageant sa vie et sa carrière entre le Québec et l&#039;Europe, elle est devenue une figure incontournable de la chanson francophone. Avec sa voix intime et affilée, elle charme les scènes du monde entier, livrant l&#039;émotion avec justesse tout en invitant la foule à célébrer. En 2025, elle revient sur scène pour présenter l&#039;album Cavale. Ce nouveau spectacle à la scénographie grandiose révèle autant la femme au piano que la star qui danse. À la fois mélancolique et vibrante, elle oscille entre douceur et envolées. Une soirée avec Cœur de pirate, c&#039;est la volatilité des sentiments maîtrisée avec un soin d&#039;orfèvre, entre introspection et exaltation."
      }
    ]
  },
