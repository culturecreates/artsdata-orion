        "@id": "https://spec.qc.ca/uploads/_1200x630_crop_center-center_82_none/alexandre-poulin-horizontal-afb25b3b82907c4f453c.jpeg?mtime=1779372089"
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/8d7ce703-b650-41be-a469-fdebc9f17243",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
