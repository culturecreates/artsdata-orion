        "@value": "630"
      }
    ],
    "http://ogp.me/ns#image:alt": [
      {
        "@language": "fr",
        "@value": "L'humoriste P-A Métoth sera au Centre culturel de Venise-en-Québec le 27 juin et présentera Pardon!? au Pôle culturel ce Chambly le 30 octobre 2026."
      }
    ]
  },
