    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Eddb"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "\nVenez découvrir un spectacle où passion, créativité et talent prennent vie sur scène ! Nos danseurs, de tous âges et niveaux, vous offrent des chorégraphies qui reflètent leur parcours, leurs efforts et leur évolution tout au long de l&#039;année. Un moment unique rempli d&#039;énergie et de plaisir à ne pas manquer !"
      }
    ]
  },
