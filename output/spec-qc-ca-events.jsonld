    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "STÉPHANE ROUSSEAU | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Allô!  Ben oui, je reviens sur scène après 10 ans d'absence. Pourquoi? C'est pas compliqué, j'en peux plus, je m'ennuie de vous autres. J'ai envie de vous…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://spec.qc.ca/uploads/_1200x630_crop_center-center_82_none/stéphane-rousseau-horizontal-0f408b4d49e554d3f359.jpeg?mtime=1764709693"
      }
    ],
    "http://ogp.me/ns#image:width": [
      {
        "@language": "fr",
        "@value": "1200"
      }
    ],
    "http://ogp.me/ns#image:height": [
      {
        "@language": "fr",
        "@value": "630"
      }
    ],
    "http://ogp.me/ns#image:alt": [
      {
        "@language": "fr",
        "@value": "L'humoriste, acteur et animateur Stéphane Rousseau fait son grand retour en humour. Il sera en spectacle au Pôle culturel de Chambly le 6 novembre 2026"
      }
    ]
  },
