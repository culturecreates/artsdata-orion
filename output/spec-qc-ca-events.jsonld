    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Sur scène, Billie du Page se révèle pleinement. À 21 ans, elle arrive avec l'assurance d'une artiste déjà bien ancrée, portée par le succès de Fake…"
      }
    ],
