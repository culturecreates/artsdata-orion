    "http://schema.org/offers": [
      {
        "@id": "https://spec.qc.ca/genid/a787fc03704be613"
      },
      {
        "@id": "https://spec.qc.ca/genid/332894e3c128a594"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/aswell"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/aswell"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Aswell"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Phénomène de la streamosphère et nouvelle sensation du rap québécois, Aswell s&#039;est imposé en quelques années seulement comme une voix incontournable de la scène musicale d&#039;ici ainsi qu&#039;une figure de proue des musiciens de sa génération.\n\nPorté par ses deux premiers projets en carrière, le EP Solo sorti en 2021 ainsi que l&#039;album Banlieue sorti en 2024 et lancé dans un Club Soda à guichet fermé, le jeune artiste comptabilise déjà plus de 55 millions d&#039;écoutes sur l&#039;ensemble des plateformes de streaming et une certification single d&#039;or pour son morceau Leaving. Il compte aussi à son actif des spectacles sur les plus grandes scènes de la province (Francos de Montréal, FEQ, Festivoix de Trois-Rivières, Le Festif! de Baie-Saint-Paul). \n\nNaviguant entre le emo rap, la pop et le folk québécois, Aswell se distingue par ses flows mélodiques et accrocheurs ainsi que par ses textes personnels, authentiques et empreints d&#039;une grande volonté introspective dans lesquelles il explore notamment les tumultes amoureux, le vide existentiel et l&#039;ambition de réussir entouré des siens."
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/3184e7bf-a8ad-4fef-b731-abed37985409",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://spec.qc.ca/uploads/aswell-horizontal-e0a536bb8aef5962c007.jpeg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=498808U-1mk"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/aswell"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "ASWELL"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Phénomène de la streamosphère et nouvelle sensation du rap québécois, Aswell s&#039;est imposé en quelques années seulement comme une voix incontournable de la scène musicale d&#039;ici ainsi qu&#039;une figure de proue des musiciens de sa génération.\n\nPorté par ses deux premiers projets en carrière, le EP Solo sorti en 2021 ainsi que l&#039;album Banlieue sorti en 2024 et lancé dans un Club Soda à guichet fermé, le jeune artiste comptabilise déjà plus de 55 millions d&#039;écoutes sur l&#039;ensemble des plateformes de streaming et une certification single d&#039;or pour son morceau Leaving. Il compte aussi à son actif des spectacles sur les plus grandes scènes de la province (Francos de Montréal, FEQ, Festivoix de Trois-Rivières, Le Festif! de Baie-Saint-Paul). \n\nNaviguant entre le emo rap, la pop et le folk québécois, Aswell se distingue par ses flows mélodiques et accrocheurs ainsi que par ses textes personnels, authentiques et empreints d&#039;une grande volonté introspective dans lesquelles il explore notamment les tumultes amoureux, le vide existentiel et l&#039;ambition de réussir entouré des siens."
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-01-30T10:31:00"
      }
    ]
  },
