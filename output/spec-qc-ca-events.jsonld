    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Dans son tout nouveau spectacle Drôle depuis 1957 , Michel Barrette revient en force avec un regard hilarant et tendre sur sa génération. Il y célèbre «…"
      }
