    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Pour célébrer ses 40 ans, le phénomène télévisuel MusiquePlus est de retour... sur scène! Revivez la frénésie de la meilleure des époques avec le…"
      }
    ],
