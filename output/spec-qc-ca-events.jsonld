    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/lensemble-den-direct-de-lunivers"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/lensemble-den-direct-de-lunivers"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&#039;ensemble D&#039;en Direct De L&#039;univers"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Porté par les musiciens et choristes de l&#039;émission En direct de l&#039;univers, ce spectacle des Fêtes est devenu un rendez-vous incontournable. Dans une ambiance festive et touchante, l&#039;Ensemble entraine le public dans un grand tourbillon de chansons où se mêlent traditions, retrouvailles et plaisir partagé. Medleys enjoués, harmonies étincelantes et moments d&#039;émotion composent ce voyage musical célébrant l&#039;amitié et la joie d&#039;être ensemble. C&#039;est le bonheur simple et vrai d&#039;un spectacle qui réchauffe le coeur et lance la magie du temps des Fêtes."
      }
    ]
  },
