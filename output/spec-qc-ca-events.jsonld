    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/dominic-paquet"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/dominic-paquet"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Dominic Paquet"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " Après avoir vendu plus de 250 000 billets de son dernier spectacle, le populaire humoriste Dominic Paquet est de retour avec un tout nouveau one-man-show : J&#039;comprends la game. Ce 5e spectacle solo est un clin d&#039;œil à ceux qui, forts de leur expérience, croient comprendre des choses inaccessibles au commun des mortels. Véritable laboratoire humoristique, J&#039;comprends la game est un terrain où la folie prend tout son sens. L&#039;humoriste y explore, décortique et met en évidence des théories farfelues pour répondre à des questions que personne ne se pose! Encore une fois, il surprend, séduit et provoque des éclats de rire grâce à son talent unique pour incarner des personnages et créer des expressions qui marquent l&#039;imaginaire.\n\nLe spectacle est présenté par Alimentation Mon Quartier, qui vous invite à vivre une expérience unique, signée par les artisans et producteurs alimentaires d&#039;ici."
      }
    ]
  },
