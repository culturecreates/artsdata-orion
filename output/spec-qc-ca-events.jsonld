    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Spectacle sur scène et projections immersives\n\nVivez l&#039;énergie incomparable de Guylaine Tanguay dans un spectacle country immersif où sa voix, sa présence et ses chansons prennent une ampleur nouvelle. Portée par des projections monumentales, cette soirée vous enveloppe dans une expérience plus grande que nature. Un rendez‑vous vibrant et lumineux avec l&#039;une des artistes les plus aimées du Québec."
      }
    ]
  },
