    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Nacer Belkacem s'est bâti, au fil des années, une situation enviable aux yeux de tous : père de famille aimant, mari heureux, employé modèle et citoyen…"
      }
    ],
