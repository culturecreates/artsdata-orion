      }
    ],
    "http://ogp.me/ns#image:alt": [
      {
        "@language": "fr",
        "@value": "L'artiste Bruno Pelletier sera en spectacle au Pôle culturel de Chambly le 14 novembre 2026 et au Cabaret-Théâtre du Vieux-Saint-Jean le 2 avril 2027"
      }
    ]
  },
