    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/classe-moyenne"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/classe-moyenne"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Classe Moyenne"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "TikTok les adore, Instagram les suit pas à pas, et leurs chansons s&#039;écoutent partout : 2 millions de clics en quelques mois. Classe moyenne est la sensation du moment, un phénomène rare. C&#039;est dans un sous-sol près de La Prairie que tout commence, là où cinq amis puisent dans leur quotidien pour écrire des chansons qui parlent autant aux trentenaires qu&#039;à tous les autres. Réunis autour de Benjamin Nadeau (réalisateur et producteur ayant collaboré avec Marc Dupré, William Cloutier, Ludovick Bourgeois et plusieurs autres), ils ont vu leur première chanson devenir virale, puis en ont écrit treize autres. Et ils continuent, simplement parce qu&#039;ils s&#039;amusent... et que le public en redemande. Ce qui les guide : liberté, plaisir, positif et gros party. Un bateau à ne pas manquer, car il ne passe pas souvent !"
      }
    ]
  },
