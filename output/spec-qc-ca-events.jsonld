    ],
    "http://schema.org/image": [
      {
        "@id": "https://spec.qc.ca/uploads/c%C3%B4t%C3%A9-danse-horizontal-4149f56a2f13b4bf8b70.jpeg"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://spec.qc.ca/genid/daa8f543e3dfd7a0"
