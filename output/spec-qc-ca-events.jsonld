    ],
    "http://schema.org/image": [
      {
        "@id": "https://spec.qc.ca/uploads/%C3%A9ric-michaud-horizontal-4647a55beb8b645ee2de.jpeg"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2300500"
      },
      {
        "@id": "_:g2300520"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/eric-michaud"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spec.qc.ca/programmation/eric-michaud"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Éric Michaud"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ce qui est extraordinaire avec les contes de fées, c&#039;est qu&#039;ils sont des miroirs de leur époque : ils révèlent les peurs, les élans du cœur et les règles qui façonnent la société. Avec le temps, ces récits se sont transformés, adoucis, et ont été diffusés dans des versions plus sages ou édulcorées. Éric Michaud vous replonge dans leurs formes premières, brutes et saisissantes. À mi-chemin entre conte, humour et éclairage historique, vous ne verrez plus jamais les contes de votre enfance de la même façon... Au moins une victime par histoire !\n\nÉclats de rire\nAttendez-vous à des éclats de rire aussi soudains que libérateurs car, derrière l&#039;ombre et le frisson, l&#039;humour surgit, vif et irrévérencieux, faisant éclater les versions trop sages et les certitudes bien rangées. Un spectacle qui secoue, surprend, et nous fait voir les contes autrement.\n\n\n\n«On retiendra son franc-parler, sa verve, sa lucidité, son charisme envoûtant et sa belle sensibilité. » \n- Nathalie Lessard, Pieuvre\n\n\n\nConte. Interprétation : Éric Michaud. Production : Oyez Oyez ! Durée : 1 h 30, sans entracte.\n_\n\n\n\nTarifs\n\nRégulier: 31 $\n\nÉtudiant: 23 $ \n\n\n\nForfait culturel L&#039;Art de la parole\n\n3 spectacles: 18.33 $ ch.\n\n6 spectacles: 11.67 $ ch.\n\n\nMise en vente: 12 mai 2026 à 10 h"
      }
    ]
  },
  {
    "@id": "https://spec.qc.ca/temporary/815b6c33-24c0-47df-8713-b5ff61a5ee01",
    "@type": [
      "http://schema.org/VideoObject"
    ],
    "http://schema.org/thumbnailUrl": [
      {
        "@id": "https://spec.qc.ca/uploads/%C3%A9ric-michaud-horizontal-4647a55beb8b645ee2de.jpeg"
      }
    ],
    "http://schema.org/embedUrl": [
      {
        "@id": "https://www.youtube.com/watch?v=BONas5XGAkg&amp;list=PLgtujagILB8gN1ENBNDfMli46dy8CqYEP&amp;index=14"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spec.qc.ca/programmation/eric-michaud"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "ÉRIC MICHAUD"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ce qui est extraordinaire avec les contes de fées, c&#039;est qu&#039;ils sont des miroirs de leur époque : ils révèlent les peurs, les élans du cœur et les règles qui façonnent la société. Avec le temps, ces récits se sont transformés, adoucis, et ont été diffusés dans des versions plus sages ou édulcorées. Éric Michaud vous replonge dans leurs formes premières, brutes et saisissantes. À mi-chemin entre conte, humour et éclairage historique, vous ne verrez plus jamais les contes de votre enfance de la même façon... Au moins une victime par histoire !\n\nÉclats de rire\nAttendez-vous à des éclats de rire aussi soudains que libérateurs car, derrière l&#039;ombre et le frisson, l&#039;humour surgit, vif et irrévérencieux, faisant éclater les versions trop sages et les certitudes bien rangées. Un spectacle qui secoue, surprend, et nous fait voir les contes autrement.\n\n\n\n«On retiendra son franc-parler, sa verve, sa lucidité, son charisme envoûtant et sa belle sensibilité. » \n- Nathalie Lessard, Pieuvre\n\n\n\nConte. Interprétation : Éric Michaud. Production : Oyez Oyez ! Durée : 1 h 30, sans entracte.\n_\n\n\n\nTarifs\n\nRégulier: 31 $\n\nÉtudiant: 23 $ \n\n\n\nForfait culturel L&#039;Art de la parole\n\n3 spectacles: 18.33 $ ch.\n\n6 spectacles: 11.67 $ ch.\n\n\nMise en vente: 12 mai 2026 à 10 h"
      }
    ],
    "http://schema.org/uploadDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-18T17:57:00"
      }
    ]
  },
