    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "SHIFTING BASELINES | SPEC du Haut-Richelieu"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Là où le Rio Grande se jette dans la mer, les fusées de SpaceX s'élancent au dessus des dunes de Boca Chica, sous le regard inquiet des astronomes. Quinze…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
