      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Undercover Legends Of Rock"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "UNDERCOVER Legends of Rock, L&#039;Ultime revue musicale commandée par la voix puissante de Dominic Michaud, célèbre ses 10 ans et présentera d&#039;ailleurs une nouvelle mouture encore plus explosive de son spectacle déployant les hits pour l&#039;occasion! Une performance épique attend la foule! Honorant les succès intemporels des piliers du rock, sous une formule &#039;Greatest Hits&#039;. Avec plus de 600 concerts donnés à travers le Québec et les Maritimes. Les classiques de Bon Jovi, Def Leppard, Foreigner, Journey, AC/DC, Styx, Queen et plusieurs autres... L&#039;Ultime revue musicale Rock! !"
      }
    ]
  },
