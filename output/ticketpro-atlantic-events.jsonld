      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10612"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Brian Patafie & Friends FUNNY AS PUCK Tour"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p> On Tuesday May 12<sup>th</sup> former NHL Calgary Flames Trainer and Greenwood Nova Scotia raised Brian Patafie will be appearing at the McCain Community Theatre. He will be bringing his brand new FUNNY AS PUCK show to the Woodstock New Brunswick Venue.  Just over five years ago Brian (affectionately referred to as Comedy's Original Enter-Trainer) finished a forty four year career as an athletic trainer in professional hockey including almost twenty years with the NHL's Calgary Flames. He also spent time back in the 80's with the AHL Moncton Golden Flames and as well he was the inaugural athletic trainer with the Saint John Flames back in 1993 . Brian kept a diary of his day to day adventures and following his hockey career he turned those notes along with a plethora of stories of his dysfunctional upbringing in a military home into an absolutely hilarious standup comedy routine. He has not only shared his stories multiple times touring across North America he also embarked on a multi city, multi show tour throughout the United Kingdom back in October of 2022. WELL, here is your opportunity to enjoy an evening with one of the most charismatic and entertaining figures from the world of professional hockey as he shares his interesting and somewhat dysfunctional life stories on stage.</p>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
