      }
    ],
    "http://schema.org/name": [
      {
        "@value": "This is Me"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>'This Is Me' is a dynamic performance bringing together the school choir, rock band, and members of the wind ensemble to present our own renditions of popular hits and beloved musical favourites. Audiences can look forward to an evening filled with music, movement, and unforgettable moments as our young performers take the stage with confidence and enthusiasm.</p>\n\n<p>This show is a true testament to the dedication and teamwork of our students, who have embraced the joy of performance and the spirit of collaboration. We can't wait to share this special event with you!</p> \n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
