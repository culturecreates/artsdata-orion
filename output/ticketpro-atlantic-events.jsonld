        "@id": "https://ticketpro.ca/place/1330337653"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1690431252.jpeg?version=4"
      }
    ],
    "http://schema.org/offers": [
      {
