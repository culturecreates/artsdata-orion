    "http://schema.org/name": [
      {
        "@value": "Youth Artist Scholarship Fundraiser"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Join us at Harmony House for our 3nd annual music scholarship fundraiser concert, hosted by Mike Ross!</p>\n<p>This concert will feature young up and coming musicians from PEI and the proceeds go towards an annual music scholarship for a deserving musician enrolled in the Holland College School of Music Program.</p>\n<p>Over the years, Harmony House has hired young talented graduates from that program and this is our way of giving back!</p>\n\n<p><b>If you would like to make a reservation to enjoy dinner before the show, please call the venue at: 902-964-2255 or email them at <a href='mailto:harmonyhousePEIresos@gmail.com'>harmonyhousePEIresos@gmail.com</a>!<br>Please note: On 2pm matinee days, The Lounge is open for dinner reservations 3:30pm onward, after the 2pm performance.<br><br>\nFor ticket details, visit Harmony House Theatre on-line at <a href='https://harmonyhousepei.com/' target='_blank'><u>harmonyhousepei.com</u></a> or call the box office at 1-888-311-9090.</i></b></p>\n\n<p><b>Harmony House Gift Certificates are not redeemable through Ticketpro. Please contact Harmony House directly to redeem.</b></p>\n\n<p><b><font size='+1'>TICKET PURCHASES ARE FINAL AND NON-REFUNDABLE</b></font></p>\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>\n\n"
