    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g803900"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10722"
