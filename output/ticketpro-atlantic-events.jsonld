  {
    "@id": "https://ticketpro.ca/event/1677389176",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-09-12T19:30:00-03:00"
      }
    ],
