      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww3.ticketpro.ca/genid/62c2e394be6d83f8"
      },
      {
        "@id": "https://ww3.ticketpro.ca/genid/b89e8f640bb98a42"
