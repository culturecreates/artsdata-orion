    ],
    "http://schema.org/name": [
      {
        "@value": "TIME WARP PROMOTIONS PRESENTS: AWESOME ABBA - Celebrating the music of ABBA"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>AWESOME ABBA is a high-energy touring  tribute band that brings the timeless magic of  ABBA to life with stunning authenticity and  electrifying stage presence. </p>\n\n<p>Featuring a talented group of seasoned  performers, the band captures the sound, style,  and spirit of ABBA with powerful vocals,  dazzling costumes, and dynamic live  performances. </p>\n\n<p>Delivering hit after hit with precision, passion,  and flair, AWESOME ABBA truly lives up to  their name—creating an unforgettable  experience that has audiences singing, dancing,  and feeling completely elevated @ AWESOME.</p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/l8iSg9V0XhY?si=GWHRQVYFLL6ebLf0' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n"
      }
    ],
