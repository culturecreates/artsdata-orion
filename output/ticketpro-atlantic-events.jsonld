    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-27T14:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1661591008"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1662795057.jpeg?version=0"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g997040"
      },
      {
        "@id": "_:g997060"
      },
      {
        "@id": "_:g997080"
      },
      {
        "@id": "_:g997100"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10584"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10584"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Monster Madness & FMX World Tour "
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>ONE MIND-BLOWING SHOW, THREE TIMES THE FUN!</b></p>\n\n<p>Feel the roar of the monster trucks as the Monster Madness Tour stops in Oyster Bed P.E.I. at Oyster Bed Speedway with stars from the 'FMX World Tour' and more! This is an action-packed afternoon fans won't want to miss!</p>\n\n<p>The MONSTER MADNESS TOUR, featuring 5 Monster Trucks, &amp; more will have you on your feet as you watch the 10,000 pound of MONSTER TRUCKS soar through the air! The competition will include tricks like wheelies, racing, monster truck freestyle and more!</p>\n\n<p>The FMX WORLD TOUR act will leave fans and families amazed as death defying stunts only the brave would attempt are performed, inside the arena. FMX World Tour is the perfect blend of athletic ability, extreme stunt competitions and tricks and flips! FMX World Tour stars will perform tricks such as, captain morgan, kiss of death, cliff hangers, in addition to the famous BACKFLIP!</p>\n\n<p><b>PIT PARTY</b> from 1:00 p.m. to 2:00 p.m. <br>\nFans will get a chance to meet the drivers, get up close to the monster trucks, stars of fmx, take pictures and receive autographs.</p>\n\n<p><b>VIP TICKETS</b>: Get access to the pre-show VIP Pity Party, receive a souvenir VIP lanyard, plus get early entry to choose your seats first!</p>\n\n<p>Children 2 and UNDER ON LAP ARE FREE<br>\nChildren 12 AND OLDER = ADULT<br>\nFor more details visit www.edgeentertainmentgroup.ca</p>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n</style>"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
