    "http://schema.org/name": [
      {
        "@value": "Coach K Classic - Current vs Alumni Fundraiser Game"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n<p><b>Event Goals and Objectives:</b> The StFX Alumni Basketball Tournament aims to reconnect former StFX varsity basketball players while raising funds for Antigonish Minor Basketball. The highlight of the event will be an exhibition game featuring current StFX varsity basketball players (men and women) against an alumni team. A Junior X team will play a game during half-time. There will be many opportunities to engage the crowd throughout the event with mini-games in between quarters. The event will promote school spirit, community engagement, and youth sports development. Last year, the Coach K tournament fundraised $3000. We want to step it up from last year and make it an even bigger event. Our goal is to fundraise over $5000 this year for the Antigonish Minor Basketball Association. </p>\n\n<style>.location-page-temp {display: block!important;}\n</style>"
      }
    ],
