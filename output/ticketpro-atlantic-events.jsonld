    "http://schema.org/name": [
      {
        "@value": "CATHERINE'S CELLO - String Quartet & Piano"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Your Osprey's new Sunday Stage kicks off with Atlantic Canadian cellist and 2026 ECMA Nominee, Catherine Little as she leads a group of world class musicians in an unforgettable afternoon concert experience. From the timeless elegance of Handel to the cinematic magic of Morricone, the iconic energy of Queen and much more, emerges a concert of both emotional depth and uplifting fun. Pair it with a brunch or lunch from one of Shelburne's great local eateries and make it an even more tasty and nourishing afternoon.</p>\n\n<style>\n    .titleTax {\n       display: none !important;\n   }\n</style>\n\n"
      }
    ],
