    ],
    "http://schema.org/name": [
      {
        "@value": "The Grand Tour"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>'THE GRAND TOUR' is a timeless journey through classic country music! Join us for electrifying performances of hits from the 50's, 60's, 70's, and 80's.</p>\n\n<p>Experience the soulful voices of George Jones, Johnny Cash, Conway Twitty, Jim Reeves, Charley Pride and much more, brought to life with fresh energy and passion. These talented musicians will have you remembering the days when you would sing along to the radio or sitting at the Grand Ole Opry! Don't miss this nostalgic celebration of country music's rich heritage!</p>\n\n<p>For info on the amazing backgrounds of the musicians in The Grand Tour visit <a href='https://thegrandtour.ca/' target='_blank'>www.thegrandtour.ca</a></p>\n\n<style>\n.location-page-temp {display: block!important;}\n</style>"
      }
