    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproastor.ticketpro.ca/api/v1/resources/1680148971.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g985360"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
