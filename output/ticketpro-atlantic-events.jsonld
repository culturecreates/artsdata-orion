    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10874"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Intervals Music Studio proudly presents Newsies Jr.!"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Seize the day with this inspiring, high-energy musical based on a true story. Follow Jack Kelly and his fellow Newsies as they rise up against powerful publishers, discovering courage and friendship along the way. As the stakes grow higher, the Newsies must decide what they're willing to risk for justice and a better future. Packed with exciting choreography and unforgettable songs like 'Seize the Day' and 'Carrying the Banner', this family-friendly production tells a story of heart, determination, and the power of standing together.</p>\n\n<p>Join us for a powerful 60 minute performance of this timeless story full of spirit and heart.</p>"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
