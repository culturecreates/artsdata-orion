      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Stage and Beyond Pass | Liverpool International Theatre Festival"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>From October 14-18, 2026, the Liverpool International Theatre Festival will showcase 10 curated one-act plays performed by visiting theatre troupes from around the world.</p>\n\n<p>A Stage & Beyond Subscription provides a complete festival experience, including:<br>\n•\tAdmission to all festival performances<br>\n•\tCoffee Critiques featuring the Festival Adjudicator's in-depth daily discussions of each play<br>\n•\tParticipation in selecting the People's Choice Award<br>\n•\tReserved seating for both the Festival Opening and Closing Awards Presentation (new this year)<br>\n•\tNightly entertainment at the Festival Club<br>\n•\tArt happenings and creative events throughout the festival</p>\n\n<p>This subscription offers exceptional value, with an early bird price of $175, compared to $320 if all events were purchased individually. Purchase today and enjoy the full LITF 2026 experience.</p>"
      }
    ],
