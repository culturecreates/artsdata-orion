      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Tunes and Tales"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Tunes and Tales is a multidisciplinary children's performance trio from Prince Edward Island, featuring Leah Ellis, Brieonna Locche, and Lucy Farrell. This lovely group of island storytellers entertain children and families with original musical stories using puppetry and beautiful illustrations delivered via the unique medium of the 'crankie'. Their performances are captivating and heartwarming that invite families into a world of imagination and song.</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
