    "http://schema.org/name": [
      {
        "@value": "TULUA - Irish Traditional"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The Osprey presents TULUA, a young traditional Irish band hailing from the southeast of the Emerald Isle. Meaning 'tribe of many paths' TULUA have been deeply exploring and sharing music of their local area and other parts of Ireland, bringing the audience with them on a captivating journey of songs about love, tunes about life and everything in between.</p>\n\n<style>\n    .titleTax {\n       display: none !important;\n   }\n</style>\n\n"
