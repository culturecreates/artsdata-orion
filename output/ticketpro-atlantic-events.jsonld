    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10775"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "ASH Entertainment Presents: The Alan Jackson Experience"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Aaron Halliday, a two-time ISSA Entertainer of the Year Award winner and Nashville recording artist, presents an internationally recognized tribute to Alan Jackson, featuring CCMA Award-winning musicians. This show is an incredible recreation of an Alan Jackson concert, boasting an authentic look, stage presence, and sound that will transport you to the real thing. Prepare yourself for an energetic and entertaining performance that will have you singing along to 'Good Time' and reminiscing about the past with 'Remember When.' As an added bonus, ticket holders can meet the artists in the lobby during intermission. </p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/Fyr8POiW08M?si=rqWLydhUMdKUytcH' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n"
      }
    ],
