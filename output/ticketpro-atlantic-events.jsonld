    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g792100"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10711"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10711"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Green Room Session with Elizabeth Sheppard"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>2025 Music NL Nominee Elizabeth Sheppard is a soulful folk/pop singer-songwriter from Corner Brook, NL. Her voice has drawn comparisons to Joan Baez and Joni Mitchel. As a therapist for more than 33 years, her songs embrace the complexities of human relationships, with themes of love, loss and resilience. Elizabeth looks forward to meeting new friends in her first show in Nova Scotia as she shares songs from her upcoming full length album. </p>\n\n<p>With listeners around the globe, Elizabeth aims to connect with her audience sharing stories and songs that lift the spirit. You can find her at ElizabethSheppardMusic.ca and streaming platforms everywhere.</p>\n\n<p><b>19+ Event</b></p>\n\n<style>\n.location-page-temp {display: block!important;}\n</style>\n\n"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
