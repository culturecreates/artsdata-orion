    "http://schema.org/name": [
      {
        "@value": "Lucy MacNeil"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Lucy MacNeil is no stranger to Maritime and Newfoundland audiences. As an original member of the famous Barra Macneils, she has criss-crossed the region and the country countless times. In addition to touring with her siblings, Lucy has worked with The Chieftains, Ron Hynes and many other roots music legends. Her concerts will feature three Nova Scotians backing her as she performs the wonderful trad she is so well known for, as well as material from her solo album, Angels Whisper, which she released in 2024.</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
