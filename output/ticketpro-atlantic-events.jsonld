    "http://schema.org/name": [
      {
        "@value": "Brooke and Brad Country Classics"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Fronted by vibrant PEI entertainers Brooke MacArthur and Brad Milliganand backed by a 7-pc band, Brooke and Brad pay homage to the timeless sounds of 60's, the nostalgic sounds of the 90's, and the polished sounds of today's country. Between heartfelt ballads, boot scootin' anthems, and playful duets, Brooke and Brad will have you celebrating the hottest hits in country all night long. Now dawn your denim and grab your cowboy hat for what promises to be a hoot and a holler!</p> \n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
