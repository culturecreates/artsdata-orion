    ],
    "http://schema.org/description": [
      {
        "@value": "<!--<p>Get ready for World Class Boxing as Brandon 'L-Jack' Brewer steps back into the ring for an electrifying showdown! Don't miss it!</p>  -->\n\n<p><i><b>No refunds. Card subject to change.</i></b></p>\n<p><b><u>Pricing:</b></u><br>\n<b>VIP A:</b> $1,200.00 + HST ($180.00) + $10.00 service fee = $1,390.00 HST & fees included per table<br>\n<b>VIP B:</b> $1,000.00 + HST ($150.00) + $10.00 service fee = $1,160.00 HST & fees included per table<br>\n<b>VIP C:</b> $800.00 + HST ($120.00) + $10.00 service fee = $930.00 HST & fees included per table<br>\n<b>Ringside Seating:</b> $160.00 + HST ($24.00) + $5.00 service fee = $189.00 HST & fees included per ticket<br>\n<b>General Admission:</b> $55.00 + HST ($8.25) + $3.00 service fee = $66.25 HST & fees included per ticket</p>"
      }
