    ],
    "http://schema.org/name": [
      {
        "@value": "Wild World - A Tribute To Cat Stevens // Yusuf"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>This Cat Stevens/Yusuf tribute makes its debut with an evening dedicated to some of the\nmost iconic songs of the 1970s. Performed by five accomplished musicians, the show\ncelebrates the timeless music and remarkable journey of the artist known as Cat Stevens,\nlater Yusuf, through a thoughtful blend of live performances and storytelling.\nFeaturing Mario Robichaud as frontman, alongside Carrie MacLellan on piano, Daniel\nDrouin on guitar, Stéphane Bouchard on bass, and Wayne Robichaud on drums, this\ntribute offers an engaging and authentic musical experience. A must-see performance for\nfans of classic songwriting and enduring melodies.</p> \n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
