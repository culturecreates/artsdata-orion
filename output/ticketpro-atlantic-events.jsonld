      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Shanneyganock Live in Concert"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>30 years in the making... Shanneyganock are true ambassadors of Newfoundland and Labrador, celebrated for their authentic brand of traditional folk music and their rollicking, high-energy live performances. Often described as the Pride of Newfoundland and Labrador, Shanneyganock have spent three decades inspiring audiences of all ages, keeping the songs, stories, and spirit of the province alive across multiple generations.</p>\n\n<p>Their concerts are joyful, foot-stomping celebrations that consistently sell out theatres and festival stages alike. From headlining major festivals to performing to sold-out audiences across Atlantic Canada, Shanneyganock have built an extraordinary and fiercely loyal fan base, sharing the culture and musical heritage of Newfoundland and Labrador with audiences around the world.</p>\n\n<p>Their impact has been recognized with numerous honours, including East Coast Music Awards, MusicNL awards, and lifetime achievement recognition, while their unmistakable sound continues to connect deeply with fans at home and on stages far beyond Newfoundland.</p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/WvvEuDOT98Y?si=a0jZAzOQzF6ZlR0M' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
