    "http://schema.org/name": [
      {
        "@value": "La Vie en Danse Studio - Competitive Showcase"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Our talented dancers, ages 8-18, will take the stage in a dynamic performance featuring a wide range of styles, including Ballet, Contemporary, Lyrical, Modern, Contemporary Jazz, and Open (a fusion of Acro and lyrical/contemporary).\nExperience the art of storytelling through movement as each routine brings emotion, creativity, and passion to life.</p>\n\n<p>'Don't miss this inspiring celebration of dance!</p>\n\n<style>\n.titleTax {display: none !important;}\n</style>\n\n\n\n\n\n"
      }
    ],
