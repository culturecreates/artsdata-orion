    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10813"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10813"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Monster Madness & FMX World Tour "
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>2 Mind Blowing Shows... Three times the fun! </b></p>\n\n<p>Feel the roar of the monster trucks as the Monster Madness Tour stops in Fredericton New Brunswick at NBEX Fair Grounds with stars from the 'FMX World Tour' and more! This is an action-packed show fans won't want to miss!</p>\n\n<p>MONSTER MADNESS TOUR: Rat Nasty Monster Madness Champion returns with 5 of the biggest Monster Trucks in the world. Including Canada's #1 female Monster Truck SABOTAGE. Monster Madness will have you on your feet as you watch the 10,000 pounds of MONSTER TRUCKS soar through the air! The competition will include tricks like wheelies, racing, monster truck freestyle and more!</p>\n\n<p>FMX WORLD TOUR will leave fans and families amazed as death defying stunts only the brave would attempt are performed, inside the arena. FMX World Tour is the perfect blend of athletic ability, extreme stunt competitions and tricks and flips! FMX World Tour stars will be performing such tricks as, captain morgan, kiss of death, cliff hangers, in addition to the famous BACKFLIP!</p>\n\n<p><b>PIT PARTY</b>\nFans will get a chance to meet the drivers, get up close to the monster trucks, stars of fmx, take pictures and receive autographs. Plus True North the official Monster Madness Ride Truck will be taking part in the pit party. </p>\n\n<p><b>VIP TICKETS</b>: Get access to the pre-show VIP Pity Party, receive a souvenir VIP lanyard, plus get early entry to choose your seats first!</p>\n\n<p>Children 2 and UNDER ON LAP ARE FREE<br>\nChildren 12 AND OLDER = ADULT<br>\nFor more details visit www.edgeentertainmentgroup.ca<br>\nTICKET PRICES INCREASE by $5.00 May 1<sup>st</sup>.</p>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n</style>"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
