    "http://schema.org/description": [
      {
        "@value": "<p>Symply Skynyrd - The Lynyrd Skynyrd Tribute show delivers an electrifying live concert\nexperience, celebrating the legendary Southern rock sound of Lynyrd Skynyrd. Playing at\ntheaters, festivals, and special events, Symply Skynyrd captures the spirit of Skynyrd's\niconic live performances with precision and passion. The band's repertoire spans Skynyrd's\nchart-topping hits and fan favourites, offering a show that resonates with both casual\nlisteners and devoted fans. Each member is a true Southern rock enthusiast, committed to\nhonouring the legacy of Lynyrd Skynyrd through authentic sound, energy, and\nperformance.<br><br>\nSee Them In Action:</p> \n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/yMhXSVftZsk?si=VenBJMNqSmuDWzGy' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
