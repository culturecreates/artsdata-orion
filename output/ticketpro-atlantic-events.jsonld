    "http://schema.org/description": [
      {
        "@value": "<p><b>VIP Amenities</b>: dedicated entry gate, premium bar service, 10% discount at The Jubilee Merch Shop & more to be announced soon! </p>\n\n<p>For more info visit: <a href='https://thejubilee.ca/' target='_blank'><b>TheJubilee.ca</b></a></p>\n\n<p><b>Refund Policy & Disclaimer: Artists subject to change, no refunds will be issued for any circumstance. </b></p>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n</style>\n\n"
