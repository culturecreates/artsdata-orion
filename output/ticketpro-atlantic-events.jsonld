    ],
    "http://schema.org/name": [
      {
        "@value": "COUNTRY BOYS, a tribute to Alan Jackson, Garth Brooks, Brad Paisley & George Strait - CHRISTMAS EDITION"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Imagine a Christmas show with these 4 Country Music icons together on one stage at the same time... The Country Boys Christmas show will take you there!</p>\n\n<p>Featuring Scott Delhunty, Gerald Delhunty, Marc Babin and Daniel Goguen, along with 5 other musicians, this show will put you in the Christmas spirit with Traditional Country Christmas songs and great Holiday Classics.  Celebrate the Holiday Season with this one-of-a-kind show!</p>\n\n\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>"
      }
    ],
