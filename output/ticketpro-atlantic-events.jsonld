  {
    "@id": "https://ticketpro.ca/event/1695801856",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-08T19:30:00-03:00"
      }
    ],
