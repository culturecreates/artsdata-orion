      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Mark Winters: Good Vibes Highway Tour"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<pThe Good Vibes Highway Tour is a musical road trip dedicated to sharing positive, nerdy energy with communities across the U.S. and Canada. Each stop blends humor, heart, and harmony — delivering feel-good acoustic performances that leave audiences smiling and inspired.</p>\n\n<p>With songs that remind us to 'Shine' with each other and share our positive energy, the tour celebrates curiosity, kindness, and connection through music. Fueled by protons, It's part science enthusiasm, part storytelling, and all about lifting spirits — one campground, coffeehouse, and community stage at a time.\n</p>\n\n<p>Whether under the stars at a national park or on stage in a bustling city, the Good Vibes Highway Tour invites everyone to unplug, laugh, and share a little light along the way.</p>\n\n<p>Find out more at <b><a href='https://www.markwintersmusic.com ' target='_blank'>markwintersmusic.com</a></b></p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/wzZdJyt09lM?si=WoVhtrV_mfDczBzT' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n"
      }
    ],
