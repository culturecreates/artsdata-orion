  {
    "@id": "https://ticketpro.ca/event/1671961188",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-21T19:30:00-03:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/10427772"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproastor.ticketpro.ca/api/v1/resources/1671919925.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1143640"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10684"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10684"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "MY LIFE - The Billy Joel Experience"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>North America's premiere Billy Joel tribute concert experience featuring a look-a-like and sound-a-like performance by Elton Lammie, who is one of the continents finest award-winning vocalists, and an accomplished multi-instrumentalist who has mastered more than 10 instruments. He is the winner of dozens of awards for his vocal skills, including two nationwide vocal competitions.</p>\n\n<p>This Definitive Tribute to Billy Joel, is an unforgettable show that showcases the best of the best songs, by one of the most recognized stars in music. </p>\n\n<p>A truly memorable evening that includes the songs; My Life, Allentown, Piano Man, She's Always A Woman, Scenes from an Italian Restaurant, Only The Good Die Young, Big Shot, Movin' Out, Just The Way You Are, New York State of Mind, Uptown Girl, For The Longest Time, Still Rock'n'Roll To Me, You May Be Right and any more classics.</p>\n\n<p>Billy Joel wrote 33 Top 40 hits, and is a six-time Grammy award winner who has sold more than 150 million records worldwide. </p>\n\n\n\n\n\n"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
