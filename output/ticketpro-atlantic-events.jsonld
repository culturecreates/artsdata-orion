    "http://schema.org/name": [
      {
        "@value": "Green Room Session with Elyse Aeryn"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Award-winning Nova Scotia artist Elyse Aeryn brings her soulful roots-rock sound and powerful storytelling to an intimate Green Room Session at Glasgow Square. Known for her gritty vocals, heartfelt songwriting, and dynamic stage presence, Elyse creates performances that are both raw and deeply personal. Named Music Nova Scotia's 2024 Entertainer of the Year, she continues to make waves across Atlantic Canada with music that blends classic rock spirit with modern edge. This special up-close performance offers audiences a chance to experience one of the region's most exciting rising artists in a unique listening-room setting.</p>\n\n\n\n<style>\n.location-page-temp {display: block!important;}\n</style>\n\n"
      }
