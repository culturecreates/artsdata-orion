    "http://schema.org/description": [
      {
        "@value": "<p>Check out our <a href='https://www.antigonishhighlandgames.ca/' target='_blank'>website</a> or <a href='https://www.facebook.com/antigonishgames' target='_blank'>Facebook</a> & <a href='https://www.instagram.com/antigonish_highland_games/' target='_blank'>Instagram</a> pages to see the schedule of events.</p>\n\n<p>We look forward to having you join us.</p>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n</style>"
      }
