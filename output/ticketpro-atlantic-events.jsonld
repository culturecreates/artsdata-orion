      {
        "@value": "Trunk 7 Music Festival - FRIDAY | Ria Mae"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Homegrown music festival featuring local youth to professional acts. </p>\n\n<p><a href='https://trunk7musicfestival.com/' target='_blank'>trunk7musicfestival.com</a></p>\n\n<p><b>VIP includes</b>:\n<ul><li><b>Dedicated/VIP-only lounge or tent area</b> (shaded, more room, seating or comfy furniture) rather than general-admission crowding. </li>\n<li><b>Priority access / shorter lines / separate entrances or bar lanes</b> for VIP holders, for drinks, restrooms.\n<li><b>Better or reserved seating or viewing zones</b> (platforms, seating near stages, etc.), less-crowded vantage points.</li> \n<li><b>Food or drink perks</b>: VIP/membership  include free snacks, water and food service delivery. </li></ul></p>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n</style>\n"
      }
