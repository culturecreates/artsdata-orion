    "http://schema.org/name": [
      {
        "@value": "Rocky Horror Picture Show with Shadowcast"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Zip up your thigh-high boots and dig out your fishnets! Truro Pride presents Rocky Horror Picture Show, just in time for Truro Pride Week. Come watch this beloved queer-classic with props in hand as a shadowcast dances and dives in front of the movie screen, re-enacting performances from the film.</p>\n\n<p>Props will be supplied to viewers upon entry. Costumes encouraged but not mandatory!</p>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>"
      }
    ],
