    "http://schema.org/name": [
      {
        "@value": "WEEKEND PASS - New Brunswick Highland Games Festival"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The NB Highland Games Festival celebrates and shares knowledge of the culture and heritage in an inclusive manner — whether visitors are of Scottish descent or simply wish to learn about and participate in this vibrant culture.The Festival offers workshops, entertainment, competitions and provides visitors an opportunity to learn more about Scottish heritage.</p>\n"
      }
