      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Off the Rock - Great Big Sea Tribute"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>An incredible high-energy show that features the greatest hits of Great Big Sea and a few select traditional east coast classics. 'Off The Rock' delivers an interactive and engaging show that keep audiences talking for days, weeks and sometimes months after the event, leaving lasting memories of good times, great music, and tons of fun out on the town!</p>\n\n<p>Featuring the musical talents of Anthony Clayton, Thom Danger Speck, Sean Battams, Steve Peckford, and David Skolnick, this dynamic group brings the spirit of the Canadian East Coast home, wherever home may be.</p>\n\n"
      }
    ],
