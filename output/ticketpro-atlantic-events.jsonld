    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1695410350.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww3.ticketpro.ca/genid/4819a992dcd6ffc7"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10950"
