      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Fiesta Night: Dance to the Rhythms"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n\n<p><b>19+ Event.</b></p>\n\n<p>Feel the rhythm at Fiesta Night! Everyone is welcome to dance the night away to reggae, salsa, bachata, merengue, reggaetón, samba, cumbia, afrobeats, electro tango, and more. Whether you're a seasoned dancer or just want to enjoy the atmosphere, this celebration is for all.</p>\n\n<p>Bring your energy, wear your dancing shoes, and join us for an unforgettable Latin-style celebration.</p>\n\n<p>Bring your friends, gather your family, surprise your partner, or come on your own and meet new people—Fiesta Night is all about sharing great music, great company, and great memories. Please plan a safe ride home so you can relax, celebrate, and enjoy the night to the fullest.</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n"
      }
