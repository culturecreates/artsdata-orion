      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1692245463.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1213300"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
