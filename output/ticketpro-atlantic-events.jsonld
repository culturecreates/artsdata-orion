        "@value": "2026-04-19T14:00:00-03:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1124746250"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1651843012.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1351700"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10471"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10471"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "The Island Jubilee Old Time Radio Music Show"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n<p>'An authentic Opry experience' - Ron Bickle - Radio Broadcaster - Tantramar 107.9FM CFTA</p>\n<p>The Island Jubilee Old Time Radio Music Show is a captivating experience that transports audiences back to the golden age of radio.   \n<p>Inspired by the beloved Grand Ole Opry and CBC's Tommy Hunter Show, this authentic production presents Old Time Country & Western, Hillbilly and Old Mountain Music interpreted by the Island's finest artists.   The show explores the early sounds of Jimmy Rogers, Kitty Wells, Hank Snow, Ernest Tubb, Bill Monroe, Johnny Cash, Patsy Cline, George Jones, Loretta Lynn and many others, in an era when voices and stories were at the forefront of music - Old school songs with three chords and the truth set to twangy telecasters, crying steel guitars, fiddle and banjo, and the thump of an old beat up doghouse bass.\n<p>With an all-star professional cast, special guests, dazzling step dancers, and captivating storytellers, each performance is recorded live in front of a studio audience here at its home at the prestigious Florence Simmons Performance Hall and edited into an exciting syndicated radio broadcast showcasing the Island's brightest stars.\n\n<p>Experience the nostalgia, join the fun and be part of our studio audience - We have spectacular shows lined up for the season.  Visit <a href='https://islandjubilee.com/' target='_blank'>www.islandjubilee.com</a> for more news on upcoming shows and please join our radio fan club.  We proudly support the QEH Foundation and the Holland College School of Performing Arts.  Proudly supported by Tantramar 107.9 FM CFTA, Coach Atlantic Transportation Group, Red Shores, and PEI Events Innovation Fund.  \n\n\n</p>\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>\n"
      }
    ],
