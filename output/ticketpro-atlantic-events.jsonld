  {
    "@id": "https://ticketpro.ca/event/1670574570",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": ""
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1368408503"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tpronsaa.ticketpro.ca/api/v1/resources/1650148344.jpeg?version=5"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1614260"
