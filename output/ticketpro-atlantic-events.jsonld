    "http://schema.org/name": [
      {
        "@value": "TIME WARP PROMOTIONS PRESENTS: PIANO MEN - Celebrating the music of Elton John and Billy Joel"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Get ready for an ultimate concert experience that is out of this world! </p>\n<p>Together, Billy Joel and Elton John have sold over a billion records worldwide. Join us in a  tribute to and celebration of two of the biggest musical superstars on the planet. This full  band musical experience with musicians from Rock of Ages will feature vocalist, pianist extraordinaire and tribute artist Jeff Brewer, who has performed internationally to large,  sold-out audiences everywhere!</p>\n<p>This will be a very interactive show, inviting YOU, THE AUDIENCE to sing along to hit after hit  to musical anthems that have been the soundtrack to many of our lives!</p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/Gn3kgiRhb0E?si=N_Y2EdOIDqd6aFMK' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n"
      }
