      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1692245475.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww3.ticketpro.ca/genid/94cea9ad96b37eef"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10885"
