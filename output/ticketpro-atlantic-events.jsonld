    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1691795557.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww3.ticketpro.ca/genid/8373d0d77d9c7490"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10878"
