    ],
    "http://schema.org/name": [
      {
        "@value": "DIDO & AENEAS - Maritime Concert Opera"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The Osprey Arts Centre proudly presents Maritime Concert Opera performing Henry Purcell's Dido & Aeneas, widely regarded as a masterpiece of early English opera admired for its intense emotional power, economical scoring, and the profound tragedy of 'Dido's Lament.'  With a stellar cast of six accompanied by the MCO Chorus and directed by Tara Scott. Reserved seating. </p>\n\n<style>\n    .titleTax {\n       display: none !important;\n   }\n</style>\n\n"
      }
    ],
