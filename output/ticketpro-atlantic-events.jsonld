  {
    "@id": "https://ticketpro.ca/event/1687322113",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-20T19:30:00-03:00"
