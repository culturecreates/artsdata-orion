    ],
    "http://schema.org/name": [
      {
        "@value": "GYPSY - Premiere \"Fleetwood Mac\" Tribute"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>'Gypsy' The Premiere 'Fleetwood Mac' Tribute band features accomplished musicians, who deliver a world-class show! The songs of this iconic recording artist transcend across three generations of music fans. Their award-winning album called' Rumours' has sold close to 50 million copies. Fleetwood Mac has reached international acclaim with countless Billboard charting smash hits.</p>\n\n<p>The 'Gypsy' Fleetwood Mac experience is a truly authentic representation of this multiple award-winning musical group, and their very best songs of all time, including Stevie Nicks duets with Don Henley and Tom Petty.</p>\n\n<p>Their spectacular show repertoire includes; 'Dreams, Go your Own Way, Rhiannon, Don't Stop, The Chain,' and many more fan favourites.</p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/_MqMRfDxVMw?si=aHg-smjsbnO7FYmK' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n\n@media screen and (max-width:728px) {\niframe{width:100%!important;}\n}\n</style>"
      }
    ],
