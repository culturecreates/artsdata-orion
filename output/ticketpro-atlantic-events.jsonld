    "http://schema.org/name": [
      {
        "@value": "Bad Moon Rising - A Tribute to CCR"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>They're BACK!<br> \nBAD MOON RISING</b> Join us for an evening of great music and the story of one of America's greatest Rock Bands Creedence Clearwater Revival. The Dunk River Band Returns to the stage in this fresh show that will take you through the rise and fall of thism iconic music group. Playing all your favorite tracks including songs from front man John Fogerty's solo career. It's going to be a great show suitable for all ages</p> \n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
