    "http://schema.org/description": [
      {
        "@value": "<p>Danspirations is proud to present their 2026 year end recital. Welcoming all to attend a fun\nfilled entertaining afternoon. Dancers ages 3 to 23 showcasing our love and enjoyment of\nballet, modern, tap and contemporary. Hope to see you there!</p> \n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
