    "http://schema.org/name": [
      {
        "@value": "JONATHAN MAK"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Coming to your Osprey this November is pianist Jonathan Mak. Winner of the 2023 inaugural Bader & Overton Canadian Piano Competition, Jonathan Mak first made his orchestra debut at the age of four. Since then, he has been a guest soloist with numerous orchestras, most notably the Orchestre Symphonique de Montréal. He has also participated in the 16th Van Cliburn International Piano Competition and the Dublin International Piano Competition, and was named as one of CBC's 30 hot Canadian classical musicians under 30.</p>\n\n<style>\n    .titleTax {\n       display: none !important;\n   }\n</style>\n\n"
      }
