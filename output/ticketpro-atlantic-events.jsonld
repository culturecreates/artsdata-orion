      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproatlantic.ticketpro.ca/api/v1/resources/1677388464.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g709380"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
