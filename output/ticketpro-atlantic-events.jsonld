  {
    "@id": "https://ticketpro.ca/event/1693100821",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-05T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/55150121"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprogst.ticketpro.ca/api/v1/resources/1693373161.jpeg?version=0"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww3.ticketpro.ca/genid/2220552da1230626"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww3.ticketpro.ca/event.php?event_id=10899"
