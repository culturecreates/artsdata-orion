        "@id": "https://ticketpro.ca/place/1314245752"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprocob.ticketpro.ca/api/v1/resources/1688242964.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
