    "http://schema.org/name": [
      {
        "@value": "Roch Voisine - The Lightfoot Sessions Live"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Acclaimed Canadian singer songwriter Roch Voisine returns to the stage with\nThe Lightfoot Sessions, a new concert experience paying tribute to the legendary Gordon\nLightfoot. Reimagining some of the most iconic songs in the Canadian songbook, Roch\nbrings a fresh and intimate perspective to Lightfoot's timeless repertoire, while revisiting\nhighlights from his own celebrated career. </p>"
      }
