    "http://schema.org/name": [
      {
        "@value": "Teagan Littlechief"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Teagan Littlechief's country rock show promises an exhilarating journey filled\nwith captivating energy and uplifting melodies. She delivers a memorable\nperformance commanding attention from the start. With powerful vocals and\ninfectious energy, she leaves audiences spellbound and hungry for more. What\ntruly sets Teagan's show apart is its unmatched energy and intensity, leaving\naudiences uplifted, inspired, and craving an encore. Teagan Littlechief's country\nrock extravaganza is not just a concert—it's an unforgettable experience\ncelebrating the power of live performance.</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n.titleTax {display: none !important;}\n</style>"
      }
    ],
