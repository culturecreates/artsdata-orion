    "http://schema.org/name": [
      {
        "@value": "WEDNESDAY SERIES | Maclab Centre for the Performing Arts | 2026-2027 Season Subscription"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>Includes a ticket to all shows presented during the 2026-2027 Wednesday Series:</b>\n\n<li><b>Tracy Millar</b> - Wednesday, September 9, 2026</li>\n<li><b>Dave McCann</b> - Wednesday, September 16, 2026</li>\n<li><b>Mark Davis</b> - Wednesday, October 7, 2026</li>\n<li><b>Black Gold School Division Teachers' Band</b> - Wednesday, October 14, 2026</li>\n<li><b>Connectivity Dance</b> - Wednesday, January 20, 2027</li>\n<li><b>Beaumont School of Highland Dance</b> - Wednesday, February 17, 2027</li>\n<li><b>Panache</b> - Wednesday, February 24, 2027</li>\n<li><b>Viter Ukrainian Dancers and Folk Choir</b> - Wednesday, March 24, 2027</li>\n<li><b>Leduc Drama Society</b> - Wednesday, March 31, 2027</li>\n<li><b>Leduc Music Festival</b> - Wednesday, May 19, 2027</li>\n<li><b>Beaumont Society School of Dance</b> - Wednesday, May 26, 2027</li>\n<li><b>Off The Rails</b> - Wednesday, June 2, 2027</li>\n<li><b>The Brasstactics</b> - Wednesday, June 9, 2027</li>\n<li><b>Everett LaRoi</b> - Wednesday, June 16, 2027</li>\n\n\n</p>\n"
      }
    ],
