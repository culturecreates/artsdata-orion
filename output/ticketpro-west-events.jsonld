    ],
    "http://schema.org/name": [
      {
        "@value": "We Lend a Hand: The Forgotten Story of the Ontario Farmerettes Film Screening "
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Discover the remarkable, long‑overlooked history of the Ontario Farm Service Force, which mobilized 40,000 teenage girls between 1941 and 1952 to sustain critical food production during wartime. Through vivid reenactments and rare archival footage, the film revisits their resilience, hardships and triumphs, as former participants describe a defining chapter of service, strength and sisterhood.</p>\n \n<p>Presented in partnership with 19 on the Park Theatre and the Whitchurch-Stouffville Museum. </p>"
      }
    ],
