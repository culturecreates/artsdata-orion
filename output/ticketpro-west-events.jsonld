    "http://schema.org/name": [
      {
        "@value": "Bangs, Bobs & Banter: Confessions of a Hairstylist"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Inspired by true stories,12x award-winning artist Joanna Rannelli stars as Nikki, a hairstylist who welcomes audiences into her salon, where a lively cast of clients spill their sassy, saucy and scandalous secrets. Portraying 10+ unforgettable characters, this humorous journey through beauty, self-expression, and unexpected connections is a must-see that will keep audiences laughing their heads off ...without messing up their hair.</p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/5HWUZEaNDU8?si=BcKnSnXlNYD9peq6' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style>"
      }
