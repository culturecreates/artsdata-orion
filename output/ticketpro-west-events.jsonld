    "http://schema.org/name": [
      {
        "@value": "Six Nations Bingo presents Monster Bingo - Over $50,000 in guaranteed prizes"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>With over $50,000 in guaranteed prizes, featuring a $20,000 must go final jackpot, it's the Sunday you won't want to miss! Join us on the 1st Sunday of every month for your chance at the monster prize!</p>\n\n<p>\n<li><b>Paper Package:</b> Includes one book of 15 faces per game. $10 in Rewards Points will be added to your Six Nations Players Card to offset any applicable fees </li>\n<li><b>Machine Package 1:</b> Machine package includes one paper book, one of each special (one strip), one warm up, one Toonie and one Big Bucks.\n$15 in Rewards Points will be added to your Six Nations Players Card to offset any applicable fees</li>\n<li><b>Machine Package 2:</b> Machine package includes one paper book, one of each special (one strip), one warm up, one Toonie and one Big Bucks. $20 in Rewards Points will be added to your Six Nations Players Card to offset any applicable fees</li>\n</p>\n\n<p>For full event details, visit <a href='https://sixnationsbingo.ca/home/monster/' target='_blank'>sixnationsbingo.ca/home/monster</a></p>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n.titleTax {display: none !important;}\n</style>\n"
      }
