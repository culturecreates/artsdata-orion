    "http://schema.org/description": [
      {
        "@value": "<p>Spectacular show featuring Monster trucks with former World Champion Overkill Evolution, but also freestyle motocross and ATV races.</p>\n\n<p>Don't miss the VIP Pit Party - meet the drivers and see the monster trucks up close on the floor before and after the show for pictures and autographs add the VIP PIT PARTY upgrade.</p>\n\n<!-- <p>For Groups 9+ Contact 647-201-3349 or <a href='mailto:Lori@FirstClassGroupTickets.com'>Lori@FirstClassGroupTickets.com</a>.</p>-->\n\n\n<style>\n.location-page-temp {display: block!important;}\n</style>"
