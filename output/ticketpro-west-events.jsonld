    "http://schema.org/name": [
      {
        "@value": "Barn Burner - Charity Game to Benefit Local Organizations"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Visit<a href=' https://bootsandheartsbarnburner.ca/' target='_blank'> bootsandheartsbarnburner.ca</a> for the most up to date information.</p>\n\n<p>The Barn Burner hockey game, which has hosted the NHL's top talent will be returning to the Sadlon Arena in Barrie on August 6th.<br><br>\n\nThe Boots and Hearts Barn Burner is a charity hockey game that raises money for the Royal Victoria Health Centre, Rotary, PIE Education, Easter Seals and CMHA in Barrie, Ontario.\n\n<br>\n\nOrder your ticket today to see NHL stars 'lace 'em up' right here in Barrie.\n</p>\n\n<p>Participating hockey players to be announced. Please visit Barn Burner <a href='https://www.facebook.com/BootsandHeartsBarnBurner/' target='_blank'><span style='color: #0066cc;'><u><b>Facebook Page</b></u></span></a>, <a href='https://www.instagram.com/bootsandheartsbarnburner/' target='_blank'><span style='color: #0066cc;'><u><b>Instagram</b></u></span></a> and <a href='https://twitter.com/BootsBarnBurner' target='_blank'><span style='color: #0066cc;'><u><b>Twitter</b></u></span></a> for more information. </p>\n\n\n\n<p>Doors open at 5:30 p.m. and the puck drops at 7:00 p.m.</p>\n\n\n"
      }
