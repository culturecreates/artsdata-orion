        "@id": "https://ticketpro.ca/place/1665574204"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprowest.ticketpro.ca/api/v1/resources/1665115383.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g623880"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7196"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7196"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Brian Patafie & Friends FUNNY AS PUCK Tour"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p> On Friday, June 12<sup>th</sup> former NHL Calgary Flames Trainer (turned Standup Comedian) Brian Patafie will be appearing at the Another Round Sports Bar here in Weyburn. He will be bringing his brand new FUNNY AS PUCK show to the 2nd Street Venue.  Just over five years ago Brian (affectionately referred to as Comedy's Original Enter-Trainer) finished a forty four year career as an athletic trainer in professional hockey including almost twenty years with the NHL's Calgary Flames. Brian kept a diary of his day to day adventures and following his hockey career he turned those notes along with a plethora of stories of his dysfunctional upbringing in a military home into an absolutely hilarious standup comedy routine. He has not only shared his stories multiple times touring across North America he also embarked on a multi city, multi show tour throughout the United Kingdom back in October of 2022. WELL, here is your opportunity to enjoy an evening with one of the most charismatic and entertaining figures from the world of professional hockey as he shares his interesting and somewhat dysfunctional life stories on stage. As an added bonus joining Brian on this show will be joined by Anjelene Mittelholtz the First Lady of Hilarity from Saskatoon.</p>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style>\n"
      }
    ],
