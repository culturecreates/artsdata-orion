        "@id": "https://ticketpro.ca/place/1470487301"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproontario.ticketpro.ca/api/v1/resources/1677388480.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1390540"
      },
