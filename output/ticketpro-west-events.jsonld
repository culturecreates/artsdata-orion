    "http://schema.org/name": [
      {
        "@value": "Last Birds"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Last Birds' intimate, one mic performance style blends contemporary folk and traditional country music. Through haunting vocal harmonies and interwoven acoustic guitars, the duo tells stories of small-town experiences and the challenges of prairie life. Mike Davis and Lindsay Arnold draw audiences into a shared experience with their honest lyrics and authentic spousal banter that is satisfyingly bittersweet, often humorous, and always mesmerizing to watch.</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n.titleTax {display: none !important;}\n</style>"
      }
