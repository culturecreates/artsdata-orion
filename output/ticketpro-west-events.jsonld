    "http://schema.org/description": [
      {
        "@value": "<p><b>Includes a ticket to all shows presented during the 2026-2027 Season:</b><br><br>\n\n<b>Kellie Loder</b> - Saturday, October 24, 2026<br>\n<b>Menestrel with guest artist Vincent Lauzer</b> - Friday, November 13, 2026<br>\n<b> Last Birds</b>- Friday, January 22, 2027</p>\n<b>The Johner Brothers</b>- Saturday, March 20, 2027</p>\n<b>The Fugitives</b>- Saturday, May 1, 2027</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n.titleTax {display: none !important;}\n.location-page-temp {display: none!important;}\n</style>"
