      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprocob.ticketpro.ca/api/v1/resources/1667605902.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww2.ticketpro.ca/genid/ee9372e1c870e205"
      },
      {
        "@id": "https://ww2.ticketpro.ca/genid/54b787923ec0c0b6"
      },
      {
        "@id": "https://ww2.ticketpro.ca/genid/15f2f644d8962890"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7211"
      }
    ],
    "http://schema.org/url": [
