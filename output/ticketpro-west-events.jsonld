    "http://schema.org/name": [
      {
        "@value": "DARK GOTHIC Candlelit Experience"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>An outstanding string quartet brings iconic, mysterious soundtracks to life in a unique, cinematic experience. It is a journey through shadow, emotion, and sound, completely illuminated by the warm glow of hundreds of candles.</p>\n<p>Program Repertoire: <i>Wednesday, Stranger Things</i> (dark pieces), <i<The Addams Family, Tim Burton</i> themes, <i>The Phantom of the Opera</i>, and many others.</p>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style> \n"
      }
