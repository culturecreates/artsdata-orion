      }
    ],
    "http://schema.org/name": [
      {
        "@value": "The Music of Ennio Morricone - Piano Recital with String Quartet"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>We invite you to experience a magnificent selection of works by one of the greatest composers in cinematic history. This unique concert brings to life a rich repertoire of Morricone's most beloved masterpieces, performed in an intimate setting as a piano recital accompanied by a string quartet.</p>\n\n<p>During this extraordinary musical journey, you will enjoy unforgettable themes from cult films that have accompanied generations of audiences worldwide, including <i>Cinema Paradiso</i>, <i>The Mission</i>, <i>The Good, the Bad and the Ugly</i>, <i>Once Upon a Time in America</i>, <i>The Untouchables</i>, and many more. Join us for an emotional voyage through the timeless world of film music created by one of the most influential composers of modern history.</p>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style> \n"
      }
    ],
