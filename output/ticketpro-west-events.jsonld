    "http://schema.org/name": [
      {
        "@value": "An Afternoon with Spirit hosted by Sherry Gallant"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Join Medium Sherry Gallant for this intimate afternoon full of messages, insight, and inspiration at An Afternoon with Spirit. Come and witness healing, questions answered, and closure as Sherry connects with spirit to deliver heartfelt messages and guidance. Experience uplifting energy, spiritual connection, and meaningful moments in a warm, welcoming atmosphere. Get your tickets today for an unforgettable afternoon with Medium Sherry Gallant and Spirit.</p>\n\n\n\n\n<style>\n@media screen and (max-width: 600px){\niframe{width:100%;}\n}\n</style>\n\n"
      }
