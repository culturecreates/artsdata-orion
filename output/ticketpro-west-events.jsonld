    "http://schema.org/name": [
      {
        "@value": "Up on Cripple Creek: The Songbook of the The Band"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>For the last 13 years <i>Up On Cripple Creek</i> has delivered wonderful interpretations of classic tunes from the deep catalogue of songs created by Levon Helm, Robbie Robertson, Garth Hudson, Rick Danko and Richard Manuel, who were collectively performed and recorded as The Band. An all-star troupe expertly performs everything from 'The Night They Drove Old Dixie Down', 'Stage Fright', 'The Weight', and solo material from Levon Helm's discography. <i>Up On Cripple Creek</i> is produced by Peter North who also produced <i>The Gift: The Words & Music of Ian Tyson</i> which previously sold-out the Shell Theatre.</p>\n\n\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style>"
      }
