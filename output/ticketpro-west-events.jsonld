    ],
    "http://schema.org/description": [
      {
        "@value": "<p>It's NWSS Music's final show of the year!  Featuring Strings, Choral, Band, and Jazz Ensembles in a memorable performance that will knock your socks off!  Alumni are invited onstage for the final piece of the night, the infamous GALLOP!   </p>\n\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
