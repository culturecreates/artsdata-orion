    "http://schema.org/image": [
      {
        "@id": "https://tprowest.ticketpro.ca/api/v1/resources/1691795577.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww2.ticketpro.ca/genid/631db4120a5eb597"
