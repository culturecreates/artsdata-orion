    "http://schema.org/name": [
      {
        "@value": "\"The Music of Adele\" ft. the Valkyrie String Quartet"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Valkyrie String Quartet is one of the most sought-after Edmonton based string ensembles and we are proud to have them back in Fort Saskatchewan this season.  Playing the contemporary music of Adele, that moves you and tugs at your heartstrings, these classically inspired renditions will make you fall in love with orchestral music all over again. See why Valkyrie String Quartet soars above the rest in a night of music that you know and love.</p>\n\n<p><a href='https://www.valkyriequartet.com/' target='_blank'>valkyriequartet.com</a></p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/5aFsKXsiIOA?si=H5mLQQ8_eFCJ4d-z' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style>"
      }
