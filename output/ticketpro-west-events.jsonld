      {
        "@value": "3 PACK - Includes 3 tickets valid for any of the events presented this season"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>2026/27 Stars for Saskatchewan Tour:</b><br />\n<i>Available online only.</i></p>\n\n<p>Ticket valid for:<br />\n<b>The Johner Brothers - Thursday, February 4, 2027<br>\nLast Birds - Saturday, March 20, 2027<br>\nJessica Rhaye with Preeper and MacKay - Friday, April 23, 2027</b><br />\nDoors: 6:30 P.M. | Showtime: 7:30 P.M.</p>\n\n<p>ADMIT 1 ENTRY<br /><br />Children 12 and under are free if accompanied by an adult. No ticket required.</span></p>\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
