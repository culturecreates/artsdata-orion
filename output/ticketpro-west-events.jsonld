    "http://schema.org/name": [
      {
        "@value": "Shari Ulrich"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Award-winning Canadian singer-songwriter and multi-instrumentalist Shari Ulrich has spent over four decades captivating audiences across North America with insightful songs, warmth, and charisma, recording 25 albums solo and with renowned bands.</p>\n\n<p>Please contact Birgit at Korner Kitchen directly for any dietary restrictions/requests: <a href='mailto:braggskornerkitchen@gmail.com'>braggskornerkitchen@gmail.com</a>.</p>\n\n<style>\n.location-page-temp {display: block!important;}\n</style>"
      }
