    "http://schema.org/name": [
      {
        "@value": "Sauble Beach Party 2026 - WEEKEND PASS - September 4-6, 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<style>\n    body {}\n .tw-page-container-image{flex-grow: unset!important;}\n\n.containerSauble {\n  max-width: 1000px;\n  margin-left: auto;\n  margin-right: auto;\n  padding-left: 10px;\n  padding-right: 10px;\n  font-size: 12px!important;\n}\n\nh2 {\n  font-size: 26px;\n  margin: 10px 0;\n  text-align: center;\n  small {\n    font-size: 14px!important;\n  }\n}\n\n.responsive-table{padding-inline-start: 0px!important;}\n    \n.responsive-table {\n  li {\n    padding: 10px 10px;\n    display: flex;\n    justify-content: space-between;\n    margin-bottom: 5px;\n  }\n  .table-header {\n    background-color: #f4f4f9;\n    font-size: 12px;\n    text-transform: uppercase;\n    font-weight: bold;\n      \n  }\n  .table-row {\n    background-color: #ffffff;\n      border: 1px solid rgba(0,0,0,0.1);\n      font-size: 12px;\n    /*box-shadow: 0px 0px 9px 0px rgba(0,0,0,0.1);*/\n  }\n  .col-1 {\n    flex-basis: 20%;\n  }\n  .col-2 {\n    flex-basis: 40%;\n  }\n  .col-3 {\n    flex-basis: 25%;\n  }\n  .col-4 {\n    flex-basis: 25%;\n  }\n  \n  @media all and (max-width: 767px) {\n    .table-header {\n      display: none;\n    }\n    .table-row{text-align: left;\n      \n    }\n    li {\n      display: block;\n    }\n    .col {\n      \n      flex-basis: 100%;\n      \n    }\n    .col {\n      /*display: flex;*/\n      padding: 10px 0;\n      &:before {\n        color: #121944;\n        padding-right: 10px;\n        content: attr(data-label);\n        flex-basis: 50%;\n        text-align: left;\n          font-weight: bold;\n      }\n    }\n  }\n}\n    </style>\n      <div class='containerSauble'>\n  <h4>Ticket Types</h4>\n  <ul class='responsive-table'>\n    <li class='table-header'>\n      <div class='col col-1'>Ticket Level</div>\n      <div class='col col-2'>Key Features</div>\n      <div class='col col-3'>Designed For</div>\n    </li>\n    <li class='table-row'>\n      <div class='col col-1' data-label='Ticket Level:'>GA - General Admission</div>\n      <div class='col col-2' data-label='Key Features:'>Full access to all shows, 2 full-service bars, food/market vendors, tented shade, picnic tables.</div>\n      <div class='col col-3' data-label='Designed For:'>Fans who want to catch every act and enjoy the festival atmosphere.</div>\n    </li>\n    <li class='table-row'>\n      <div class='col col-1' data-label='Ticket Level:'>VIP</div>\n      <div class='col col-2' data-label='Key Features:'><strong>All GA amenities</strong> + Premium stage-front viewing at both stages, exclusive food/bar areas, premium hard liquor bar, draft beer garden, covered VIP areas, private bathrooms.</div>\n      <div class='col col-3' data-label='Designed For:'>Fans seeking more space, comfort, and premium perks close to the action.</div>\n    </li>\n    <li class='table-row'>\n      <div class='col col-1' data-label='Ticket Level:'>Super VIP</div>\n      <div class='col col-2' data-label='Key Features:'><strong>All VIP amenities</strong> + Elevated viewing at both stages, <strong>all-inclusive drinks</strong>, complimentary buffet food, exclusive bar access, preferred large bathroom trailers, weather extras (ponchos/umbrellas).</div>\n      <div class='col col-3' data-label='Designed For:'>Guests wanting maximum convenience, comfort, and exclusive, hassle-free access.</div>\n    </li>\n     <li class='table-row'>\n      <div class='col col-1' data-label='Ticket Level:'>All-Inclusive Suite (24 People)</div>\n      <div class='col col-2' data-label='Key Features:'><strong>All-you-can-eat and all-you-can-drink</strong> on a private double-decker terrace, private chef-prepared dinner, private bathroom, backstage tour, early access, full access to VIP areas.</div>\n      <div class='col col-3' data-label='Designed For:'>Groups seeking the ultimate luxury, privacy, and exclusive festival experience.</div>\n    </li>\n  </ul>\n        <h4>Camping Information</h4>\n        <p>Important: All campers must have a valid festival ticket. Max 6 campers per site. Sites are assigned upon arrival—arrive together to camp together.</p>\n        <ul class='responsive-table'>\n    <li class='table-header'>\n      <div class='col col-1'>Campsite Type</div>\n      <div class='col col-2'>Size & Accommodation</div>\n      <div class='col col-3'>Additional Info</div>\n    </li>\n    <li class='table-row'>\n      <div class='col col-1' data-label='Campsite Type:'>Tent Site</div>\n      <div class='col col-2' data-label='Size & Accommodation:'>Approx. <strong>20' x 15'</strong> (Vehicle length + 3' clearance x 15' wide).</div>\n      <div class='col col-3' data-label='Additional Info:'>Ideal for fans wanting to camp on-site close to the action.</div>\n    </li>\n    <li class='table-row'>\n      <div class='col col-1' data-label='Campsite Type:'>Trailer / RV Site</div>\n      <div class='col col-2' data-label='Size & Accommodation:'>Approx. <strong>44' x 15'</strong> (Vehicle/trailer combination length x 15' wide).</div>\n      <div class='col col-3' data-label='Additional Info:'>Designed for fans bringing RVs or travel trailers, offering more space and comfort.</div>\n    </li>\n  \n  </ul>\n   <ul>\n       <h4>General Camping Rules:</h4>\n      <li>Amenities: There is <strong>NO power, water, or sewer</strong> hookup at any site.</li>  \n       <li>Cooking: Small generators are permitted. Only small, propane cooking barbecues (propane tanks under 5lbs, like Coleman) are allowed. <strong>NO open fires</strong> for warmth or cooking.</li> \n       <li><strong>Alcohol Limits (Per Person)</strong>: You may bring in <strong>ONE</strong> of the following per person:\n<ol>\n        <li>48 cans of beer/seltzer/RTD</li>\n               <li>(2) 26oz bottles of hard liquor</li>\n               <li>(8) 25.4oz bottles of wine/spirits</li>\n          </ol>\n</li> \n       <li>Concert Grounds: <strong>NO outside food or drink</strong> is permitted inside the concert grounds area. Food, water, and camping supplies are allowed in the camping area only.</li> \n       <li>Vehicle Policy <strong>(Non-Negotiable)</strong>: Your vehicle <strong>MUST</strong> stay parked inside the camping area at all times unless you are leaving the event for its duration. Vehicles will be searched at check-in (5-10 minutes per vehicle).</li> \n       <li><strong>Cleanliness</strong>: Sites not returned to their original condition will incur a <strong>$500 cleanup charge</strong>.</li> \n   </ul>     \n          <h4>Passes & Extras</h4>\n      <li><strong>Camping Shower Pass</strong>: Valid for the whole weekend for one person per use. Access to the new campground shower trailer. Available to all campers. Shower passes are $9.99 (specifically for Trailer/RV sites, assumed for Tent as well). First come, first serve.</li>  \n       <li><strong>Parking Pass - Weekend</strong>: Provides parking for the entire festival weekend with in/out privileges. Required for any vehicle arriving separately from a camping group. Does not include festival admission.</li> \n   </ul>    \n</div>"
      }
    ],
