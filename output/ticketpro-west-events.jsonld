    "http://schema.org/name": [
      {
        "@value": "Weekend Pass | August 21-23, 2026 - Summerfolk Music & Crafts Festival"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>From November 28 to December 1, buy your weekend pass and get a 15% off coupon* for the Summerfolk General Store. Early Bird ticket pricing lasts through December 31, but this exclusive offer ends Monday, December 1 at 11:59 PM ET.</p>\n\n<p>Join us for the 51<sup>st</sup> Summerfolk, August 21-23, 2026, in Owen Sound, ON.</p>\n\n<p>Secure your pass now and save on festival merch!</p>\n\n<p><small>*Valid only for on-site purchases at the Summerfolk General Store during the festival. No promo codes or physical coupons needed—your name will be on file at the store.</small></p>\n\n<table style='width: 100%; border-collapse: collapse; border-style: solid;' border='1'>\n<tbody>\n<tr>\n<td style='width: 20%; text-align: center;'><b>WEEKEND PASS</b></td>\n<td style='width: 20%; text-align: center;'>Early Bird<br /><small><i>(until December 31)<br /></small></i></td>\n<td style='width: 20%; text-align: center;'>Advance<br /><small><i>(January 1-May 31)<br /></small></i></td>\n<td style='width: 20%; text-align: center;'>Regular<br /><small><i>(until Aug. 15)<br /></small></i></td>\n<td style='width: 20%; text-align: center;'>Gate<br /><small><i>(as of Aug. 16)<br /></small></i></td>\n</tr>\n<tr>\n<td style='width: 20%; text-align: center;'>Adult (25+)</td>\n<td style='width: 20%; text-align: center;'>$185.00</td>\n<td style='width: 20%; text-align: center;'>$210.00</td>\n<td style='width: 20%; text-align: center;'>$225.00</td>\n<td style='width: 20%; text-align: center;'>$250.00</td>\n</tr>\n<tr>\n<td style='width: 20%; text-align: center;'>Senior (65+)</td>\n<td style='width: 20%; text-align: center;'>$155.00</td>\n<td style='width: 20%; text-align: center;'>$155.00</td>\n<td style='width: 20%; text-align: center;'>$155.00</td>\n<td style='width: 20%; text-align: center;'>$199.00</td>\n</tr>\n<tr>\n<td style='width: 20%; text-align: center;'>Young Adult (19-24)</td>\n<td style='width: 20%; text-align: center;'>$125.00</td>\n<td style='width: 20%; text-align: center;'>$125.00</td>\n<td style='width: 20%; text-align: center;'>$130.00</td>\n<td style='width: 20%; text-align: center;'>$145.00</td>\n</tr>\n<tr>\n<td style='width: 20%; text-align: center;'>Youth (14-18)</td>\n<td style='width: 20%; text-align: center;'>$50.00</td>\n<td style='width: 20%; text-align: center;'>$50.00</td>\n<td style='width: 20%; text-align: center;'>$50.00</td>\n<td style='width: 20%; text-align: center;'>$69.00</td>\n</tr>\n<tr>\n<td style='width: 20%; text-align: center;'>Child (0-13)</td>\n<td style='width: 20%; text-align: center;'>N/A</td>\n<td style='width: 20%; text-align: center;'>FREE**</td>\n<td style='width: 20%; text-align: center;'>FREE**</td>\n<td style='width: 20%; text-align: center;'>FREE**</td>\n</tr>\n</tbody>\n</table>\n\n<p><small><i>** Call 1-888 655-9090 to add free Child ticket(s) to your order.</i></small></p>\n\n<table style='width: 100%; border-collapse: collapse; border-style: solid;' border='1'>\n<tbody>\n<tr>\n<td style='width: 20%; text-align: center;'><b>DAY PASS</b></td>\n<td style='width: 20%; text-align: center;'>Early Bird<br /><small><i>(until December 31)<br /></small></i></td>\n<td style='width: 20%; text-align: center;'>Advance<br /><small><i>(January 1-May 31)<br /></small></i></td>\n<td style='width: 20%; text-align: center;'>Regular<br /><small><i>(until Aug. 14)<br /></small></i></td>\n<td style='width: 20%; text-align: center;'>Gate<br /><small><i>(as of Aug. 15)<br /></small></i></td>\n</tr>\n<tr>\n<td style='width: 20%; text-align: center;'>Friday</td>\n<td style='width: 20%; text-align: center;'>N/A</td>\n<td style='width: 20%; text-align: center;'>$120.00</td>\n<td style='width: 20%; text-align: center;'>$125.00</td>\n<td style='width: 20%; text-align: center;'>$140.00</td>\n</tr>\n<tr>\n<td style='width: 20%; text-align: center;'>FLEX (Sat. or Sun.)</td>\n<td style='width: 20%; text-align: center;'>N/A</td>\n<td style='width: 20%; text-align: center;'>$140.00</td>\n<td style='width: 20%; text-align: center;'>$150.00</td>\n<td style='width: 20%; text-align: center;'>$165.00</td>\n</tr>\n</tbody>\n</table>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n</style>\n"
      }
