    "http://schema.org/name": [
      {
        "@value": "International Guitar Night 2027"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>International Guitar Night (IGN), the world's premier touring acoustic guitar festival is back!  IGN has a deep history in Canada, having launched on the West Coast and maintained a solid presence for over two decades. This 2027 tour continues IGN's tradition of bringing audiences the best acoustic guitarists from around the world. </p>\n<p>This year's tour features classical and flamenco guitarist Itamar Erez, Spanish classical guitarist Victoria Ruiz de la Rubia, fretless guitar pioneer and jazz artist Cenk Erdoğan, and contemporary blues and jazz manouche master, Remi Harris.</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
      }
