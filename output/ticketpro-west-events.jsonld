  {
    "@id": "https://ticketpro.ca/event/1686541175",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-02T19:30:00-04:00"
      }
    ],
