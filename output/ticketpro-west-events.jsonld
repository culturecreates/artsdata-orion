    "http://schema.org/name": [
      {
        "@value": "DanceForce. Spotlight 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Join us as we celebrate our General Program and Sprinkle dancers as they take the stage to showcase everything they've learned throughout the season. From their very first steps to the growth in their confidence, technique, and performance skills, this showcase is a special opportunity for our dancers to shine in front of family and friends.</p>\n\n<p>We are incredibly proud of the hard work, dedication, and joy these dancers have brought to the studio throughout the year. DanceForce. Spotlight is a celebration of their progress, passion, and love of dance, and we cannot wait to celebrate all of their accomplishments together on stage.</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
      }
