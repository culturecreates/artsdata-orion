  {
    "@id": "https://ticketpro.ca/event/1688454696",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-24T18:30:00-07:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1677415608"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprowest.ticketpro.ca/api/v1/resources/1678588388.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1379700"
      },
      {
        "@id": "_:g1379720"
      },
      {
        "@id": "_:g1379740"
      },
      {
        "@id": "_:g1379760"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7370"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7370"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Monster Madness"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p style='color:red'><b>Saturday shows sold out - Tickets available for Sunday</b></p><p>Feel the roar of the monster trucks as the Monster Madness Tour stops in Kamloops British Columbia at the Mt Paul Events Centre with stars from the 'FMX World Tour' and more! This is an action-packed afternoon fans won't want to miss!</p>\n\n<p>MONSTER MADNESS TOUR: Rat Nasty Monster Madness Champion returns with the biggest Monster Trucks in the world. Including Canada's #1 female Monster Truck SABOTAGE. Monster Madness will have you on your feet as you watch the 10,000 pounds of MONSTER TRUCKS soar through the air! The competition will include tricks like wheelies, racing, monster truck freestyle and more!</p>\n\n<p>FMX WORLD TOUR will leave fans and families amazed as death defying stunts only the brave would attempt are performed, inside the arena. FMX World Tour is the perfect blend of athletic ability, extreme stunt competitions and tricks and flips! FMX World Tour stars will be performing such tricks as, captain morgan, kiss of death, cliff hangers, in addition to the famous BACKFLIP!</p>\n\n<p>POWER WHEELS DEMOLITION DERBY - Watch as these young up and coming demolition drivers show off their driving skills during the Monster Madness Power Wheels Demolition Derby.</p>\n\n<p><b>VIP TICKETS</b>: Get access to the pre-show VIP Pity Party, receive a souvenir VIP lanyard, plus get early entry to choose your seats first!</p>\n\n<p>Children 2 and UNDER ON LAP ARE FREE<br>\nChildren 12 AND OLDER = ADULT</p>\n\n<style>\n.location-page-temp {display: block!important;}\n.location-event-temp {display: none!important;}\n</style>"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
