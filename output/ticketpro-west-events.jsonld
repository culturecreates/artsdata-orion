    ],
    "http://schema.org/name": [
      {
        "@value": "A Place Where I Belong Film Screening"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Join us at a special FREE relaxed screening of the award-winning film, A Place Where I Belong. The documentary follows six LGBTQ+ people with intellectual and/or developmental disabilities in the Connecting Queer Communities (CQC) initiative as they fight for love, freedom and visibility. Enjoy special treats and connect with friends at a Reception before the screening. After, participate in a Q&A Session with the Director and people in the film. Accessible seating is available for those with mobility issues and in wheelchairs.</p>\n\n\n<p>Reception: 6:00 p.m. |  Screening: 7:00 p.m. | Discussion Panel: 8:10 p.m.</p>\n\n<div style='padding:56.25% 0 0 0;position:relative;'><iframe src='https://player.vimeo.com/video/1094465335?badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479' frameborder='0' allow='autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share' referrerpolicy='strict-origin-when-cross-origin' style='position:absolute;top:0;left:0;width:100%;height:100%;' title='A Place Where I Belong Trailer'></iframe></div><script src='https://player.vimeo.com/api/player.js'></script>\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
      }
