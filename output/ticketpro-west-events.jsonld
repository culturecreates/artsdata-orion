    ],
    "http://schema.org/name": [
      {
        "@value": "Fizzlewit & The Fairy Finding Tour - Maclab Family Series"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Fizzlewit's Fairy Finding is a fun trip into the world of folk lore and fairy tale. Join Fizzlewit on his whimsical adventures.</p>\n\n<p><a href='https://www.fairyfinding.com/' target='_blank'>fairyfinding.com</a><br>\n<a href='https://www.youtube.com/channel/UC8J26DztwrUV2ZsuDm8qVoQ' target='_blank'>Fairy Finding - Youtube Channel</a><br>\n<a href='https://www.instagram.com/fairyfinding' target='_blank'>Fairy Finding - Instagram</a><br>\n<a href='https://www.facebook.com/fairyfinding' target='_blank'>Fairy Finding - Facebook</a></p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/CCxyme4zqCk?si=0klpKAUON6RIOhpt' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<p>Free Admission </p>\n\n<center><b>Tickets available through Leduc Public Library, #2, Alexandra Park, Leduc, AB, T9E 4C4, Ph: 780-986-2637 <a href='https://leduclibrary.ca/' target='_blank'>leduclibrary.ca</a></b> or at the Maclab Centre for the Performing Arts starting on July 2, 2026 and online, here.<center>\n\n\n\n<style>.location-page-temp {\n    display: block!important;\n}\n.titleTax {display: none !important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n\n"
      }
