    "http://schema.org/name": [
      {
        "@value": "New Moon Folk Club 2026/2027 SEASON PASS"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>All‑access 12 show pass to full season of intimate, high‑quality folk concerts—great sound, close‑up performances\n\nIncludes a ticket to all shows presented during the 2026-2027 Season:<br><br>\n\nFriday, September 18, 2026 - Derina Harvey Band<br>\n\nFriday, October 2, 2026 - Generations<br>\n\nFriday, October 16, 2026 - Lloyd Spiegel<br>\n\nFriday, October 30, 2026 - Colin Linden<br>\n\nFriday, November 20, 2026 - Double Bill: Mia Kelly and Eliza Mary Doyle Band<br>\n\nFriday, November 27, 2026 - The Sultans of String<br>\n\nFriday, January 22, 2027 - John Wort Hannam Trio\n<br>\nFriday, February 19, 2027 - Double Bill: Terra Spencer and Ken Stead<br>\nFriday, March 5, 2027 - The Andrew Collins Trio<br>\n\nFriday, March 19, 2027 - The Unfaithful Servants\n<br>\nFriday, April 2, 2027 - Jeffery Straker\n<br>\nFriday, April 16, 2027 - Maggie's Wake</p>\n\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n\n</style>"
      }
    ],
