    "http://schema.org/url": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7506"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Menestrel with guest artist Vincent Lauzer"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Savour the tradition of the troubadours, as Ménestrel breathes vivid life into music that has been shaped by centuries. Their voyage through historic repertoire is accented by lute, guitar and the intricate colours of the human voice. With selections ranging from grand compositions by Purcell, Dowland, and Monteverdi to nostalgic Gaelic, Québécois, and English folk melodies, Ménestrel reminds us of the pleasure of these musical forms. The group consists of recognized artists Janelle Lucyk (soprano), Kerry Bursey (tenor, guitar and lute) and Vincent Lauzer (recorder). who have established a reputation for combining ancient repertoire with elements of folk song.</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n.titleTax {display: none !important;}\n</style>"
      }
    ],
