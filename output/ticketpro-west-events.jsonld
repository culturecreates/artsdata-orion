    "http://schema.org/name": [
      {
        "@value": "Celeigh Cardinal - Maclab Indigenous Series"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n<p>Celeigh Cardinal is a JUNO-winning Indigenous singer-songwriter whose rich, soulful voice has earned her national acclaim. Her latest album Boundless Possibilities garnered 2025 WCMA nominations for Indigenous Artist and Roots Album of the Year, following multiple CFMA wins and JUNO nods. Her music explores grief, hope, and powerful self-reclamation.</p>\n\n\n<p><b><a href='https://www.celeighcardinal.com' target='_blank'>Website</a> <a href='https://open.spotify.com/artist/7HAq3UBI3pb8ok9k7dkdGR?si=bPmtf_oaSJqP9eSMC5ccZA' target='_blank'>Spotify</a> <a href='https://www.instagram.com/celeighcardinal' target='_blank'>Instagram</a> <a href='https://linktr.ee/celeighcardinal' target='_blank'>Linktree</a></b></p>\n"
      }
    ],
