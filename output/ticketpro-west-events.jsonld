      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprowest.ticketpro.ca/api/v1/resources/1664570002.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww2.ticketpro.ca/genid/f5c6dd9205c0fedf"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
