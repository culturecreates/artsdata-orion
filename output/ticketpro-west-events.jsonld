    "http://schema.org/name": [
      {
        "@value": "DanceForce. Ovation 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Join us for an unforgettable evening as our DanceForce. Company dancers take the stage for DanceForce. Ovation 2026. This elevated performance showcase highlights the passion, dedication, artistry, and hard work our dancers have poured into their season.</p>\n\n<p>Featuring award-winning choreography, powerful performances, and the incredible talent of our Company program, Ovation is a celebration of excellence, growth, and the commitment it takes to perform at this level. We are so proud of the heart, discipline, and love for dance that these dancers bring to the stage and cannot wait to share this special evening with our DanceForce. families and community.</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
      }
