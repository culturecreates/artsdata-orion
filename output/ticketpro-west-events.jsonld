    ],
    "http://schema.org/name": [
      {
        "@value": "Oktopus"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Oktopus is a leading presence on the Canadian world music scene, with over 350 performances to its credit at home and abroad. While the group's arrangements and performances are undeniably rooted in the klezmer tradition, they also weave in compositions by Brahms, Kodály, or Mahler, Quebecois songs and even jazz improvisation. Respect for different authentic traditions, and the desire to bring people together through music lies at the heart of the stellar performers that combine to form... Oktopus.</p>\n\n<p><a href='https://www.oktopus.ca/' target='_blank'>oktopus.ca</a></p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/evpFK0-V83M?si=9MwmbeN5MS1Jbblp' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/-z-wqf1X3K4?si=3FqW1FMKGANAKZ6V' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style>"
      }
