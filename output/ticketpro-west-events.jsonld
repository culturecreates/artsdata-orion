    "http://schema.org/name": [
      {
        "@value": "Sounds Like Home Series - Summer of 69 - Tribute to Bryan Adams"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Run to You, Cuts Like a Knife, (Everything I Do) I Do It for You, Summer of 69 - the music of Bryan Adams is beloved across the globe. With a Grammy, multiple Junos and the Order of Canada, he has entertained generations. Summer of 69 brings these hits and more in a celebration of Canada's rock musician to the world.  </p>\n\n<p><b>For accessibility seating options please call 905-640-2322</b></p>\n\np>Notice of filming and photography: When you and any minor children attending an event with you, attend an event, you enter an area where photography, audio, and video recording may occur.<br>\nBy entering the event premises, you consent to such recording media and its release, publication, exhibition, or reproduction.</p>\n\n<p><b><a href='https://tows.ticketpro.ca/en/pages/19onthePark' target='_blank'>More Events Happening at 19 on the Park</a></b>.</p>\n "
      }
