  {
    "@id": "https://ticketpro.ca/event/1686263894",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-06T19:30:00-06:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1159247505"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprowest.ticketpro.ca/api/v1/resources/1686265550.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1107020"
      },
      {
        "@id": "_:g1107040"
