    "http://schema.org/name": [
      {
        "@value": "ANUV JAIN - DASTAKHAT WORLD TOUR 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Vancouver  welcome Canada tour stop of DASTAKHAT ANUV JAIN WORLD TOUR 2026. On Friday, May 15, Anuv Jain brings his signature indie-acoustic sound to the city for an intimate, emotional live set. Known for fan favourites like Baarishein, Alag Aasmaan, Gul, Jo Tum Mere Ho, and Husn, Anuv's music captures love, longing, and hope with a rare simplicity that stays with you.  50 Super Fans can Meet and Greet Anuv Jain for 100 CAD.  <p>\n\n<p>Super Fan Ticket Includes:  Meet & Greet with Anuv Jain -Photo with Anuv Jain (taken by crew member using fan's camera/phone).  Collectible laminate with Dastakhat World Tour 2026  this ticket are only available to fans who buy the concert ticket.   </p>\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.pricelevel-price-temp-to {display: none;}\n.pricelevel-price-temp-pricemax {display: none;}\n</style>\n"
      }
    ],
