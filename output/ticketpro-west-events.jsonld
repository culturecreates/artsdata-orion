      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww2.ticketpro.ca/genid/03a05b70c5297f6a"
      },
      {
        "@id": "https://ww2.ticketpro.ca/genid/6af1fe439bc6e083"
