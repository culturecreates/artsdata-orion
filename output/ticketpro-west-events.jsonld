      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Celebrate a milestone with Collingwood Neighbourhood House (CNH) at our 40th Anniversary Fundraiser Gala on Saturday, May 23!</p>\n<p>Featuring live music, canapés and the opportunity to participate in our silent auction and raffle, this inaugural event aims to raise funds for core programs and essential services at CNH, a non-profit organization supporting residents in East Vancouver.</p>\n<p>•\tHeadliner: Krystle Dos Santos<br>\n•\tOpening band: TheBrowniez<br>\n•\tEmcee: Francis Arevalo</p>\n\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
      }
    ],
