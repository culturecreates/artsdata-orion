    "http://schema.org/name": [
      {
        "@value": "Ballet BC Annex"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Ballet BC Annex is the junior ensemble of Canada's leading contemporary dance company. Each season, Ballet BC Annex presents works by renowned and emerging choreographers on stages across British Columbia, bringing world-class dance repertoire to local and regional schools and community venues. Annex dancers are a cohort of pre-professional artists currently training with Vancouver dance institutions Modus Operandi and Arts Umbrella Dance. The program supports the development of the dancers' careers by providing professional stage experience, while offering creation opportunities for emerging choreographers. In the 2026/27 season, Ballet BC Annex will share a triple bill of three exciting works: world premieres by Canadian choreographer Cameron Fraser-Monroe and Ballet BC company dancer Michael Garcia, as well as Vancouver-based Out Innerspace's Last Flower, originally created for Ballet BC in 2024.</p>\n\n<style>\n.location-page-temp {display: block!important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n"
      }
    ],
