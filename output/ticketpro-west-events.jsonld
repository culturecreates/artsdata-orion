    "http://schema.org/name": [
      {
        "@value": "Hellarious: The World's Bloodiest & Funniest Magic Show"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>HELLARIOUS - THE WORLD'S BLOODIEST & FUNNIEST HALLOWEEN ILLUSION SHOW </b></p>\n\n<p>Canada's wildest Halloween spectacle is coming to the stage! HELLARIOUS blends jaw-dropping illusions, outrageous comedy, and over-the-top horror into a one-of-a-kind live experience.</p>\n\n<p>Expect shocking illusions, twisted characters, and laugh-out-loud moments you'll be talking about long after the curtain drops.</p>\n\n<p>Leading the cast is the phenomenal Aaron Matthews, one of Canada's top illusionists. </p>\n\n<p>Attention! Please be advised that Hellarious incorporates mature content. We recommend you be over the age of 16 to experience all the laughter and macabre magic.</p>\n\n\n\n<style>\n@media screen and (max-width: 600px){\niframe{width:100%;}}\n</style>\n\n\n\n\n\n"
      }
