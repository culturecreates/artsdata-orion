    "http://schema.org/name": [
      {
        "@value": "Pro Coro - \"A Christmas Carol\""
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Experience the magic of <i>A Christmas Carol</i> like never before! Beloved Christmas Carols become the soundtrack to Scrooge's thrilling and heartwarming journey. Step into a spellbinding musical adventure of ghosts, redemption, and festive joy that will leave the whole family feeling truly alive this Christmas.</p>\n\n<p>Benedict Sheehan, composer/arranger<br>\nApril Banigan, narrator<br>\nMichael Zaugg, conductor<br>\nPro Coro Canada, choir</p>\n\n<p>Run-time: 75 minutes, no intermission</p>\n\n<p><a href='https://www.procoro.ca/' target='_blank'>procoro.ca</a></p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/vaD07nx4xOg?si=AkHNl9HN53nGFkq-' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style>"
