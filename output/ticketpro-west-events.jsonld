    ],
    "http://schema.org/name": [
      {
        "@value": "Old MacDonald - Redemption Road Tour"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>All Ages</b></p>\n\n<p>Old MacDonald is a twin-brother duo delivering powerful harmonies over a rootsy mix of folk rock and country rock.</p>\n\n<p>Their songs trace the roads they've walked — family, failure, faith, resilience, and the bond that only brothers understand. Honest stories, big choruses, and music that feels earned.</p>\n\n<style>\n.location-page-temp {display: block!important;}\n</style>\n\n\n"
      }
