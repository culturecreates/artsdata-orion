    "http://schema.org/name": [
      {
        "@value": "State of Morinville 2026 - With Mayor Boersma"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n <p>Join us for Morinville's first annual State of Morinville event — a community forum sharing progress, priorities, and what's ahead for our growing community.</p>\n\n \n\n <p>Mayor Boersma's keynote address will introduce Council's new 2026 - 2030 Strategic Plan, and highlight Morinville's long-term direction and community infrastructure investments. </p>\n\n \n\n <p>Ticket price includes dessert bar. </p>\n\n \n\n <p>Doors Open: 6:30 p.m. <br>\nProgram Begins: 7 p.m.<br>\nReception: 7:30 p.m.</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\ntw-seats-selectes-plv{display: none !important;}\n</style>"
      }
    ],
