    "http://schema.org/name": [
      {
        "@value": "Edmonton Pops Orchestra - \"More! Ticket to Hollywood\" "
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Following last season's sensational cinematic journey, the Edmonton Pops Orchestra is back with MORE! TICKET TO HOLLYWOOD. Join this dynamic twelve-piece orchestra and two powerhouse vocalists for another unforgettable night of movie magic. From the golden age of Hollywood to today's biggest blockbusters, the Edmonton Pops Orchestra brings iconic film music to vibrant life. Get ready for soaring melodies, nostalgic favourites, and the electrifying thrill of live orchestral performance. </p>\n\n<p><a href='https://edmontonpops.ca/' target='_blank'>edmontonpops.ca</a></p>\n\n<style>\n@media screen and (max-width: 600px){\niframe{width:100%;}\n}\n.location-page-temp {\n    display: block!important;\n}\n</style>"
      }
    ],
