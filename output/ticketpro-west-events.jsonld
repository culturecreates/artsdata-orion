    "http://schema.org/name": [
      {
        "@value": "Kempenfest 2026 - JAMIE FINE w/ special guests"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n\n<p><b>VIP Includes:</b><br />\n• Specialty Bar with table service and expanded bar menu.<br />\n• Food service.<br />\n• Executive portable trailer restrooms with sinks, running water, mirrors, heating/cooling.<br />\n• Premium sight lines to the stage.<br />\n• Limited shading is provided on a first come first serve basis - Access is not guaranteed.</p>\n\n<p><b>Kids 12 and under enter for free in the <u>GA Section!</u></b>. Sponsored by Ticketpro (ticket required and must be accompanied by an Adult)</p>\n\n<style>\n.location-event-temp {\n    display: none!important;\n}\n</style>"
      }
    ],
