      }
    ],
    "http://schema.org/name": [
      {
        "@value": "The Irish Descendants - Our Tribute to Stan Rogers"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The Irish Descendants' tribute to Stan Rogers is a heartfelt celebration of one of Canada's most enduring songwriters. Rooted in deep respect and a shared musical lineage, the album honours Rogers' powerful storytelling and the timeless themes of sea, land, and community that resonate so strongly in Newfoundland and Labrador. With rich arrangements, warm harmonies, and performances by Rowan Sherlock, Jeff Kinsman, Madeline Carter, and Con O'Brien, the project carries Rogers' legacy forward for new listeners while offering longtime fans a fresh, lovingly crafted interpretation. This performance and album stand as both a thank‑you and a continuation—keeping these iconic songs alive, connected, and sung with pride.</p>\n\n<style>\n@media screen and (max-width: 600px){\niframe{width:100%;}\n}\n</style>"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
