      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww2.ticketpro.ca/genid/1f2960db6f4bb289"
      },
      {
        "@id": "https://ww2.ticketpro.ca/genid/7c8a68ece90d332e"
