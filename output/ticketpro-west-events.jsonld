    ],
    "http://schema.org/name": [
      {
        "@value": "CHARTwell presents Morinville Seniors' Week - Dinner & Show, featuring \"Hillbilly Wedding\""
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n <p><b><a href='https://chartwell.com/ab/st-albert/st-albert?gad_source=1&gad_campaignid=19701870226&gbraid=0AAAAApVoKNfjaeZy4sVDLi0uBbydMEF91&gclid=CjwKCAiAzZ_NBhAEEiwAMtqKy-UoTp3LNKXAhbEtQib4RwY7GaGjeFPRjLSCqJNEYcs4DtgsE9NNeRoCxJUQAvD_BwE' target='_blank'>CHARTwell</a> presents Morinville Seniors' Week</b><br>Join us for Hillbilly Wedding, a laugh-out-loud, interactive murder mystery featuring a mocktail-hour, catered dinner, wild hillbilly antics, and a cast of unforgettable characters. As soon as guests arrive, actors mingle, spark hilarious moments, and drop early hints. During dinner, the mystery deepens with gossip, chaos, and a crowd-favorite Pig Hollerin' contest! Casual, social, and totally unpredictable—play along, question suspects, and compete for the Super Sleuth award! </p>\n\n<p>Tickets on sale starting March 10, 2026.</p>\n\n <p><b>$45 Advance Tickets, $49 after May 8 at midnight +GST</b></p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\ntw-seats-selectes-plv{display: none !important;}\n</style>"
      }
    ],
