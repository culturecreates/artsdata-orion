      {
        "@value": "A Mighty Mess of Munsch!"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Family favourite M. John Kennedy brings a new crop of Robert Munsch tales to the stage this March Break. Celebrate all that is messy with laughter-filled tales including <i>Purple, Green and Yellow</i>, <i>Jonathan Cleaned Up Then He Heard A Sound</i>, <i>PIGS</i> and <i>Moira's Birthday</i>.</p>\n \n<p>Part of the Discover Your Stage 2026 - 2027 Series at 19 on the Park Theatre</p>"
      }
    ],
