    "http://schema.org/name": [
      {
        "@value": "Leduc School of Music and Art Presents Magic In The Air"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>The Leduc School of Music and Art's Musical Theatre program invites audiences to experience Magic in the Air with its enchanting year end performance. This special evening brings to life the timeless stories of Aladdin KIDS and Mary Poppins JR., celebrating the wonder and magic that define both beloved tales.  Guests can also enjoy a cash only concession during intermission, with proceeds supporting the program. \nDisney's Aladdin KIDS and Disney and Cameron Mackintosh's Mary Poppins JR. are presented through special arrangement with, and all materials provided by, Music Theatre International.\n</p>\n\n<style>\n@media screen and (max-width: 600px){iframe{width:100%;}}\n.location-page-temp {display: block!important;}\n</style>"
      }
