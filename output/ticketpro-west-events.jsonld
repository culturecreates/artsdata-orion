    "http://schema.org/name": [
      {
        "@value": "Beppie - Maclab Family Series"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>Beppie</b> (Stephanie Nhan) is a two-time JUNO-nominated children's musician and educator from Edmonton, Alberta. Her vibrant, high-energy shows and award-winning songs take kids and families on an eclectic musical adventure filled with fun, humor, and heart. Beppie is a Western Canadian Music Award winner and International Songwriting Competition finalist who inspires creativity and connection through her playful, genre-bending approach to children's music.</p>\n\n<p><a href='https://www.beppiemusic.com/' target='_blank'>beppiemusic.com</a></p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/WwpHl4UfAq4?si=4FZU8EUB8o07FFpZ' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<p>Free Admission </p>\n\n<center><b>Tickets available through Leduc Public Library, #2, Alexandra Park, Leduc, AB, T9E 4C4, Ph: 780-986-2637 <a href='https://leduclibrary.ca/' target='_blank'>leduclibrary.ca</a></b> or at the Maclab Centre for the Performing Arts starting on July 2, 2026 and online, here.<center>\n\n\n\n<style>.location-page-temp {\n    display: block!important;\n}\n.titleTax {display: none !important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n\n"
