    "http://schema.org/name": [
      {
        "@value": "The Boo Revue - Maclab Family Series"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p><b>The Boo Revue!</b> is a frightfully fun, blacklight, musical puppet show put on every year by the friendly inhabitants of a ghostly old graveyard. Get ready to shiver and shake along to spine-tingling musical numbers, and be dazzled by supernatural sights! Each year, the show returns with new numbers and characters, constantly expanding our cast of frighteningly fun friends, and bringing new spectre-tacular delights every Halloween! </p>\n\n<p><a href='https://www.theboorevue.ca/' target='_blank'>theboorevue.ca</a><br></p>\n\n<iframe width='560' height='315' src='https://www.youtube.com/embed/bcZMq5I_IzY?si=xTMXZDhhKX7r2tqQ' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' referrerpolicy='strict-origin-when-cross-origin' allowfullscreen></iframe>\n\n<p>Free Admission </p>\n\n<center><b>Tickets available through Leduc Public Library, #2, Alexandra Park, Leduc, AB, T9E 4C4, Ph: 780-986-2637 <a href='https://leduclibrary.ca/' target='_blank'>leduclibrary.ca</a></b> or at the Maclab Centre for the Performing Arts starting on July 2, 2026 and online, here.<center>\n\n<style>.location-page-temp {\n    display: block!important;\n}\n.titleTax {display: none !important;}\n@media screen and (max-width: 600px){iframe{width:100%;}}\n</style>\n\n\n"
      }
