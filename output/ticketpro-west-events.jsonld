    ],
    "http://schema.org/image": [
      {
        "@id": "https://tpromaclab.ticketpro.ca/api/v1/resources/1694494650.jpeg?version=1"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://ww2.ticketpro.ca/genid/9cd5d3f3ddd06b8e"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7626"
