  {
    "@id": "https://ticketpro.ca/event/1687322126",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-06T18:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://ticketpro.ca/place/1314245751"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://tprocob.ticketpro.ca/api/v1/resources/1686488044.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g685460"
      },
      {
        "@id": "_:g685480"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7476"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://ww2.ticketpro.ca/event.php?event_id=7476"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Canvas and Creativity: Spring Paint Night"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "\n\n<p>Join us for a refreshing Spring-Themed Paint Night at Five Points Theatre! </p>\n\n<p>With winter on the way out, we will soon enjoy gardens full of daffodils, irises and colorful tulips. Let's paint!</p>\n\n<p>Bring your friends, enjoy a specialty drink, and immerse yourself in the cozy, creative atmosphere. Whether you're a seasoned artist or picking up a brush for the first time, this event is perfect for all skill levels. Our instructor will guide you step-by-step through creating a beautiful spring bloom inspired painting.</p>\n\n<p>Come for the art, stay for the fun, and leave with a masterpiece!</p>\n\n<p>Ticket price includes: All materials and supplies with guided instructions to create your canvas.</p>\n\n<style>\n.location-page-temp {\n    display: block!important;\n}\n</style>\n"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
