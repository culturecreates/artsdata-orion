      {
        "@value": "My Pre Academy Spring Recital"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "<p>Please join us for My Pre Academy's Spring Recital featuring performances by our youngest stars in the infant room right up to our Kindergarten class!<br><br>\t\t\t\t\t\t\t\nThis will be a show you won't want to miss!</p>"
