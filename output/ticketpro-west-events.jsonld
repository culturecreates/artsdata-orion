    ],
    "http://schema.org/image": [
      {
        "@id": "https://tproontario.ticketpro.ca/api/v1/resources/1688242968.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1944540"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
