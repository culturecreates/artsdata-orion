    "http://schema.org/image": [
      {
        "@id": "https://tprocob.ticketpro.ca/api/v1/resources/1667605902.jpeg?version=2"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1830320"
      },
      {
        "@id": "_:g1830340"
      },
      {
        "@id": "_:g1830360"
