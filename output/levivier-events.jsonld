      },
      {
        "@id": "https://www.youtube.com/channel/UCBZChDFqywAUSV-VkonoAJg"
      },
      {
        "@id": "https://open.spotify.com/intl-fr/artist/2TJYC40BQbARzEreu3TVJL?si=C3ZFt4cOT-28eXT9GswWug"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://www.collectivelovemusic.com"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "lovemusic"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "lovemusic est un collectif de musiciens spécialisés dans la création basé à Strasbourg.Travailler avec des compositeurs•trices sur de nouvelles œuvres qui enrichiront le monde de la musique de nos jours est au cœur de leur activité. Ils tiennent à faire naître des collaborations entre artistes soucieux de créer ensemble une nouvelle musique dans laquelle le•a compositeur•trice et les musiciens•nes sont tous activement impliqués•es dans le processus de création.&nbsp;Ils ont à coeur de changer les systèmes patriarcaux et hiérarchiques qui se sont peu à peu enracinés dans notre milieu, en créant un environnement sûr et inclusif dans lequel les musiciens•nes peuvent décider par eux-mêmes de leur contribution dans chaque projet. Ainsi chacun•e peut être force de proposition, aussi bien dans l’élaboration des programmes que dans le choix des compositeurs.trices avec lesquel.les le collectif souhaite travailler.&nbsp;"
      }
    ],
    "@type": [
      "http://schema.org/PerformingGroup"
    ]
  },
