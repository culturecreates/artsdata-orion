    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ensemble SuperMusique"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fondé en 1998, l’Ensemble SuperMusique (ESM) est dirigé par Joane Hétu et Danielle Palardy Roger. Cette formation à géométrie variable entièrement vouée à l’interprétation de la musique actuelle et à l’improvisation figure parmi les rares ensembles dont le répertoire est exclusivement formé d’oeuvres de musique actuelle. L’ESM est constitué des instrumentistes et des compositeurs les plus en vue de la bouillonnante scène de musique actuelle de Montréal. Depuis sa fondation, l’ESM a commandé plus de 50 oeuvres qui combinent musique écrite et improvisation. La maison de disques montréalaise DAME a publié plusieurs de ses enregistrements.\r\n"
      }
    ],
    "@type": [
      "http://schema.org/PerformingGroup"
    ]
  },
  {
    "@id": "_:g546800",
    "http://schema.org/url": [
      {
        "@id": "https://jeanderome.com/"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "https://jeanderome.com/"
      },
      {
        "@id": "https://fr.wikipedia.org/wiki/Jean_Derome"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/jean-derome"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jean Derome"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Jean"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Derome"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L’un des musiciens les plus actifs et les plus éclectiques de la scène canadienne des musiques créatives, Jean Derome est aussi l’un des rares à s’être mérité l’estime et la reconnaissance d’un public élargi. Par ses grands projets de musique actuelle (Je me souviens, Canot-camping), par son travail d’improvisateur (avec René Lussier, Joane Hétu et Pierre Tanguay, mais aussi avec Fred Frith, Louis Sclavis et Han Bennink), par ses groupes de jazz (Évidence, le Trio Derome Guilbeault Tanguay) et ses musiques pour le cinéma, le théâtre et la danse, Derome s’est..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g546820",
    "http://schema.org/url": [
      {
        "@id": "https://prestonbeebe.com/"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "https://prestonbeebe.com/"
