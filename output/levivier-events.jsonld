      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Philippe Lauzier"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Philippe"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Lauzier"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Philippe Lauzier est un musicien improvisateur, compositeur et artiste interdisciplinaire. Après des études en composition de 1998 à 2002, il dédie beaucoup de son temps à l’art de l’improvisation sur le saxophone, et plus tard, la clarinette basse qui devient son instrument de prédilection. Il prend part à plusieurs tournées et résidences au Canada, Europe, ÉU, Mexique, Australie et Chine, où il se réalise en solo ou avec les groupes et collectifs Sainct Laurens, Motel Hélène, Quartetski, Not the Music, Ensemble SuperMusique ainsi que d’autres. Il se produit également..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g580580",
    "http://schema.org/url": [
      {
        "@id": "https://levivier.ca/fr/artistes/annie-saint-jean"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/annie-saint-jean"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Annie Saint-Jean"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Annie"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Saint-Jean"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Annie Saint-Jean une artiste qui habite à Inverness dans la belle région du Centre-du-Québec. Elle exerce une pratique en photographie et en vidéo d’art depuis 2012. Elle a cinq expositions solo de photographie argentique à son actif et plusieurs de ses courts métrages ont fait partie de programmations de festivals tant au Canada qu’à l’étranger. Ses projets sont fréquemment réalisés en collaboration avec la poète victoriavilloise Andrée-Anne Fréchette ainsi qu’avec différents artistes du milieu de la musique actuelle.&nbsp;Pour chacun de ses projets, elle fabrique ses appareils photo argentiques à sténopé : simples boîtes noires percées d’un petit trou d’épingle faisant office d’objectif. Le sténopé est non seulement l’ancêtre de l’appareil photo, il est principalement, au cœur de sa démarche artistique, l’outil d’une magie sans artifice."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
