      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/le-vivier/membres/organismes/quasar/jean-marc-bouchard"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jean-Marc Bouchard"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Jean-Marc"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Bouchard"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Passionné par la musique de création, Jean-Marc Bouchard en explore les différentes facettes soit en tant qu’interprète, improvisateur ou compositeur. Membre fondateur du quatuor de saxophones Quasar, il y assure la direction artistique de la série In Vivo, dédiée à l’improvisation. Avec In Vivo, qui en est à sa 7e édition, Jean-Marc Bouchard propose des parcours musicaux où se rencontrent, s’hybrident et se mêlent l’improvisation, la composition électronique et les nouvelles lutheries.\r\n\r\nSon travail d’improvisateur a ainsi amené Jean-Marc Bouchard à collaborer..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g461300",
    "http://schema.org/url": [
      {
        "@id": "https://quasar4.com/fr"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "https://quasar4.com/fr"
      },
      {
