  {
    "@id": "https://levivier.ca/fr/concert/saison-2026-27/ensembles-zafraan-paramirabo",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "fr",
        "@value": "Le Vivier"
      }
    ],
    "https://ogp.me/ns#type": [
