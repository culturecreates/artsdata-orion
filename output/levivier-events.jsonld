  {
    "@id": "https://levivier.ca/genid/dc16d2baa616e7a8",
    "http://schema.org/url": [
      {
        "@id": "https://levivier.ca/fr/artistes/rosane-lajoie"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/rosane-lajoie"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Rosane Lajoie"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Rosane"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Lajoie"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Rosane Lajoie est diplômée du Conservatoire de musique de Montréal, où elle a complété une maîtrise avec distinction dans la classe de Suzanne Goyette. Passionnée par l’art vocal, elle se perfectionne en accompagnement à la Guildhall School of Music and Drama de Londres, où elle remporte le Jubilee Piano Accompaniment Prize ainsi que le Tracey Chadwell Memorial Award en musique contemporaine. Diverses bourses lui permettent de se perfectionner en solo et en accompagnement lors de stages à l’Académie Francis Poulenc (France), au Festival Euro Music (Allemagne) et à l’Internationaal Lied Festival (Pays-Bas). En 2020, elle approfondit l'interprétation du Lied allemand à Stuttgart grâce à une bourse complète de la Fondation Baden-Württemberg.Intéressée par la musique nouvelle, elle participe à une résidence de création au Centre d’arts de Sabrevois et obtient la Bourse Lorraine Vaillancourt en musique contemporaine pour l'interprétation d'une œuvre de Tristan Murail. On a pu l'entendre en récital à la Société d'art vocal de Montréal, aux Concerts Lachine et aux Jeunesses Musicales Canada. En 2022, elle participe à la tournée canadienne de l’opérette La veuve joyeuse avec les Jeunesses Musicales.Récipiendaire en 2020 de la Médaille du Lieutenant-gouverneur pour son implication sociale, Rosane s’intéresse à la technique Alexander, à la pédagogie et à l’improvisation."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
