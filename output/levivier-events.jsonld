    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Veerle Vervoort"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Veerle"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Vervoort"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pendant ses études de musicologie, Veerle pensait que sa seule contribution utile à la société serait d'élever des moutons en Nouvelle-Zélande. Son amour pour un autre musicologue et pour une cuisine plus sophistiquée que celle de la ferme l'ont convaincue de rester. Aujourd'hui, elle rassemble des musiciens et son levain est une contribution utile à la société bactériologique. En plus de Nadar, Veerle dirige sa propre entreprise, Ursa Maior, qui produit, planifie et coordonne de nombreux projets différents dans le domaine de la musique et du théâtre musical. Elle est une virtuose des listes de tâches."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
