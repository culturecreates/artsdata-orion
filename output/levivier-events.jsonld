    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "St-Pierre"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Olivier St-Pierre est un compositeur, pianiste et organiste montréalais spécialisé en musique contemporaine. Actif comme pianiste depuis l’enfance, Olivier entreprend d’abord des études de philosophie, avant de retourner à la musique et de compléter des concours en composition instrumentale et en analyse au Conservatoire de musique de Montréal, sous la direction de Nicolas Gilbert et Jimmie LeBlanc. Depuis 2019, il est organiste titulaire du Sanctuaire-du-Saint-Sacrement, à Montréal, où il présente régulièrement des programmes dédiés au répertoire organistique des XXe et..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
