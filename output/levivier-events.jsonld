    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/michael-beil"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Michael Beil"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Michael"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Beil"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Michael Beil a étudié le piano et la théorie musicale à la Hochschule für Musik Stuttgart, puis la composition avec Manuel Hidalgo. En 1996, il a enseigné la théorie musicale et la composition aux conservatoires de musique de Kreuzberg et Neukölln à Berlin en tant que directeur du département pré-universitaire et du département de musique contemporaine. À cette époque, Michael Beil a également dirigé le Klangwerkstatt, un festival de musique contemporaine à Berlin, et a fondé en 2000, avec Stephan Winkler, l'équipe Skart afin de présenter des concerts basés sur des concepts interdisciplinaires. En 2007, il est devenu professeur de musique électronique à la Hochschule für Musik und Tanz de Cologne et directeur du studio de musique électronique."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
