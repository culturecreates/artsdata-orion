    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://levivier.ca/genid/e380bb5491eb4a2e"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Chants Libres - Oper'Actuel"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Oper’Actuel est un événement phare de Chants Libres, compagnie lyrique de création. Cette 9e édition rassemble publics, artistes et professionnel·le·s du milieu autour de spectacles, ateliers, discussions et vitrines professionnelles mettant en lumière les nouvelles pratiques lyriques d’aujourd’hui. Point culminant du festival, le spectacle Oper’Actuel propose une carte blanche à la soprano Sarah Albu, accompagnée de l’Ensemble Paramirabo sous la direction de Stephen Mulligan.Au cours de la semaine, le festival présentera également Come Closer, une création de la compagnie torontoise Opera 5 dirigée par Rachel Krehm; askîwan, une œuvre du créateur cri-métis Tyson Houseman ; ainsi qu'une première présentation de Akasha : &nbsp;Le souffle de l’univers, un opéra-danse interculturel proposé par Hamsa créations lyriques sous la direction de la soprano Kripa Nageshwar.&nbsp;&nbsp;"
      }
    ]
  },
