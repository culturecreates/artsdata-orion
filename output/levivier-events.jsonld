      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Myriam Bleau"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Myriam"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Bleau"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Myriam Bleau est une compositrice, artiste numérique et performeuse basée à Montréal. Utilisant la musique et le son comme point de départ, elle crée des performances audiovisuelles, des œuvres vidéo, des installations et des interfaces interactives qui articulent le son, la lumière et le mouvement. Son travail est principalement canalisé par la performance, embrassant des contextes éphémères et insaisissables. Du code et de l’apprentissage automatique à l’informatique physique et aux dispositifs, elle considère la technologie comme une autre agence qui co-crée le résultat. Sa pratique hybride explore les espaces poreux entre le monde physique et le monde virtuel, entre le naturel et le synthétique. Son travail a été reconnu et présenté internationalement dans des festivals et événements tels que le Prix Ars Electronica , Sónar, Transmediale, Sonic Arts Award, Elektra, Mutek, ISEA, ACT, L.E.V et LABoral, Scopitone."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
