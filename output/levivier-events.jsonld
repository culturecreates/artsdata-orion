      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/la-chorale-joker"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Chorale Joker"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fondée et dirigée par Joane Hétu depuis 2012, La Chorale Joker est une chorale a cappella inusitée pour une douzaine de chanteurs-solistes. La Chorale Joker explore les qualités de la texture et du timbre vocal, les paysages sonores, les motifs rythmiques, la poésie phonique et les sons extramusicaux comme le souffle, le babillage, les bruits de bouche. La Chorale Joker s’intéresse aux sons marginaux, aux défaillances vocales, aux territoires périphériques, aux interstices entre les tons afin d’accéder à un chant choral, non pas par le biais du répertoire, mais par celui..."
      }
    ],
    "@type": [
      "http://schema.org/PerformingGroup"
    ]
  },
