    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/yves-goemaere"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Yves Goemaere"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Yves"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Goemaere"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Yves Goemaere est né à Audenarde, en Belgique, le 30 septembre 1982. Il a toutefois grandi à Gavere, où il s'est intéressé à la musique dès son plus jeune âge. Il a commencé par jouer du piano, mais après quelques années, il s'est senti de plus en plus attiré par les percussions. Il a commencé sa carrière à l'école de musique de Zottegem sous la direction de Johan Cockaert, puis au Kunsthumaniora de Gand sous la direction de Wim De Vlaeminck et Wim Lasoen. Il a obtenu sa licence en percussion classique au Conservatoire de Gand avec Wim Konink et son master au Conservatoire royal de Bruxelles avec Gert Francois et Bart Quartier."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
