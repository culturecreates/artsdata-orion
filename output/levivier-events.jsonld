  {
    "@id": "_:g640620",
    "http://schema.org/url": [
      {
        "@id": "http://www.andrea-young.ca/"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "http://www.andrea-young.ca/"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/andrea-young"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Andrea Young"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Andrea"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Young"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Andrea Young est une interprète et une compositrice canadienne spécialisé dans la voix expérimentale et l’électronique en direct. Elle effectue une voix acoustique, amplifiée, traitée et resynthétisée, ainsi qu’une voix de contrôle du son ré-proposée grâce à une extraction de fonctionnalités et à une électronique en direct pilotée par des données. Alors que son travail repose sur l’innovation numérique, sa sortie musicale repose sur l’intégration de son interface numérique avec des médias électroniques analogiques et re-proposés.\r\n"
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g640640",
    "http://schema.org/url": [
      {
        "@id": "http://terrihron.com/"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "http://terrihron.com/"
      },
      {
        "@id": "https://soundcloud.com/terrihron"
      },
      {
        "@id": "https://concordia.academia.edu/TerriHron"
      },
      {
        "@id": "https://facebook.com/terrihron"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/membres/organismes/terri-hron"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Terri Hron"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Terri"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Hron"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Terri Hron est musicienne, performeuse et artiste multimédia. Son travail explore l’interprétation du répertoire et jeu d'instruments historiques, les pratiques d'écoute et les partitions expérimentales. Elle travaille souvent en étroite collaboration avec d'autres et produit des performances, des congrès et des événements. Terri a étudié la musicologie et l'histoire de l'art à l'Université d'Alberta, la performance historique et contemporaine au Conservatoire d'Amsterdam et la composition électroacoustique à l'Université de Montréal. Ses recherches portent sur la..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
