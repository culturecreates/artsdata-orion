      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/kapitolina-tsvetkova"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Kapitolina Tsvetkova"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Kapitolina"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Tsvetkova"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Kapitolina Tsvetkova, née en 1992 à Tcheliabinsk (Russie), est une metteuse en scène, scénographe et artiste basée en France.Travaillant sur des formes expérimentales d'opéra, de performance et d'installation, elle explore les questions de fragilité, de féminité, d'écologie et de mémoire.Engagée dans la recherche transdisciplinaire, elle travaille en collaboration avec des spécialistes de différents domaines scientifiques et techniques (biologistes, chimistes, ingénieurs, parfumeurs) afin de remettre en question les formes d'art traditionnelles et leur lien avec les questions contemporaines (thèse de maîtrise en arts sur l'art olfactif, créatrice du projet scientifique et artistique « Plant opera »). Elle utilise différents supports (vidéo, sculpture, son, scénographie) pour créer des installations et des performances multisensorielles et multidimensionnelles, dans lesquelles l'espace, l'objet et le corps s'efforcent de coexister et d'interagir de manière équitable."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
