    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/vanessa-massera"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Vanessa Massera"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Vanessa"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Massera"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Vanessa Massera, PhD (b. 1987/Montréal) &nbsp; specialised in electroacoustic music, a medium she now uses as a means to express poetic ideas whilst being anchored in the many different spaces and cultural environments she is inspired by. &nbsp; Her works have been performed amongst others at the ZKM (DE), Nordlyst (NO), NWEAMO Festival (JP/US), EMUFest (IT), Miso Music (PT), NYCEMF (US), TES (CA), Ai-Maako (CL), FRST (SE), MOKS (EE), with Éclats de Feux receiving the JTTP Canadian Electroacoustic Award. In 2019, she received her PhD at the University of Sheffield with the practice-based research subject Environment in Electroacoustic Music. &nbsp; Latest publication: Taking the Temperature: Curating, Crisis and Musical Diversity at OnCurating. Her album &nbsp; FULGURANCES is available under the prestigious label empreintes DIGITALes."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
