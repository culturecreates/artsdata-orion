  {
    "@id": "_:g580960",
    "http://schema.org/url": [
      {
        "@id": "https://levivier.ca/fr/artistes/nous-percons-les-oreilles"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/nous-percons-les-oreilles"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Nous perçons les oreilles"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Deux saxophones, deux voix; deux gargouilles, deux satyres; deux forces de la nature qui se démènent, chuintent, couinent, raclent, soufflent, mordent et transforment la musique en incantation profane et en un festin de sons.\r\n\r\nDéjà par son instrumentation, Nous perçons les oreilles constitue un duo assez particulier. On y trouve une certaine symétrie à la base: deux saxophones alto improvisant ensemble, mais des saxophonistes qui chantent aussi, chacun prenant le relais de l’autre si bien que dans certaines sections on ne sait plus du tout qui joue quoi. Un jeu de miroir, un..."
      }
    ],
    "@type": [
      "http://schema.org/PerformingGroup"
    ]
  },
  {
    "@id": "_:g580980",
