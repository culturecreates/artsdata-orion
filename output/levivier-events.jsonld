    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Originaire de Québec, Elizabeth Lima se produit en tant que clarinettiste et chanteuse au sein du duo d’improvisation Framboos, du collectif Ample et de l’Ensemble Kô. Elle s’intéresse à la fois à la musique ancienne et aux musiques actuelle et contemporaine.\r\n\r\nSource: www.quatuorbozzini.ca\r\n"
      }
    ],
