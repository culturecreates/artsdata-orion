    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Champagne"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Gabo est un.e artiste œuvrant dans les milieux de la musique contemporaine et des arts vivants. Ayant étudié en théâtre, en danse et en musique, ses expériences professionnelles l’ont mené.e à participer à plusieurs productions scéniques tant autoproduites qu’au sein de groupes de création, de même qu’à plusieurs œuvres d’art performance solo et en collectif. Elle a suivi plusieurs formations et ateliers, notamment au Japon en nô, en gagaku et en butoh; au Danemark avec l’Odin Teatret; au Banff Center for the Arts avec l’International Contemporary Ensemble; à..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
