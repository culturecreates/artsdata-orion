    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Hron"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Terri Hron est musicienne, performeuse et artiste multimédia. Son travail explore l’interprétation du répertoire et jeu d'instruments historiques, les pratiques d'écoute et les partitions expérimentales. Elle travaille souvent en étroite collaboration avec d'autres et produit des performances, des congrès et des événements. Terri a étudié la musicologie et l'histoire de l'art à l'Université d'Alberta, la performance historique et contemporaine au Conservatoire d'Amsterdam et la composition électroacoustique à l'Université de Montréal. Ses recherches portent sur la..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
