    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Andrea Young"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Andrea"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Young"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Andrea Young est une interprète et une compositrice canadienne spécialisé dans la voix expérimentale et l’électronique en direct. Elle effectue une voix acoustique, amplifiée, traitée et resynthétisée, ainsi qu’une voix de contrôle du son ré-proposée grâce à une extraction de fonctionnalités et à une électronique en direct pilotée par des données. Alors que son travail repose sur l’innovation numérique, sa sortie musicale repose sur l’intégration de son interface numérique avec des médias électroniques analogiques et re-proposés.\r\n"
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g479520",
