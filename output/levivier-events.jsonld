    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Pauline Oliveros"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Pauline"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Oliveros"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pauline Oliveros (1932–2016) est une accordéoniste et compositrice américaine emblématique, pionnière des musiques électroniques et figure marquante du minimalisme des années 1970. Membre fondatrice du San Francisco Tape Music Center, qu’elle a ensuite dirigé, elle a également enseigné au Mills College, à l’Université de Californie à San Diego et au Rensselaer Polytechnic Institute. Créatrice du concept de Deep Listening, elle a profondément influencé la manière d’aborder l’écoute, ouvrant de nouveaux horizons à la musique contemporaine et à la conscience sonore."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
