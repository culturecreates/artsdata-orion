    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Cité du son"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/le-vivier/repertoire/la-cite-du-son"
      }
    ],
    "http://schema.org/abstract": [
      {
        "@language": "fr",
        "@value": "Commande du Ministère français pour Proxima CentauriDans La Cité du son, le compositeur crée une architecture sonore et temporelle où s’établit une relation entre le son et le silence. « La musique invente le silence, l'architecture invente l'espace », nous rappelle le poète mexicain Octavio Paz. Le terme d’« architecture sonore » s'applique aussi bien à l'urbanisme d'une ville qu'à la composition d'une œuvre musicale, et Arturo Fuentes intègre ici dans une composition instrumentale des échantillons sonores provenant d’espaces acoustiques qu’il a explorés à México..."
      }
    ],
    "@type": [
      "http://schema.org/MusicComposition"
    ]
