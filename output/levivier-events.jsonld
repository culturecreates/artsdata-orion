    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alexandre Babel"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Alexandre"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Babel"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Lauréat du Prix suisse de musique 2021, Alexandre Babel est percussionniste, compositeur et commissaire artistique, engagé dans divers contextes contemporains tels que la musique classique moderne, la musique expérimentale et l’art de la performance. Babel crée des œuvres qui interrogent les attentes des auditeurs et auditrices à l’égard des formes musicales conventionnelles, dans une exploration de nouveaux contextes. Il est membre fondateur du collectif de performance Radial avec l’artiste Mio Chareteau et a été percussionniste soliste au sein de l’ensemble de musique contemporaine KNM Berlin de 2009 à 2019. En 2020, le festival monographique Les Amplitudes, à La Chaux-de-Fonds, a mis en lumière son travail de compositeur et de commissaire artistique. Jusqu’en 2022, Babel a été directeur artistique du collectif de percussion contemporaine Eklekto. Il vit actuellement à Berlin."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
