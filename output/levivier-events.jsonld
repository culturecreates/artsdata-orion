  {
    "@id": "https://levivier.ca/fr/concert/saison-2025-26/ensemble-litineraire-courantscontrecourants",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "fr",
        "@value": "Le Vivier"
      }
    ],
    "https://ogp.me/ns#type": [
