    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/raphael-siefert"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Raphaël Siefert"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Raphaël"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Siefert"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Raphael Siefert est un créateur d’univers, d’images, d’espaces lumineux. Avec les plasticiens, scénographes, danseurs et musiciens l’ensemble il a participé à la création de la grande majorité des spectacles d’HANATSUmiroir.&nbsp;Poésie des feux, force de construction, dynamique des espaces, Raphael travaille également à création d’interfaces de programmation lumineuses tissant des ponts entre les différents médiums artistiques de l’ensemble. Issu du théâtre, passionné de cadrage vidéo et de pyrotechnie, il est un technicien polyvalent toujours au service de la scène, du la musique et de l’idée.&nbsp;"
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
