      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/membres/organismes/emiliano-gavito"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Emiliano Gavito"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Emiliano"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Gavito"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Emiliano est flûtiste, interprète et cofondateur de lovemusic, lauréat du prix Ernst von Siemens Ensemble 2025. À travers cette plateforme, il promeut et crée de nouveaux répertoires, concevant des projets qui encouragent de nouvelles perspectives sur la musique contemporaine. Il s'intéresse particulièrement à l'exploration des instruments et des techniques d'interprétation comme outils d'expression de thèmes sociaux et politiques. Pour Emiliano, la musique nouvelle, en tant qu'art du spectacle, va au-delà de l'expérience sonore. Il est convaincu que la musique nouvelle, comme toute forme d'art contemporain, reflète la société actuelle et doit être accessible à tous."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g513500",
    "http://schema.org/url": [
