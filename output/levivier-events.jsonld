  {
    "@id": "https://levivier.ca/fr/concert/saison-2026-27/rosane-lajoie-voix-croisees",
    "https://ogp.me/ns#site_name": [
      {
        "@language": "fr",
        "@value": "Le Vivier"
      }
    ],
    "https://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "article"
      }
    ],
    "https://ogp.me/ns#url": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/concert/saison-2026-27/rosane-lajoie-voix-croisees"
      }
    ],
    "https://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Rosane Lajoie - Voix croisées | Le Vivier"
      }
    ],
    "https://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Conçu dans une étroite collaboration entre compositeurs et interprètes, le concert se veut un lieu de rencontre entre la tradition de la mélodie et la musique nouvelle, dans une approche esthétique sans compromis. Ce programme de Rosane Lajoie explore l’art intime de la mélodie à travers la création de deux cycles pour voix et piano. Sur des textes en français, les compositeurs Louis-Michel Tougas et Olivier St-Pierre signent deux œuvres portées par la soprano Brittany Rae et la pianiste Rosane Lajoie."
      }
    ],
    "https://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/sites/default/files/evenements/visuel-concert.jpg"
      }
    ],
    "https://ogp.me/ns#updated_time": [
      {
        "@language": "fr",
        "@value": "2026-06-22T16:53:10-04:00"
      }
    ],
