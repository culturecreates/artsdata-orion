    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Josiane Leblanc"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Josiane"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Leblanc"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Josiane Leblanc acquiert un baccalauréat en enseignement des arts en mai 2019. Née à Trois-Rivières, elle s’installe dans les Laurentides pour étudier le multimédia au niveau collégial à Montréal. Présentement active dans le milieu de la technique de scène, elle se réalise à travers l’artisanat du cuir depuis plusieurs années. Elle crée aussi des vidéos d’arts et s’implique dans les spectacles équestres."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
