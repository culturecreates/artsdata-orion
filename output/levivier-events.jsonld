      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Thomas Gauthier-Lang"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Thomas"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Gauthier-Lang"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Thomas Gauthier-Lang est un saxophoniste interprète et improvisateur animé par la recherche du rôle du saxophone dans la musique d’aujourd’hui, spécifiquement dans l’esthétique contemporaine. Il développe une palette sonore qui pousse les limites des saxophones en passant par une maîtrise des techniques étendues et une expérience grandissante en interprétation du répertoire des musiques nouvelles. Son implication en musique contemporaine passe par un questionnement de la conformité et des normes. En tant qu’organisateur, cette perspective guide ses choix de..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "https://levivier.ca/genid/5ba672555418cb16",
    "http://schema.org/url": [
