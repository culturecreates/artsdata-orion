    "https://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Quasar – quatuor de saxophones renouvelle sa collaboration avec la Escuela Superior de Música y Danza de Monterrey (ESMDM). Cette initiative transculturelle fait dialoguer les univers de la musique et de la danse contemporaine du Québec et du Mexique à travers une production ambitieuse."
      }
