    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Soumah"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Corie Rose Soumah est une compositrice montréalaise présentement basée à New York.\r\n\r\nSes œuvres ont été interprétées au Canada, aux États-Unis, aux Pays-Bas, en Allemagne et en Italie.&nbsp; Elle s’intéresse à des composantes sonores brisées et reconstituées par le biais de collages et de gestualités physiques. Elle explore ces textures au travers de médiums acoustiques et de technologies électroniques et analogiques. Sa démarche s’inscrit dans une redéfinition active d’une nouvelle québécitude sous l’influence de multiplicités culturelles, sonores et..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
