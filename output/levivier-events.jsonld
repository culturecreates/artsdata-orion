      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Cage"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Longtemps associé à l’avant-garde américaine de l’après-guerre, le compositeur John Cage était aussi, entre autres, philosophe, écrivain et graveur; il est considéré comme le compositeur américain le plus influent de sa génération. Il a été l’élève d’Henri Cowell (1933) à New York, puis d’Arnold Schoenberg, en Californie (1933-35). En 1937, il forme un premier orchestre de percussions à Seattle, puis à San Francisco, à Chicago et enfin à New York, où il se fixe en 1942. Il participe au développement de la danse moderne en étant, pendant de nombreuses..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g673720",
