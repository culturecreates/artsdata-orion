    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Omer Barash"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Omer"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Barash"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Omer Barash est un compositeur dont la musique explore fréquemment les notions de «betweenness» et d’identité, en reliant des interprétations personnelles des traditions hébraïques à des paysages sonores et des technologies contemporains. Ses œuvres ont été interprétées par des ensembles de premier plan tels que l’Ensemble Modern et le Meitar Ensemble, et ont été récompensées par des prix internationaux, notamment le Concours de composition impuls et le Salvatore Martirano Award. Barash a étudié la composition à l’Académie de musique et de danse de Jérusalem, à l’Université McGill, à l’Université de musique et des arts du spectacle de Vienne, ainsi qu’à l’Ircam à Paris. Il poursuit actuellement un doctorat en composition à l’Université Columbia. Il a été mentoré par Philippe Leroux, George Lewis, Georg-Friedrich Haas, et Zosha Di Castri."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
