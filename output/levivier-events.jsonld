    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le Vivier a pour mission de favoriser le développement des musiques nouvelles et d’offrir à tous, par la diffusion d’œuvres de qualité, une porte ouverte sur la culture."
