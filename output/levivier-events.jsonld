    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Productions Totem contemporain"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Les Productions Totem contemporain (PTC) se dédie essentiellement à la création, au développement, à la production et à la diffusion des instruments inventés et installations sonores de Jean-François Laporte.\r\n\r\nEn juillet 2004, l’organisme a investi l’Espace Totem qui se veut à la fois atelier et lieu de répétition pour le compositeur et son ensemble, lieu de résidence pour des artistes, puis lieu de diffusion.\r\n\r\nEn 2008, PTC mettait en place trois séries de concerts: Totem Danse met en valeur les instruments et installations des PTC en parallèle avec une œuvre..."
      }
    ],
    "@type": [
      "http://schema.org/PerformingGroup"
    ]
