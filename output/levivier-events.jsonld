  {
    "@id": "_:g573340",
    "http://schema.org/url": [
      {
        "@id": "https://www.architekpercussion.com/"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "https://www.architekpercussion.com/"
      },
      {
        "@id": "https://www.facebook.com/architekperc"
      },
      {
