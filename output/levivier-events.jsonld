        "@value": "Opéra Magnolia (Musique 3 femmes)"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Opéra Magnolia (anciennement Musique 3 Femmes) est un ensemble montréalais et organisme à but non-lucratif qui se dédie à encourager la prochaine génération de créatrices opératiques. Fondé en 2018, Opéra Magnolia trouve son inspiration dans un désir de voir plus de direction créative feminine dans notre industrie et de créer une plateforme qui pourrait nourrir des œuvres innovantes, créer de nouvelles opportunités et soutenir du talent émergent.&nbsp;"
      }
    ],
    "@type": [
      "http://schema.org/PerformingGroup"
    ]
  },
