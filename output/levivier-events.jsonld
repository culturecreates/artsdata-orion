    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Innovations en concert (IEC)"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Innovations en concert a été fondé en 1994 pour soutenir la diversité dans la création de nouvelle musique de chambre en présentant et faisant la promotion de concerts, d’événements spéciaux et d’autres activités. Dix-neuf ans plus tard, ce but est tout aussi pertinent. Sous la direction d’Isak Goldschneider, nous continuons à servir musiciens et public en facilitant le contact entre les artistes, en donnant aux musiciens la chance de créer de la musique pour ensembles ou lieux inusités et en stimulant la création de nouvelles œuvres. Nous pouvons offrir des..."
      }
    ],
    "@type": [
      "http://schema.org/PerformingGroup"
    ]
  },
