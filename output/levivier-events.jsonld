    "http://schema.org/url": [
      {
        "@id": "https://levivier.ca/fr/evenement/saison-2025-26/symposium-sqeqip-steltitelem-chants-pour-rassembler-les-gens"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-03-08T13:00:00-04:00"
