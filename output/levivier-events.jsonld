    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/eloain-lovis-hubner"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Eloain Lovis Hübner"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Eloain"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Lovis Hübner"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Eloain Lovis Hübner travaille depuis plus de dix ans dans le domaine de la musique nouvelle et du théâtre musical contemporain : composition, conception, collaboration, conservation, enseignement – et enfin, défense des intérêts de la scène indépendante dans la politique culturelle. Ses intérêts particuliers portent actuellement sur la recherche sonore expérimentale dans le monde analogique, les formats spatiaux et transdisciplinaires, la collaborativité ainsi que les liens entre la pratique musicale et les environnements sociaux, naturels, techniques, urbains, domestiques et médiatiques et leurs phénomènes sonores. Bon nombre de ses œuvres relèvent du domaine de la recherche artistique ou intègrent des influences issues des sciences humaines, en particulier de la sociologie et des études queer."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
