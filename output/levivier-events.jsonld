    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ana Maria Romano G. est une compositrice, artiste sonore et artiste interdisciplinaire colombienne. Ses recherches se situent à l'intersection du genre, des sexualités, du son et de la technologie, et portent sur l'écoute, le paysage sonore, l'espace, le corps, la noise, l'expérimentation, le cyberespace et les dimensions politiques de la création. Dans tous les espaces de sa vie, elle considère le travail collectif et collaboratif comme fondamental."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
