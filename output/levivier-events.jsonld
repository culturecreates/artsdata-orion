      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Charles"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Xavier Charles, musicien improvisateur et compositeur est une figure incontournable de la scène des nouvelles musiques européennes. Virtuose irréprochable, il s’invente un langage unique et épouse les musiques les plus aventureuses valsant entre l’art conceptuel, le punk rock de The Ex, la musique électroacoustique, le jazz éthiopien, l’écriture et l’improvisation, avec différents collectifs , l’orchestre Système Friche et Jacques Di Donato, sans oublier le travail minimaliste de groupes comme Dans les arbres, la chanson avec son premier album avec Les Navires et avec des formes comme la danse, le cinéma ou le théâtre sonore et la compagnie Roland Furieux."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
