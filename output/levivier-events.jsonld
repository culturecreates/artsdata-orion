    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Kalun Leung is a trombonist, improvisor, composer and creative technologist based in Brooklyn, New York. His work as an instrumentalist is motivated by the exploration of new and unexpected contexts in which the trombone can thrive. This ongoing research-based approach has manifested in travels to the Guča, the capital of Serbian brass band music, audiovisual performances of Keith Haring’s unpublished computer art, a Fluxus-inspired trombone sound sculpture, ecoacoustic improvisations on what was the largest landfill in the world, and the creation of mubone, a custom..."
      }
    ],
