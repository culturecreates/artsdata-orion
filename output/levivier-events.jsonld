    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Dupuis"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Sophie Dupuis est une compositrice francophone originaire et établie au Nouveau-Brunswick. Elle s'intéresse à la musique d'art interdisciplinaire, à l'opéra et à la voix, à la musique électroacoustique et acoustique. Elle trouve son inspiration dans les paysages pittoresques des Maritimes où elle a grandi, dans son attirance pour les sons électriques bruts et dans diverses formes d'art de la performance. Ses œuvres ont été commandées et interprétées par des solistes et des groupes tels que Duo Holz, The Art Song Project, Made in Trio, Din of Shadows, Caution Tape Sound..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
