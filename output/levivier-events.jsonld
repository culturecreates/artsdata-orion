    "https://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "AMBRES est un concert d’œuvres surgissant de l’univers musical de la compositrice québécoise Michelle Boudreau. Son ensemble à géométrie variable regroupant des musiciens de la scène lyrique et instrumentale se dédie totalement à la musique de création souterraine de la nouvelle avant-garde et éruptive de l’actualité contemporaine."
      }
    ],
