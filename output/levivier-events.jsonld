    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ayako Okulo"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Ayako"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Okulo"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ayako Okubo est née à Fukui,&nbsp;&nbsp;au Japon. Elle s’initie très tôt à ce qui deviendra une passion, puis un métier et quitte le Japon afin de poursuivre ses études en Europe : Arnhem,&nbsp;&nbsp;Amsterdam et Strasbourg où elle se perfectionne dans la classe de Mario Caroli.&nbsp;\r\n\r\nDepuis 2009, elle participe ainsi à de nombreux concerts, festivals et tournées avec l’ensemble strasbourgeois Accroche Note. Elle fonde en 2010 l’ensemble HANATSUmiroir avec le percussionniste Olivier Maurel et s’occupe depuis de sa direction artistique.&nbsp;\r\n\r\nElle s’est produite au..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
  {
    "@id": "_:g775640",
    "http://schema.org/url": [
      {
        "@id": "https://levivier.ca/fr/le-vivier/equipes/olivier-maurel"
      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/le-vivier/equipes/olivier-maurel"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Olivier Maurel"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Olivier"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Maurel"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Passionné par la musique dès son plus jeune âge, Olivier Maurel découvre les percussions à travers la pop des Beatles et l’écriture puissante et torturée de Yoshihisa Taïra. Après avoir étudié le violon, il se forme aux conservatoires de Rennes, St Malo et Strasbourg et obtient après un cursus classique le Prix Supérieur Inter-régional. Il s’initie également aux ondes Martenot.\r\n\r\nEn marge de ses études classiques il reste curieux de tous univers musicaux. De Stockhausen à Radiohead, de la hardtech à la cumbia, il explore pratiques et cultures et tisse alors dans le..."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
