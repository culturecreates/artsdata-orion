      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Annie Gagnon"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Annie "
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Gagnon"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Annie Gagnon étudie en arts visuels puis se tourne vers la danse contemporaine et décroche un diplôme à l’École de danse contemporaine de Montréal (EDCM) en 2002. Interprète et chorégraphe, elle a présenté ses pièces à travers le Québec, notamment Si j’étais une de ces femmes, Tout à Trac, Lotus, La Marche invisible, Étude sur le cœur, Les femmes de la Lune Rouge, Reviens vers moi le ventre en premieret Rituel Géométrique. Annie est directrice des répétitions et conseillère artistique pour plusieurs chorégraphes et compagnies de danse : La Compagnie Marie Chouinard, O Vertigo, Estelle Clareton, Alan Lake, Emmanuelle Calvé, Jessica Serli, Destins croisés et PPS Danse."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
