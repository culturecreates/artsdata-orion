      }
    ],
    "http://schema.org/identifier": [
      {
        "@language": "fr",
        "@value": "https://levivier.ca/fr/artistes/stefan-prins"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Stefan Prins"
      }
    ],
    "http://schema.org/givenName": [
      {
        "@language": "fr",
        "@value": "Stefan"
      }
    ],
    "http://schema.org/familyName": [
      {
        "@language": "fr",
        "@value": "Prins"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après avoir obtenu son diplôme d'ingénieur (spécialisé en photonique), Stefan Prins (né en Belgique en 1979) a étudié le piano et la composition au Conservatoire royal flamand d'Anvers, en Belgique, où il a obtenu son master en composition avec Luc Van Hove. Parallèlement, il a étudié la « technologie dans la musique » au Conservatoire royal de Bruxelles avec Peter Swinnen et la « sonologie » au Conservatoire royal de La Haye, puis a obtenu un doctorat en composition musicale à l'université Harvard (Cambridge, Massachusetts) sous la direction de Chaya Czernowin.Sa musique intègre et reflète souvent les technologies contemporaines et les nouveaux médias, en thématisant leur relation avec le corps physique, le corps performatif et les environnements qu'il habite. Avec Pieter Matthynssens, Stefan Prins est directeur artistique de l'ensemble belge de musique contemporaine Nadar Ensemble."
      }
    ],
    "@type": [
      "http://schema.org/Person"
    ]
  },
