  {
    "@id": "_:g775780",
    "http://schema.org/url": [
      {
        "@id": "https://filippkapa.com"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "https://filippkapa.com"
      },
      {
        "@id": "https://www.instagram.com/kapitopina/"
