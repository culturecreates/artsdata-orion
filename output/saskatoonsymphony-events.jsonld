  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/d5f5b5a7-8a45-4267-b61e-e418689338d5",
    "@type": [
      "https://schema.org/CreativeWork"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/time-for-toddlers-10/"
      }
    ],
    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\t\n\n\n10:00AM, Friday, November 27, 2026\nNutrien Wonderhub\n\n\n950 Spadina Crescent E\nSaskatoon, SK S7K 3H6\nGoogle Maps Directions\n\n\nRegister\n\n\n11:15AM, Friday, November 27, 2026\nNutrien Wonderhub\n\n\n950 Spadina Crescent E\nSaskatoon, SK S7K 3H6\nGoogle Maps Directions\n\n\nRegister\n\n\n10:00AM, Saturday, November 28, 2026\nNutrien Wonderhub\n\n\n950 Spadina Crescent E\nSaskatoon, SK S7K 3H6\nGoogle Maps Directions\n\n\nRegister\n\n\n11:15AM, Saturday, November 28, 2026\nNutrien Wonderhub\n\n\n950 Spadina Crescent E\nSaskatoon, SK S7K 3H6\nGoogle Maps Directions\n\n\nRegister\n\n\n\nCrisp snow, skaters and sleigh rides! The Saskatoon Symphony invites you to join us for a winter inspired program with music of the season, rhymes games and more!\nSpecifically designed for your mini-maestro, these parent and child experiences are perfect for your 2- to 4-year-old music lover.\nExplore music through movement, song and dance with SSO musicians. Let the music connect you and your child and send you both on a journey through melody, rhythm, colour, and beautiful sound.\nBy buying a ticket to the Time for Toddlers 11:15am session on November 28th, you consent to photos being taken by the SSO for promotional purposes.\n\n\n\t\t"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/event/home-alone/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
