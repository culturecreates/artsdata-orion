      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/6d172820-6cd0-4a07-9567-3b1f185bc653",
    "@type": [
      "https://schema.org/Blog"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/picasso-symphony/"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/605a208a-615f-42b1-87c2-56bf775c12a7",
    "@type": [
      "https://schema.org/WPHeader"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/picasso-symphony/"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/e8e086cd-a13e-48d3-945e-dc97437e5fc4",
    "@type": [
      "https://schema.org/CreativeWork"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/picasso-symphony/"
      }
    ],
    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\t\n\n\n7:30PM, Saturday, November 7, 2026\nTCU Place, Sid Buckwold Theatre\n\n\n35 – 22nd Street East\nSaskatoon, SK S7K 0C8\nGoogle Maps Directions\n\n\nSubscribe and Save\n\n\n\nKevin Zakreskyconductor\n\n\nEl Sombrero de Tres Picos – Danza de la MolineroManuel de Falla\nGuitar Concerto – Allegro preciso – Poco menoHeitor Villa-Lobos\nSimple Symphony 3 – Sentimental SarabandeBenjamin Britten\nOverture for OrchestraGermaine Tailleferre\nRite of Spring – First Two MovementsIgor Stravinsky\nParade – Petite fille américaine / Acrobates / Suite au prelude du rideau rougeErik Satie\nPour PabloIgor Stravinsky / Bradley Hawkins\nSymphony No. 1 – First MovementSergei Prokofiev\nLa Création du Monde – Overture – 1st DanceDarius Milhaud\nGuitar Concerto – Second MovementHeitor Villa-Lobos\nJupiterGustav Holst\nTorre BermejaIsaac Albéniz\nScherzo – Symphony No. 1 in E-flatIgor Stravinsky\n\n\nSaskatoon has a special connection to the great Pablo Picasso thanks to the generous donation of more than 400 Picasso linocuts to the Remai Modern from the Frank and Ellen Remai Foundation.\nThe SSO is thrilled to present the Canadian debut of a brand new concert experience, the Picasso Symphony.\nCreated and led by Saskatoon-born Maestro Kevin Zakresky, this multi-media event features the music of Stravinsky, de Falla, Villa-Lobos, Britten, Satie, and more as the SSO underscores footage of Picasso bringing each of his artistic periods to life.\nA multimedia symphonic experience celebrating the life, works and times of the most prolific artist of all time, Pablo Picasso. This experience explores the artistic genius who revolutionized art and the way we view the painted canvas.\n\n\n\t\t"
      }
    ]
  },
