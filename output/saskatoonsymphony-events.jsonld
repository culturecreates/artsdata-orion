    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Picasso Symphony"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Created and led by Saskatoon-born Maestro Kevin Zakresky, this multi-media event features the music of Stravinsky, de Falla, Villa-Lobos, Britten, Satie, and more as the SSO underscores footage of Picasso bringing each of his artistic periods to life."
      }
    ],
