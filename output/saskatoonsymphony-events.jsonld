    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Home Alone"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A true holiday favorite, this beloved comedy classic features renowned composer John Williams' charming and delightful score performed live to picture by the SSO."
      }
    ],
