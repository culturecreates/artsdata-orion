        "@language": "en",
        "@value": "Handel's Messiah"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Podium Partner Karl Hirzer returns to the intricate music of Handel for a third year in a row. If you had a chance to see the SSO and Chorus led by Hirzer in previous seasons, you know we’re in for a special treat."
      }
    ],
