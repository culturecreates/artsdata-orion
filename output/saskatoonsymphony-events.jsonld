    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Croon"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "As part of the SaskJazz Festival, crooner Michael Lewis joins your SSO at the Broadway Theatre on July 6, 2026."
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/c7ef07c9-31d1-494c-9826-6aae5df0c067",
    "@type": [
      "https://schema.org/Blog"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
