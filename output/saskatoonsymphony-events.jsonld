    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "In Love Again"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A concert designed specifically for your Valentines' weekend–full of romance, passion, and music with cellist Johannes Moser!"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/20ebfb88-e3a2-482a-922c-5394865a94ff",
    "@type": [
