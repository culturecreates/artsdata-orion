      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Finding Light"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "In a season tied together by its search for light in the darkness, Maestro Judith Yan finds the light with a special program including Pergolesi’s transcendent Stabat Mater featuring Saskatoon’s own Kateryna Khartova and Oli Guselle. "
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/95983416-7db9-4f2d-8776-cf9af732873b",
    "@type": [
      "https://schema.org/Blog"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/finding-light/"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/e49d8d04-5d00-4a51-89d3-5cb605c9fd1f",
    "@type": [
      "https://schema.org/WPHeader"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/finding-light/"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/f1d8a13a-ebc5-44cf-be7c-fc1f2a389780",
    "@type": [
      "https://schema.org/CreativeWork"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/finding-light/"
      }
    ],
    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\t\n\n\n7:30PM, Saturday, May 30, 2026\nKnox United Church\n\n\n838 Spadina Crescent E\nSaskatoon, SK S7K 3H4\nGoogle Maps Directions\n\n\nSave Your Seats\n\n\n\nJudith Yanconductor\nKateryna Khartovasoprano\nOli Gusellealto\n\n\nStabat MaterPergolesi\n\n\nMaestro Judith Yan returns to close out our season in a very special concert.\nIn a season that has been tied together by its search for light in the darkness, Judith has put together a program new and old to find the light.\nWritten in the dwindling light of his life, Pergolesi’s Stabat Mater is a transcendent work that feels as modern today as the day it was written, 290 years ago.\nJean-Jacques Rousseau praised the work as “the most perfect and touching duet to come from the pen of any composer”\nSaskatoon’s own Kateryna Khartova and Oli Guselle take centre stage for this arresting music.\nAdd this show to your subscription package and save!\n\n\n\t\t"
      }
    ]
  },
