    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Pirates of the Caribbean"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The SSO presents Disney’s Pirates of the Caribbean: The Curse of the Black Pearl in concert featuring Klaus Badelt & Hans Zimmer’s score performed live to the film."
      }
