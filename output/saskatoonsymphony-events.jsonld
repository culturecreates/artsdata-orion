  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/70586710-f3b5-4081-b8dd-dfd5a9b48ad1",
    "@type": [
      "https://schema.org/Blog"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
