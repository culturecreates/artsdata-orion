    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Vers la flamme"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Podium Partner Judith Yan curates a unique concert experience as we move towards the flame. The evening features 5 brand new works by female composers and Violinist Nikki Chooi returns to perform Iman Habibi’s Atash."
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/54caf203-f42c-4f64-9c22-2c98bdc36c56",
