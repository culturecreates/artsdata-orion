        "@language": "en",
        "@value": "Summer Sounds At Black Fox, Powered by ATB Wealth"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Join us at Black Fox Farm &amp; Distillery again this summer for a Hollywood-themed event on their luscious landscape! Summer Sounds at Black Fox, powered by ATB Wealth."
      }
    ],
