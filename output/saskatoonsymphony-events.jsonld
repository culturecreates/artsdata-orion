    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\t\n\n\n2:00PM, Sunday, November 1, 2026\nGrosvenor Park Church\n\n\n407 Cumberland Ave S\nSaskatoon, Saskatchewan S7H 2L3\nGoogle Maps Directions\n\n\nFREE EVENT\n\n\n\nSpend a Sunday afternoon at a concert featuring the SSO Chamber Ensemble! Whether you are bringing your family, your friends, or just looking to enjoy beautiful music, this concert is a delightful way to spend an hour on Sunday, November 10th.\n\n\nThis is a free event.\n\n\n\t\t"
      }
    ]
