        "@value": "Hunchback of Notre Dame"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Returning to the historic Roxy Theatre, Michael Bridge creates a new improvised score for the legendary silent film The Hunchback of Notre Dame."
