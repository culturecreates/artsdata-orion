    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Elements"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Alexa Haynes-Pilon returns home to Saskatoon with a new baroque concert experience that she has designed, depicting the elements through musical imagery, using specific instrumentation and textures to evoke natural forces."
      }
    ],
