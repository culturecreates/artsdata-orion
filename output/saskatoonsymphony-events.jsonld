  {
    "@id": "https://saskatoonsymphony.org/temporary/b01aa4ce-0f67-4041-97c6-c08ac3844c2b",
    "@type": [
      "https://schema.org/CreativeWork"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/sing-along-messiah-4/"
      }
    ],
    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\t\n\n\n2:00PM, Saturday, December 12, 2026\nKnox United Church\n\n\n838 Spadina Crescent E\nSaskatoon, SK S7K 3H4\nGoogle Maps Directions\n\n\nSubscriber Presale\n\n\n\nKarl Hirzerconductor\nCasey Pedensoprano\nOli Gusellealto\nSpencer McKnighttenor\nNicholas Borgbass\nSSO ChorusDuff Warkentin & Kerry Agnew\n\n\nIt’s the return of Sing-Along Messiah! Want to learn more? Visit our Sing-Along FAQs.\nWith an all-Saskatchewan line of soloists and the SSO Chorus, we continue our favourite tradition where you get to join in the chorus.\nSing-Along Messiah is dedicated to the memory of longtime SSO chorus member and friend, Kathleen Brannen. \n\n\n\t\t"
      }
    ]
  },
