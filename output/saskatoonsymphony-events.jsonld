    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://saskatoonsymphony.org/event/a-change-is-gonna-come/"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://saskatoonsymphony.org/event/a-change-is-gonna-come/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "A Change is Gonna Come"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "There is nothing like the soulful voice of an R&amp;B diva, and we couldn’t be more thrilled to be bringing the powerhouse voice of Saskatoon’s very own Sonia Reid to the music of Whitney, Dion, Aretha, and so much more."
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://saskatoonsymphony.org/temporary/a477c5fc-c148-44ce-a793-1eaeaeb4528d",
    "@type": [
      "https://schema.org/Blog"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
