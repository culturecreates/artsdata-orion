      }
    ],
    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\t\n\n\n7:30PM, Sunday, December 20, 2026\nSt John’s Cathedral\n\n\n 816 Spadina Crescent E\nSaskatoon, Saskatchewan S7K 3H4\nGoogle Maps Directions\n\n\nSave Your Seats\n\n\n\nSSO Chamber Ensemble\n\n\nA new holiday tradition has been born!\nJoin the SSO in the stunning acoustics of the historic St John’s Cathedral on Spadina for this beautiful night of Christmas carols and holiday favourites.\nIf you’re thinking about attending multiple shows, bundle your tickets and save!\n\n\n\t\t"
      }
    ]
  },
