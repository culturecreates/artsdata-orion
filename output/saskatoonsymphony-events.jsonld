    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "All Beethoven"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Renowned cellist Johannes Moser is joined by superstar pianist Marc-André Hamelin for a concert featuring works for cello and piano by Ludwig van Beethoven."
      }
    ],
