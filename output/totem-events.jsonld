    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Exploring Babel Table — Atelier de pratique performative et nouvelles lutheries | Productions Totem Contemporain"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Jean-François Laporte dirige un atelier intensif avec les étudiants et doctorants du Conservatoire San Pietro a Majella autour de la Table de Babel, multi-instrument hybride à air comprimé emblématique du répertoire de Productions Totem Contemporain. Deux jours d'immersion dans la prassi performative contemporaine, en préparation du concert Totem Électrique Napoli.Le 10 et 11 mai de 10 à 18h.Entrée libre"
      }
    ],
