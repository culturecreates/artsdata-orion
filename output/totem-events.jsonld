    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Marginale II — Festival d'arts transmédiaux"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Jean-François Laporte participe au festival Marginale II à l'Opificio Puca, dans le cadre de la rassegna napoliGROUND. Il prend part à une impro solo dès 20 h, puis présente Rituel en clôture de soirée à 23 h, dans une diffusion octophonique sur le système Ambisonics Volta.Programme complet: https://www.napolitotaleelettronica.it/marginale/timetable.php&nbsp;"
      }
    ],
