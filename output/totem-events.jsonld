    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Super Totem 2 | Productions Totem Contemporain"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Le concert Super Totem 2, présenté le 22 février 2026, rassemblera des œuvres de Bernard Falaise, Audréanne Filion, Joane Hétu et Jean-François Laporte. Cette soirée mettra en lumière une instrumentation singulière et audacieuse, réunissant deux Tables de Babel, un Orgue de Sirènes, guitare électrique, saxophone, objets sonores et voix. Un parcours sonore immersif où l’expérimentation instrumentale et la puissance expressive se rencontrent."
      }
    ],
