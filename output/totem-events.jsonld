      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr",
        "@value": "https://totemcontemporain.com/fr/calendrier/2025-2026/marginale-ii-festival-darts-transmediaux"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Marginale II — Festival d'arts transmédiaux | Productions Totem Contemporain"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Jean-François Laporte participe au festival Marginale II à l'Opificio Puca, dans le cadre de la rassegna napoliGROUND. Il prend part à une impro solo dès 20 h, puis présente Rituel en clôture de soirée à 23 h, dans une diffusion octophonique sur le système Ambisonics Volta.Programme complet: https://www.napolitotaleelettronica.it/marginale/timetable.php"
      }
    ],
    "http://ogp.me/ns#image": [
