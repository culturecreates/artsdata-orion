    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Totem Électrique XX - FOCUS Compositeur "
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Nous avons le plaisir de présenter, en coproduction avec Groupe Le Vivier, deux concerts exclusifs Totem Électrique, mettant en lumière le travail de compositrices et compositeurs de grand talent sur nos instruments uniques.Le dimanche 1er février 2026, nous vous retrouvons à l’Espace Bleu du Wilder à 19 h 30 pour le concert Totem Électrique XX, présentant des œuvres remarquables de James O’Callaghan, Stéphane Roy, Paolo Montella, Martin Parker et I Putu Arya Deva Suryanegara."
      }
    ],
