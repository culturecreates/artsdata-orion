      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://rendezvoustheatre.ca/piece/le-chiard-2"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://rendezvoustheatre.ca/piece/le-chiard-2"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Gaspésie. Début du XXe siècle. Équinoxe d’automne. Donatienne, femme de pêcheur et mère de deux grands enfants, fait le meilleur chiard de morue salée des environs. Devant la demande aussi pressante et insistante qu’incongrue du grand patron pour lui préparer son fameux plat, Donatienne s’entête à le lui refuser. Les pauvres, dit-elle, n’ont pour fortune que leur honneur. Le geste, en apparence banal, aura des répercussions politiques sur le système d’exploitation en place depuis 200 ans. La question va diviser l’ensemble du village, tout en plongeant la femme et sa famille dans un tourment existentiel.\nRéfléchir à notre passé, c’est se donner des outils pour faire face à notre présent, éviter de répéter les mêmes erreurs et construire un avenir qu’on espère meilleur.\nAlors qu’on déboulonne les statues des héros de la grande Histoire, il est intéressant de porter notre regard sur la toute petite histoire – celle de nos grands-parents et de leurs ancêtres qui, bien que truffées de paradoxes, paraît désormais plus inspirante pour rêver d’un monde meilleur."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le chiard"
      }
    ]
  },
