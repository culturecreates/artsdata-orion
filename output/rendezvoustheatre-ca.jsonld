    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Un nuage dans mon ventre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Qui n’a jamais été envahi d’émotions complexes et paradoxales ? Dès nos premiers pas, on apprend à les reconnaître, les observer, les apprivoiser… Elles…"
      }
