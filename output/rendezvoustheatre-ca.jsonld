      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Virginie se déterre d’entre les morts \navec une seule envie : manger un cornet à la vanille. Mais il coûte \ndorénavant 275 $, et même plus. À la recherche…"
      }
