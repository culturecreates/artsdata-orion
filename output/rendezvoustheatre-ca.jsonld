    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Après on va où?"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Par la fenêtre de sa chambre, un homme d’âge mûr regarde fleurir un magnolia et décide d’en faire le témoin de ses questionnements. Entre un rendez-vous…"
      }
    ],
