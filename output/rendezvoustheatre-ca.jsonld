    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Joffrey Corboz est un artiste multidisciplinaire basé à Victoriaville (Centre-du-Québec). Son travail combine notamment conte, slam, musique, mise en scène et médiation culturelle.\n//\nLe Moulin Michel (lieu de représentation du spectacle Road Moovie) est un pôle culturel important du Centre-du-Québec : à la fois salle de spectacle au cachet unique, musée agréé, salle de réception pour réunions et mariages, restaurant et café-boutique en terrasse, le moulin fait vivre la culture dans toutes ses facettes."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Joffrey Corboz / Moulin Michel"
      }
    ]
  },
