  {
    "@id": "_:g544220",
    "@type": [
      "http://schema.org/PerformingArtsTheater"
    ],
    "http://schema.org/address": [
      {
        "@id": "_:g544240"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://auxecuries.com/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le Théâtre Aux Écuries est un incubateur théâtral. Un centre de création à l’écoute des rythmes, des besoins et des rêves des créateur·trice·s. Un lieu de diffusion pour les compagnies émergentes. Un théâtre qui offre au grand public des découvertes toujours plus singulières, étonnantes et poétiques. \n\nLe Théâtre Aux Écuries, c’est :\nLa maison de six compagnies résidentes;\nDes projets en incubation sur deux ans;\nDes accueils de création et de diffusion inspirantes;\nDes spectacles issus de démarches de création atypiques;\nUn suivi artistique et administratif personnalisé pour chaque créateur·trice;\nTrois espaces de répétition;\nDes événements spontanés;\nUne relation de proximité avec le quartier Villeray; \nUn lien avec le milieu scolaire dans tout le Québec."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Théâtre Aux Écuries"
      }
    ]
  },
