    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Après plus de 80 représentations à succès, <em>Verdict</em> revient pour de nouvelles plaidoiries abordant différents débats de société inspirés de causes judiciaires emblématiques. Le public devient juré, plongé dans un procès captivant où chaque spectateur devra délibérer et rendre son verdict, tel un véritable membre du jury.</p>"
      }
