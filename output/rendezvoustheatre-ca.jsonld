    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Joffrey Corboz est un artiste multidisciplinaire basé à Victoriaville (Centre-du-Québec). Son travail combine notamment conte, slam, musique, mise en scène et médiation culturelle.\n//\nL'espace culturel de Victoriaville, Le Carré 150 (lieu de représentation du spectacle Road Moovie) est géré par Diffusion Momentum, organisme sans but lucratif fondé en 2001 ayant pour mission la diffusion pluridisciplinaire de spectacles professionnels et de diffusion des arts visuels et médiatiques contemporains."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Joffrey Corboz / Le Carré 150"
      }
    ]
  },
