  {
    "@id": "https://rendezvoustheatre.ca/genid/f15d5c56819206a4",
    "@type": [
      "http://schema.org/PerformingArtsTheater"
    ],
    "http://schema.org/address": [
      {
        "@id": "https://rendezvoustheatre.ca/genid/3575d3f9b170467d"
