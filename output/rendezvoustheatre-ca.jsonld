      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Cougar, le chef des motards veut mettre la main sur Jambon et Patpou. Il accuse les deux ex-mécaniciens d’avoir essayé de l’assassiner! Cachés dans le centre de santé de la belle-sœur de Jambon, les deux fugitifs se font passer, à son insu, pour des massothérapeutes aux techniques surprenantes. L’adaptation est brutale, mais les choses se compliquent encore plus lorsqu’ils découvrent que leur premier client est… Cougar.</p>"
      }
    ],
    "http://schema.org/headline": [
