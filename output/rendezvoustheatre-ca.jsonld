    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fondé en 2002, le Jamais Lu est un organisme qui a pour mandat de développer la dramaturgie contemporaine en créant des rendez-vous artistiques et publics autour de celle-ci.\nQue ce soit à Montréal, à Québec, au Saguenay-Lac-Saint-Jean, à Gaspé, en Estrie, en Abitibi-Témiscamingue, à Paris, à la Caraïbe, ou dans tout autre territoire où il se sent le bienvenu. Le Jamais Lu a à cœur de créer des espaces d’essai, où les paroles inédites peuvent naître avec bienveillance et joie."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "FESTIVAL DU JAMAIS LU - 25e ÉDITION"
      }
    ]
  },
