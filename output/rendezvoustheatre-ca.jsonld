    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Alain Bouchard, un Québécois, élève ses filles dans un esprit de tolérance. Cependant, il est déstabilisé par la diversité culturelle de sa famille : trois de ses quatre filles sont en couple avec des hommes d’origines différentes. Pour rétablir l'harmonie, sa femme Marie propose une grande réunion de Noël, où Alain espère présenter un Québécois « pure laine » à sa fille Karine. Cette fête promet d'être pleine de surprises, mêlant rires et réflexions sur la diversité. Une comédie touchante qui célèbre les liens familiaux et la richesse de notre monde moderne!"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Qu'est-ce qu'on a fait au Bon Dieu"
      }
    ]
