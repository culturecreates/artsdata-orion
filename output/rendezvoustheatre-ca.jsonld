    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Joffrey Corboz est un artiste multidisciplinaire basé à Victoriaville (Centre-du-Québec). Son travail combine notamment conte, slam, musique, mise en scène et médiation culturelle.\n//\nLe Carrefour Jean-Louis Vallée (lieu de représentation du spectacle Road Moovie) est un centre culturel et de services touristiques situé au cœur de la ville de Plessisville (Québec). Il fait partie du site du Parc de la Rivière‑Bourbon, ce qui lui confère un cadre naturel attractif, avec aires de pique-nique, jeux pour enfants, sentiers et stationnement."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Joffrey Corboz / Carrefour Jean-Louis Vallée"
      }
    ]
  },
