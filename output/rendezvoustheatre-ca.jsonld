      {
        "@type": "http://schema.org/Date",
        "@value": "2027-02-26T00:00:00-05:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://rendezvoustheatre.ca/piece/la-florida"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://rendezvoustheatre.ca/piece/la-florida"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Léo Lespérance, sa merveilleuse femme Ginette, leurs enfants et \nPépère prennent la route pour Hollywood Beach, convaincus d’avoir trouvé\n leur paradis jusqu’à ce que leur rêve se noie dans le fond de la \npiscine.\nClients capricieux, voisins intimidants et rénovations à ne plus \nfinir : bienvenue au Motel Ginette, où le rêve américain se prend une \nbonne tasse d’eau salée… et de réalité.\nDans un décor tropical délicieusement kitsch, les répliques cultes \nque tout le monde connaît par cœur sont de retour, servies dans une \ncomédie aussi hilarante que touchante, aussi lumineuse que cruelle.\nAdaptée du film culte de 1993, récipiendaire du Prix Bobine d’Or pour\n le plus grand succès au box-office québécois, La Florida revient \nbriller sur scène sous la mise en scène de Charles Dauphinais, entourée \nde nos snowbirds préférés, Louis Champagne, Didier Lucien, Lauren \nHartley, Gary Boudreault, Marc St-Martin et Joakim Robillard et \nplusieurs autres.\nEnweille au théâtre, maudites chanceuses… et chanceux !"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Florida"
      }
    ]
  },
