  {
    "@id": "https://rendezvoustheatre.ca/genid/d3a4c134f0d278e0",
    "@type": [
      "http://schema.org/PerformingArtsTheater"
    ],
    "http://schema.org/address": [
      {
        "@id": "https://rendezvoustheatre.ca/genid/6fa4a995bb9a6036"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://nouveautheatredelile.com/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le Nouveau théâtre de l’Île d’Orléans a été fondé en 2011 par Bruno Marquis & Marylise Tremblay. Grâce au travail de ses fondateurs, le café-théâtre de 140 places a connu dès ses premières années un grand succès.\n\nEn 2013, Sébastien Dorval & Claude Montminy ont pris le relais à la codirection du théâtre. Leur mandat était de produire des comédies québécoises actuelles et rassembleuses. En 2014, la salle a été réaménagée pour améliorer la visibilité des spectateurs. Une salle en pente a été construite faisant passer la capacité à 172 places. \n\nDepuis 2023, ce sont Alex Desmarais & Catherine Simard qui ont repris le flambeau, à la codirection du théâtre avec ce même souci de jouer des comédies reflétant notre société d'aujourd'hui en prônant le théâtre de chez-nous."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Nouveau Théâtre de l'Île d'Orléans"
      }
    ]
  },
