    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Duceppe est un théâtre rassembleur qui prend le pouls de la société et en expose les enjeux importants. On y propose des histoires qui captivent, des œuvres à grand déploiement, jouées dans une langue directe et vivante."
      }
