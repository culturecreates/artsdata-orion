    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://rendezvoustheatre.ca/piece/tout-sur-le-sexe"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Monarque vous plonge dans l’univers aussi explosif \nqu’irrésistiblement drôle de Laurent Paquin et de Simon Boudreault, sous\n la direction du maître des fantasmes scéniques, Serge Denoncourt. \nEnsemble, ils vous proposent un survol complet (ou presque) de ce sujet \naussi fascinant que controversé.\nOn vous prépare une pièce de théâtre décoincée, débridée… et totalement assumée.Une comédie à sketchs sur le thème le plus universel qui soit : le sexe.\nRetrouvez sur scène SIMON BOUDREAULT, BRIGITTE LAFLEUR et LAURENT PAQUIN dans une galerie de personnages plus chauds que votre historique de navigation.\nDes\n fantasmes aux malaises, du désir au délire… Que vous ayez 13 ou 113 \nans, cette comédie grand public fera rire toutes les générations… mais \npeut-être pas pour les mêmes raisons."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tout sur le sexe"
      }
    ]
  },
