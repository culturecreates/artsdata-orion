    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://rendezvoustheatre.ca/piece/%C3%A9lectre-anatomis%C3%A9e-anatole-%C3%A9lectrifi%C3%A9"
