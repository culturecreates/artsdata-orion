    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La Salle Pauline-Julien, lieu culturel francophone de l’ouest de l’île de Montréal, est située à Sainte-Geneviève dans le Cégep Gérald-Godin. Organisme de diffusion professionnelle pluridisciplinaire voué à la promotion et au développement des arts de la scène, cette salle à géométrie variable offre une programmation de spectacles variée qui rejoint tous les publics en plus de proposer un volet cinématographique ainsi qu’un service de location de salle. La Salle Pauline-Julien se dédie particulièrement au développement de la culture francophone dans l’Ouest-de-l’Île et l’est de Vaudreuil–Soulanges, en plus d’offrir un service de location de salle."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Salle Pauline-Julien"
      }
    ]
  },
