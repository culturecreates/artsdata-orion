    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Les Filles d’Ève de Logane Maori Portelance-Provencher – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Afin de clore la saison 2025-26, l’Écart accueille Logane Maori Portelance-Provencher dans le cadre de son programme d’emploi d’été. Depuis sa fondation, le centre souhaite développer et encourager la relève en arts visuels. Ce programme permet à de jeunes artistes de vivre l’expérience de la mise en exposition en galerie dans un contexte professionnel. Plusieurs artistes qui pratiquent […]"
      }
    ],
