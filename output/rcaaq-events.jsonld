    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Les semences de nos lendemains de xecê, khadija baker – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Récolter le soin que l’on sèmeCommissaire : Geneviève Wallen Les semences de nos lendemains offre une exploration en profondeur des thèmes qui ont inspiré la performance participative de xecê, khadija baker Performing Community Garden en 2021. Baker y explore les limites de nos relations interpersonnelles en examinant des notions comme le soin, l’appartenance, l’interconnectivité, la mémoire […]"
      }
    ],
