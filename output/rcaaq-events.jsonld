    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Cadence de Pavitra Wickramasinghe et RythÂ Kesselring | Cadence – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Cadence réunit les œuvres de RythÂ Kesselring et Pavitra Wickramasinghe qui, tous deux, explorent les écologies matérielles. Ce projet d’exposition examine le lien entre rythmes, répétitions et cycles sous forme d’œuvres installatives. Le travail des deux artistes se rejoint par un regard critique sur notre époque, passant des douces ondulations écologiques aux pulsations effrénées du monde […]"
      }
    ],
