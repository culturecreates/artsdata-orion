  {
    "@id": "https://reseauartactuel.org/evenement/je-sauve-souris-devenir-chiroptere-de-cynthia-g-renard/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-fr",
        "@value": "fr_FR"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-fr",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Je Sauve-Souris / Devenir chiroptère de Cynthia G.Renard – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Cette exposition nous présente la chauve-souris sous tous ses aspects, mais surtout sa fragilité et sa vulnérabilité. Au Québec, 3 des 8 espèces présentes sont en voie d’extinction : la pipistrelle de l’est, la petite chauve-souris brune et la chauve-souris nordique. Animal mal aimé et méconnu, cette exposition partage la passion et l’engagement de l’artiste […]"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-fr",
