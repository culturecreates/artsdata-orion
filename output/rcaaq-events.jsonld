    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Spirale 292 – Enquêtes dans l’archive coloniale – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Dirigé par Renato Rodriguez-Lefebvre et Miriam Sbih, le dossier « Enquêtes dans l’archive coloniale » analyse l’archive comme un lieu de reproduction de la violence. Du Québec à l’Algérie, en passant par le Guatemala et Chicago, les textes réunis dans ce dossier interrogent les formes de mémoire qui émergent lorsque les secrets, les oublis et les voix marginalisées prennent le […]"
      }
    ],
