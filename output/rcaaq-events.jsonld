    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Stina Baudin – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Adélard présente The Sky Still Carries the Stories, une œuvre extérieure monumentale de l’artiste Stina Baudin. Installée sur le toit de la grange d’Adélard, l’œuvre évoque un vaste ciel étoilé et transforme l’architecture agricole du lieu en une surface de mémoire dédiée aux présences historiques de personnes noires dans la région au XIXe siècle. Réfléchissante […]"
      }
    ],
