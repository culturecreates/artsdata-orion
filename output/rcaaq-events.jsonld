    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Cogner sur la table. 17 ans de Spill Propagation – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Fondé en 2009 par Tiphaine Girault et Paula Bath, Spill Propagation avait pour objectif de rapprocher les cultures et les créations des personnes sourdes et celles des personnes entendantes, en déconstruisant le phonocentrisme. Dans ce contexte, les artistes sourds et entendants sont encouragés à collaborer sans recourir à la langue des signes, et à trouver […]"
      }
    ],
    "http://ogp.me/ns#url": [
