    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "HTMlles 2026 - À Échelle Humaine – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "L’exposition À échelle humaine regroupe cinq propositions artistiques qui explorent des zones interstitielles. Des points de rencontre où mémoire, technologie, écologie et corps se croisent. Les œuvres déplacent la centralité du regard afin de désamorcer la prétendue neutralité des technologies. Attentif·ve·s aux récits non hégémoniques, les artistes refusent toute universalité abstraite et affirment des pratiques […]"
      }
    ],
