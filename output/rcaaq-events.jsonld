  {
    "@id": "https://reseauartactuel.org/evenement/de-ses-propres-yeux-parastoo-anoushahpour-faraz-anoushahpour-et-ryan-ferko/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-fr",
        "@value": "fr_FR"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-fr",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "De ses propres yeux de Parastoo Anoushahpour, Faraz Anoushahpour et Ryan Ferko – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "De ses propres yeux. Parastoo Anoushahpour, Faraz Anoushahpour et Ryan Ferko S’emparant de stratégies proches de l’ethnographie visuelle, ce trio multiplie les regards sur la modernisation de l’Iran, ses régions rurales et les familles témoins de leur industrialisation. Les archives et les dispositifs de production d’images deviennent des terrains de jeu et de subversion autant que des moteurs de […]"
      }
    ],
    "http://ogp.me/ns#url": [
