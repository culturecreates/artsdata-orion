    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Nous sommes souterreux de Mariane Tremblay – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Le centre Bang est fier de présenter l’exposition Nous sommes souterreux de l’artiste Mariane Tremblay. Comme l’an dernier, Bang souhaite multiplier le rayonnement du travail d’un·e artiste de la région lors de la période estivale en exposant ses œuvres au sein de deux de ses lieux de diffusion. Cet été, le travail de Mariane Tremblay sera ainsi […]"
      }
    ],
