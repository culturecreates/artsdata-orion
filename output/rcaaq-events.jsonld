    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Sans Speakers de James Schidlowksy – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Sans Speakers est une installation sonore immersive qui explore la transformation et l’autonomie du son à travers un dispositif constitué de 100 haut-parleurs interconnectés. Dans un espace d’écoute octogonal, des signaux électroniques se propagent d’un haut-parleur à l’autre. Guidée par un automate cellulaire, l’installation produit une composition évolutive où émergent fréquences, textures et rythmes. Entre glitches […]"
      }
    ],
