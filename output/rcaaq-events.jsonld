    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Pour son exposition estivale, le Livart a invité six artistes de la boutique d’art à réinterpréter et explorer une expression de la langue française dont la richesse symbolique demeure souvent méconnue : le bouquet final. À travers leur travail photographique, les artistes en proposent une relecture singulière : à travers l’hommage, le point culminant, la […]"
      }
    ],
