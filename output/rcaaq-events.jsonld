      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "L’exposition de la biennale nationale de sculpture contemporaine, Accumuler/ Classer, arrive à Silex du 27 juin au 13 septembre! Les artistes présenté·e·s à Silex sont Chun Hua Catherine Dong et Kablusiak."
      }
