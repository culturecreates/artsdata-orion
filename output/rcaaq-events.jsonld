    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "la colonia de Valérian Mazataud – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Arprim et Les Éditions du Renard vous invitent au lancement du livre photographique «la colonia» de Valérian Mazataud. Co-édité avec le centre VU et accompagné d’un texte de Sophie Bertrand, cet ouvrage documente en images les espaces de rencontres et de socialisation en Amérique centrale."
      }
    ],
