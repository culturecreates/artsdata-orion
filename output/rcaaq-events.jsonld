    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Basse mer – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Regart a le plaisir de vous inviter au vernissage de l’exposition Basse mer, en présence des cinq artistes Andrée-Anne Laberge, Catherine Sheedy, Émile Couture, Olivier Moisan Dufour et Sarah Lajoie-Asselin. Issue du projet LAB40, premier volet de la programmation soulignant les 40 ans de Regart, cette exposition estivale est le fruit d’une expérience de création collective […]"
      }
    ],
