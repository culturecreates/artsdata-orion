    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Infinite Games de Alfred Muszynski – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "En 2021, un étudiant de l’Université Concordia tente d’envoyer un courriel à son professeur d’histoire de l’art. En cherchant son adresse, il tombe sur une notice nécrologique. François-Marc Gagnon était décédé depuis 2019, mais ses cours enregistrés étaient encore offerts à l’insu de ses étudiants. Infinite Games schématise les vies après la mort qui nous sont […]"
      }
    ],
