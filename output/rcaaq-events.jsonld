  {
    "@id": "https://reseauartactuel.org/evenement/saisons-une-experience-de-la-temporalite-judiciaire-de-poline-harbali/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-fr",
        "@value": "fr_FR"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-fr",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Saisons - une expérience de la temporalité judiciaire de Poline Harbali – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Du dépôt d’un témoignage à l’attente de l’ouverture d’un procès au criminel pour des faits de violences conjugales, l’exposition explore le temps qui passe, les saisons qui se succèdent, pendant lesquelles la victime n’a aucun contrôle sur la temporalité judiciaire et fait face à un silence imposé. Dans ce temps suspendu, l’artiste traverse une disparition […]"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-fr",
        "@value": "https://reseauartactuel.org/evenement/saisons-une-experience-de-la-temporalite-judiciaire-de-poline-harbali/"
      }
    ],
