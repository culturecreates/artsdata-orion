    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Vent bleu – Réseau Art Actuel"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Le retour exceptionnel à Montréal d’un chef-d’œuvre de l’abstraction québécoise. La Fondation Guido Molinari invite les représentants des médias et les personnes impliquées dans le projet au vernissage de l’exposition Vent bleu, qui marquera le retour à Montréal d’une œuvre majeure de Guido Molinari, l’une des figures les plus importantes de l’histoire de l’art canadien. Présentée […]"
      }
    ],
