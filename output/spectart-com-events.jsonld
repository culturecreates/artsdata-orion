      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/05/Laurence20Jalbert_-Oryn64hEMFFi8I9oKBi_.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
