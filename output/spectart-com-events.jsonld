    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/Sinem20Kara_-OpmVHXvRVLon6SKTh4F_.jpg"
      }
    ],
    "http://schema.org/startDate": [
