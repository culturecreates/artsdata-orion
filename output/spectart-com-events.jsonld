    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Passe Festi Jazz"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "La Passe Festi Jazz comprend tous les spectacles payants de la 40e édition du Festi Jazz international de Rimouski présentée par Vidéotron.nPrévente disponible pendant 48h. Tarif régulier à 175$.nAnnonce de la programmation le jeudi 18 juin à 12h !n&nbsp;nNote importante :nSi vous choisissez l&rsquo;option de récupération sur place, votre bracelet se trouvera chez Spect&rsquo;Art Rimouski, salle Desjardins, 25 Rue St Germain O, Rimouski, QC G5L 4B4, à partir du 5 août."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Passe Festi Jazz"
      }
    ]
  },
