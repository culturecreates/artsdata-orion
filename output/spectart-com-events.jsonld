    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/pascal-cameron-2/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Pascal Cameron"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pascal Cameron présente son premier one man show un spectacle. qui est une représentation humoristique qui veut parler à tout le monde et de tout le monde. Par contre, il est important de noter que c&rsquo;est un spectacle d&rsquo;humour, donc les propos de cette représentation seraient inappropriés au Parlement ou à des funérailles mais plus que correct dans un pool party, Noël, un accouchement, la St-Jean ou à crier à travers la fenêtre de ton char quand tu es pogné dans le trafic. Un spectacle. c&rsquo;est un show de stand up traditionnel avec des blagues fraiches.n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Pascal Cameron"
      }
    ]
  },
