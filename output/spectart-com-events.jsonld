    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Véronique Bilodeau"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Flirtant avec le folk et l’électro, des années 90 à aujourd’hui, Véronique Bilodeau arrive comme un vent de fraîcheur avec sa musique pop francophone. Avec sa voix cristalline et puissante, elle nous fait danser et nous touche en plein cœur avec sa vulnérabilité. Un périple nostalgique à travers l’insouciance de notre adolescence où, l’espace d’un moment, on reconnecte tous ensemble.n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Véronique Bilodeau"
      }
    ]
  },
