    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/megan-brouillard-2/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Mégan Brouillard"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "«Le chiendent, c’est subjectif. La mauvaise herbe, c’est quelque chose qui pousse là où toi, tu ne voulais pas. Ce qui est du chiendent pour l’un ne l’est peut-être pas pour l’autre et ce qui est du chiendent quelque part, ne l’est pas ailleurs… Mon spectacle tourne autour de cette perspective, des différentes perceptions de chacun et chacune et autour de mes propres perceptions. »nLe premier one-woman-show de Mégan Brouillard est un spectacle mordant et authentique, où Mégan présente elle et les siens, sans filtre et toujours de façon hilarante!"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Mégan Brouillard"
      }
    ]
  },
