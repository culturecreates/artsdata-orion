    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/bia-et-maracuja/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Bïa et Maracujá"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dans le cadre des Nuits Jazz Toyota Rimouski, le Festi Jazz international de Rimouski présenté par Vidéotron et en collaboration avec Toyota Rimouski, est fier de vous offrir une performance de Bïa &amp; Maracujá.nBïa, artiste brésilienne installée à Montréal, est reconnue pour sa voix envoûtante et son univers musical riche et métissé. Auteure-compositrice prolifique, elle a reçu en 2024 la distinction de Chevalier des Arts et des Lettres de la République française. Ses albums ont été primés aux Félix, aux Juno Awards et au Grand Prix de l’Académie Charles Cros. En 2025, elle présente un nouvel EP, La Délicatesse.nÀ ses côtés, le groupe montréalais Maracujá propose une musique brésilienne festive et énergique, mêlant compositions originales et classiques du répertoire. Ensemble, Bïa et Maracujá offrent un spectacle vibrant où douceur, puissance, émotions et rythmes entraînants se rencontrent dans une performance irrésistible qui invite à la danse et à la joie.nCe spectacle est inclus dans la Passe Festi Jazz qui donne accès à tous les spectacles de la 40e édition présentée par Vidéotron."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Bïa et Maracujá"
      }
    ]
  },
