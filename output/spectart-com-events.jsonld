      {
        "@id": "https://spectart.com/pascal-cameron/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2025/10/Pascal-Cameron.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
