    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "J&rsquo;ai fait un humain &#8211; le balado"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Gabrielle Caron reçoit une invitée pour enregistrer J’AI FAIT UN HUMAIN, un balado à saveur parental, où l’on parle sans filtre d’accouchement, de parentalité et de tout ce qui vient avec. De A à Z. Avec amour, humour et sincérité. n**Notez qu&rsquo;un spectacle en soirée est également présenté et qu&rsquo;un forfait est disponible pour profiter des deux événements."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "J&rsquo;ai fait un humain &#8211; le balado"
      }
    ]
  },
