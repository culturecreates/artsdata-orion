  {
    "@id": "https://spectart.com/temporary/29df81f3-77de-4414-9505-068b289c7dd6",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spectart.com/dialogues/"
      }
    ],
    "http://schema.org/image": [
