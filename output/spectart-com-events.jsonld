    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/guillaume-arsenault/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Guillaume Arsenault"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L’auteur-compositeur-interprète Guillaume Arsenault né en Gaspésie, tient une shop à chansons depuis plus de 20 ans. Fort de six albums et de deux EP, l’artiste propose une œuvre sensible, poétique et profondément ancrée dans son vaste territoire. Il partage la même force tranquille, le même don pour la contemplation, la même envie de se réinventer à chaque projet.   nAccompagné de Jean-Guy Leblanc à la contrebasse et d’Éric Dion à la guitare à résonateur, Guillaume offre un nouveau spectacle « Les plantes continuent de pousser même quand tu dors » et y présente ses plus récentes chansons tirées des EP du même nom (Face A et Face B), ainsi qu’un survol de son répertoire.  n(Une mise en scène de Jacques Laroche et une conception d’éclairage de Cyril Bussy.) "
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Guillaume Arsenault"
      }
    ]
  },
