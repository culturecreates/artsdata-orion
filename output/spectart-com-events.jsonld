      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2025/11/Patrice20L27C389cuyer_-OeMRF1QQPNKn3d9k3kI_.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
