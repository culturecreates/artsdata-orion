      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Propulse Énergie présentenUN 2 pour 1nRetour sur scène du groupe mont-jolien, Les T-Birds qui a rempli les salles de partout au Québec à la fin des années 70 et début 80. Des souvenirs inoubliables.nPremière partie : Azimut, groupe de Rimouski qui promet de mettre la table pour une soirée nostalgique."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Les T-Birds"
      }
    ]
