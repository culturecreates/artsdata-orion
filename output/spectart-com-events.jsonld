    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/le-lac-des-cygnes/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le lac des cygnes"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "À l&rsquo;occasion du 25e anniversaire de la compagnie en 2012, le directeur artistique et chef de la direction Bengt Jörgen a revisité le classique et dramatique Lac des Cygnes, en y ajoutant une touche d&rsquo;héritage canadien, souvent caractéristique de son travail. Si cette production du Lac des Cygnes met en valeur l&rsquo;extraordinaire beauté du ballet traditionnel dans sa forme la plus pure, Jörgen l&rsquo;a réimaginée dans le pittoresque paysage marin de la forteresse de Louisbourg, en Nouvelle-Écosse. Les décors élaborés, conçus par Camellia Koo, reflètent la beauté du parc patrimonial national du Canada et offrent un cadre saisissant aux costumes du XVIIe siècle de Robert Doyle. Fort de son expérience sur le projet de restauration de la forteresse de Louisbourg, Doyle était ravi de participer à cette interprétation unique du Lac des Cygnes.nDurée : 135 minutes incluant un entracten&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Le lac des cygnes"
      }
    ]
  },
