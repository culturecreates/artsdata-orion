    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Flore Laurentienne"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ancrée dans le territoire québécois et inspirée par l’immensité du fleuve Saint-Laurent, la musique de Flore Laurentienne — issue d’un mariage harmonieux entre cordes et synthétiseurs analogiques — nous entraîne dans un voyage intérieur aux frontières du sublime, où l’on se découvre à la fois fragile et puissant, suspendu entre vulnérabilité et émerveillement.n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Flore Laurentienne"
      }
    ]
  },
