      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/TADAM20et20les20lutins20magnifiques_-OqgLIHU8WiHB5hmNAJr_-2.jpg"
      }
    ],
    "http://schema.org/startDate": [
