    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/dom-babin/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Dom Babin"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "J’pas un érudit, un sociologue, un politicien, un anthropologue. J’suis juste un gars qui a laissé parler l’silence.nQui écoute quand ça craque, parce que les bonnes histoires sont dans les livres, mais les meilleurs sont dans les murs.nD’in murs d’un gars de trop. Trop Américain pour être Français, trop Canadien pour être Américain, pis trop Français pour être Canadien. Ni l’un ni l’hôte.nDe celui qu’on a sculpté à la pierre du Manitoba, peint et dépeint à l’huile d’Alberta, encadré dans le Canada, recadré par l’Angleterre, poli depuis 262 ans, impoli depuis tout autant.nDe celui qui a bûché pour s’en tirer une pis qui s’brûle pour apaiser le froid de son public. Et de sa flamme est né, l’Américain du Nord français.n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Dom Babin"
      }
    ]
  },
