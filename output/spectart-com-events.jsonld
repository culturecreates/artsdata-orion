    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Concert-bénéfice &#8211; Sons et saveurs"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "En collaboration avec les Jardins de MétisnEnsemble : Ensemble de musique de chambre avec le pianiste Philippe Gagné et des musicien·ne·s de l&rsquo;OSEnDans le cadre enchanteur des Jardins de Métis, laissez-vous emporter par une expérience sensorielle inédite, où les saveurs s’accordent harmonieusement aux œuvres interprétées par nos musicien·ne·s d’exception. Ensemble, les artistes puiseront dans l’essence des compositions pour créer de nouvelles alliances, à la croisée de la musique et de la gastronomie.nLes places sont limitées, réservez rapidement!"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Concert-bénéfice &#8211; Sons et saveurs"
      }
    ]
  },
