    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/sinem-kara/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Sinem Kara"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Sinem Kara monte sur scène avec une énergie contagieuse. D&rsquo;origine turque et née au Québec, elle porte un regard à la fois tendre et piquant sur nos habitudes, nos contradictions et nos petites manies — un regard qui mélange deux cultures avec la finesse d&rsquo;un trait d&rsquo;humour bien placé. Attendez-vous à des anecdotes du quotidien revisitée à la manière Sinem, la famille, la langue, les repas qui durent des heures, les malentendus et ces petites situations qui prennent une dimension universelle quand elle les raconte. Son ton est chaleureux, souvent autodérisoire toujours proche du public.nVenez pour rire, mais aussi pour voir l&rsquo;œuvre naître, vos réactions comptent, vos rires aident à sculpter le spectacle. C&rsquo;est une expérience intime et généreuse, parfaite pour celles et ceux qui aiment l&rsquo;humour en devenir et le regard neuf d&rsquo;une artiste qui observe le monde et nous le rend plus drôle."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Sinem Kara"
      }
    ]
  },
