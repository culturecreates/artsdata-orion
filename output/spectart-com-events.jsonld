      {
        "@language": "fr",
        "@value": "OSE chanter !"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "CONCERT FAMILIALnCheffe d’orchestre : Léa Moisan-PerriernUne centaine d’enfants d’âge primaire de la région se réuniront sur scène pour chanter accompagnés de l’OSE. Des répétiteur·trice·s chevronné·e·s les auront préparés préalablement, leur enseignant lors de rencontres hebdomadaire un tour du monde en chant élaboré par notre directrice artistique. Ce programme offert gratuitement vise à contrer le décrochage scolaire par la musique et initier les jeunes à la musique d&rsquo;ensemble."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "OSE chanter !"
      }
    ]
  },
