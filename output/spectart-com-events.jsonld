  {
    "@id": "https://spectart.com/temporary/fd466ffd-643a-4ab1-b699-5104073008b2",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spectart.com/andes-a-leuphrate/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/02/Andes20C3A020l27Euphrate_-OmB-Jy42XOlJ1-1ibSK_-2.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
