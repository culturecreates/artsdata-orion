    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/tocadeo/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tocadéo"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Tocadéo vous invite à célébrer le temps des fêtes avec son tout nouveau spectacle: Noël blanc. Dans une nouvelle mise en scène, un nouveau concept et un nouveau décor, Benoit, Dany, Patrick et René revisitent à leur façon les grands classiques de Noël dans une ambiance festive et nostalgique qui vous fera revivre l’époque des réveillons d’antan.nDepuis plus de 13 ans, le spectacle de Noël de Tocadéo s’est imposé comme un événement annuel incontournable et une véritable tradition dans le calendrier musical des fêtes. Laissez-vous emporter, bercer et émouvoir par le talent exceptionnel et les magnifiques voix du sympathique quatuor et plongez dans la magie du Noël blanc de Tocadéo.n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Tocadéo"
      }
    ]
  },
