    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Passe Festi Jazz"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "**Suite à l&rsquo;achat de cette passe, vous serez en admission générale dans les sections réservées pour nos détenteurs de passes lors des spectacles à la Salle Desjardins** nLa Passe Festi Jazz comprend tous les spectacles payants de la 40e édition du Festi Jazz international de Rimouski présentée par Vidéotron.nGRANDS SPECTACLES, Salle Desjardinsn3 septembre 2026 &#8211; 19h00 : Michel Cussonn3 septembre 2026 &#8211; 21h00 : Alain Caronn4 septembre 2026 &#8211; 18h30 : Jill Barbern5 septembre 2026 &#8211; 18h30 : Keyon HarroldnSÉRIE ÉCLATÉE VIDÉOTRON, Chapiteau de la Place Festi Jazz Vidéotronn4 septembre 2026 &#8211; 20h00 : Empanadas Ilegalesn4 septembre 2026 &#8211; 21h45 : Five Alarm Funkn5 septembre 2026 &#8211; 20h00 : Kinga Głykn5 septembre 2026 &#8211; 21h30 : AfrotronixnNUITS JAZZ TOYOTA RIMOUSKI, Salle Desjardinsn4 septembre 2026 &#8211; 21h00 : Emie R Roussel Trion5 septembre 2026 &#8211; 21h00 : Bïa &amp; MaracujánOISEAUX DE NUIT,Chapiteau de la Place Festi Jazz Vidéotronn3 septembre 2026 &#8211; 21h : Ping Pong GonOISEAUX DE NUIT, Bains Publicsn4 septembre 2026 &#8211; 23h30 : Laura Schembrin5 septembre 2026 &#8211; 23h30 : El BalcónnNote importante :nSi vous choisissez l&rsquo;option de récupération sur place, votre bracelet se trouvera chez Spect&rsquo;Art Rimouski, salle Desjardins, 25 Rue St Germain O, Rimouski, QC G5L 4B4, à partir du 5 août."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Passe Festi Jazz"
      }
    ]
  },
