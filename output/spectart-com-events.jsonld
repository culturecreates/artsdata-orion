    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/a-la-rencontre-de-charlotte-sohy/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "À la rencontre de Charlotte Sohy"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "DÉLICAT. LYRIQUE. BIOGRAPHIQUE. nConcert-portrait de Charlotte Sohy, compositrice française de la Belle époque récemment redécouverte. Alors que le monde de la musique classique a passé sous silence la musique de ses compositrices pendant plusieurs siècles, le vent tourne depuis quelques années et, pour notre plus grand bonheur, nous avons la chance de découvrir des voix affirmées qui ont beaucoup à dire. C’est ainsi que vous pourrez entendre plusieurs œuvres de Sohy pour piano, violon et violoncelle interprétées par un trio de musiciennes parmi les meilleures de leur génération et en apprendre sur la destinée de cette femme restée dans le silence pendant près de cent ans. nChloé Dumoulin, pianonChloé Chabanole, violonnAndrea Stewart, violoncelle et présentation nŒuvres de Charlotte Sohy :n&#8211; Fantaisie op. 3, pour pianon&#8211; Thème varié op. 15 bis, pour violon et pianon&#8211; Quatre pièces romantiques op. 30 pour pianon&#8211; Octobre op. 23 n°1, pour violoncelle et pianon&#8211; Trio op. 24, pour violon, violoncelle et pianon*Le tarif Bienfaiteur donne accès à une section réservée vers l’avant de l’église.nEn collaboration avec La Cité des compositrices (France)."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "À la rencontre de Charlotte Sohy"
      }
    ]
  },
