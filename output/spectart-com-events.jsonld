    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/voyage-en-mer/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Voyage en mer"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "POÉTIQUE. RÊVEUR. ROMANTIQUE. nUn concert matinée dans la pittoresque Chapelle de Notre-Dame-des-Murailles de Saint-Fabien-sur-Mer, coincée entre la mer et la crête rocheuse qui longe le littoral. Vous êtes invités à suivre les élans lyriques et nostalgiques de l’officier de marine et compositeur breton Jean Cras. À ses côtés, on retrouve de nouveau Charlotte Sohy pour deux mouvements de son premier quatuor à cordes ainsi que des compositions plus proches de nous qui, elles aussi, évoquent la poésie et l’idée romantique qu’on associe à la vie au grand large. Une invitation à commencer la journée en douceur et à contempler des horizons lointains. nMarilène Provencher-Leduc, flûtenAntoine Malette-Chénier, harpenChloé Chabanole, TJ Skinner, violonsnÉtienne Chénard, altonAndrea Stewart, violoncellenŒuvres de Jean Cras, Charlotte Sohy, Philip Glass et plus.n*Le tarif Bienfaiteur donne accès à une section réservée vers l’avant de la chapelle.."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Voyage en mer"
      }
    ]
  },
