      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2025/11/Pour20une20autre20histoire20d27un20soir_-OeMUz8mD0CRG9vpRiL2_-2.jpg"
      }
    ],
