    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/charles-pellerin/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Charles Pellerin"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Je suis fier de vous présenter le rodage de mon nouveau spectacle. Encore une fois, je suis dans une approche autobiographique intimiste. J’explore avec vous la question de l’identité et de l’estime à travers une grande histoire, celle de mon passage vers la vie adulte. Je voudrais vous donner plus de détails, mais je vous priverais du plaisir de la découverte. Ça, c’est la description, mais il y a aussi des maudites bonnes jokes là-dedans, peut-être même mes meilleures. Hâte de vous voir Rimouski xxn18 ans et + | Spectacle présenté aux Bains Publics"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Charles Pellerin"
      }
    ]
  },
