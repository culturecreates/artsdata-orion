    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/le-showcase-2026/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le Showcase 2026"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le programme Danse-Compétitions de l’École de danse Quatre Temps vous invite à son showcase annuel, qui se tiendra le 24 mai à 15 h 30 à la salle Desjardins. Cet événement met en lumière le travail, la rigueur et la passion des danseuses et danseurs ayant évolué au sein du programme compétitif tout au long de l’année. Ayant fièrement représenté l’ÉDQT et la région à travers le Québec lors de différentes compétitions, ces jeunes artistes présentent le fruit de leur engagement et de leurnévolution.n&nbsp;nÀ travers une série de chorégraphies variées, le public pourra découvrir des performances alliant technique, expressivité et créativité, issues de différentesndisciplines et niveaux.n&nbsp;nVéritable vitrine du talent et de l’engagement des élèves, ce spectacle souligne également le travail des chorégraphes et de l’équipe pédagogique, qui accompagnentnles danseurs et danseuses dans leur développement artistique et personnel.n&nbsp;nUn rendez-vous inspirant et énergisant, où dépassement de soi et passion de la danse sont à l’honneur!"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Le Showcase 2026"
      }
    ]
  },
