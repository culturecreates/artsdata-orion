        "@id": "https://spectart.com/bang-bang/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/Bang20Bang_-OqGZk60M4cnO8t-phOS_.jpg"
      }
    ],
