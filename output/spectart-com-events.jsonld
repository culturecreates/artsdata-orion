    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/chantal-lamarre/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Chantal Lamarre"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Steppettes et cornemuses; un joyeux cabaret bio-comique !nEt si, pour un soir, on faisait comme si? 40 ans dans le métier; sans avoir pensé qu’elle retrouverait la scène, et encore moins en solo, Chantal Lamarre osera le monologue, la steppette et la chansonnette. La fille à lunettes qui aime par dessus tout raconter des histoires a bricolé un spectacle unique dans l’offre culturelle&#8230; et si, on retournait au cabaret, le temps d’une soirée? Une soirée pour se souvenir du bon et moins bon vieux temps, pour rire de nos travers, pour chercher la joie dans l’adversité de l’époque."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Chantal Lamarre"
      }
    ]
  },
  {
    "@id": "https://spectart.com/programmation/ose-chanter-2/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-fr",
        "@value": "fr_FR"
