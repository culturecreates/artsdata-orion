    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Sam Breton"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Vivre un épuisement professionnel, c&rsquo;est aussi vivre une recharge professionnelle. Autrement dit : travailler mon deuxième one-man-show de façon encore plus efficace, sans perdre de temps avec des niaiseries. Là, j&rsquo;aimerais bien te vanter mon spectacle pour te convaincre de venir me voir sur scène, mais ça entrerait dans la catégorie « perte de temps », parce que de toute façon, juste avec ma face, tu l&rsquo;sais déjà si tu vas venir voir mon show ou non. Avoue? 😉"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Sam Breton"
      }
    ]
  },
