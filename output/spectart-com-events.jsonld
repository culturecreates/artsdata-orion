    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Piala"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Piala est une artiste originaire de Bretagne et vivant à Rimouski depuis 7 ans, durant le 5 à l’Angélus, elle présentera le travail fait durant une résidence au Spect’Art accompagnée par d’autres musicien.ne.s de Rimouski et d’ailleurs : Kim Savard (guitare et voix), Fabrice Blais Poirier (Drum), François Landry (basse) et Alexis Garceau (Clavier). Le groupe joueront des morceaux de son premier E.P : Strangers on remote sorti en juin 2026 en plus de quelques nouveaux morceaux."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Piala"
      }
    ]
  },
