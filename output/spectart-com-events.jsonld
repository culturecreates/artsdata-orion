        "@value": "Michelle Desrochers"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Mi-cuit, c’est mon spectacle… presque prêt! Idéal si vous avez envie de rire et si vous souhaitez secrètement qu’une trentenaire qui ne sait pas cuisiner vous donne la recette du bonheur. Je vous promets une soirée qui fait autant de bien que d’éteindre la hotte du four après une longue recette!"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Michelle Desrochers"
      }
    ]
  },
