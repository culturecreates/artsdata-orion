      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/BC3A9nC3A9volat_-OqHQTwUS1hwW4I992_K_.jpg"
      }
    ],
    "http://schema.org/startDate": [
