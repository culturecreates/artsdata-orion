    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/Jean-Michel20Anctil20_-Oqkuj9uvvNuRnK7F6hC_.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
