    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/anne-sarah-charbonneau/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Anne-Sarah Charbonneau"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fasciné·e d’enjeux sociopolitiques, Anne-Sarah se sert du couvert de la blague pour aborder des sujets sérieux de façons drôle et décontractée tels que son homosexualité et la honte d’avoir des seins. Iel se sert de situations anodines de son quotidien pour générer le rire tout en suscitant la réflexion. Comment est-il possible d&rsquo;avoir honte de montrer ses poils, sans avoir honte d&rsquo;avoir déjà longuement travaillé sur un Scrapbook de Zach Efron? C’est avec un sourire contagieux qu’iel nous emmène sur scène dans ses aventures de super lesbienne non-binaire!n18 ans et + | Spectacle présenté aux Bains Publics"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Anne-Sarah Charbonneau"
      }
    ]
  },
