      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "WANTED"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "« WANTED Bon Jovi Tribute » est une célébration des hymnes iconiques qui ont marqué l’un des plus grands groupes rock de tous les temps! Ce spectacle en direct met en vedette un groupe puissant, des voix dynamiques et des performances électrisantes de succès comme You Give Love a Bad Name, Wanted Dead or Alive, Livin’ on a Prayer, Bad Medicine, et plusieurs autres classiques du répertoire légendaire de Bon Jovi. Avec le talent et la passion des artistes sur scène, ce tribute vous ramènera à l’époque dorée du rock d’aréna. Venez chanter à pleins poumons les succès intemporels qui ont fait de Bon Jovi une sensation mondiale!"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "WANTED"
      }
    ]
  },
