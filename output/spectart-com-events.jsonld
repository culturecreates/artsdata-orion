      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alicia Moffet"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après le succès de son premier album Billie Ave. (2021) et de son EP Intertwine (2022), qui cumulent plus de 17 millions d’écoutes, Alicia Moffet continue de repousser ses limites. Son nouvel album No, I’m Not Crying n’est pas seulement un nouveau chapitre pour elle; c’est un tournant audacieux destiné à captiver son public et le témoignage de son évolution. Fusionnant pop, R&amp;B et tout ce qui se trouve entre les deux, l’artiste se découvre comme jamais et offre un regard sans filtre au-delà de l’image qu’elle projette sur ses plateformes. "
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Alicia Moffet"
      }
    ]
  },
