  {
    "@id": "https://spectart.com/temporary/288353fa-167f-4301-bdc2-df987b3a954c",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spectart.com/major-moran/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2025/10/Major-Moran.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-04T20:00:00"
      }
    ],
    "http://schema.org/location": [
