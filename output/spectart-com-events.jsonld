    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/lensemble-vocal-diapason/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "L&rsquo;Ensemble vocal Diapason"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L’Ensemble vocal Diapason de Rimouski chante ‘’OSER DIRE« .nOSER DIRE c’est ouvrir une porte, cela commence souvent par un souffle, une vibration une note fragile.nOSER DIRE ne signifie pas forcément parler fort, ni tout dire.nOSER DIRE c’est accepter que sa voix existe, même imparfaite et qu’elle mérite d’être entendue. La voix individuelle devient alors voix collective. Ensemble, nous transformons des paroles isolées en un espace commun, où DIRE devient possible parce que nous ne sommes pas seuls.nOSONS DIRE, osons chanter : tout ce que l’on dit…nDirigés par Josée Fortin, accompagnés par des musiciens de chez nous, sur une mise en scène de Natali Saint-Pierre, les 48 choristes entonneront une vingtaine de chansons populaires du répertoire québécois et francophone. Des chansons de Pierre Lapointe, Garou, Patrick Fiori, Les TroisAccords et Cœur de Pirate, etc.n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "L&rsquo;Ensemble vocal Diapason"
      }
    ]
  },
