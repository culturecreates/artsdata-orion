    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/abba-memories/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "ABBA Memories"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le fabuleux spectacle d’envergure, ONE THE ABBA MEMORIES SHOW se veut non pas une caricature du légendaire groupe ABBA, mais bien la reproduction vocale et musicale intégrale des fabuleuses chansons du groupe. Depuis 2009, quelques deux cent mille personnes ont acclamé ce spectacle qui ne cesse d’étonner le plus fanatiques.nII n’y a qu’une seule manière de jouer ABBA et c’est à la manière de ABBA. Ce spectacle vous donnera de l’énergie, vous rendra joyeux et fera fuir les blues. Pour les fans de ABBA, vous allez certainement chanter leurs plus grands succès et même peut-être en découvrir de nouveaux et pour ceux qui ne les connaisse pas ou peu, nous pouvons vous garantir que vous allez devenir des adeptes de cette merveilleuse musique qui ont fait de ABBA une légende."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "ABBA Memories"
      }
    ]
  },
