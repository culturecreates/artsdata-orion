    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Illusion Floyd"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Illusion Floyd est un groupe hommage qui vous invite à plonger dans l&rsquo;univers hypnotique la musique de Pink Floyd. Rejoignez-les pour revivre les classiques emblématiques des albums The Dark Side of The Moon et The Wall avec leur spectacle The Dark Side of The Wall. Venez découvrir l&rsquo;essence de ce groupe légendaire au travers des performances captivantes. Préparez-vous à une expérience musicale et visuelle inoubliable!n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Illusion Floyd"
      }
    ]
  },
