        "@value": "Sur scène, des musiciens et professeurs d&rsquo;exception partagent leur passion et complicité. Interprètes accomplis, ils offrent un programme riche et varié, où se mêlent harmonie, mouvement et dialogues musicaux. Une soirée d’exception à ne pas manquer !"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Concert annuel des professeurs du Conservatoire"
      }
    ]
  },
