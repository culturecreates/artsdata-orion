    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Auteur-compositeur-interprète guitariste, Jonny est un artiste à la voix chaude et puissante. Il transmet l’émotion avec son jeu de guitare et ses textes et promet un spectacle qui groove. Un voyage avec ses chansons de son plus récent album et des reprises d’artistes qui l’ont influencé.n&nbsp;n&nbsp;"
      }
    ],
