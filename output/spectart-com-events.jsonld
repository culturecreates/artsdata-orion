    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Choeur Gospel"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L’École de musique du Bas-Saint-Laurent vous invite au concert annuel du Chœur Gospel. Sous la dynamique direction de Natasha Poirier, le Chœur Gospel de l’École de musique du Bas-Saint-Laurent vous présentera comme toujours un programme vibrant et survolté! En plus d’oeuvres traditionnelles ou modernes tirées du répertoire gospel, le chœur interprétera des pièces des plus variées (Beatles, Queen, Beyoncé, Maroon 5, etc.)nLes choristes seront accompagnés par un ensemble de sept musiciens de la région : Olivier Gosselin (piano), Emie Lachapelle (saxophone), Richard Gagnon (trompette), Philippe Robichaud (guitare), Lino Bélanger (guitare), Médéryc Turgeon-Chamelot (basse) et Alexis Carrier (batterie)."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Choeur Gospel"
      }
    ]
  },
