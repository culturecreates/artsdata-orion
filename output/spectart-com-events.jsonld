      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/Amandine202620GC3A9dC3A9on_-OqR7wwnTFQuprwLY-ZN_-2.jpg"
      }
    ],
    "http://schema.org/startDate": [
