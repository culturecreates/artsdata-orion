    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/03/Yves20Lambert_-Oo6_5mgh12brOyGLS8T_-1.jpg"
      }
    ],
    "http://schema.org/startDate": [
