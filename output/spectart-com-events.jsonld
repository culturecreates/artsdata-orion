    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Mona de Grenoble"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "« J’aurais pu appeler ce show d’humour Étalon en talons ou Entre Bâton Rouge et matante, mais après je me suis rendu compte que vous alliez sûrement vous reconnaître dans mon personnage que certains décrivent comme étant flamboyant, grivois et solvable depuis Big Brother. Parce que dans le fond, on le sait, les paillettes, les robes pis les grosses perruques, c’est juste de la poudre aux yeux ! » – Mona de Grenoble"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Mona de Grenoble"
      }
    ]
  },
