    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/forfait-double-2/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Forfait triple pour clôturer le festival"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour les amoureux de belle musique, voici une offre rafraîchissante. Découvrez la vitalité et la richesse de notre territoire à un coût avantageux avec des concerts en salle tout en contrastes, soit : n1) Grand Cabaret du 25e, le vendredi 7 août à 19 h 30 à l’église du Bic;n2) Voyage en mer, le samedi 8 août à 10 h à la chapelle de Saint-Fabien-sur-Mer;n3) Concert de clôture : Racines, le samedi 8 août à 19 h 30 à l’église du Bic. nPour compléter votre passeport, nous vous invitons à ajouter d&rsquo;autres concerts à l’unité pour profiter pleinement du festival selon vos préférences. n*Le tarif Bienfaiteur donne accès à une section réservée vers l’avant de la salle. "
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Forfait triple pour clôturer le festival"
      }
    ]
  },
