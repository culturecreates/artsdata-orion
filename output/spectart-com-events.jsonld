    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/jose-gaudet/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "José Gaudet"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Humoriste, José Gaudet nous fait rire depuis déjà très longtemps ! Il a à son actif plus de 25 ans d’animation radio, deux tournées de spectacles bien récompensées, animation de galas et 10 ans à la barre de talks-shows dont Ça finit bien la semaine.nUn mois à peine après la première Montréalaise totalement réussit, il atteignait déjà les 25 000 billets vendus avec sa première tournée solo! Ce premier spectacle est parfaitement à l’image de l’homme dans la cinquantaine, qu’est José. Avec son franc parlé et sa censure limitée, il nous amène dans son univers de la façon la plus sentie qu’il pourrait le faire. Tout de ce spectacle est à son image.nC’est le cas de le dire… Y’était temps!"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "José Gaudet"
      }
    ]
  },
