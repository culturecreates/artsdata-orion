    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/evelyne-molgat/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Evelyne Roy-Molgat"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Evelyne Roy-Molgat montera sur scène pour présenter son tout nouveau spectacle Un peu de jokes, beaucoup de crowdwork (ou l&rsquo;inverse, on verra)! Pour ceux qui ne la connaissent pas, elle se démarque par son sens de la répartie, son énergie contagieuse et surtout parce qu’elle est incapable de ne pas parler au public. Dans ce spectacle, Evelyne se donne le défi de faire une heure 100% improvisée, ce qui veut dire qu’il y aura du crowdwork, des blagues, des anecdotes, mais surtout rien de préparé à l’avance. C’est votre chance de voir un show unique qui se construit devant vos yeux selon ce que le public lui donne comme informations.n18 ans et + | Spectacle présenté aux Bains Publics"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Evelyne Roy-Molgat"
      }
    ]
  },
