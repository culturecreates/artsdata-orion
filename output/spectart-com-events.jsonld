      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/03/Le20dC3AEner20de20cons_-On3T9W1t6PYN7aiIlkZ_.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
