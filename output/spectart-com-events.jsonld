    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ensemble Antoine-Perreault"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "L’Ensemble Antoine-Perreault vous offre un concert printanier dédié aux grandes musiques orchestrales de jeux vidéo. Ces œuvres grandioses vous plongeront dans une vaste variété denmondes imaginaires allant de la Légende de Zelda à Final Fantasy, en passant par Mario Bros.,Tetris, Civilization et bien d’autres. En compagnie des membres de cet orchestre d&rsquo;harmonie bien connu de Rimouski, découvrez ou revisitez en musique ces univers virtuels qui ont peut-être marqué votre jeunesse!"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Ensemble Antoine-Perreault"
      }
    ]
  },
