    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/alphonse-bisaillon/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Alphonse Bisaillon"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Alphonse est une bête de scène et un poète. Il nous arrive avec un nouveau spectacle;  t.o.m. ou la trajectoire des perséides, qui surprend et émeut, une plongée au cœur de son passé, de sa trajectoire de jeune garçon venant de la ruralité. C’est une épopée qui vous fera danser, mais aussi réfléchir sur notre époque et sur les modèles masculins qu’on offre aux jeunes hommes. nSur scène, six musicien.ne.s, six ami.e.s transforment son énergie en musique. Éclectiques, du jazz au Dubstep, ses chansons plongent toujours leurs racines dans la force des mots. Elles donnent corps à la poésie, l’amplifie. C’est un spectacle théâtral et littéraire, un univers de lucioles intersidérales où Alphonse rencontre t.o.m., tour à tour ami, amour, frère, miroir et qui joue le rôle du repoussoir autant que du modèle. t.o.m., c’est la silhouette magnétique de ce que chaque homme peut devenir. n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Alphonse Bisaillon"
      }
    ]
  },
