    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/laurence-jalbert/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Laurence Jalbert"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Une voix née de la mer, portée par le cœur et l’instinct.nCélébrez 35 ans de musique et redécouvrez ce premier album mythique de Laurence Jalbert, dans un spectacle haut en émotions et en intensité. Accompagnée de ses musiciens, elle vous fera vibrer au son de ses plus grands succès tirés de cet album dont; Tomber, Au nom de la raison, Les yeux noirs, Rage. L’artiste vous réserve en plus quelques surprises qui sauront réconforter et toucher l’âme du public.n&nbsp;nCe spectacle se veut une célébration de passion, de force et d’un amour profond envers le public depuis plus de 35 ans! n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Laurence Jalbert"
      }
    ]
  },
