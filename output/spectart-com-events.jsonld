  {
    "@id": "https://spectart.com/temporary/0237bc96-7685-49e5-a916-287c034f77ff",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spectart.com/dialogues/"
      }
    ],
    "http://schema.org/image": [
      {
