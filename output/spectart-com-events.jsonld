    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "LE PUNCH CLUB x RIMOUSKI"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le Punch Club, c’est les joueurs étoiles des plus grandes ligues d’impro du Québec qui s’affrontent dans un match sans règles, dans l’arène la plus compétitive du monde de l’impro. La formule classique est 3 contre 3, mais une autre version du spectacle est le 1 contre 1. L’enjeu demeure toutefois le même : gagner la faveur du public et la bourse en argent qui y est associée. On appelle ça la street impro."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "LE PUNCH CLUB x RIMOUSKI"
      }
    ]
  },
