    ],
    "http://schema.org/url": [
      {
        "@id": "https://spectart.com/lobgesang/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/05/lobgesang.jpg"
      }
    ],
    "http://schema.org/startDate": [
