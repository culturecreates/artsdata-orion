    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/charles-antoine-des-granges/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Charles-Antoine       Des Granges"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Charles-Antoine est un gentil géant. Il ne se sent jamais tout à fait à sa place, comme un éléphant dans un jeu de quille. Ses anecdotes plus hilarantes les unes que les autres savent charmer le public, que ce soit sur les réseaux sociaux, en première partie de Mégan Brouillard et de Christine Morency ou dans ce premier spectacle de rodage. Venez assister à l&rsquo;éclosion d&rsquo;un compteur né!n18 ans et + | Spectacle présenté aux Bains publicsn&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Charles-Antoine       Des Granges"
      }
    ]
  },
