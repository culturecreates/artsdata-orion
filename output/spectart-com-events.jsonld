      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/Jean-Michel20Anctil_-OqkuYs5LQor566sPZ9E_-1.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
