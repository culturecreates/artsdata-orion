  {
    "@id": "https://spectart.com/temporary/f0950230-7c03-40dd-9bae-a7286e4768a6",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spectart.com/maroc-en-vanlife/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2025/05/LGE-Maroc.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-27T19:30:00"
      }
    ],
