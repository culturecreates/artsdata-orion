    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/le-country-de-nos-idoles/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le country de nos idoles"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Forts de leur amitié de longue date et animés par cette même passion pour la musique country, deux interprètes aimés du public québécois, Maxime Landry et Annie Blanchard, se retrouvent en studio pour un nouvel album et sur scène pour un spectacle à grand déploiement à la suite du succès de la tournée Jolene and the Gambler. Ce tout nouveau spectacle vous transportera cette fois-ci dans l&rsquo;univers des grands de la chanson country québécoise. De la famille Daraîche à Renée Martel en passant par Patrick Norman, tous les éléments sont réunis pour garantir une soirée haute en couleur, pleine de moments magiques et d&rsquo;émotions uniques. n&nbsp;"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Le country de nos idoles"
      }
    ]
  },
