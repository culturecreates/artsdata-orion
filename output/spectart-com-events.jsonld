      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://spectart.com/genid/07a79b93b5091281"
      },
      {
        "@id": "https://spectart.com/genid/f94fc9344c1a60f0"
      },
      {
        "@id": "https://spectart.com/genid/3ad491e160ad5e97"
