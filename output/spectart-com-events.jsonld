    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://spectart.com/programmation/citadelle-representation-b/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Citadelle – Représentation B"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Au cœur d’un ancien royaume, la Citadelle s’anime : rues vivantes, marchés colorés, danses populaires et cérémonies nobles rythment la vie, au milieu des fortifications médiévales. Entre la cour, le peuple et les protecteur·rices du royaume, chaque geste reflète une époque faite de traditions, de rituels et de joutes.nPeu à peu, l’étrange s’invite dans ce quotidien. La frontière entre le réel et l’imaginaire s’estompe, laissant place à un monde chargé de mystère et de poésie.nDans un grand élan collectif, les danses se mêlent, les énergies s’unissent, et la Citadelle retrouve son harmonie. Ainsi naît un royaume où le Moyen Âge et le merveilleux se rencontrent pour faire vivre une cité qui rêve… et danse."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Citadelle – Représentation B"
      }
    ]
  },
