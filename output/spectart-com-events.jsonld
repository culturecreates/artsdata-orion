    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le GGRIL"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le GGRIL présente d&rsquo;abord une collaboration inédite avec l&rsquo;artiste Nour Symon et sa partition graphique « Né·e à l’est du Cosmos », en première québécoise. Le groupe interprète ensuite un collage unique formé d&rsquo;extraits de morceaux choisis parmi son parcours des quinze dernières années."
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "fr",
        "@value": "Le GGRIL"
      }
    ]
