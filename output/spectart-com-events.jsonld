  {
    "@id": "https://spectart.com/temporary/ee5f7fef-9189-45ee-8def-0395ca07f803",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://spectart.com/albanie-paradis-secret-deurope/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://spectart.com/wp-content/uploads/2026/04/Albanie2C20paradis20secret20d27Europe_-OqgTC_2EXdy-6zC9TGU_-1.jpg"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
