    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Montreal Jazz Odyssey | Plongez dans l’histoire riche et méconnue du jazz à Montréal avec John Roney et Charles Biddle Jr. Ce spectacle inédit célèbre les géants qui ont marqué la scène locale — d’Oscar Peterson à Oliver Jones, en passant par Charles Biddle et Reggie Wilson. Revivez les décenni"
      }
    ],
    "http://ogp.me/ns#image": [
