    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le Duo Fortin-Poirier célèbre ses 20 ans avec un spectacle visuel et musical explorant la dualité : Rhapsody in Blue de Gershwin, Danse sacrale de Stravinsky. Entre clair-obscur et virtuosité, leurs mains dansent sur scène, soutenues par les jeux de lumière de Julie Basse. Une expérience scénique où"
      }
    ],
