    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Un voyage entre jazz et cinéma | Daniel Mille, virtuose de l’accordéon, vous emmène dans les sentiers oniriques de son album Après la pluie. Entre jazz intimiste et une touche de mélancolie, ses compositions agrémentées des pièces d’Yves Léveillé et de l’inoubliable Oblivion de Piazzolla — enve"
      }
    ],
