    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Jean-Philippe Sylvestre vous transporte des Rhapsodies hongroises de Liszt à la douceur du Clair de lune de Beethoven, en passant par la Pavane pour une infante défunte de Ravel. Découvrez aussi l’énergie envoûtante d’Islamey de Balakirev et l’hommage québécois d’André Mathieu. Un programme où la pa"
      }
    ],
