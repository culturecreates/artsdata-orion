    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Découvrez un spectacle vibrant et ludique où Éric Bégin et Éloi Amesse réinventent les traditions québécoises avec humour, rap et électro ! Entre gigues irlandaises, chansons à répondre et clins d’œil savoureux, ce duo dépoussière le folklore pour en faire une fête rythmée, festive et intergénératio"
      }
