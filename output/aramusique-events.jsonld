    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Jean-Michel Dubé rend hommage à son frère, le compositeur Ghislain Dubé, en interprétant pour la première fois ses œuvres inédites, aux accents cinématographiques. Entre les partitions de Ghislain et celles de ses inspirations (Einaudi, Zimmer, Chopin…), ce récital commenté mêle musique, anecdotes e"
      }
