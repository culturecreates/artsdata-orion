    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Découvrez Caity Gyorgy, trois fois lauréate d’un Prix Juno, et son pianiste Mark Limacher pour un voyage musical chaleureux et sophistiqué. Entre standards intemporels (The Man I Love, All of Me) et compositions originales, cette artiste au swing naturel et à l’improvisation virtuose réinvente le ja"
      }
    ],
