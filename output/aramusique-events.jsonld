    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le Duo Cordelia brise les codes du concert classique : un voyage entre contemplation, humour et audace. Au programme : des œuvres de compositeurs révolutionnaires, des créations originales de Vanessa Marcoux, et des moments d’improvisation. Une expérience musicale où la résilience des artistes d’hie"
      }
