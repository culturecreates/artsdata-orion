    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "C’est avec émotion que le  Trio Lorraine Desmarais , accompagné de la chanteuse  Sonia Johnson , recrée sur scène leurs pièces coups de cœur du légendaire pianiste, chanteur et acclamé compositeur  Michel Legrand  sur des arrangements de  Lorraine Desmarais .  Dans des styles allant du swing au funk"
      }
