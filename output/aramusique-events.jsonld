    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Juju et Marcelle sont des jumelles débordantes d’énergie. Du haut de la chambre de bain du deuxième étage de leur maisonnée, elles réinventent le monde afin de gagner du temps… Tout, tout, tout pour retarder ce moment fatidique où elles devront prendre leur bain. Ce théâtre musical ludique a été cré"
      }
    ],
