    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Découvrez Babouche, un spectacle délirant où quatre clowns musiciens débarquent avec une charrette d’instruments mystérieux ! Entre jonglage dans le noir, acrobaties verbales et métamorphoses en moustiques, ils marient imagination, mots espiègles et accordéon clownesque. Un voyage musical et poétiqu"
      }
