    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Noël en famille : 4 voix, 3 générations, 100 000 souvenirs Natalie Choquette, Florence K, Ariane Lagacé et Alice Rose Cyr vous ouvrent leur salon pour un Noël musical comme à la maison. Entre les classiques intemporels et les airs populaires qui font chanter, chaque génération apporte sa touche magi"
      }
