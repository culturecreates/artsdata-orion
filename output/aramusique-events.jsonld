    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "La Nef vous transporte au cœur d’un tournant de la Nouvelle-France : le naufrage de la flotte anglaise de l’amiral Walker. Ce concert inédit marie des chants de marins anglophones réinterprétés en français. Entre tradition et modernité, ce spectacle est une première mondiale, où 300 ans d’Histoire r"
      }
