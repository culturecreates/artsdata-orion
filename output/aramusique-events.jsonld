    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Plongez dans un spectacle interactif où chant, danse et musique traditionnelle vous transportent ! Avec Adama Daou (balafon, djembés) et Luc Bambara (danse, percussions), découvrez masques africains et rythmes envoûtants. Vous êtes les héros : dansez, chantez et vivez l’Afrique de l’Ouest comme jama"
      }
    ],
